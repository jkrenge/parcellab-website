---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="About Us - parcelLab" description="parcelLab is the most powerful end-to-end post-purchase platform, helping brands optimize Customer Lifetime Value and create lasting customer relationships.">
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Company"
      title="We create customers for life"
      description="parcelLab is the most powerful end-to-end post-purchase platform, helping brands optimize Customer Lifetime Value and create lasting customer relationships."
      ctaText="Learn more"
      ctaHref={`${import.meta.env.BASE_URL}/why-parcellab/`}
    />

    <!-- Mission Statement -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Our Mission</span>
          <h2 class="text-display text-[var(--ink)]">Build the world's most powerful post-purchase platform</h2>
          <p class="mt-6 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">Empowering brands to design highly engaging experiences that deliver maximum lifetime value. We understand the business of retail and eCommerce. We help you optimize Customer Lifetime Value and create customers for life.</p>
        </div>
      </div>
    </section>

    <!-- Key Stats -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
          {[
            { value: "1.6B+", label: "Packages Tracked" },
            { value: "550+", label: "Carrier Connections" },
            { value: "200+", label: "Employees" },
            { value: "1,000+", label: "Customers" },
          ].map((stat) => (
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 text-center">
              <p class="text-display text-[#3D3AD3]">{stat.value}</p>
              <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Company Values -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-2xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Our Values</span>
          <h2 class="text-display text-[var(--ink)]">What drives us every day</h2>
        </div>
        <div class="mt-16 grid gap-8 md:grid-cols-2">
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">We Build and Succeed Together</h3>
            <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">Teamwork drives collaborative success beyond individual achievements. We believe that the best outcomes happen when diverse teams work toward a shared goal.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Own It, Improve It</h3>
            <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">Taking responsibility for our work with a focus on proactive problem-solving and continuous improvement. We don't wait for permission to make things better.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/20">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Stronger Through Diversity</h3>
            <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">An inclusive culture where varied perspectives fuel innovation and better solutions. We celebrate what makes each person unique and use our differences as a competitive advantage.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Challenge, Learn, Grow</h3>
            <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">Stepping outside comfort zones through curiosity and continuous development. We embrace challenges as opportunities to learn and become better at what we do.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Office Locations -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-2xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Our Offices</span>
          <h2 class="text-display text-[var(--ink)]">A global presence</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">parcelLab operates as a global leader in post-purchase software with regional presence in North America and EMEA, serving enterprise retail brands worldwide.</p>
        </div>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { city: "Munich", country: "Germany", flag: "DE", address: "Kapellenweg 6, 81371 Munich" },
            { city: "London", country: "United Kingdom", flag: "UK", address: "Moor Place, 1 Fore Street Avenue, EC2Y 9DT" },
            { city: "Boston", country: "United States", flag: "US", address: "75 State Street, Boston, MA 02109" },
            { city: "Paris", country: "France", flag: "FR", address: "24-26 Rue De la Pepiniere, 75008 Paris" },
          ].map((office) => (
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--surface-sunken)] text-sm font-bold text-[var(--ink-secondary)]">
                {office.flag}
              </div>
              <h3 class="text-lg font-semibold text-[var(--ink)]">{office.city}</h3>
              <p class="text-sm text-[var(--ink-secondary)]">{office.country}</p>
              <p class="mt-3 text-sm leading-relaxed text-[var(--ink-muted)]">{office.address}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
