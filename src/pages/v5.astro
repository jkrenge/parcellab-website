  /* ─── Cycling word with glow + scale/blur transition ─── */
  .v5-cycle-word {
    display: inline-block;
    position: relative;
    min-width: 280px;
    height: 1.15em;
    vertical-align: bottom;
  }
  .v5-cycle-item {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    background: linear-gradient(135deg, #818cf8, #a78bfa, #c084fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
    filter: blur(0px);
    animation: v5-cycle 10s ease-in-out infinite;
    white-space: nowrap;
