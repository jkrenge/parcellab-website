<script>
  document.addEventListener("DOMContentLoaded", () => {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (prefersReduced) {
      document.querySelectorAll(".v5-stagger-child").forEach((el) => {
        (el as HTMLElement).style.opacity = "1";
        (el as HTMLElement).style.transform = "none";
      });
      document.querySelectorAll(".v5-section-reveal").forEach((el) => {
        (el as HTMLElement).style.opacity = "1";
        (el as HTMLElement).style.transform = "none";
        (el as HTMLElement).style.filter = "none";
      });
      // Still trigger bar/gauge/line animations statically
      document.querySelectorAll(".v5-bar-animate").forEach((el) => {
        (el as HTMLElement).style.width = (el as HTMLElement).style.getPropertyValue("--bar-width");
      });
      return;
    }

    // ── Mouse-follow glow on hero ──
    const heroSection = document.getElementById("v5-hero-section");
    if (heroSection) {
      heroSection.addEventListener("mousemove", (e) => {
        const rect = heroSection.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        heroSection.style.setProperty("--mouse-x", x + "%");
        heroSection.style.setProperty("--mouse-y", y + "%");
      });
    }

    // ── Section reveal observer ──
    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("v5-section-visible");
            sectionObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08 }
    );
    document.querySelectorAll(".v5-section-reveal").forEach((el) => {
      sectionObserver.observe(el);
    });

    // ── Staggered scroll entrance ──
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const children = entry.target.querySelectorAll(".v5-stagger-child");
            children.forEach((child, i) => {
              setTimeout(() => {
                child.classList.add("v5-visible");
              }, i * 120);
            });
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    document.querySelectorAll(".v5-stagger-parent").forEach((parent) => {
      observer.observe(parent);
    });

    // Standalone stagger children
    const standaloneObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("v5-visible");
            standaloneObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    document.querySelectorAll(".v5-stagger-child:not(.v5-stagger-parent .v5-stagger-child)").forEach((el) => {
      standaloneObserver.observe(el);
    });

    // ── Bar chart animation (scroll triggered) ──
    const barObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.querySelectorAll(".v5-bar-animate").forEach((bar) => {
              bar.classList.add("v5-animate-bars");
            });
            barObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );
    document.querySelectorAll(".v5-glass-card, .v5-ab-border").forEach((el) => {
      // Observe parent containers
      const parent = el.closest("section") || el.parentElement;
      if (parent) barObserver.observe(parent);
    });
    // Also target A/B test section directly
    document.querySelectorAll(".v5-bar-animate").forEach((bar) => {
      const section = bar.closest("section");
      if (section) {
        barObserver.observe(section);
      }
    });

    // ── Gauge animation ──
    const gaugeObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("v5-animate-gauge");
            gaugeObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );
    document.querySelectorAll(".v5-gauge-fill").forEach((el) => {
      gaugeObserver.observe(el);
    });

    // ── Line draw animation ──
    const lineObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.querySelectorAll(".v5-line-draw, .v5-line-draw-forecast, .v5-band-fade").forEach((el) => {
              el.classList.add("v5-animate-line");
            });
            lineObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );
    document.querySelectorAll(".v5-line-draw").forEach((el) => {
      const container = el.closest("div");
      if (container) lineObserver.observe(container);
    });

    // ── Typewriter lines ──
    const twObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.querySelectorAll(".v5-typewriter-line").forEach((el) => {
              el.classList.add("v5-animate-tw");
            });
            twObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );
    document.querySelectorAll(".v5-agent-card").forEach((card) => {
      twObserver.observe(card);
    });

    // ── Subtle parallax on scroll for mock UIs ──
    const parallaxEls = document.querySelectorAll(".v5-parallax-subtle");
    if (parallaxEls.length > 0) {
      let ticking = false;
      window.addEventListener("scroll", () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            parallaxEls.forEach((el) => {
              const rect = (el as HTMLElement).getBoundingClientRect();
              const viewportCenter = window.innerHeight / 2;
              const elCenter = rect.top + rect.height / 2;
              const offset = (viewportCenter - elCenter) * 0.03;
              (el as HTMLElement).style.transform = `translateY(${offset}px)`;
            });
            ticking = false;
          });
          ticking = true;
        }
      });
    }
  });
</script>
