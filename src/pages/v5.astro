---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";
const b = import.meta.env.BASE_URL;
---

<Layout
  title="The AI-Powered Post-Purchase Platform - parcelLab"
  description="parcelLab's AI Suite — Copilot, WISMO/R Agent, and Insights Agent — automates decisions, predicts issues, and unlocks hidden revenue across the post-purchase journey."
>
  <Header client:load />
  <main>

    <!-- ═══════════════════════════════════════════════════
         SECTION 1 — HERO: Maximum Visual Impact
    ═══════════════════════════════════════════════════ -->
    <section class="v5-hero relative overflow-hidden text-white" id="v5-hero-section">
      <!-- Multi-layer animated background -->
      <div class="v5-hero-base pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="v5-hero-grid pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="v5-hero-orb v5-hero-orb--1 pointer-events-none absolute" aria-hidden="true"></div>
      <div class="v5-hero-orb v5-hero-orb--2 pointer-events-none absolute" aria-hidden="true"></div>
      <div class="v5-hero-orb v5-hero-orb--3 pointer-events-none absolute" aria-hidden="true"></div>
      <div class="v5-hero-orb v5-hero-orb--4 pointer-events-none absolute" aria-hidden="true"></div>
      <!-- Aurora / northern lights bands -->
      <div class="v5-aurora pointer-events-none absolute inset-x-0 top-0 h-[40%]" aria-hidden="true"></div>
      <!-- Noise grain overlay -->
      <div class="v5-noise pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <!-- Mouse-follow glow -->
      <div class="v5-mouse-glow pointer-events-none absolute inset-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-[1440px] px-6 pb-28 pt-36 md:px-12 lg:pb-36 lg:pt-44">
        <div class="grid items-center gap-16 lg:grid-cols-[1fr_440px]">
          <!-- Left column -->
          <div>
            <p class="v5-fade-in mb-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 text-sm font-medium text-[#a5b4fc] backdrop-blur-md">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Introducing the parcelLab AI Suite
            </p>

            <h1 class="v5-fade-in text-hero text-white" style="animation-delay:.1s">
              The AI that knows your<br />
              <span class="v5-cycle-word relative inline-block">
                <span class="v5-cycle-item" data-index="0">customers</span>
                <span class="v5-cycle-item" data-index="1">shipments</span>
                <span class="v5-cycle-item" data-index="2">returns</span>
                <span class="v5-cycle-item" data-index="3">revenue</span>
                <span class="v5-cursor" aria-hidden="true"></span>
              </span>
            </h1>

            <p class="v5-fade-in mt-6 max-w-xl text-lg font-light leading-relaxed text-slate-300" style="animation-delay:.2s">
              parcelLab's AI suite &mdash; Copilot, WISMO/R Agent, and Insights Agent &mdash; learns from billions of data points to automate decisions, predict issues, and unlock revenue you didn't know existed.
            </p>

            <div class="v5-fade-in mt-10 flex flex-wrap gap-4" style="animation-delay:.3s">
              <a href="#ai-agents" class="v5-cta-glow inline-flex items-center gap-2 rounded-full bg-[#3D3AD3] px-7 py-3.5 text-sm font-semibold text-white transition-all hover:bg-[#4b47e8]">
                Meet the AI
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
              <a href={`${b}/live-demo/`} class="inline-flex items-center gap-2 rounded-full border border-white/20 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/50 hover:bg-white/[0.06]">
                Book a demo
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            </div>
          </div>

          <!-- Right column — Mock AI chat with animated gradient border -->
          <div class="v5-float-card v5-fade-in relative" style="animation-delay:.4s">
            <div class="v5-chat-card relative overflow-hidden rounded-2xl p-6 shadow-2xl shadow-[#3D3AD3]/20">
              <!-- Animated gradient border -->
              <div class="v5-gradient-border pointer-events-none absolute inset-0 rounded-2xl" aria-hidden="true"></div>
              <!-- Scanline effect -->
              <div class="v5-scanline pointer-events-none absolute inset-0 rounded-2xl" aria-hidden="true"></div>
              <!-- Glass content -->
              <div class="relative z-10">
                <!-- Chat header -->
                <div class="mb-4 flex items-center gap-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#3D3AD3]/20">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                  </div>
                  <div>
                    <p class="text-xs font-semibold text-white">parcelLab Copilot</p>
                    <p class="text-[10px] text-slate-500">AI-powered data assistant</p>
                  </div>
                  <div class="ml-auto flex h-2 w-2 rounded-full bg-emerald-400">
                    <span class="h-2 w-2 animate-ping rounded-full bg-emerald-400"></span>
                  </div>
                </div>

                <!-- User message -->
                <div class="mb-3 flex justify-end">
                  <div class="max-w-[280px] rounded-2xl rounded-br-md bg-[#3D3AD3] px-4 py-2.5 text-[13px] leading-snug text-white">
                    Show me which carriers had the most delays last month
                  </div>
                </div>

                <!-- AI response -->
                <div class="flex justify-start">
                  <div class="max-w-[320px] rounded-2xl rounded-bl-md border border-white/5 bg-white/[0.06] px-4 py-3 text-[13px] leading-relaxed text-slate-300 backdrop-blur-sm">
                    Based on <span class="font-semibold text-white">2.3M shipments</span>, Carrier&nbsp;X had <span class="font-semibold text-[#F4373D]">12.4% delays</span> vs network average of 4.2%. I recommend shifting volume to <span class="font-semibold text-emerald-400">Carrier&nbsp;Y</span> for routes A and B.
                    <div class="mt-2 flex gap-2">
                      <span class="inline-flex items-center rounded-md bg-white/5 px-2 py-0.5 text-[10px] text-slate-400">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mr-1"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        Live data
                      </span>
                      <span class="inline-flex items-center rounded-md bg-white/5 px-2 py-0.5 text-[10px] text-slate-400">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mr-1"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                        0.8s response
                      </span>
                    </div>
                  </div>
                </div>

                <!-- Typing indicator -->
                <div class="mt-3 flex justify-start">
                  <div class="flex items-center gap-1.5 rounded-2xl rounded-bl-md border border-white/5 bg-white/[0.04] px-4 py-2.5">
                    <span class="v5-typing-dot h-1.5 w-1.5 rounded-full bg-slate-400"></span>
                    <span class="v5-typing-dot h-1.5 w-1.5 rounded-full bg-slate-400" style="animation-delay:.15s"></span>
                    <span class="v5-typing-dot h-1.5 w-1.5 rounded-full bg-slate-400" style="animation-delay:.3s"></span>
                  </div>
                </div>

                <!-- Input mock -->
                <div class="mt-4 flex items-center gap-2 rounded-xl border border-white/10 bg-white/[0.04] px-3 py-2 backdrop-blur-sm">
                  <span class="text-xs text-slate-500">Ask anything about your data...</span>
                  <svg class="ml-auto" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         SECTION 2 — AI CAPABILITY CARDS (Dramatic)
    ═══════════════════════════════════════════════════ -->
    <section id="ai-agents" class="v5-section-reveal section-generous relative overflow-hidden bg-[var(--surface)]">
      <!-- Subtle animated dots for light sections -->
      <div class="v5-noise-light pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto mb-16 max-w-2xl text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#3D3AD3]">AI Suite</p>
          <h2 class="text-display text-[var(--ink)]">Three agents, one platform</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            Purpose-built AI agents that work across your post-purchase data to answer questions, resolve tickets, and surface insights &mdash; automatically.
          </p>
        </div>

        <div class="v5-stagger-parent grid gap-8 md:grid-cols-3">
          <!-- Card 1: Copilot -->
          <div class="v5-stagger-child v5-agent-card v5-agent-card--purple group relative overflow-hidden rounded-2xl bg-[var(--surface-raised)] p-8 transition-all duration-500 hover:-translate-y-2">
            <!-- Animated gradient border -->
            <div class="v5-card-border v5-card-border--purple pointer-events-none absolute inset-0 rounded-2xl" aria-hidden="true"></div>
            <div class="relative z-10">
              <div class="v5-icon-gradient v5-icon-gradient--purple mb-5 flex h-12 w-12 items-center justify-center rounded-xl">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
                  <path d="M20 3v4"/><path d="M22 5h-4"/>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-[var(--ink)]">Copilot</h3>
              <p class="mb-1 text-sm font-medium text-[#3D3AD3]">Chat with your data</p>
              <p class="mt-3 text-sm font-light leading-relaxed text-[var(--ink-secondary)]">
                Ask questions in plain English. Get instant answers from your shipment, returns, and communication data &mdash; no SQL, no dashboards, no waiting.
              </p>
              <div class="mt-5 space-y-2">
                <div class="v5-typewriter-line rounded-lg bg-[var(--surface-sunken)] px-3 py-2 text-xs text-[var(--ink-secondary)]" style="--tw-delay:0s">
                  <span class="mr-1.5 text-[#3D3AD3]">&rsaquo;</span> "What's my returns rate this quarter?"
                </div>
                <div class="v5-typewriter-line rounded-lg bg-[var(--surface-sunken)] px-3 py-2 text-xs text-[var(--ink-secondary)]" style="--tw-delay:.3s">
                  <span class="mr-1.5 text-[#3D3AD3]">&rsaquo;</span> "Which products have the highest exchange rate?"
                </div>
                <div class="v5-typewriter-line rounded-lg bg-[var(--surface-sunken)] px-3 py-2 text-xs text-[var(--ink-secondary)]" style="--tw-delay:.6s">
                  <span class="mr-1.5 text-[#3D3AD3]">&rsaquo;</span> "Compare carrier performance in DACH vs UK"
                </div>
              </div>
            </div>
            <!-- Hover glow -->
            <div class="pointer-events-none absolute -inset-1 rounded-2xl opacity-0 transition-all duration-500 group-hover:opacity-100" style="box-shadow: 0 0 40px rgba(61,58,211,0.3), 0 0 80px rgba(61,58,211,0.1)"></div>
          </div>

          <!-- Card 2: WISMO/R Agent -->
          <div class="v5-stagger-child v5-agent-card v5-agent-card--green group relative overflow-hidden rounded-2xl bg-[var(--surface-raised)] p-8 transition-all duration-500 hover:-translate-y-2">
            <div class="v5-card-border v5-card-border--green pointer-events-none absolute inset-0 rounded-2xl" aria-hidden="true"></div>
            <div class="relative z-10">
              <div class="v5-icon-gradient v5-icon-gradient--green mb-5 flex h-12 w-12 items-center justify-center rounded-xl">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 1 1 18 0m0 0v5a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3Z"/>
                  <path d="M21 16v2a4 4 0 0 1-4 4h-5"/>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-[var(--ink)]">WISMO/R Agent</h3>
              <p class="mb-1 text-sm font-medium text-[#035740]">Automate customer service</p>
              <p class="mt-3 text-sm font-light leading-relaxed text-[var(--ink-secondary)]">
                Resolve "Where is my order?" and "Where is my return?" inquiries automatically. Integrates with Gorgias, Zendesk, Salesforce, and Kustomer.
              </p>
              <div class="mt-5 flex items-center gap-3 rounded-xl border border-[#035740]/10 bg-[#035740]/5 p-4">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#035740]/10">
                  <span class="text-lg font-bold text-[#035740]">45</span>
                </div>
                <div>
                  <p class="text-sm font-semibold text-[var(--ink)]">Up to 45%</p>
                  <p class="text-xs text-[var(--ink-secondary)]">automated resolution rate</p>
                </div>
              </div>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {["Gorgias", "Zendesk", "Salesforce", "Kustomer"].map((name) => (
                  <span class="rounded-md bg-[var(--surface-sunken)] px-2 py-0.5 text-[10px] font-medium text-[var(--ink-muted)]">{name}</span>
                ))}
              </div>
            </div>
            <div class="pointer-events-none absolute -inset-1 rounded-2xl opacity-0 transition-all duration-500 group-hover:opacity-100" style="box-shadow: 0 0 40px rgba(3,87,64,0.3), 0 0 80px rgba(3,87,64,0.1)"></div>
          </div>

          <!-- Card 3: Insights Agent -->
          <div class="v5-stagger-child v5-agent-card v5-agent-card--yellow group relative overflow-hidden rounded-2xl bg-[var(--surface-raised)] p-8 transition-all duration-500 hover:-translate-y-2">
            <div class="v5-card-border v5-card-border--yellow pointer-events-none absolute inset-0 rounded-2xl" aria-hidden="true"></div>
            <div class="relative z-10">
              <div class="v5-icon-gradient v5-icon-gradient--yellow mb-5 flex h-12 w-12 items-center justify-center rounded-xl">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 3v18h18"/>
                  <path d="m19 9-5 5-4-4-3 3"/>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-[var(--ink)]">Insights Agent</h3>
              <p class="mb-1 text-sm font-medium text-[#b8860b]">Predictions, not just reports</p>
              <p class="mt-3 text-sm font-light leading-relaxed text-[var(--ink-secondary)]">
                AI-generated analysis delivered proactively. Returns forecasting, anomaly detection, and carrier performance predictions &mdash; before you even ask.
              </p>
              <div class="mt-5 flex items-start gap-2 rounded-xl border border-[#FFC943]/20 bg-[#FFC943]/5 px-4 py-3">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                <p class="text-xs leading-relaxed text-[var(--ink-secondary)]">
                  <span class="font-semibold text-[var(--ink)]">Proactive alert:</span> Get alerts before problems become incidents
                </p>
              </div>
            </div>
            <div class="pointer-events-none absolute -inset-1 rounded-2xl opacity-0 transition-all duration-500 group-hover:opacity-100" style="box-shadow: 0 0 40px rgba(255,201,67,0.3), 0 0 80px rgba(255,201,67,0.1)"></div>
          </div>
        </div>

        <!-- Animated data-flow connectors between cards (desktop) -->
        <div class="v5-data-flow-lines pointer-events-none mt-8 hidden justify-center gap-0 md:flex" aria-hidden="true">
          <div class="v5-data-flow-line v5-data-flow-line--1 h-px flex-1"></div>
          <div class="v5-data-flow-node h-2 w-2 rounded-full bg-[#3D3AD3]"></div>
          <div class="v5-data-flow-line v5-data-flow-line--2 h-px flex-1"></div>
          <div class="v5-data-flow-node h-2 w-2 rounded-full bg-[#035740]"></div>
          <div class="v5-data-flow-line v5-data-flow-line--3 h-px flex-1"></div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════
         SECTION 3 — PLATFORM INTELLIGENCE FLOW (Dramatic)
    ═══════════════════════════════════════════════════ -->
    <section class="v5-section-reveal v5-dark-section relative section-generous overflow-hidden bg-gradient-to-b from-[#0a0a1a] to-[#0f172a] text-white">
      <div class="v5-star-field pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="v5-noise pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto mb-16 max-w-2xl text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#818cf8]">Platform Intelligence</p>
          <h2 class="text-display text-white">From data to decisions</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-slate-400">
            See how raw logistics data transforms into automated, revenue-driving actions in four steps.
          </p>
        </div>

        <!-- Flow diagram -->
        <div class="v5-flow-container v5-stagger-parent relative grid gap-0 md:grid-cols-4">
          <!-- Step 1 -->
          <div class="v5-stagger-child v5-flow-step group relative flex flex-col items-center text-center">
            <div class="v5-flow-icon relative z-10 flex h-16 w-16 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.04] shadow-lg shadow-[#3D3AD3]/10 backdrop-blur-sm transition-all duration-500 group-hover:border-[#3D3AD3]/50 group-hover:shadow-[#3D3AD3]/30">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                <path d="M3 5v14a9 3 0 0 0 18 0V5"/>
                <path d="M3 12a9 3 0 0 0 18 0"/>
              </svg>
            </div>
            <h3 class="mt-4 text-sm font-semibold text-white">Data Integration</h3>
            <p class="mt-2 max-w-[200px] text-xs font-light leading-relaxed text-slate-400">
              50M+ shipments/month from 175+ carriers flowing into a unified data lake.
            </p>
            <!-- Animated connector line (desktop) -->
            <div class="v5-flow-line absolute right-0 top-8 hidden h-px w-[calc(50%-32px)] overflow-hidden md:block" aria-hidden="true">
              <div class="v5-flow-line-animated h-full w-full"></div>
              <div class="v5-flow-particle absolute top-[-2px] h-[5px] w-[5px] rounded-full bg-[#818cf8]"></div>
            </div>
            <div class="v5-flow-line-v mx-auto mt-4 h-8 w-px md:hidden" aria-hidden="true"></div>
          </div>

          <!-- Step 2 -->
          <div class="v5-stagger-child v5-flow-step group relative flex flex-col items-center text-center">
            <div class="v5-flow-icon relative z-10 flex h-16 w-16 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.04] shadow-lg shadow-[#3D3AD3]/10 backdrop-blur-sm transition-all duration-500 group-hover:border-[#3D3AD3]/50 group-hover:shadow-[#3D3AD3]/30">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a4 4 0 0 0-4 4c0 2 1 3 2 4l2 2 2-2c1-1 2-2 2-4a4 4 0 0 0-4-4z"/>
                <path d="M12 12v4"/>
                <path d="M8 18h8"/>
                <path d="M9 22h6"/>
              </svg>
            </div>
            <h3 class="mt-4 text-sm font-semibold text-white">AI Processing</h3>
            <p class="mt-2 max-w-[200px] text-xs font-light leading-relaxed text-slate-400">
              ML models trained on billions of historical data points identify patterns and predictions.
            </p>
            <div class="v5-flow-line absolute right-0 top-8 hidden h-px w-[calc(50%-32px)] overflow-hidden md:block" aria-hidden="true">
              <div class="v5-flow-line-animated h-full w-full"></div>
              <div class="v5-flow-particle absolute top-[-2px] h-[5px] w-[5px] rounded-full bg-[#818cf8]"></div>
            </div>
            <div class="v5-flow-line absolute left-0 top-8 hidden h-px w-[calc(50%-32px)] overflow-hidden md:block" aria-hidden="true">
              <div class="v5-flow-line-animated h-full w-full"></div>
            </div>
            <div class="v5-flow-line-v mx-auto mt-4 h-8 w-px md:hidden" aria-hidden="true"></div>
          </div>

          <!-- Step 3 -->
          <div class="v5-stagger-child v5-flow-step group relative flex flex-col items-center text-center">
            <div class="v5-flow-icon relative z-10 flex h-16 w-16 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.04] shadow-lg shadow-[#3D3AD3]/10 backdrop-blur-sm transition-all duration-500 group-hover:border-[#3D3AD3]/50 group-hover:shadow-[#3D3AD3]/30">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 12h5"/><path d="M17 12h5"/>
                <path d="M12 2v5"/><path d="M12 17v5"/>
                <circle cx="12" cy="12" r="4"/>
                <path d="m4.93 4.93 2.83 2.83"/><path d="m16.24 16.24 2.83 2.83"/>
