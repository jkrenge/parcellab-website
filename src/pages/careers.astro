---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";

const values = [
  {
    title: "We Build and Succeed Together",
    desc: "Teamwork and shared achievement drive everything we do.",
    color: "#3D3AD3",
  },
  {
    title: "Own It, Improve It",
    desc: "Taking ownership and continuous improvement are in our DNA.",
    color: "#035740",
  },
  {
    title: "Stronger Through Diversity",
    desc: "Inclusive culture valuing different perspectives and backgrounds.",
    color: "#FFC943",
    textColor: "#b8860b",
  },
  {
    title: "Challenge, Learn, Grow",
    desc: "Embracing continuous development and stepping outside comfort zones.",
    color: "#3D3AD3",
  },
];

const benefits = [
  { icon: "home", title: "Remote-First", desc: "Flexible work from anywhere with a remote-first culture" },
  { icon: "globe", title: "Work From Abroad", desc: "Work from abroad policy for global flexibility" },
  { icon: "calendar", title: "Generous PTO", desc: "Generous paid time off to recharge and reset" },
  { icon: "shield", title: "401K / Pension", desc: "Retirement plans available in US, UK, and DE" },
  { icon: "heart", title: "Parental Leave", desc: "Enhanced parental leave policies (US, UK)" },
  { icon: "plus", title: "Healthcare", desc: "Paid healthcare coverage (US, UK)" },
  { icon: "umbrella", title: "Sick Pay", desc: "Comprehensive sick pay for when you need it" },
  { icon: "users", title: "Team Offsites", desc: "Twice-yearly company offsites to connect in person" },
  { icon: "star", title: "Leadership Development", desc: "Programs to grow your leadership skills" },
  { icon: "check", title: "Structured Onboarding", desc: "30-60-90 day onboarding to set you up for success" },
  { icon: "life-buoy", title: "Employee Assistance", desc: "Employee assistance programs for wellbeing support" },
  { icon: "trending-up", title: "Career Growth", desc: "Clear paths for professional development and advancement" },
];

const testimonials = [
  {
    quote: "parcelLab treats employee wellbeing as sacred. Concerns receive utmost respect.",
    name: "Robert Rodgers",
    role: "Technical Support Engineer, US",
  },
  {
    quote: "Working with passionate people solving universal problems is inspiring and rare.",
    name: "Mark Dunlap",
    role: "Global Head of Solution Consulting, UK",
  },
  {
    quote: "Amazing employees, customers, and cutting-edge tech make each day exciting.",
    name: "Sabrina Luedtke",
    role: "Account Executive, US",
  },
  {
    quote: "Trusting environment with autonomy allows professional and personal growth.",
    name: "Jessica Bann",
    role: "Senior Legal Counsel, UK",
  },
];
---

<Layout title="Careers at parcelLab - Join the parcelCrew" description="Build your career and help shape the future of post-purchase experiences. Join a global team redefining post-purchase for the world's biggest brands.">
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Careers"
      title="Build your career and help shape the future of post-purchase experiences"
      description="We're building something amazing at parcelLab, and we want you to be part of it. Join a global team that's redefining post-purchase experiences for the world's biggest brands."
      ctaText="View open positions"
      ctaHref={`${import.meta.env.BASE_URL}/careers/#positions`}
    />

    <!-- Company Overview Stats -->
    <section class="section-standard">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
          {[
            { value: "200+", label: "Employees" },
            { value: "1,000+", label: "Brands trust us" },
            { value: "3", label: "Offices worldwide" },
            { value: "1", label: "Mission" },
          ].map((stat) => (
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6 text-center">
              <p class="text-display text-[#3D3AD3]">{stat.value}</p>
              <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Our Values -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-2xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Our Culture</span>
          <h2 class="text-display text-[var(--ink)]">Values that guide us</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">Our four core values shape how we work, collaborate, and grow together.</p>
        </div>
        <div class="mt-12 grid gap-6 sm:grid-cols-2">
          {values.map((value) => (
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
              <div class="mb-4 h-1 w-12 rounded-full" style={`background: ${value.color}`}></div>
              <h3 class="text-xl font-semibold text-[var(--ink)]">{value.title}</h3>
              <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">{value.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-2xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Benefits & Perks</span>
          <h2 class="text-display text-[var(--ink)]">We take care of our people</h2>
        </div>
        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {benefits.map((benefit) => (
            <div class="flex items-start gap-4 rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#3D3AD3]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-[var(--ink)]">{benefit.title}</h3>
                <p class="mt-1 text-xs leading-relaxed text-[var(--ink-secondary)]">{benefit.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Employee Testimonials -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-2xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Life at parcelLab</span>
          <h2 class="text-display text-[var(--ink)]">Hear from the parcelCrew</h2>
        </div>
        <div class="mt-12 grid gap-8 md:grid-cols-2">
          {testimonials.map((testimonial) => (
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="#3D3AD3" opacity="0.12" class="mb-4"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
              <p class="text-[var(--ink)] leading-relaxed">"{testimonial.quote}"</p>
              <div class="mt-5 border-t border-[var(--line)] pt-4">
                <p class="text-sm font-semibold text-[var(--ink)]">{testimonial.name}</p>
                <p class="text-xs text-[var(--ink-secondary)]">{testimonial.role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Open Positions -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-2xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Open Positions</span>
          <h2 class="text-display text-[var(--ink)]">Find your next role</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">Explore opportunities across our teams in Boston, London, and Munich.</p>
        </div>
        <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {[
            { dept: "Engineering", roles: ["Senior Backend Engineer", "Frontend Engineer", "DevOps Engineer"], location: "Munich / Remote" },
            { dept: "Product", roles: ["Product Manager", "UX Designer", "Data Analyst"], location: "Munich / Remote" },
            { dept: "Sales", roles: ["Account Executive", "Solutions Consultant", "Sales Development Rep"], location: "Boston / London" },
            { dept: "Customer Success", roles: ["Customer Success Manager", "Implementation Specialist", "Technical Support Engineer"], location: "Boston / London / Munich" },
            { dept: "Marketing", roles: ["Content Marketing Manager", "Demand Generation Lead", "Events Manager"], location: "Boston / London" },
            { dept: "Operations", roles: ["People Partner", "Finance Manager", "Legal Counsel"], location: "Munich / Remote" },
          ].map((dept) => (
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
              <h3 class="text-lg font-semibold text-[var(--ink)]">{dept.dept}</h3>
              <p class="mb-4 text-xs text-[var(--ink-muted)]">{dept.location}</p>
              <ul class="space-y-2">
                {dept.roles.map((role) => (
                  <li>
                    <a href={`${import.meta.env.BASE_URL}/careers/`} class="group flex items-center justify-between rounded-lg px-3 py-2 text-sm text-[var(--ink-secondary)] transition-colors hover:bg-[var(--surface-sunken)] hover:text-[var(--ink)]">
                      {role}
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 transition-opacity group-hover:opacity-100"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a
            href={`${import.meta.env.BASE_URL}/careers/`}
            class="group inline-flex items-center gap-3 rounded-full bg-[#3D3AD3] py-4 pl-7 pr-6 text-base font-medium text-white shadow-[0_2px_16px_rgba(61,58,211,0.3)] transition-all hover:shadow-[0_4px_24px_rgba(61,58,211,0.4)] hover:-translate-y-0.5"
          >
            View all positions on TeamTailor
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Office Locations -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <h2 class="text-heading text-[var(--ink)]">Our offices</h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-3">
          {[
            { city: "Boston, USA", address: "75 State Street, Boston, MA 02109" },
            { city: "London, UK", address: "Moor Place, 1 Fore Street Avenue, EC2Y 9DT" },
            { city: "Munich, Germany", address: "Kapellenweg 6, 81371 Munich" },
          ].map((office) => (
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5 text-center">
              <h3 class="text-sm font-semibold text-[var(--ink)]">{office.city}</h3>
              <p class="mt-1 text-xs text-[var(--ink-secondary)]">{office.address}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
