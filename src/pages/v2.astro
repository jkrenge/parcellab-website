    text-transform: uppercase;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: clamp(2rem, 3vw, 3rem);
    max-width: 40rem;
    margin-left: auto;
    margin-right: auto;
  }

  .v2-cta__pods {
    display: flex;
    justify-content: center;
    gap: clamp(2rem, 4vw, 4rem);
    margin-bottom: 2.5rem;
  }

  .v2-cta__pod {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .v2-cta__pod-num {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--v2-purple);
    line-height: 1;
  }
  .v2-cta__pod-label {
    font-size: 0.8rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-top: 0.3rem;
  }

  /* ── SCROLL ANIMATIONS ── */
  .v2-slide-left,
  .v2-slide-right {
    opacity: 0;
    transition: opacity 0.7s var(--v2-ease), transform 0.7s var(--v2-ease);
  }
  .v2-slide-left {
    transform: translateX(-40px);
  }
  .v2-slide-right {
    transform: translateX(40px);
  }
  .v2-slide-left.is-visible,
  .v2-slide-right.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Reduce motion ── */
  @media (prefers-reduced-motion: reduce) {
    .v2-hero__badge-wrap,
    .v2-hero__line,
    .v2-hero__sub,
    .v2-hero__ctas,
    .v2-hero__logos,
    .v2-slide-left,
    .v2-slide-right {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      animation: none !important;
    }
    .v2-word {
      opacity: 1 !important;
      transition: none !important;
    }
    .v2-chat-typing span {
      animation: none;
    }
    .v2-accordion__content {
      animation: none;
    }
  }
</style>

<!-- ═══════════════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════════════ -->
<script>
  // Only animate when user has not requested reduced motion
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ── 1. Hero staggered reveal on load ──
  function animateHero() {
    if (prefersReducedMotion) return;

    const badge = document.querySelector(".v2-hero__badge-wrap") as HTMLElement | null;
    const lines = document.querySelectorAll<HTMLElement>(".v2-hero__line");
    const sub = document.querySelector(".v2-hero__sub") as HTMLElement | null;
    const ctas = document.querySelector(".v2-hero__ctas") as HTMLElement | null;
    const logos = document.querySelector(".v2-hero__logos") as HTMLElement | null;

    const elements = [badge, ...Array.from(lines), sub, ctas, logos].filter(Boolean) as HTMLElement[];

    elements.forEach((el, i) => {
      el.style.transition = `opacity 0.6s cubic-bezier(0.22,1,0.36,1) ${i * 0.1}s, transform 0.6s cubic-bezier(0.22,1,0.36,1) ${i * 0.1}s`;
      requestAnimationFrame(() => {
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
      });
    });
  }

  // ── 2. Mission statement word-by-word scroll reveal ──
  function initMissionReveal() {
    if (prefersReducedMotion) return;

    const words = document.querySelectorAll<HTMLElement>(".v2-word");
    if (!words.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add("is-visible");
          }
        });
      },
      {
        threshold: 0.5,
        rootMargin: "0px 0px -10% 0px",
      }
    );

    words.forEach((word, i) => {
      word.style.transitionDelay = `${i * 0.08}s`;
      observer.observe(word);
    });
  }

  // ── 3. Slide-in animations for feature sections and cards ──
  function initSlideAnimations() {
    if (prefersReducedMotion) return;

    const slides = document.querySelectorAll<HTMLElement>(".v2-slide-left, .v2-slide-right");
    if (!slides.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.15,
        rootMargin: "0px 0px -50px 0px",
      }
    );

    slides.forEach((el) => observer.observe(el));
  }

  // ── 4. Stats count-up animation ──
  function initCountUp() {
    if (prefersReducedMotion) {
      // Still set final values even without animation
      document.querySelectorAll<HTMLElement>(".v2-stat__num").forEach((el) => {
        const target = parseInt(el.dataset.target || "0", 10);
        const suffix = el.dataset.suffix || "";
        el.textContent = target + suffix;
      });
      return;
    }

    const stats = document.querySelectorAll<HTMLElement>(".v2-stat__num");
    if (!stats.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);

          const target = parseInt(el.dataset.target || "0", 10);
          const suffix = el.dataset.suffix || "";
          const duration = 2000;
          const startTime = performance.now();

          function update(now: number) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            // Ease out cubic
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = Math.round(eased * target);
            el.textContent = current + suffix;
            if (progress < 1) {
              requestAnimationFrame(update);
            }
          }
          requestAnimationFrame(update);
        });
      },
      { threshold: 0.3 }
    );

    stats.forEach((el) => observer.observe(el));
  }

  // ── Initialise everything ──
  document.addEventListener("DOMContentLoaded", () => {
    animateHero();
    initMissionReveal();
    initSlideAnimations();
    initCountUp();
  });

  // Also run on Astro page transitions if using View Transitions
  document.addEventListener("astro:page-load", () => {
    animateHero();
    initMissionReveal();
    initSlideAnimations();
    initCountUp();
  });
</script>
