<script>
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ── 1. Hero staggered reveal (scale + blur-to-sharp) ──
  function animateHero() {
    if (prefersReducedMotion) return;

    const badge = document.querySelector(".v2-hero__badge-wrap") as HTMLElement | null;
    const lines = document.querySelectorAll<HTMLElement>(".v2-hero__line");
    const sub = document.querySelector(".v2-hero__sub") as HTMLElement | null;
    const ctas = document.querySelector(".v2-hero__ctas") as HTMLElement | null;
    const logos = document.querySelector(".v2-hero__logos") as HTMLElement | null;

    // Badge animates first
    if (badge) {
      badge.style.transition = `opacity 0.6s cubic-bezier(0.22,1,0.36,1) 0.1s, transform 0.6s cubic-bezier(0.22,1,0.36,1) 0.1s`;
      requestAnimationFrame(() => {
        badge.style.opacity = "1";
        badge.style.transform = "translateY(0)";
      });
    }

    // Lines scale in from 0.7 with blur-to-sharp
    lines.forEach((line, i) => {
      const delay = 0.2 + i * 0.15;
      line.style.transition = `opacity 0.8s cubic-bezier(0.22,1,0.36,1) ${delay}s, transform 0.8s cubic-bezier(0.22,1,0.36,1) ${delay}s, filter 0.8s cubic-bezier(0.22,1,0.36,1) ${delay}s`;
      requestAnimationFrame(() => {
        line.style.opacity = "1";
        line.style.transform = "translateY(0) scale(1)";
        line.style.filter = "blur(0)";
      });
    });

    // Sub, CTAs, logos
    const rest = [sub, ctas, logos].filter(Boolean) as HTMLElement[];
    rest.forEach((el, i) => {
      const delay = 0.6 + i * 0.12;
      el.style.transition = `opacity 0.6s cubic-bezier(0.22,1,0.36,1) ${delay}s, transform 0.6s cubic-bezier(0.22,1,0.36,1) ${delay}s`;
      requestAnimationFrame(() => {
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
      });
    });
  }

  // ── 2. Mission statement word-by-word (scale + blur) ──
  function initMissionReveal() {
    if (prefersReducedMotion) return;

    const words = document.querySelectorAll<HTMLElement>(".v2-word");
    if (!words.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add("is-visible");
          }
        });
      },
      {
        threshold: 0.5,
        rootMargin: "0px 0px -10% 0px",
      }
    );

    words.forEach((word, i) => {
      word.style.transitionDelay = `${i * 0.1}s`;
      observer.observe(word);
    });
  }

  // ── 3. Slide-in animations ──
  function initSlideAnimations() {
    if (prefersReducedMotion) return;

    const slides = document.querySelectorAll<HTMLElement>(".v2-slide-left, .v2-slide-right");
    if (!slides.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.15,
        rootMargin: "0px 0px -50px 0px",
      }
    );

    slides.forEach((el) => observer.observe(el));
  }

  // ── 4. Stats count-up with glow ──
  function initCountUp() {
    if (prefersReducedMotion) {
      document.querySelectorAll<HTMLElement>(".v2-stat__num").forEach((el) => {
        const target = parseInt(el.dataset.target || "0", 10);
        const suffix = el.dataset.suffix || "";
        el.textContent = target + suffix;
      });
      return;
    }

    const stats = document.querySelectorAll<HTMLElement>(".v2-stat__num");
    if (!stats.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);

          const target = parseInt(el.dataset.target || "0", 10);
          const suffix = el.dataset.suffix || "";
          const duration = 2000;
          const startTime = performance.now();

          // Add glow while counting
          el.classList.add("is-counting");

          function update(now: number) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = Math.round(eased * target);
            el.textContent = current + suffix;
            if (progress < 1) {
              requestAnimationFrame(update);
            } else {
              // Counting done — transition to pulse then fade glow
              el.classList.remove("is-counting");
              el.classList.add("is-done");
            }
          }
          requestAnimationFrame(update);
        });
      },
      { threshold: 0.3 }
    );

    stats.forEach((el) => observer.observe(el));
  }

  // ── 5. Parallax effect for mock UI cards ──
  function initParallax() {
    if (prefersReducedMotion) return;

    const parallaxEls = document.querySelectorAll<HTMLElement>(".v2-parallax");
    if (!parallaxEls.length) return;

    let ticking = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        parallaxEls.forEach((el) => {
          const speed = parseFloat(el.dataset.speed || "0.05");
          const rect = el.getBoundingClientRect();
          const center = rect.top + rect.height / 2;
          const viewCenter = window.innerHeight / 2;
          const offset = (center - viewCenter) * speed;
          el.style.transform = `translateY(${offset}px)`;
        });
        ticking = false;
      });
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  // ── 6. 3D tilt effect on hover ──
  function initTiltCards() {
    if (prefersReducedMotion) return;

    const cards = document.querySelectorAll<HTMLElement>(".v2-tilt-card");
    cards.forEach((card) => {
      card.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = ((y - centerY) / centerY) * -4;
        const rotateY = ((x - centerX) / centerX) * 4;
        card.style.transform = `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateZ(4px)`;
      });

      card.addEventListener("mouseleave", () => {
        card.style.transform = "perspective(800px) rotateX(0) rotateY(0) translateZ(0)";
      });
    });
  }

  // ── Initialise everything ──
  function initAll() {
    animateHero();
    initMissionReveal();
    initSlideAnimations();
    initCountUp();
    initParallax();
    initTiltCards();
  }

  document.addEventListener("DOMContentLoaded", initAll);
  document.addEventListener("astro:page-load", initAll);
</script>
