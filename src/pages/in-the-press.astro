---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";

const pressItems = [
  {
    publication: "Multichannel Marketer",
    title: "Caraway Home reduces theft, WISMO calls with better communication",
    date: "Feb 25, 2025",
  },
  {
    publication: "U.S. Chamber of Commerce",
    title: "4 Ways Retailers Are Tapping AI to Mitigate the High Cost of Product Returns",
    date: "Feb 3, 2025",
  },
  {
    publication: "Practical eCommerce",
    title: "New Ecommerce Tools: January 16, 2025",
    date: "Jan 16, 2025",
  },
  {
    publication: "MediaPost",
    title: "Romancing After The Sale: AI Tools For Post-Purchase Messaging",
    date: "Jan 13, 2025",
  },
  {
    publication: "Retail TouchPoints",
    title: "How True Classic Turned VoC Strategy into Post-Purchase Perfection",
    date: "Nov 18, 2024",
  },
  {
    publication: "Multichannel Marketer",
    title: "Can retailers besides Amazon have a paid membership program?",
    date: "Oct 31, 2024",
  },
  {
    publication: "Home of Direct Commerce",
    title: "parcelLab and Metapack announce strategic partnership",
    date: "Oct 10, 2024",
  },
  {
    publication: "Retail Insight Network",
    title: "Back-to-school shopping: how parcelLab's data is shaping retail strategies",
    date: "Sep 3, 2024",
  },
  {
    publication: "IMRG",
    title: "Top Cross-Border eCommerce Trends in 2024",
    date: "Jul 1, 2024",
  },
  {
    publication: "PYMNTS",
    title: "parcelLab Launches AI-Powered Tool for Forecasting, Analyzing Returns",
    date: "Jun 25, 2024",
  },
  {
    publication: "Authority Magazine",
    title: "Noel Hamill Of parcelLab: How AI Is Disrupting Our Industry, and What We Can Do About It",
    date: "Jun 22, 2024",
  },
  {
    publication: "Retail Times",
    title: "Nearly 40% of UK retailers fail to meet delivery times - new report finds",
    date: "Jun 10, 2024",
  },
];
---

<Layout title="In the Press - parcelLab" description="From breaking news to expert insights, explore how parcelLab is shaping the future of post-purchase experience - one headline at a time.">
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Company"
      title="parcelLab in the media"
      description="From breaking news to expert insights, explore how parcelLab is shaping the future of post-purchase experience — one headline at a time."
    />

    <!-- Press Grid -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {pressItems.map((item) => (
            <article class="group flex flex-col rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6 transition-all hover:border-[#3D3AD3]/20 hover:shadow-[0_4px_24px_rgba(61,58,211,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <span class="inline-block rounded-full bg-[var(--surface-sunken)] px-3 py-1 text-xs font-medium text-[var(--ink-secondary)]">
                  {item.publication}
                </span>
                <time class="text-xs text-[var(--ink-muted)]">{item.date}</time>
              </div>
              <h3 class="flex-1 text-base font-semibold leading-snug text-[var(--ink)] group-hover:text-[#3D3AD3] transition-colors">
                {item.title}
              </h3>
              <div class="mt-4 flex items-center gap-2 text-sm font-medium text-[#3D3AD3] opacity-0 transition-opacity group-hover:opacity-100">
                Read article
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Press Contact -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-2xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Press Inquiries</span>
          <h2 class="text-display text-[var(--ink)]">Get in touch with our press team</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">For media inquiries, interviews, or press kit requests, reach out to our marketing team.</p>
          <div class="mt-8">
            <a
              href="mailto:marketing@parcellab.com"
              class="group inline-flex items-center gap-3 rounded-full border border-[var(--line)] bg-[var(--surface-raised)] px-7 py-4 text-base font-medium text-[var(--ink)] transition-all hover:border-[#3D3AD3]/30 hover:shadow-[0_4px_16px_rgba(61,58,211,0.08)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              marketing@parcellab.com
            </a>
          </div>
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
