    padding: 0;
    min-height: 280px;
    box-shadow: 0 8px 40px rgba(3,87,64,0.08);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .v8-after-frame:hover {
    box-shadow: 0 12px 50px rgba(3,87,64,0.12);
    transform: translateY(-2px);
  }
  .v8-after-glow {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    box-shadow: inset 0 0 60px rgba(3,87,64,0.03);
    pointer-events: none;
    z-index: 2;
  }

  /* Metric between */
  .v8-comparison-metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-width: 120px;
  }
  .v8-comparison-metric-value {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #3D3AD3, #035740);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .v8-comparison-metric-label {
    font-size: 12px;
    color: var(--ink-secondary);
    margin-top: 0.25rem;
    line-height: 1.4;
  }
  .v8-comparison-metric-vs {
    font-size: 11px;
    font-weight: 700;
    color: var(--ink-muted);
    margin-top: 0.5rem;
    padding: 4px 10px;
    border-radius: 100px;
    background: rgba(0,0,0,0.04);
  }

  /* Carrier mockup */
  .v8-mockup-carrier {
    padding: 16px;
  }
  .v8-mockup-carrier-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 12px;
    border-bottom: 1px solid #eee;
    margin-bottom: 12px;
  }
  .v8-mockup-carrier-logo {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    background: #ddd;
  }
  .v8-mockup-carrier-body {
    padding: 4px 0;
  }
  .v8-mockup-carrier-timeline {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 4px;
  }
  .v8-mockup-carrier-step {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
    color: #bbb;
  }
  .v8-mockup-carrier-step--done { color: #999; }
  .v8-mockup-carrier-step--active { color: #666; font-weight: 600; }
  .v8-mockup-carrier-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ddd;
    flex-shrink: 0;
  }
  .v8-mockup-carrier-step--done .v8-mockup-carrier-dot { background: #bbb; }
  .v8-mockup-carrier-step--active .v8-mockup-carrier-dot { background: #999; }

  /* OSP mockup */
  .v8-mockup-osp {
    display: flex;
    flex-direction: column;
  }
  .v8-mockup-osp-banner {
    background: linear-gradient(90deg, #3D3AD3, #6B68FF);
    padding: 8px;
    text-align: center;
  }
  .v8-mockup-osp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid #f0f0f0;
  }
  .v8-mockup-osp-logo {
    width: 60px;
    height: 16px;
    border-radius: 3px;
    background: linear-gradient(90deg, #3D3AD3, #6B68FF);
  }
  .v8-mockup-osp-nav {
    display: flex;
    gap: 12px;
    font-size: 9px;
    color: #999;
  }
  .v8-mockup-osp-body {
    padding: 16px;
  }
  .v8-mockup-osp-status {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .v8-mockup-osp-status-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(3,87,64,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v8-mockup-osp-progress {
    height: 6px;
    border-radius: 3px;
    background: #f0f0f0;
    margin-bottom: 12px;
    overflow: hidden;
  }
  .v8-mockup-osp-progress-fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, #035740, #10B981);
  }
  .v8-mockup-osp-map {
    height: 60px;
    border-radius: 8px;
    background: linear-gradient(135deg, #e8f4f0, #dbeafe);
    margin-bottom: 12px;
    position: relative;
    overflow: hidden;
  }
  .v8-mockup-osp-map::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 30%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #035740;
    box-shadow: 0 0 0 3px rgba(3,87,64,0.2);
  }
  .v8-mockup-osp-cta {
    background: linear-gradient(90deg, #3D3AD3, #6B68FF);
    padding: 8px 16px;
    border-radius: 8px;
    text-align: center;
  }

  /* Email mockup */
  .v8-mockup-email {
    padding: 16px;
  }
  .v8-mockup-email-header {
    padding-bottom: 10px;
    border-bottom: 1px solid #eee;
    margin-bottom: 12px;
  }
  .v8-mockup-email-body {
    padding: 4px 0;
  }

  /* Returns mockup */
  .v8-mockup-returns {
    display: flex;
    flex-direction: column;
  }
  .v8-mockup-returns-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid #f0f0f0;
  }
  .v8-mockup-returns-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .v8-mockup-returns-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid #eee;
    transition: border-color 0.2s;
  }
  .v8-mockup-returns-option--highlight {
    border-color: #035740;
    background: rgba(3,87,64,0.02);
  }
  .v8-mockup-returns-radio {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid #ddd;
    flex-shrink: 0;
  }
  .v8-mockup-returns-radio--active {
    border-color: #035740;
    background: #035740;
    box-shadow: inset 0 0 0 3px white;
  }
  .v8-mockup-returns-badge {
    font-size: 8px;
    font-weight: 700;
    color: #035740;
    background: rgba(3,87,64,0.08);
    padding: 2px 8px;
    border-radius: 100px;
    margin-left: auto;
    flex-shrink: 0;
  }
  .v8-mockup-returns-retention {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(255,201,67,0.08), rgba(255,201,67,0.02));
    border: 1px dashed rgba(255,201,67,0.3);
    margin-top: 4px;
  }

  /* Single email mockup */
  .v8-mockup-single-email {
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .v8-mockup-single-email-icon {
    margin-bottom: 12px;
  }

  /* Timeline mockup */
  .v8-mockup-timeline {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .v8-mockup-timeline-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 6px 0;
    position: relative;
  }
  .v8-mockup-timeline-item::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 18px;
    bottom: -6px;
    width: 1px;
    background: #e5e5e5;
  }
  .v8-mockup-timeline-item:last-child::before {
    display: none;
  }
  .v8-mockup-timeline-item--done::before {
    background: #035740;
  }
  .v8-mockup-timeline-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 2px solid #e5e5e5;
    background: white;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .v8-mockup-timeline-item--done .v8-mockup-timeline-dot {
    background: #035740;
    border-color: #035740;
  }
  .v8-mockup-timeline-item--active .v8-mockup-timeline-dot {
    border-color: #3D3AD3;
    background: #3D3AD3;
    box-shadow: 0 0 0 3px rgba(61,58,211,0.15);
  }
  .v8-mockup-timeline-content {
    display: flex;
    flex-direction: column;
  }
  .v8-mockup-timeline-title {
    font-size: 10px;
    font-weight: 700;
    color: #0f172a;
  }
  .v8-mockup-timeline-desc {
    font-size: 9px;
    color: #94a3b8;
  }
  .v8-mockup-timeline-item--done .v8-mockup-timeline-title { color: #035740; }
  .v8-mockup-timeline-item--active .v8-mockup-timeline-title { color: #3D3AD3; }

  /* ════════════════════════════════════════════════════
     SECTION 4 — CUSTOMER RESULTS
     ════════════════════════════════════════════════════ */
  .v8-results {
    background: var(--v8-ink);
  }
  .v8-results-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #0f172a, #1a1f3a, #0f172a);
  }
  .v8-results-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(61,58,211,0.08) 0%, transparent 40%),
      radial-gradient(ellipse at 70% 80%, rgba(3,87,64,0.06) 0%, transparent 40%);
  }

  .v8-results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  @media (max-width: 900px) {
    .v8-results-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 901px) and (max-width: 1200px) {
    .v8-results-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .v8-result-card {
    position: relative;
    border-radius: 20px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .v8-result-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  .v8-result-card-inner {
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 19px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .v8-result-card-border {
    position: absolute;
    bottom: 0;
    left: 1.5rem;
    right: 1.5rem;
    height: 2px;
    background: var(--result-accent);
    border-radius: 2px;
    opacity: 0.5;
  }
  .v8-result-category {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .v8-result-metric {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0.75rem 0 0.5rem;
  }
  .v8-result-what {
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1rem;
  }
  .v8-result-quote {
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255,255,255,0.35);
    font-style: italic;
    margin: 0;
  }

  /* Brand strip */
  .v8-brand-strip {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .v8-brand-strip-label {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    margin-bottom: 1.5rem;
  }
  .v8-brand-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    opacity: 0.5;
  }
  .v8-brand-logos img {
    height: 24px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.6;
    transition: opacity 0.3s;
  }
  .v8-brand-logos img:hover { opacity: 1; }

  /* ════════════════════════════════════════════════════
     SECTION 5 — BENTO GRID
     ════════════════════════════════════════════════════ */
  .v8-bento { background: var(--v8-surface); }

  .v8-bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto;
    gap: 1.25rem;
  }
  .v8-bento-card {
    background: white;
    border: 1px solid var(--line);
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .v8-bento-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.06);
  }
  .v8-bento-card--large {
    grid-column: span 2;
  }
  .v8-bento-card--small {
    grid-column: span 1;
  }
  .v8-bento-card--dark {
    background: var(--v8-ink);
    border-color: rgba(255,255,255,0.06);
    position: relative;
  }
  .v8-bento-card-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(139,92,246,0.1) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(61,58,211,0.08) 0%, transparent 50%);
    animation: v8-mesh-move 10s ease-in-out infinite alternate;
  }
  @keyframes v8-mesh-move {
    0% { opacity: 0.6; }
    100% { opacity: 1; }
  }
  .v8-bento-card-content {
    padding: 1.75rem;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) {
    .v8-bento-grid {
      grid-template-columns: 1fr 1fr;
    }
    .v8-bento-card--large {
      grid-column: span 2;
    }
  }
  @media (max-width: 600px) {
    .v8-bento-grid {
      grid-template-columns: 1fr;
    }
    .v8-bento-card--large,
    .v8-bento-card--small {
      grid-column: span 1;
    }
  }

  .v8-bento-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 100px;
    margin-bottom: 1rem;
  }
  .v8-bento-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--v8-ink);
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-bottom: 1rem;
  }
  .v8-bento-title--light { color: white; }
  .v8-bento-big-number {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .v8-bento-ai-agents {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .v8-bento-agent {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    transition: background 0.2s;
  }
  .v8-bento-agent:hover {
    background: rgba(255,255,255,0.08);
  }
  .v8-bento-agent-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .v8-bento-badges-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .v8-bento-security-badge {
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 700;
    color: var(--v8-purple);
    background: rgba(61,58,211,0.06);
    border: 1px solid rgba(61,58,211,0.1);
  }

  .v8-bento-flags {
    display: flex;
    gap: 6px;
    font-size: 16px;
    margin-top: 0.5rem;
  }

  .v8-bento-uptime-bar {
    height: 8px;
    border-radius: 4px;
    background: #f0f0f0;
    overflow: hidden;
    margin-top: 0.75rem;
  }
  .v8-bento-uptime-fill {
    height: 100%;
    width: 99.9%;
    border-radius: 4px;
    background: linear-gradient(90deg, #035740, #10B981);
  }

  .v8-bento-integrations {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  @media (max-width: 600px) {
    .v8-bento-integrations { grid-template-columns: repeat(2, 1fr); }
  }
  .v8-bento-integration {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border-radius: 10px;
    background: #f8f9fa;
    border: 1px solid #f0f0f0;
    font-size: 11px;
    font-weight: 600;
    color: var(--v8-ink);
    transition: background 0.2s;
  }
  .v8-bento-integration:hover { background: #f0f1f3; }

  .v8-bento-worldmap {
    margin-top: 0.5rem;
  }

  /* ════════════════════════════════════════════════════
     SECTION 6 — CTA
     ════════════════════════════════════════════════════ */
  .v8-cta {
    background: var(--v8-ink);
  }
  .v8-cta-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(61,58,211,0.15), rgba(3,87,64,0.1), rgba(61,58,211,0.15));
    background-size: 400% 400%;
    animation: v8-cta-gradient 8s ease infinite;
  }
  @keyframes v8-cta-gradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .v8-cta-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }
  .v8-cta-orb--1 {
    width: 500px;
    height: 500px;
    background: rgba(61,58,211,0.12);
    top: -200px;
    right: -100px;
    animation: v8-float 20s ease-in-out infinite;
  }
  .v8-cta-orb--2 {
    width: 400px;
    height: 400px;
    background: rgba(3,87,64,0.1);
    bottom: -150px;
    left: -100px;
    animation: v8-float 25s ease-in-out infinite reverse;
  }

  .v8-cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 5rem);
    align-items: center;
  }
  @media (max-width: 900px) {
    .v8-cta-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .v8-cta-title {
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3.25rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: white;
    margin-bottom: 1.25rem;
  }
  .v8-cta-desc {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255,255,255,0.55);
    margin-bottom: 2rem;
    max-width: 480px;
  }
  .v8-cta-stats {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .v8-cta-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .v8-cta-stat-value {
    font-size: 20px;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
  }
  .v8-cta-stat-label {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }

  /* Form */
  .v8-cta-form-wrapper {
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 24px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .v8-cta-form-glow {
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    border-radius: 26px;
    background: linear-gradient(135deg, rgba(61,58,211,0.3), rgba(3,87,64,0.2), rgba(255,201,67,0.15));
    background-size: 300% 300%;
    animation: v8-cta-gradient 6s ease infinite;
    z-index: -1;
    filter: blur(1px);
  }
  .v8-cta-form-title {
    font-size: 20px;
    font-weight: 700;
    color: white;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  .v8-cta-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .v8-form-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .v8-form-label {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
  }
  .v8-form-input {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 14px;
    color: white;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    font-family: inherit;
  }
