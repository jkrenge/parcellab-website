---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";
const b = import.meta.env.BASE_URL;
---

<Layout title="parcelLab — The ROI of Post-Purchase Excellence">
  <Header client:load />
  <main>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 1 — HERO: The Cost of Doing Nothing (Split Screen)
         ════════════════════════════════════════════════════════════════ -->
    <section class="v8-hero relative overflow-hidden" style="min-height: 100vh; min-height: 100dvh;">
      <!-- Floating orbs (decorative) -->
      <div class="v8-orb v8-orb--1 pointer-events-none absolute" aria-hidden="true"></div>
      <div class="v8-orb v8-orb--2 pointer-events-none absolute" aria-hidden="true"></div>
      <div class="v8-orb v8-orb--3 pointer-events-none absolute" aria-hidden="true"></div>

      <div class="v8-hero-split">
        <!-- LEFT: Dark half — the problem -->
        <div class="v8-hero-dark">
          <div class="v8-hero-dark-bg" aria-hidden="true"></div>
          <div class="v8-hero-dark-mesh" aria-hidden="true"></div>
          <div class="v8-hero-content v8-hero-content--left">
            <div class="v8-hero-label v8-hero-label--red">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              The problem
            </div>
            <h1 class="v8-hero-title v8-hero-title--light">
              Your post-purchase experience is <span class="v8-text-leak">leaking revenue</span>
            </h1>
            <div class="v8-counter-block v8-counter-block--red">
              <div class="v8-counter-label">Average revenue lost per day</div>
              <div class="v8-counter-value v8-counter-value--red" data-target="2847" data-prefix="$" data-suffix=" lost per day">
                $0 lost per day
              </div>
            </div>
            <p class="v8-hero-sub v8-hero-sub--light">
              Average revenue lost to generic tracking pages, preventable returns, and WISMO support calls.
            </p>
          </div>
        </div>

        <!-- Diagonal divider -->
        <div class="v8-hero-divider" aria-hidden="true">
          <div class="v8-hero-divider-gradient"></div>
        </div>

        <!-- RIGHT: Light half — the solution -->
        <div class="v8-hero-light">
          <div class="v8-hero-light-bg" aria-hidden="true"></div>
          <div class="v8-hero-light-dots" aria-hidden="true"></div>
          <div class="v8-hero-content v8-hero-content--right">
            <div class="v8-hero-label v8-hero-label--green">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              The solution
            </div>
            <h1 class="v8-hero-title v8-hero-title--dark">
              parcelLab customers <span class="v8-text-recover">recover it</span>
            </h1>
            <div class="v8-counter-block v8-counter-block--green">
              <div class="v8-counter-label v8-counter-label--dark">Revenue recovered per day</div>
              <div class="v8-counter-value v8-counter-value--green" data-target="2847" data-prefix="$" data-suffix=" recovered per day">
                $0 recovered per day
              </div>
            </div>
            <p class="v8-hero-sub v8-hero-sub--dark">
              Through branded tracking experiences, smart returns management, and proactive customer communications.
            </p>
          </div>
        </div>
      </div>

      <!-- Scroll CTA -->
      <a href="#the-math" class="v8-scroll-cta" aria-label="See the math">
        <span class="v8-scroll-cta-text">See the math</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
      </a>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 2 — THE MATH: ROI Calculator Style
         ════════════════════════════════════════════════════════════════ -->
    <section id="the-math" class="v8-math relative overflow-hidden" style="padding-top: clamp(6rem, 10vw, 9rem); padding-bottom: clamp(6rem, 10vw, 9rem);">
      <div class="v8-math-bg" aria-hidden="true"></div>
      <div class="container-pl relative z-10">
        <!-- Section header -->
        <div class="mx-auto mb-16 max-w-3xl text-center v8-reveal">
          <div class="v8-section-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg>
            ROI Calculator
          </div>
          <h2 class="v8-section-title">
            The post-purchase <span class="v8-gradient-text">revenue equation</span>
          </h2>
          <p class="v8-section-desc">
            For a brand processing 1M shipments per year, here is the measurable impact across three critical areas.
          </p>
        </div>

        <!-- Equation cards -->
        <div class="v8-equation-grid">
          <!-- Card 1: WISMO -->
          <div class="v8-equation-card v8-reveal" style="--card-accent: #3D3AD3; --card-glow: rgba(61,58,211,0.15);">
            <div class="v8-equation-card-inner">
              <div class="v8-equation-icon" style="background: linear-gradient(135deg, #3D3AD3, #6B68FF);">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/><line x1="15" y1="2" x2="15" y2="5"/><line x1="18" y1="5" x2="18" y2="2"/><line x1="21" y1="2" x2="21" y2="5"/></svg>
              </div>
              <div class="v8-equation-input">
                <span class="v8-equation-pct v8-count-up" data-target="20">0</span>
                <span class="v8-equation-pct-sign">%</span>
                <span class="v8-equation-input-label">fewer WISMO calls</span>
              </div>
              <div class="v8-equation-equals" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="9" x2="19" y2="9"/><line x1="5" y1="15" x2="19" y2="15"/></svg>
              </div>
              <div class="v8-equation-output">
                <span class="v8-equation-result v8-gradient-text">$340K</span>
                <span class="v8-equation-output-label">saved per year</span>
              </div>
              <div class="v8-equation-card-glow" aria-hidden="true"></div>
            </div>
          </div>

          <!-- Card 2: Returns to Exchanges -->
          <div class="v8-equation-card v8-reveal" style="--card-accent: #035740; --card-glow: rgba(3,87,64,0.15);">
            <div class="v8-equation-card-inner">
              <div class="v8-equation-icon" style="background: linear-gradient(135deg, #035740, #0D7A5F);">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
              </div>
              <div class="v8-equation-input">
                <span class="v8-equation-pct v8-count-up" data-target="11">0</span>
                <span class="v8-equation-pct-sign">%</span>
                <span class="v8-equation-input-label">returns converted to exchanges</span>
              </div>
              <div class="v8-equation-equals" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="9" x2="19" y2="9"/><line x1="5" y1="15" x2="19" y2="15"/></svg>
              </div>
              <div class="v8-equation-output">
                <span class="v8-equation-result v8-gradient-text-green">$890K</span>
                <span class="v8-equation-output-label">retained per year</span>
              </div>
              <div class="v8-equation-card-glow" aria-hidden="true"></div>
            </div>
          </div>

          <!-- Card 3: Conversion Lift -->
          <div class="v8-equation-card v8-reveal" style="--card-accent: #FFC943; --card-glow: rgba(255,201,67,0.12);">
            <div class="v8-equation-card-inner">
              <div class="v8-equation-icon" style="background: linear-gradient(135deg, #D4A017, #FFC943);">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>
              </div>
              <div class="v8-equation-input">
                <span class="v8-equation-pct v8-count-up" data-target="5">0</span>
                <span class="v8-equation-pct-sign">%</span>
                <span class="v8-equation-input-label">checkout conversion lift</span>
              </div>
              <div class="v8-equation-equals" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="9" x2="19" y2="9"/><line x1="5" y1="15" x2="19" y2="15"/></svg>
              </div>
              <div class="v8-equation-output">
                <span class="v8-equation-result v8-gradient-text-warm">$1.2M</span>
                <span class="v8-equation-output-label">revenue per year</span>
              </div>
              <div class="v8-equation-card-glow" aria-hidden="true"></div>
            </div>
          </div>
        </div>

        <!-- Total Impact bar -->
        <div class="v8-total-bar v8-reveal">
          <div class="v8-total-bar-inner">
            <div class="v8-total-bar-fill" aria-hidden="true"></div>
            <div class="v8-total-bar-content">
              <span class="v8-total-label">Total annual impact</span>
              <span class="v8-total-value">$2.4M+</span>
              <span class="v8-total-sub">combined yearly value for a brand processing 1M shipments</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 3 — BEFORE / AFTER Comparisons
         ════════════════════════════════════════════════════════════════ -->
    <section class="v8-compare relative overflow-hidden" style="padding-top: clamp(6rem, 10vw, 9rem); padding-bottom: clamp(6rem, 10vw, 9rem);">
      <div class="container-pl relative z-10">
        <div class="mx-auto mb-20 max-w-3xl text-center v8-reveal">
          <div class="v8-section-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
            Before vs. After
          </div>
          <h2 class="v8-section-title">
            The difference is <span class="v8-gradient-text">unmistakable</span>
          </h2>
          <p class="v8-section-desc">
            See how leading brands transform their post-purchase experience from generic to extraordinary.
          </p>
        </div>

        <!-- Comparison A: Tracking Experience -->
        <div class="v8-comparison v8-reveal">
          <div class="v8-comparison-header">
            <span class="v8-comparison-number">01</span>
            <h3 class="v8-comparison-title">Tracking Experience</h3>
          </div>
          <div class="v8-comparison-grid">
            <!-- Before -->
            <div class="v8-before">
              <div class="v8-before-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                Before
              </div>
              <div class="v8-before-frame">
                <div class="v8-before-crack v8-before-crack--1" aria-hidden="true"></div>
                <div class="v8-before-crack v8-before-crack--2" aria-hidden="true"></div>
                <!-- Generic carrier page mockup -->
                <div class="v8-mockup-carrier">
                  <div class="v8-mockup-carrier-header">
                    <div class="v8-mockup-carrier-logo"></div>
                    <span style="font-size: 10px; color: #999; font-family: monospace;">CARRIER TRACKING</span>
                  </div>
                  <div class="v8-mockup-carrier-body">
                    <div style="font-size: 11px; color: #666; margin-bottom: 8px;">Tracking #: 1Z999AA10123456784</div>
                    <div style="font-size: 11px; color: #444; margin-bottom: 12px; font-weight: 600;">In Transit</div>
                    <div class="v8-mockup-carrier-timeline">
                      <div class="v8-mockup-carrier-step v8-mockup-carrier-step--done">
                        <div class="v8-mockup-carrier-dot"></div>
                        <span>Label Created</span>
                      </div>
                      <div class="v8-mockup-carrier-step v8-mockup-carrier-step--done">
                        <div class="v8-mockup-carrier-dot"></div>
                        <span>Picked Up</span>
                      </div>
                      <div class="v8-mockup-carrier-step v8-mockup-carrier-step--active">
                        <div class="v8-mockup-carrier-dot"></div>
                        <span>In Transit</span>
                      </div>
                      <div class="v8-mockup-carrier-step">
                        <div class="v8-mockup-carrier-dot"></div>
                        <span>Delivered</span>
                      </div>
                    </div>
                    <div style="margin-top: 12px; font-size: 9px; color: #bbb;">No branding. No engagement. No revenue.</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Metric -->
            <div class="v8-comparison-metric">
              <div class="v8-comparison-metric-value">85%</div>
              <div class="v8-comparison-metric-label">engagement rate</div>
              <div class="v8-comparison-metric-vs">vs 0%</div>
            </div>

            <!-- After -->
            <div class="v8-after">
              <div class="v8-after-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                After
              </div>
              <div class="v8-after-frame">
                <div class="v8-after-glow" aria-hidden="true"></div>
                <!-- Branded OSP mockup -->
                <div class="v8-mockup-osp">
                  <div class="v8-mockup-osp-banner">
                    <span style="font-size: 10px; font-weight: 700; color: white; letter-spacing: 0.05em;">SPRING SALE: 20% OFF YOUR NEXT ORDER</span>
                  </div>
                  <div class="v8-mockup-osp-header">
                    <div class="v8-mockup-osp-logo"></div>
                    <div class="v8-mockup-osp-nav">
                      <span>Shop</span>
                      <span>Account</span>
                      <span>Help</span>
                    </div>
                  </div>
                  <div class="v8-mockup-osp-body">
                    <div class="v8-mockup-osp-status">
                      <div class="v8-mockup-osp-status-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      </div>
                      <div>
                        <div style="font-size: 13px; font-weight: 700; color: #0f172a;">Your order is on its way!</div>
                        <div style="font-size: 10px; color: #64748b;">Estimated delivery: Tomorrow by 5 PM</div>
                      </div>
                    </div>
                    <div class="v8-mockup-osp-progress">
                      <div class="v8-mockup-osp-progress-fill" style="width: 70%;"></div>
                    </div>
                    <div class="v8-mockup-osp-map"></div>
                    <div class="v8-mockup-osp-cta">
                      <span style="font-size: 10px; font-weight: 600; color: white;">Complete the look</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison B: Returns Process -->
        <div class="v8-comparison v8-reveal" style="margin-top: clamp(4rem, 6vw, 6rem);">
          <div class="v8-comparison-header">
            <span class="v8-comparison-number">02</span>
            <h3 class="v8-comparison-title">Returns Process</h3>
          </div>
          <div class="v8-comparison-grid">
            <!-- Before -->
            <div class="v8-before">
              <div class="v8-before-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                Before
              </div>
              <div class="v8-before-frame">
                <div class="v8-before-crack v8-before-crack--1" aria-hidden="true"></div>
                <!-- Generic return email -->
                <div class="v8-mockup-email">
                  <div class="v8-mockup-email-header">
                    <div style="font-size: 9px; color: #999;">From: noreply@carrier.com</div>
                    <div style="font-size: 9px; color: #999;">Subject: Return Received</div>
                  </div>
                  <div class="v8-mockup-email-body">
                    <p style="font-size: 11px; color: #666; line-height: 1.6; margin: 0;">
                      Dear Customer,<br/><br/>
                      Your return has been received. Please allow 5-10 business days for processing. Refund will be issued to your original payment method.<br/><br/>
                      Thank you.
                    </p>
                    <div style="margin-top: 12px; font-size: 9px; color: #ccc; border-top: 1px solid #eee; padding-top: 8px;">
                      Do not reply to this email.
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Metric -->
            <div class="v8-comparison-metric">
              <div class="v8-comparison-metric-value">11%</div>
              <div class="v8-comparison-metric-label">more exchanges</div>
              <div class="v8-comparison-metric-vs">15% less fraud</div>
            </div>

            <!-- After -->
            <div class="v8-after">
              <div class="v8-after-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                After
              </div>
              <div class="v8-after-frame">
                <div class="v8-after-glow" aria-hidden="true"></div>
                <!-- Returns portal UI -->
                <div class="v8-mockup-returns">
                  <div class="v8-mockup-returns-header">
                    <div class="v8-mockup-osp-logo"></div>
                    <span style="font-size: 12px; font-weight: 700; color: #0f172a;">Returns Portal</span>
                  </div>
                  <div class="v8-mockup-returns-body">
                    <div class="v8-mockup-returns-option v8-mockup-returns-option--highlight">
                      <div class="v8-mockup-returns-radio v8-mockup-returns-radio--active"></div>
                      <div>
                        <div style="font-size: 11px; font-weight: 700; color: #035740;">Exchange for different size</div>
                        <div style="font-size: 9px; color: #64748b;">Get the right fit, no extra charge</div>
                      </div>
                      <span class="v8-mockup-returns-badge">Recommended</span>
                    </div>
                    <div class="v8-mockup-returns-option">
                      <div class="v8-mockup-returns-radio"></div>
                      <div>
                        <div style="font-size: 11px; font-weight: 600; color: #0f172a;">Store credit + 10% bonus</div>
                        <div style="font-size: 9px; color: #64748b;">$55.00 credit to your account</div>
                      </div>
                    </div>
                    <div class="v8-mockup-returns-option">
                      <div class="v8-mockup-returns-radio"></div>
                      <div>
                        <div style="font-size: 11px; font-weight: 600; color: #0f172a;">Refund to original payment</div>
                        <div style="font-size: 9px; color: #64748b;">5-10 business days</div>
                      </div>
                    </div>
                    <div class="v8-mockup-returns-retention">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFC943" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      <span style="font-size: 9px; font-weight: 600; color: #0f172a;">Keep the item + get 20% off your next order</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison C: Customer Communications -->
        <div class="v8-comparison v8-reveal" style="margin-top: clamp(4rem, 6vw, 6rem);">
          <div class="v8-comparison-header">
            <span class="v8-comparison-number">03</span>
            <h3 class="v8-comparison-title">Customer Communications</h3>
          </div>
          <div class="v8-comparison-grid">
            <!-- Before -->
            <div class="v8-before">
              <div class="v8-before-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                Before
              </div>
              <div class="v8-before-frame">
                <div class="v8-before-crack v8-before-crack--2" aria-hidden="true"></div>
                <!-- Single generic email -->
                <div class="v8-mockup-single-email">
                  <div class="v8-mockup-single-email-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  </div>
                  <div style="font-size: 11px; font-weight: 600; color: #666; margin-bottom: 4px;">Your package has shipped</div>
                  <div style="font-size: 10px; color: #999; line-height: 1.5;">
                    Your order #12345 has been shipped via Standard Shipping. Track your package using the link below.
                  </div>
