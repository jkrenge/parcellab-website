---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Enhance your delivery experience - parcelLab"
  description="Maximize your post-purchase impact by enhancing your delivery experience, keeping customers informed, and creating meaningful engagements."
>
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Deliver"
      title="Take control of your delivery experience"
      description="From the moment your customers hit 'buy' to the package at their doorstep, make every delivery an opportunity to boost engagement, build loyalty, and drive more revenue."
      ctaText="Book a demo"
      ctaHref={`${import.meta.env.BASE_URL}/live-demo/`}
      secondaryCtaText="See how it works"
      secondaryCtaHref={`${import.meta.env.BASE_URL}/live-demo/`}
    />

    <!-- Stats Banner -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
          <div class="text-center">
            <div class="text-4xl font-semibold text-[#3D3AD3] md:text-5xl">20%</div>
            <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">Reduction in WISMO inquiries</p>
          </div>
          <div class="text-center">
            <div class="text-4xl font-semibold text-[#3D3AD3] md:text-5xl">90%</div>
            <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">Delay detection accuracy</p>
          </div>
          <div class="text-center">
            <div class="text-4xl font-semibold text-[#3D3AD3] md:text-5xl">550+</div>
            <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">Global carrier integrations</p>
          </div>
          <div class="text-center">
            <div class="text-4xl font-semibold text-[#3D3AD3] md:text-5xl">4 wks</div>
            <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">Rapid onboarding</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Features Grid -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto mb-16 max-w-2xl text-center">
          <h2 class="text-display text-[var(--ink)]">Everything you need for delivery excellence</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            A comprehensive suite of tools to transform every delivery into a branded, revenue-driving experience.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <!-- Track and Communicate -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Track & Communicate</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">
              Real-time automated updates across email, SMS, app push, and chatbots. End-to-end visibility across all fulfillment types with proactive notifications.
            </p>
          </div>
          <!-- Branded Tracking Portal -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Branded Tracking Portal</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">
              A customizable tracking page embedded directly on your website or app. Complete order visibility including split shipments, delivering an on-brand experience.
            </p>
          </div>
          <!-- Personalized Journeys -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/15">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Personalized Journeys</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">
              Hyper-personalized post-purchase experiences at scale. Trigger updates based on real-time order status, leveraging customer data and order history.
            </p>
          </div>
          <!-- Targeted Campaigns -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Targeted Campaigns</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">
              Segment customers by behavior and preferences. Embed upsell and cross-sell offers in emails and tracking pages to boost revenue per order.
            </p>
          </div>
          <!-- Predict Delivery Delays -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Predict Delivery Delays</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">
              AI-powered delay detection with 90% accuracy. Custom threshold settings by region and carrier, with dynamic predictions at every tracking checkpoint.
            </p>
          </div>
          <!-- Streamline Claims -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#EF4444]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Streamline Claims</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">
              Centralized claims data with investigation reports. Self-service customer portal for damage and loss reporting, plus faster processing and recurring issue identification.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Resolve Customer Inquiries -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div>
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Customer Service</span>
            <h2 class="text-heading text-[var(--ink)]">Resolve customer inquiries faster</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Give your support team real-time order details in one platform. Integrations with Salesforce, Zendesk, and Gorgias reduce system toggling and accelerate resolution times.
            </p>
            <ul class="mt-8 space-y-4">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Real-time order details in a single platform</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Salesforce, Zendesk, and Gorgias integration</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Reduced system toggling for support teams</span>
              </li>
            </ul>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
            <div class="space-y-4">
              <div class="rounded-xl bg-[var(--surface-sunken)] p-4">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="h-8 w-8 rounded-full bg-[#3D3AD3]/10 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    </div>
                    <div>
                      <div class="text-sm font-medium text-[var(--ink)]">Order #PLB-4829</div>
                      <div class="text-xs text-[var(--ink-muted)]">In transit</div>
                    </div>
                  </div>
                  <span class="rounded-full bg-[#035740]/10 px-3 py-1 text-xs font-medium text-[#035740]">On time</span>
                </div>
              </div>
              <div class="rounded-xl bg-[var(--surface-sunken)] p-4">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="h-8 w-8 rounded-full bg-[#FFC943]/15 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div>
                      <div class="text-sm font-medium text-[var(--ink)]">Order #PLB-5031</div>
                      <div class="text-xs text-[var(--ink-muted)]">Delayed &mdash; weather</div>
                    </div>
                  </div>
                  <span class="rounded-full bg-[#FFC943]/15 px-3 py-1 text-xs font-medium text-[#b8860b]">Delayed</span>
                </div>
              </div>
              <div class="rounded-xl bg-[var(--surface-sunken)] p-4">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="h-8 w-8 rounded-full bg-[#035740]/10 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <div>
                      <div class="text-sm font-medium text-[var(--ink)]">Order #PLB-4711</div>
                      <div class="text-xs text-[var(--ink-muted)]">Delivered</div>
                    </div>
                  </div>
                  <span class="rounded-full bg-[#035740]/10 px-3 py-1 text-xs font-medium text-[#035740]">Delivered</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="section-standard">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="#3D3AD3" opacity="0.15" class="mx-auto mb-6"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
          <blockquote class="text-xl font-light leading-relaxed text-[var(--ink)] md:text-2xl">
            &ldquo;ParcelLab provided the tools we needed to deliver on our brand goals while minimizing overhead costs. The implementation was seamless and straightforward.&rdquo;
          </blockquote>
          <div class="mt-6">
            <div class="font-medium text-[var(--ink)]">Logan Dunn</div>
            <div class="text-sm text-[var(--ink-muted)]">Head of eCommerce, WYZE</div>
          </div>
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
