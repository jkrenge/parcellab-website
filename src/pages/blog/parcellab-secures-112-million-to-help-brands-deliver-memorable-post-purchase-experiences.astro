---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="parcelLab Secures $112 Million to Help Brands Deliver Memorable Post-Purchase Experiences - parcelLab"
  description="parcelLab announces a $112 million Series C funding round led by Insight Partners to accelerate global expansion and product development."
>
  <Header client:load />
  <main>
    <!-- Article Header -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Company News</span>
          <h1 class="text-display text-[var(--ink)]">parcelLab Secures $112 Million to Help Brands Deliver Memorable Post-Purchase Experiences</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab Team</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2021-06-11">June 11, 2021</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>4 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          parcelLab has announced a Series C funding round of US$112 million (EUR 92.5 million). The investment, led by Insight Partners and Endeit Capital with participation from existing backers Capnamic Ventures and coparion, will support expansion and growth initiatives.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Key Milestones</h2>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Operations across 153 countries</strong> globally</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">7 million+ personalized communications</strong> daily (approximately 82 per second)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">3 million+ shipments tracked daily</strong> across 150+ carriers</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">30 million+ customer interactions</strong> generated daily</span>
          </li>
        </ul>

        <div class="my-10 rounded-2xl bg-[var(--surface-sunken)] p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.1em] text-[var(--ink-muted)]">CEO Perspective</p>
          <p class="mt-2 text-lg font-medium text-[var(--ink)]">"As e-commerce becomes increasingly competitive, delivering unique and personalized experiences is a major growth issue for brands."</p>
          <p class="mt-1 text-sm text-[var(--ink-muted)]">-- Tobias Buxhoidt, CEO and co-founder, parcelLab</p>
        </div>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Client Success Stories</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Notable brands including Lidl, IKEA, Bose, Nespresso, Puma, and Back Market have achieved measurable results:
        </p>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Double-digit shopping cart value increases</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Email open rates exceeding 90%</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">25% reductions in "Where Is My Order" inquiries</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Triple-digit customer review growth</span>
          </li>
        </ul>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Use of Funding</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          New capital will accelerate global expansion, support product development, and enhance the recently launched returns portal to streamline end-to-end return processes for customers.
        </p>

        <div class="my-12 border-t border-[var(--line)]"></div>

        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Founded in 2015 by Tobias Buxhoidt, Julian Krenge (CTO), and Anton Eder (COO), parcelLab has established offices in Munich, London, Paris, and New York. The Financial Times recognized the firm as one of Europe's fastest-growing technology companies in 2021.
        </p>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
