---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="UK Operations Experience Study 2021 Key Findings: Checkout - parcelLab"
  description="How the UK's top 150 retailers perform across checkout, shipping, and returns operations, revealing significant gaps in post-purchase engagement."
>
  <Header client:load />
  <main>
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Research</span>
          <h1 class="text-display text-[var(--ink)]">UK Operations Experience Study 2021 Key Findings: Checkout</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2021-07-25">July 25, 2021</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>5 min read</span>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          The study assessed test orders placed with the top 150 UK retailers to evaluate performance across checkout, shipping and returns. A notable finding: the vast majority of top retailers stop marketing to their customers after checkout.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Key Findings</h2>
        <div class="mt-6 space-y-6">
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">79% offer free shipping</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Without restrictions or with a minimum order value. Shipping costs represent a major conversion barrier.</p>
          </div>
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">41% have Buy Now, Pay Later</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Options like Klarna remove purchasing restrictions tied to paydays and allow customers to pay only for retained items.</p>
          </div>
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">87% give 2+ delivery options</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Multiple delivery options increase customer choice likelihood and satisfaction.</p>
          </div>
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">73% offer next-day delivery</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">With retail stores reopening, next-day delivery expectations will continue to strengthen.</p>
          </div>
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">87% have Click and Collect</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Either in-store or from a parcel shop, providing guaranteed delivery availability.</p>
          </div>
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
