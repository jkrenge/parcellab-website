---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="January Product Innovations - Campaign Manager and Returns Portal - parcelLab"
  description="Discover the latest parcelLab product updates including new Campaign Manager banner slots, HTML content types, gift returns for Shopify, and more."
>
  <Header client:load />
  <main>
    <!-- Article Header -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Product Updates</span>
          <h1 class="text-display text-[var(--ink)]">January Product Innovations -- Campaign Manager and Returns Portal</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">Anna Lapezo</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2024-02-14">February 14, 2024</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>5 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          January brought exciting updates to parcelLab's Campaign Manager and Returns Portal, along with improvements to Insights and Connect modules. Here is a summary of the latest product innovations.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Campaign Manager</h2>

        <h3 class="text-lg font-semibold text-[var(--ink)] mt-8 mb-3">New Banner Slots for Order Status Page</h3>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Users can now add up to five banners to further customize the order status page, enhancing conversion potential and personalization capabilities.
        </p>

        <h3 class="text-lg font-semibold text-[var(--ink)] mt-8 mb-3">HTML Content Type for Email Campaigns</h3>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          A new HTML editor enables campaign banner creation using HTML code, with content directly rendered into emails for improved design flexibility.
        </p>

        <h3 class="text-lg font-semibold text-[var(--ink)] mt-8 mb-3">Additional Improvements</h3>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[#3D3AD3]"></span>
            <span class="text-[var(--ink-secondary)]">Shop ID integration with message type preview, allowing users to see how banners will look in the actual messages</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[#3D3AD3]"></span>
            <span class="text-[var(--ink-secondary)]">Default language list based on user-defined languages during campaign selection</span>
          </li>
        </ul>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Returns Portal</h2>

        <div class="mt-6 space-y-6">
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">Gift Returns Portal for Shopify</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              Digital gift returns launched for Shopify stores, allowing gift receivers to log in and select between receiving store gift cards or exchanging items for different colors or sizes.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">Additional Customs Invoice for Returns</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              New capability to generate supplementary invoices for cross-border returns, facilitating customs clearance with essential information like VAT and EORI numbers.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">SSO for Customer Service Returns Portals</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              Customer service returns portals now use Single Sign-On (SSO) for enhanced security, ensuring authorized access through portal configuration.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">Display Refund Payment Provider</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              Merchants can display refund payment providers to customers, showing original payment methods and processing timelines to increase trust.
            </p>
          </div>
        </div>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Insights</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          The Analytics module now displays webhook data, including types sent and their success and response metrics within the Engagement dashboard.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Connect</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Compliance updates aligned with February 2024 email provider requirements from Google and Yahoo include one-click unsubscribe functionality and enhanced spam rate monitoring.
        </p>

        <div class="my-12 border-t border-[var(--line)]"></div>

        <p class="text-[var(--ink-secondary)] leading-relaxed">
          All features are immediately available. Contact your account manager, visit how.parcelLab.works, or access the parcelLab Portal for additional details.
        </p>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
