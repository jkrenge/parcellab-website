---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout title="What is Post-Purchase Evaluation? - parcelLab" description="Understand the importance of post-purchase evaluation in gauging customer satisfaction and loyalty, shaping future business strategies.">
  <Header client:load />
  <main>
    <section class="section-generous"><div class="mx-auto max-w-[1440px] px-6 md:px-12"><div class="mx-auto max-w-[800px]">
      <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>Back to blog</a>
      <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Post-Purchase</span>
      <h1 class="text-display text-[var(--ink)]">What is Post-Purchase Evaluation?</h1>
      <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
        <span>By <strong class="font-medium text-[var(--ink-secondary)]">Anna Lapezo</strong></span><span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
        <time datetime="2023-06-12">June 12, 2023</time><span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span><span>7 min read</span>
      </div>
    </div></div></section>
    <section class="pb-16 md:pb-24"><div class="mx-auto max-w-[800px] px-6 md:px-12">
      <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">Post-purchase evaluation represents the phase where customers assess their satisfaction with a product or service after buying and using it. This evaluation significantly shapes future buying decisions and brand loyalty.</p>
      <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">The 6 Key Steps</h2>
      <div class="mt-6 space-y-6">
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">1. Unboxing</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Quality packaging and good condition create positive first impressions.</p></div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">2. Using the Product</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Active customer interaction with the product heavily influences opinions.</p></div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">3. Comparison with Expectations</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Customers evaluate whether their experience matches pre-purchase expectations.</p></div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">4. Satisfaction or Dissatisfaction</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">When products meet expectations, satisfaction results. Falls short trigger cognitive dissonance.</p></div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">5. Feedback and Reviews</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Customers provide ratings, reviews, or direct feedback based on their experience.</p></div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">6. Keep, Return, or Dispose</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">The final verdict determines product fate based on overall experience.</p></div>
      </div>
      <div class="my-12 border-t border-[var(--line)]"></div>
      <p class="text-[var(--ink-secondary)] leading-relaxed">Understanding and optimizing post-purchase evaluation is essential for building successful ecommerce operations.</p>
    </div></section>
    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
