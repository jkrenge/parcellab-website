---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="parcelLab Secures $112M to Help Global Brands Deliver a Seamless Experience - parcelLab"
  description="The Operations Experience Management platform secures $112M in Series C funding to help global brands transform their post-purchase customer experiences."
>
  <Header client:load />
  <main>
    <!-- Article Header -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Company News</span>
          <h1 class="text-display text-[var(--ink)]">parcelLab, the Operations Experience Management Platform, Secures $112M to Help Global Brands Deliver a Seamless Experience</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab Team</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2021-06-11">June 11, 2021</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>5 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          parcelLab has announced a Series C funding round of US$112 million led by Insight Partners, with co-investors including Endeit Capital, Capnamic Ventures, and coparion. The investment supports the company's expansion into new markets and product development.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Company Milestones</h2>
        <div class="mt-6 space-y-6">
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <div class="flex items-center gap-4">
              <span class="text-2xl font-bold text-[#3D3AD3]">153</span>
              <span class="text-[var(--ink-secondary)]">Countries where parcelLab operates</span>
            </div>
          </div>
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <div class="flex items-center gap-4">
              <span class="text-2xl font-bold text-[#3D3AD3]">3M+</span>
              <span class="text-[var(--ink-secondary)]">Shipments processed daily across 150+ carriers</span>
            </div>
          </div>
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <div class="flex items-center gap-4">
              <span class="text-2xl font-bold text-[#3D3AD3]">7M+</span>
              <span class="text-[var(--ink-secondary)]">Personalized communications sent each day (82 per second)</span>
            </div>
          </div>
        </div>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Customer Results</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Notable clients including IKEA, Farfetch, and Lidl have achieved impressive results: double-digit basket size increases, email open rates exceeding 90%, 25% reductions in "Where Is My Order" inquiries, and triple-digit increases in customer reviews.
        </p>

        <div class="my-10 rounded-2xl bg-[var(--surface-sunken)] p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.1em] text-[var(--ink-muted)]">Leadership Statement</p>
          <p class="mt-2 text-lg font-medium text-[var(--ink)]">"Brands leveraging Operations Experience Management are transforming operational complexity into opportunities."</p>
          <p class="mt-1 text-sm text-[var(--ink-muted)]">-- Tobias Buxhoidt, CEO, parcelLab</p>
        </div>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Use of Funds</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          The investment will accelerate global expansion, support new product development, and enhance the recently launched returns portal for seamless end-to-end customer returns experiences. The company continues to scale its team and infrastructure to meet growing demand.
        </p>

        <div class="my-12 border-t border-[var(--line)]"></div>

        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Founded in 2015 by Tobias Buxhoidt (CEO), Julian Krenge (CTO), and Anton Eder (COO), parcelLab operates with offices in New York, Munich, London, and Paris. The company continues to help brands worldwide transform their post-purchase operations into competitive advantages.
        </p>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
