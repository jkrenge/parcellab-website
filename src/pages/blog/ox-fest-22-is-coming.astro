---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="OX Fest '22 Is Coming! - parcelLab"
  description="parcelLab announces OX Fest '22, a three-day virtual event featuring live content from industry speakers on e-commerce, sustainability, and customer experience."
>
  <Header client:load />
  <main>
    <!-- Article Header -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Events</span>
          <h1 class="text-display text-[var(--ink)]">OX Fest '22 Is Coming!</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab Team</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2022-08-19">August 19, 2022</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>3 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          Following the success of our flagship virtual event from last year, we're excited to announce that OX Fest '22 is arriving soon. Get ready for three days of live content from industry speakers, supplemented by on-demand sessions available for flexible viewing.
        </p>

        <div class="my-10 rounded-2xl bg-[var(--surface-sunken)] p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.1em] text-[var(--ink-muted)]">Event Details</p>
          <p class="mt-2 text-lg font-medium text-[var(--ink)]">September 12-14 -- Virtual format, accessible globally</p>
        </div>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Who Should Attend?</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          OX Fest '22 is designed for e-commerce professionals working in customer experience, service, operations, supply chain, marketing, or branding -- essentially anyone prioritizing customer-first principles.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">What Makes OX Fest Different?</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Unlike typical e-commerce conferences, attendees can shape their experience by selecting preferred sessions from expert panelists. The combination of live and recorded content allows customization for maximum team benefit.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Featured Topics</h2>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Sustainability in e-commerce</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Zero-party data collection strategies</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Email marketing best practices</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Evolving supply chain management</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Customer experience optimization and Operations Experience Management</span>
          </li>
        </ul>

        <div class="my-12 border-t border-[var(--line)]"></div>

        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Join us to collaboratively explore customer experience boundaries and Operations Experience Management opportunities. Details about speakers and the full agenda will be shared in the coming weeks.
        </p>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
