---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout title="What is Inclusive E-Commerce? - parcelLab" description="Online retailers miss billions annually by neglecting inclusivity. Explore what inclusive e-commerce entails and practical strategies for implementation.">
  <Header client:load />
  <main>
    <section class="section-generous"><div class="mx-auto max-w-[1440px] px-6 md:px-12"><div class="mx-auto max-w-[800px]">
      <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>Back to blog</a>
      <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Research</span>
      <h1 class="text-display text-[var(--ink)]">What is Inclusive E-Commerce?</h1>
      <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
        <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab</strong></span><span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
        <time datetime="2022-05-20">May 20, 2022</time><span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span><span>4 min read</span>
      </div>
    </div></div></section>
    <section class="pb-16 md:pb-24"><div class="mx-auto max-w-[800px] px-6 md:px-12">
      <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">Inclusive retail welcomes all customers through accessible stores, inclusive messaging, and representative advertising. UK retailers lose an estimated 17 billion pounds annually by ignoring accessibility requirements for disabled customers.</p>
      <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Why Customers Expect Inclusivity</h2>
      <p class="text-[var(--ink-secondary)] leading-relaxed">42% of consumers willingly pay premiums for diversity-committed retailers. 55% would abandon brands with non-inclusive reputations. Nearly 70% base shopping decisions on personal values.</p>
      <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">How to Make Your Online Store More Inclusive</h2>
      <ul class="mt-4 space-y-3">
        <li class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg><span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Technical accessibility</strong> -- Ensure compatibility with screen readers and assistive technologies</span></li>
        <li class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg><span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">UX improvements</strong> -- Use inclusive language and accommodate diverse devices</span></li>
        <li class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg><span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Payment flexibility</strong> -- Accept alternative payment methods</span></li>
        <li class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg><span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Representation</strong> -- Feature diverse imagery and language across marketing</span></li>
      </ul>
      <div class="my-12 border-t border-[var(--line)]"></div>
      <p class="text-[var(--ink-secondary)] leading-relaxed">Inclusivity requires consistent communication throughout the customer journey. Every touchpoint communicates organizational values.</p>
    </div></section>
    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
