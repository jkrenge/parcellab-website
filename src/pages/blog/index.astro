---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import PageHero from "../../components/PageHero.astro";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const posts = [
  {
    title: "NRF '26 Recap: How True Classic Built a Post-Purchase Journey That Never Ends",
    description: "At NRF, parcelLab's Chief Product Officer sat down with Jordan Gesky of True Classic to discuss redefining customer journeys beyond the checkout.",
    category: "Featured",
    accent: "bg-[#3D3AD3]",
  },
  {
    title: "How Retailers Can Reduce Their eCommerce Return Rates in 2026",
    description: "eCommerce return rates are a thorn in most retailers' sides. Discover proven strategies to turn the tide and reduce costly returns.",
    category: "Returns",
    accent: "bg-[#035740]",
  },
  {
    title: "Retail Trends and Predictions Shaping eCommerce in 2026",
    description: "A new year always feels like a reset button. Explore the trends and predictions that will define the retail landscape this year.",
    category: "Trends",
    accent: "bg-[#FFC943]",
  },
  {
    title: "Top 6 Return Management Solutions of 2026",
    description: "A comprehensive look at the leading return management platforms helping retailers streamline reverse logistics and recover revenue.",
    category: "Returns",
    accent: "bg-[#035740]",
  },
  {
    title: "The Return Shift: Why Companies Saving Most on Returns Won't Share Numbers",
    description: "The brands achieving the biggest savings on returns are keeping their strategies close to the chest. Here's what we know.",
    category: "Returns",
    accent: "bg-[#F4373D]",
  },
  {
    title: "What Is eCommerce Returns Management?",
    description: "Everything you need to know about eCommerce returns management — from policy design to logistics optimization and customer communication.",
    category: "Returns",
    accent: "bg-[#3D3AD3]",
  },
  {
    title: "Turning Returns Into ROI: A Department-by-Department Playbook",
    description: "Returns touch every department. This playbook shows how each team can contribute to turning returns from a cost center into a growth lever.",
    category: "Returns",
    accent: "bg-[#FFC943]",
  },
  {
    title: "How to Handle Customer Returns",
    description: "Best practices for handling customer returns efficiently while preserving satisfaction and building long-term loyalty.",
    category: "Operations",
    accent: "bg-[#035740]",
  },
  {
    title: "What Is a Self-Service Return?",
    description: "Self-service returns empower customers and reduce support costs. Learn how to implement them and why they matter for your brand.",
    category: "Returns",
    accent: "bg-[#F4373D]",
  },
];
---

<Layout title="The Post-Purchase Experience Blog - parcelLab" description="Read our blogs for the latest industry trends, thought leadership, and best practices relating to the post-purchase experience.">
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Resources"
      title="The post-purchase experience blog"
      description="Read our blogs for the latest industry trends, thought leadership, and best practices relating to the post-purchase experience."
    />

    <section class="section-standard">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <!-- Featured post -->
        <div class="mb-16">
          <a href={`${import.meta.env.BASE_URL}/blog/`} class="group block overflow-hidden rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] transition-shadow hover:shadow-lg">
            <div class="grid md:grid-cols-2">
              <div class="flex h-64 items-center justify-center bg-gradient-to-br from-[#3D3AD3] to-[#6360e8] md:h-auto">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
              </div>
              <div class="flex flex-col justify-center p-8 md:p-10">
                <span class="mb-3 inline-block w-fit rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Featured</span>
                <h2 class="text-heading text-[var(--ink)] group-hover:text-[#3D3AD3] transition-colors">{posts[0].title}</h2>
                <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">{posts[0].description}</p>
              </div>
            </div>
          </a>
        </div>

        <!-- Post grid -->
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.slice(1).map((post) => (
            <article class="group flex flex-col overflow-hidden rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] transition-shadow hover:shadow-lg">
              <div class={`flex h-48 items-center justify-center ${post.accent}`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-30"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
              </div>
              <div class="flex flex-1 flex-col p-6">
                <span class="mb-3 inline-block w-fit rounded-full bg-[var(--surface-sunken)] px-3 py-1 text-xs font-semibold text-[var(--ink-secondary)]">{post.category}</span>
                <h3 class="text-lg font-medium leading-snug text-[var(--ink)] group-hover:text-[#3D3AD3] transition-colors">{post.title}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-[var(--ink-secondary)]">{post.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
