---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout title="Which External Systems Is parcelLab Integrated With? - parcelLab" description="Discover how parcelLab integrates with major enterprise systems including SAP, Zendesk, Oracle, and Trustpilot to create branded, personalized post-purchase experiences.">
  <Header client:load />
  <main>
    <section class="section-generous"><div class="mx-auto max-w-[1440px] px-6 md:px-12"><div class="mx-auto max-w-[800px]">
      <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>Back to blog</a>
      <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Integrations</span>
      <h1 class="text-display text-[var(--ink)]">Which External Systems Is parcelLab Integrated With?</h1>
      <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
        <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab</strong></span><span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
        <time datetime="2021-03-05">March 5, 2021</time><span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span><span>4 min read</span>
      </div>
    </div></div></section>
    <section class="pb-16 md:pb-24"><div class="mx-auto max-w-[800px] px-6 md:px-12">
      <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">The parcelLab platform integrates with major enterprise systems including SAP, Zendesk, Oracle, and Trustpilot. The service requires no technical resources from clients and focuses on creating branded, personalized experiences rather than one-size-fits-all solutions.</p>
      <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Core Platform Capabilities</h2>
      <div class="mt-6 space-y-6">
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">Customer-Focused Updates</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Enable automated workflow creation for delivery communications such as missed delivery alerts, pickup notifications, delay notices, and return confirmations.</p></div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">Order Status Page</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Provides customers with real-time tracking visibility through branded interfaces, increasing engagement and reducing customer service inquiries.</p></div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">Embedded Content</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Allow personalization through targeted images, videos, product recommendations, and customer reviews at each customer touchpoint.</p></div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">Analytics Portal</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">Features analytics tools for monitoring logistics processes against KPIs and proactive issue detection before customer escalation.</p></div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6"><h3 class="text-lg font-semibold text-[var(--ink)]">Our Network</h3><p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">The integration connects existing marketing, customer service, content, feedback, and fulfillment tools already in use across your organization.</p></div>
      </div>
      <div class="my-12 border-t border-[var(--line)]"></div>
      <p class="text-[var(--ink-secondary)] leading-relaxed">The platform transforms multiple data sources into unified systems, enabling automated communication workflows without coding requirements while maintaining brand consistency throughout customer interactions.</p>
    </div></section>
    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
