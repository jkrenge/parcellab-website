---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="Watches of Switzerland and parcelLab Provide Luxury Delivery and Returns Experience - parcelLab"
  description="The Watches of Switzerland Group partners with parcelLab to deliver a premium post-purchase experience for high-value luxury watch purchases."
>
  <Header client:load />
  <main>
    <!-- Article Header -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Company News</span>
          <h1 class="text-display text-[var(--ink)]">Watches of Switzerland and parcelLab Provide Luxury Delivery and Returns Experience</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab Team</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2022-04-28">April 28, 2022</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>4 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          The Watches of Switzerland Group -- comprising Mappin and Webb, Watches of Switzerland, and Goldsmiths -- has partnered with parcelLab to enhance its delivery and returns experience. As the UK's largest retailer of luxury watch brands including Rolex, Cartier, OMEGA, TAG Heuer, and Breitling, the group operates over 130 stores with an average order value exceeding $5,900.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Key Partnership Benefits</h2>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Elevated final mile experience</strong> matching the luxury quality customers expect</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Cross-brand engagement</strong> within the group portfolio of prestigious brands</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Reduced support costs</strong> while increasing customer satisfaction</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Online experiences</strong> matching in-store luxury standards</span>
          </li>
        </ul>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Platform Features</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          parcelLab will provide instant order status communications and a branded tracking page, keeping customers informed about their high-value purchases while creating opportunities for cross-selling across group brands.
        </p>

        <div class="my-10 rounded-2xl bg-[var(--surface-sunken)] p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.1em] text-[var(--ink-muted)]">Quote</p>
          <p class="mt-2 text-lg font-medium text-[var(--ink)]">"The luxury experience customers expect involves proactive delivery updates and leveraging platform opportunities for future purchases -- critical components of the online experience."</p>
          <p class="mt-1 text-sm text-[var(--ink-muted)]">-- Tobias Buxhoidt, CEO and Co-Founder at parcelLab</p>
        </div>

        <div class="my-10 rounded-2xl bg-[var(--surface-sunken)] p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.1em] text-[var(--ink-muted)]">Quote</p>
          <p class="mt-2 text-lg font-medium text-[var(--ink)]">"This partnership introduces innovative technology ensuring customers receive a luxurious experience matching their purchase quality."</p>
          <p class="mt-1 text-sm text-[var(--ink-muted)]">-- Ian Warwick, Director of eCommerce at Watches of Switzerland Group</p>
        </div>

        <div class="my-12 border-t border-[var(--line)]"></div>

        <p class="text-[var(--ink-secondary)] leading-relaxed">
          The partnership leverages parcelLab's Operations Experience Management platform to establish a premium order and returns tracking service that lives up to the expectations set by the world's finest watch brands.
        </p>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
