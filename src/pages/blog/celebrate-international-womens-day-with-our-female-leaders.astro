---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="Celebrate International Women's Day with Our Female Leaders - parcelLab"
  description="Five female leaders at parcelLab share their experiences, career advice, and perspectives on building inclusive workplaces for International Women's Day."
>
  <Header client:load />
  <main>
    <!-- Article Header -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Research</span>
          <h1 class="text-display text-[var(--ink)]">Celebrate International Women's Day with Our Female Leaders</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2022-04-08">April 8, 2022</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>6 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          To mark International Women's Day, we are highlighting the accomplishments of five female leaders on our team. These executives discuss their roles, workplace experiences, and advice for organizations seeking to build more inclusive leadership structures.
        </p>

        <div class="mt-8 space-y-8">
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h2 class="text-lg font-semibold text-[var(--ink)]">Felicitas Schweiker</h2>
            <p class="text-sm text-[var(--ink-muted)]">VP People, Operations and Culture</p>
            <div class="mt-3 rounded-lg bg-[var(--surface-sunken)] px-4 py-2">
              <p class="text-sm italic text-[var(--ink-secondary)]">Working at parcelLab in three words: "Dynamic, exciting, challenging"</p>
            </div>
            <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">
              Advocates for early diversity initiatives, noting that diverse teams demonstrate better communication and innovation. Recommends aspiring leaders embrace curiosity and build networks across organizational boundaries.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h2 class="text-lg font-semibold text-[var(--ink)]">Caroline Heil</h2>
            <p class="text-sm text-[var(--ink-muted)]">Team Lead Technical Account Management</p>
            <div class="mt-3 rounded-lg bg-[var(--surface-sunken)] px-4 py-2">
              <p class="text-sm italic text-[var(--ink-secondary)]">Working at parcelLab in three words: "Adventure, Journey, Rollercoaster"</p>
            </div>
            <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">
              Advises that inclusive recruitment begins with diverse marketing communications. Suggests professionals focus on personal strengths rather than perceived limitations.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h2 class="text-lg font-semibold text-[var(--ink)]">Paula Morales</h2>
            <p class="text-sm text-[var(--ink-muted)]">Head of Marketing Operations</p>
            <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">
              Emphasizes the value of internal promotion and peer support for female talent. Offers three pieces of guidance: pursue ambitious goals despite self-doubt, prioritize work-life balance, and allow adequate time to evaluate new opportunities.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h2 class="text-lg font-semibold text-[var(--ink)]">Frankie McEnery</h2>
            <p class="text-sm text-[var(--ink-muted)]">Head of Learning and Development</p>
            <div class="mt-3 rounded-lg bg-[var(--surface-sunken)] px-4 py-2">
              <p class="text-sm italic text-[var(--ink-secondary)]">Working at parcelLab in three words: "Fun, friendly and fast-paced"</p>
            </div>
            <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">
              Stresses that visible senior female leadership attracts future women leaders. Recommends building confidence and trusting personal judgment.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h2 class="text-lg font-semibold text-[var(--ink)]">Heidi Tombs</h2>
            <p class="text-sm text-[var(--ink-muted)]">Director of People Operations</p>
            <div class="mt-3 rounded-lg bg-[var(--surface-sunken)] px-4 py-2">
              <p class="text-sm italic text-[var(--ink-secondary)]">Working at parcelLab in three words: "Collaborative. Challenging. Refreshing"</p>
            </div>
            <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">
              Advocates intentional executive-level representation to inspire other women. Encourages professionals to voice developmental needs and seek female mentors as advocates.
            </p>
          </div>
        </div>

        <div class="my-12 border-t border-[var(--line)]"></div>

        <p class="text-[var(--ink-secondary)] leading-relaxed">
          parcelLab reaffirms its commitment to creating an inclusive workplace where everyone can thrive. Interested in joining the team? Visit our careers page to explore current opportunities.
        </p>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
