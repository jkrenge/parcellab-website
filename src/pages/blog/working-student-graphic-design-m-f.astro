---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="Working Student Graphic Design (m/f) - parcelLab"
  description="parcelLab is looking for a graphic design working student to join the marketing team in Munich, creating mockups, presentations, and marketing materials."
>
  <Header client:load />
  <main>
    <!-- Article Header -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Careers</span>
          <h1 class="text-display text-[var(--ink)]">Working Student Graphic Design (m/f)</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab Team</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2018-12-07">December 7, 2018</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>3 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          parcelLab addresses a gap in e-commerce by managing customer communication during shipping, a responsibility typically left to carriers. The company supports over 300 online retailers including Marc O'Polo, Teufel, MediaMarkt, and Saturn. To expand the marketing team in Munich, we are seeking a graphic design working student.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Responsibilities</h2>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Creating mockups and screenshots for prospective and current clients</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Developing presentations for the sales department</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Assisting the marketing team with website design, print materials, and related projects</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[var(--ink-secondary)]">Examining both qualitative and quantitative user experience metrics</span>
          </li>
        </ul>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Required Qualifications</h2>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span class="text-[var(--ink-secondary)]">Strong affinity for online platforms and digital environments</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span class="text-[var(--ink-secondary)]">Proficiency with Adobe Photoshop; experience with InDesign, Illustrator, or Sketch preferred</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span class="text-[var(--ink-secondary)]">Fluent German language skills with English proficiency</span>
          </li>
        </ul>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">What We Offer</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          parcelLab emphasizes meaningful work in a motivated environment, genuine flexibility, team activities, and competitive compensation. We build a product that brings real joy to its customers.
        </p>

        <div class="my-10 rounded-2xl bg-[var(--surface-sunken)] p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.1em] text-[var(--ink-muted)]">What Our Partners Say</p>
          <p class="mt-2 text-lg font-medium text-[var(--ink)]">"You guys are awesome."</p>
          <p class="mt-1 text-sm text-[var(--ink-muted)]">-- Christian, COO of 11teamsports</p>
          <p class="mt-4 text-lg font-medium text-[var(--ink)]">"It's just fun working with you guys."</p>
          <p class="mt-1 text-sm text-[var(--ink-muted)]">-- Mathias, CRM Manager at Jochen Schweizer</p>
        </div>

        <div class="my-12 border-t border-[var(--line)]"></div>

        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Interested in joining the parcelLab team? This position is based in Munich. Contact Laura Gessler at hr@parcellab.com for more information.
        </p>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
