---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="[Podcast] Post-Purchase Success: Transforming Customer Services from Cost to Revenue - parcelLab"
  description="Episode 4 features Breanna Moreno from True Classic discussing how to transform customer services from a cost center into a revenue driver."
>
  <Header client:load />
  <main>
    <!-- Article Header -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <div class="mb-4 flex gap-2">
            <span class="inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Customer Experience</span>
            <span class="inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Post-Purchase</span>
          </div>
          <h1 class="text-display text-[var(--ink)]">[Podcast] Post-Purchase Success: Transforming Customer Services from Cost to Revenue</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab Team</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2024-05-23">May 23, 2024</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>2 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          In episode four of the Post-Purchase Success podcast, we feature Breanna Moreno, VP of Customer Experience at True Classic, recorded live at ShopTalk 2024 in Las Vegas.
        </p>

        <div class="my-10 rounded-2xl bg-[var(--surface-sunken)] p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.1em] text-[var(--ink-muted)]">Episode 4</p>
          <p class="mt-2 text-lg font-medium text-[var(--ink)]">Transforming Customer Services from Cost to Revenue</p>
          <p class="mt-1 text-sm text-[var(--ink-muted)]">Guest: Breanna Moreno, VP of Customer Experience at True Classic</p>
        </div>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Key Discussion Points</h2>
        <div class="mt-6 space-y-6">
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">From Cost Center to Revenue Driver</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              How True Classic transformed its Customer Services division from a cost center into a revenue-generating operation, proving that great service directly impacts the bottom line.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">Culture as a Scaling Mechanism</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              The importance of company culture in scaling Customer Services effectively -- how the right mindset and values enable teams to deliver exceptional experiences at scale.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">Doing More with Less</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              Strategies for achieving superior outcomes with reduced resource allocation, leveraging smart tools and processes to maximize impact.
            </p>
          </div>
        </div>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Listen Now</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          The podcast is available on multiple platforms:
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a href="https://parcellab.com" class="inline-flex items-center gap-2 rounded-lg border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-2 text-sm font-medium text-[var(--ink)] transition-colors hover:border-[#3D3AD3] hover:text-[#3D3AD3]">YouTube</a>
          <a href="https://parcellab.com" class="inline-flex items-center gap-2 rounded-lg border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-2 text-sm font-medium text-[var(--ink)] transition-colors hover:border-[#3D3AD3] hover:text-[#3D3AD3]">Spotify</a>
          <a href="https://parcellab.com" class="inline-flex items-center gap-2 rounded-lg border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-2 text-sm font-medium text-[var(--ink)] transition-colors hover:border-[#3D3AD3] hover:text-[#3D3AD3]">Apple Podcasts</a>
          <a href="https://parcellab.com" class="inline-flex items-center gap-2 rounded-lg border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-2 text-sm font-medium text-[var(--ink)] transition-colors hover:border-[#3D3AD3] hover:text-[#3D3AD3]">Amazon Music</a>
        </div>

        <div class="my-12 border-t border-[var(--line)]"></div>

        <p class="text-[var(--ink-secondary)] leading-relaxed">
          Subscribe to the Post-Purchase Success podcast for future episodes featuring industry leaders sharing insights on transforming customer experiences.
        </p>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
