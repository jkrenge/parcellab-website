---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout
  title="parcelLab Recognized on the Forbes America's Best Startup Employers 2022 List - parcelLab"
  description="parcelLab earned recognition on the Forbes list of America's Best Startup Employers 2022, a prestigious award presented jointly by Forbes and Statista Inc."
>
  <Header client:load />
  <main>
    <!-- Article Header -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-[800px]">
          <a href={`${b}/blog/`} class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--ink-muted)] transition-colors hover:text-[#3D3AD3]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Back to blog
          </a>
          <span class="mb-4 inline-block rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Company News</span>
          <h1 class="text-display text-[var(--ink)]">parcelLab Recognized on the Forbes America's Best Startup Employers 2022 List</h1>
          <div class="mt-6 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
            <span>By <strong class="font-medium text-[var(--ink-secondary)]">parcelLab Team</strong></span>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <time datetime="2022-04-24">April 24, 2022</time>
            <span class="h-1 w-1 rounded-full bg-[var(--ink-muted)]"></span>
            <span>3 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-[800px] px-6 md:px-12">
        <p class="text-[var(--ink-secondary)] leading-relaxed text-lg">
          parcelLab earned recognition on the Forbes list of America's Best Startup Employers 2022, a prestigious award presented jointly by Forbes and Statista Inc. The announcement occurred on March 8, 2022.
        </p>

        <h2 class="text-heading text-[var(--ink)] mt-12 mb-4">Selection Methodology</h2>
        <p class="text-[var(--ink-secondary)] leading-relaxed">
          The awards evaluated employer excellence across three dimensions:
        </p>

        <div class="mt-6 space-y-6">
          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">Employee Satisfaction</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              Research examined average employment tenure and online employer reviews to assess workplace quality.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">Employer Reputation</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              Social media analysis extracted company information from news outlets, blogs, and social networks.
            </p>
          </div>

          <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
            <h3 class="text-lg font-semibold text-[var(--ink)]">Company Growth</h3>
            <p class="mt-2 text-[var(--ink-secondary)] leading-relaxed">
              Assessments included website traffic metrics, headcount expansion rates, and job opening volumes.
            </p>
          </div>
        </div>

        <p class="text-[var(--ink-secondary)] leading-relaxed mt-6">
          Eligible companies required U.S. headquarters and founding dates between 2012-2019. The final ranking recognized 500 top companies from over 8 million data points.
        </p>

        <div class="my-10 rounded-2xl bg-[var(--surface-sunken)] p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.1em] text-[var(--ink-muted)]">Team Response</p>
          <p class="mt-2 text-lg font-medium text-[var(--ink)]">"We're thrilled to be among Forbes America's Best Startup Employers 2022. Since parcelLab was founded, we've put our customers at the heart of what we do."</p>
          <p class="mt-1 text-sm text-[var(--ink-muted)]">-- Felicitas Schweiker, VP of People, Operations and Culture</p>
        </div>

        <div class="my-12 border-t border-[var(--line)]"></div>

        <p class="text-[var(--ink-secondary)] leading-relaxed">
          parcelLab operates as the leading post-purchase platform globally, serving 500+ brands including IKEA, Bose, Puma, Farfetch, and Nespresso. With offices in Munich, London, Paris, and Boston, the company was highlighted by the Financial Times as one of Europe's fastest-growing technology firms in 2021.
        </p>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
