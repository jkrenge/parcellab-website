---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<Layout
  title="App Store - parcelLab"
  description="The parcelLab App Store unites our platform's native power with the innovation of world-leading returns partners."
>
  <Header client:load />
  <main>
    <PageHero
      eyebrow="App Store"
      title="The industry's first App Store designed to optimize your returns experience"
      description="From logistics to loyalty, unite parcelLab's native power with the innovation of world-leading returns partners. Discover, activate, and optimize returns and post-purchase solutions without replatforming."
      ctaText="Book a demo"
      ctaHref={`${base}/live-demo/`}
      secondaryCtaText="Take a tour"
      secondaryCtaHref={`${base}/live-demo/`}
      gradient="linear-gradient(135deg, #1e293b 0%, #0f172a 100%)"
    />

    <!-- Problem Statement -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="text-display text-[var(--ink)]">The returns tech stack is broken</h2>
          <p class="mt-5 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            Retailers are juggling disconnected tools, legacy systems, and endless custom integrations. It's slow, inflexible, and expensive &mdash; and shoppers feel the impact.
          </p>
        </div>
        <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#F4373D]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F4373D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[var(--ink)]">Heavy Dev Lift</h3>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Adding a new returns solution often means weeks or months of custom development work.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/15">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[var(--ink)]">Fragmented Tech Stacks</h3>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Retailers stitch together returns portals, label providers, and carrier integrations that don't talk to each other.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[var(--ink)]">Rigid Legacy Systems</h3>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Most returns platforms aren't designed to adapt to business-specific rules, regional variations, or return models.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[var(--ink)]">No Built-in Intelligence</h3>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Most systems lack insights into return reasons, refund delays, or save opportunities &mdash; let alone automation to act on them.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Value Proposition -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto mb-16 max-w-2xl text-center">
          <h2 class="text-display text-[var(--ink)]">One platform. Every capability you need.</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            The parcelLab App Store is your central hub to discover, activate, and optimize returns and post-purchase solutions &mdash; without replatforming or building from scratch.
          </p>
        </div>

        <!-- parcelLab Returns -->
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div>
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">parcelLab Returns</span>
            <h2 class="text-heading text-[var(--ink)]">Native returns capabilities</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Powerful, built-in returns features that work out of the box. Full visibility, self-service, and personalized communication flows.
            </p>
            <ul class="mt-8 space-y-4">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Full visibility into returns with real-time tracking and automated updates</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Empower customers with a policy-driven, self-service returns portal</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Create segmented and personalized returns journey communication flows</span>
              </li>
            </ul>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-[#3D3AD3]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
              </div>
              <h4 class="text-sm font-semibold text-[var(--ink)]">Retain Returns Portal</h4>
              <p class="mt-1 text-xs text-[var(--ink-secondary)]">Self-service returns with revenue retention</p>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-[#3D3AD3]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              </div>
              <h4 class="text-sm font-semibold text-[var(--ink)]">Shopify Returns Portal</h4>
              <p class="mt-1 text-xs text-[var(--ink-secondary)]">Native Shopify integration for returns</p>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-[#3D3AD3]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h4 class="text-sm font-semibold text-[var(--ink)]">Single Sign-On</h4>
              <p class="mt-1 text-xs text-[var(--ink-secondary)]">Secure, unified authentication</p>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-[#F4373D]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F4373D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <h4 class="text-sm font-semibold text-[var(--ink)]">Fraud Return Tagging</h4>
              <p class="mt-1 text-xs text-[var(--ink-secondary)]">Shopify fraud detection for returns</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Returns Partner Solutions -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto mb-16 max-w-2xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">Partner Integrations</span>
          <h2 class="text-display text-[var(--ink)]">Industry-leading returns partners</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            Best-in-class partner integrations, activated directly from the App Store. No custom development needed.
          </p>
        </div>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5 hover:border-[#3D3AD3]/20">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Metapack</h3>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Generate return labels and manage return carriers with ease. Connects retailers to 350+ carriers for streamlined shipping and returns.</p>
          </div>
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5 hover:border-[#3D3AD3]/20">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">ReBound</h3>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Manage cross-border returns seamlessly. Advanced global returns technology for multi-channel efficiency.</p>
          </div>
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5 hover:border-[#3D3AD3]/20">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Global-e</h3>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Easily generate return labels, access local return hubs, and receive timely refunds across 200+ international markets.</p>
          </div>
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5 hover:border-[#3D3AD3]/20">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Happy Returns</h3>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Access over 8,000 Return Bar locations for box-free, in-store returns with a modern, eco-friendly experience.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Returns Recipes -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="order-2 md:order-1 grid grid-cols-2 gap-4">
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-[#FFC943]/15">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <h4 class="text-sm font-semibold text-[var(--ink)]">Returns Feedback Survey</h4>
              <p class="mt-1 text-xs text-[var(--ink-secondary)]">Collect insights to improve your returns process</p>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-[#FFC943]/15">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
              </div>
              <h4 class="text-sm font-semibold text-[var(--ink)]">Return to Sender Follow-Up</h4>
              <p class="mt-1 text-xs text-[var(--ink-secondary)]">Automated follow-up for failed deliveries</p>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-[#FFC943]/15">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <h4 class="text-sm font-semibold text-[var(--ink)]">Return Experience Emails</h4>
              <p class="mt-1 text-xs text-[var(--ink-secondary)]">Branded communication throughout the return</p>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-5">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-[#FFC943]/15">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <h4 class="text-sm font-semibold text-[var(--ink)]">High Returners Outreach</h4>
              <p class="mt-1 text-xs text-[var(--ink-secondary)]">Targeted campaigns for frequent returners</p>
            </div>
          </div>
          <div class="order-1 md:order-2">
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#b8860b]">Returns Recipes</span>
            <h2 class="text-heading text-[var(--ink)]">Accelerate your returns journey</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Recipes accelerate your returns journey with pre-configured templates that solve real-world problems. Reduce setup time and deploy proven flows instantly.
            </p>
            <ul class="mt-8 space-y-4">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Reduce manual setup with automated flows for feedback, return-to-sender, and more</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Enhance communication with proven templates for high-returners, experience emails, and surveys</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Apply and adjust Recipes directly in your parcelLab workflows &mdash; no heavy dev lift needed</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Agents -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div>
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">AI Agents</span>
            <h2 class="text-heading text-[var(--ink)]">Returns AI Agents for smart automation</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              parcelLab's assistive and autonomous AI Agents are designed to learn and adapt continuously to deliver fully automated, hyper-personalized returns experiences.
            </p>
          </div>
          <div class="space-y-6">
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
              <div class="flex items-start gap-5">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <div>
                  <h3 class="text-base font-semibold text-[var(--ink)]">Return Save Agent</h3>
                  <p class="mt-1 text-sm text-[var(--ink-secondary)]">Proactively engages with customers initiating a return and offers instant, personalized discounts to keep the product and retain revenue.</p>
                </div>
              </div>
            </div>
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
              <div class="flex items-start gap-5">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                </div>
                <div>
                  <h3 class="text-base font-semibold text-[var(--ink)]">Returns Forecast AI</h3>
                  <p class="mt-1 text-sm text-[var(--ink-secondary)]">Predicts return volumes and generates actionable insights to help warehouse teams optimize staffing and reduce operational bottlenecks.</p>
                </div>
              </div>
            </div>
