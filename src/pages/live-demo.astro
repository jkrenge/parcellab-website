---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";

const benefits = [
  {
    icon: "package",
    title: "Proactive delivery communication",
    description: "See how brands send branded, real-time shipping updates that reduce WISMO inquiries by up to 25%.",
  },
  {
    icon: "refresh",
    title: "Seamless returns experience",
    description: "Walk through a self-service returns portal that turns a pain point into a loyalty-building moment.",
  },
  {
    icon: "bar-chart",
    title: "Data-driven post-purchase insights",
    description: "Explore dashboards that surface carrier performance, delivery exceptions, and customer sentiment.",
  },
  {
    icon: "zap",
    title: "AI-powered automation",
    description: "Discover how AI Agents handle exception management, predictive ETAs, and personalized recommendations.",
  },
  {
    icon: "users",
    title: "Real-world impact across retail",
    description: "Learn how top retailers like Bose, LIDL, and Farfetch use parcelLab to cut costs and boost satisfaction.",
  },
];
---

<Layout
  title="Live Demo - See parcelLab in Action"
  description="Curious how top retailers are transforming the post-purchase experience? Join our live 20-minute demo to see how parcelLab helps brands cut costs, automate operations, and keep customers coming back."
>
  <Header client:load />
  <main>
    <!-- Hero -->
    <section class="section-generous bg-gradient-to-br from-[#1e293b] to-[#0f172a] rounded-b-[32px]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="max-w-3xl">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-white/50">
            Live demo
          </span>
          <h1 class="text-hero text-white">
            See parcelLab in action
          </h1>
          <p class="mt-5 max-w-xl text-[var(--text-body-lg)] font-light leading-relaxed text-white/70">
            Curious how top retailers are transforming the post-purchase experience? Join our live 20-minute demo to see how parcelLab helps brands cut costs, automate operations, and create moments that keep customers coming back.
          </p>
        </div>
      </div>
    </section>

    <!-- Benefits + Form -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid gap-16 lg:grid-cols-2">

          <!-- Left: Benefits -->
          <div>
            <h2 class="text-display text-[var(--ink)]">What you'll see</h2>
            <p class="mt-4 text-[var(--ink-secondary)] leading-relaxed max-w-lg">
              In just 20 minutes, we'll walk you through the platform capabilities and real-world impact across retail and eCommerce.
            </p>

            <div class="mt-10 flex flex-col gap-8">
              {benefits.map((benefit) => (
                <div class="flex gap-5">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
                    {benefit.icon === "package" && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                    )}
                    {benefit.icon === "refresh" && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
                    )}
                    {benefit.icon === "bar-chart" && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>
                    )}
                    {benefit.icon === "zap" && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
                    )}
                    {benefit.icon === "users" && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    )}
                  </div>
                  <div>
                    <h3 class="text-base font-semibold text-[var(--ink)]">{benefit.title}</h3>
                    <p class="mt-1 text-sm leading-relaxed text-[var(--ink-secondary)]">{benefit.description}</p>
                  </div>
                </div>
              ))}
            </div>

            <!-- Trust signal -->
            <div class="mt-12 flex items-center gap-4 rounded-2xl border border-[var(--line)] bg-[var(--surface-sunken)] p-5">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#035740]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 11.08-.22-.02A7 7 0 0 0 12 4.34a7 7 0 0 0-9.78 6.72.26.26 0 0 0 0 .02"/><path d="m2.18 12.96.06.22a7 7 0 0 0 9.78 6.72A7 7 0 0 0 21.8 13"/><circle cx="12" cy="12" r="1"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[var(--ink)]">Trusted by leading brands worldwide</p>
                <p class="text-xs text-[var(--ink-secondary)]">Wyze decreased WISMO inquiries by 20% with parcelLab</p>
              </div>
            </div>
          </div>

          <!-- Right: Demo Request Form -->
          <div>
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 shadow-sm md:p-10">
              <h3 class="text-heading text-[var(--ink)]">Book a demo</h3>
              <p class="mt-2 text-sm text-[var(--ink-secondary)]">
                Fill out the form and one of our specialists will be in touch to schedule your personalized demo.
              </p>

              <form class="mt-8 flex flex-col gap-5" onsubmit="return false;">
                <div class="grid gap-5 sm:grid-cols-2">
                  <div>
                    <label for="first-name" class="mb-1.5 block text-sm font-medium text-[var(--ink)]">First name *</label>
                    <input
                      type="text"
                      id="first-name"
                      placeholder="Jane"
                      class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] transition-colors focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20"
                    />
                  </div>
                  <div>
                    <label for="last-name" class="mb-1.5 block text-sm font-medium text-[var(--ink)]">Last name *</label>
                    <input
                      type="text"
                      id="last-name"
                      placeholder="Doe"
                      class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] transition-colors focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20"
                    />
                  </div>
                </div>

                <div>
                  <label for="email" class="mb-1.5 block text-sm font-medium text-[var(--ink)]">Work email *</label>
                  <input
                    type="email"
                    id="email"
                    placeholder="jane@company.com"
                    class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] transition-colors focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20"
                  />
                </div>

                <div>
                  <label for="company" class="mb-1.5 block text-sm font-medium text-[var(--ink)]">Company *</label>
                  <input
                    type="text"
                    id="company"
                    placeholder="Acme Inc."
                    class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] transition-colors focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20"
                  />
                </div>

                <div>
                  <label for="job-title" class="mb-1.5 block text-sm font-medium text-[var(--ink)]">Job title</label>
                  <input
                    type="text"
                    id="job-title"
                    placeholder="Head of eCommerce"
                    class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] transition-colors focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20"
                  />
                </div>

                <div>
                  <label for="message" class="mb-1.5 block text-sm font-medium text-[var(--ink)]">How can we help?</label>
                  <textarea
                    id="message"
                    rows="3"
                    placeholder="Tell us about your post-purchase challenges..."
                    class="w-full resize-none rounded-xl border border-[var(--line)] bg-[var(--surface)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] transition-colors focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20"
                  ></textarea>
                </div>

                <button
                  type="submit"
                  class="group mt-2 inline-flex w-full items-center justify-center gap-3 rounded-full bg-[#3D3AD3] py-4 px-7 text-base font-medium text-white shadow-[0_2px_16px_rgba(61,58,211,0.3)] transition-all hover:shadow-[0_4px_24px_rgba(61,58,211,0.4)] hover:-translate-y-0.5"
                >
                  Request a demo
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </button>

                <p class="text-center text-xs text-[var(--ink-muted)]">
                  By submitting this form, you agree to our
                  <a href={`${import.meta.env.BASE_URL}/privacy-policy/`} class="underline hover:text-[var(--ink-secondary)]">privacy policy</a>.
                </p>
              </form>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
