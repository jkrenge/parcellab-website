---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";

import { Header } from "../components/Header";
import HeroSection from "../components/HeroSection.astro";
import LogoBar from "../components/LogoBar.astro";
import PostPurchaseJourney from "../components/PostPurchaseJourney.astro";
import { ProductCards } from "../components/ProductCards";
import SolutionsSection from "../components/SolutionsSection.astro";
import { CustomerProof } from "../components/CustomerProof";
import { TeamsSection } from "../components/TeamsSection";
import WhatsHappening from "../components/WhatsHappening.astro";
import G2Reviews from "../components/G2Reviews.astro";
import CTASection from "../components/CTASection.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Header client:load />
  <main>
    <HeroSection />
    <LogoBar />
    <PostPurchaseJourney />
    <ProductCards client:visible />
    <SolutionsSection />
    <CustomerProof client:visible />
    <TeamsSection client:visible />
    <WhatsHappening />
    <G2Reviews />
    <CTASection />
  </main>
  <Footer />
</Layout>
