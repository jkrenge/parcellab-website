---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";
const b = import.meta.env.BASE_URL;
---

<Layout title="parcelLab — The Journey: Every Order Tells a Story">
  <Header client:load />
  <main class="v9-main" id="v9Main">

    <!-- ═══════════════════════════════════════════════════════════
         PROGRESS INDICATOR — right-side chapter dots
         ═══════════════════════════════════════════════════════════ -->
    <nav class="v9-progress" id="v9Progress" aria-label="Chapter navigation">
      <div class="v9-progress__track">
        <button class="v9-progress__dot active" data-chapter="1" aria-label="Chapter 1: The Promise"><span class="v9-progress__label">Promise</span></button>
        <button class="v9-progress__dot" data-chapter="2" aria-label="Chapter 2: Confirmation"><span class="v9-progress__label">Confirm</span></button>
        <button class="v9-progress__dot" data-chapter="3" aria-label="Chapter 3: Tracking"><span class="v9-progress__label">Track</span></button>
        <button class="v9-progress__dot" data-chapter="4" aria-label="Chapter 4: Delivery"><span class="v9-progress__label">Deliver</span></button>
        <button class="v9-progress__dot" data-chapter="5" aria-label="Chapter 5: Returns"><span class="v9-progress__label">Return</span></button>
        <button class="v9-progress__dot" data-chapter="6" aria-label="Chapter 6: Re-engage"><span class="v9-progress__label">Re-engage</span></button>
        <button class="v9-progress__dot" data-chapter="7" aria-label="Chapter 7: Platform"><span class="v9-progress__label">Platform</span></button>
        <button class="v9-progress__dot" data-chapter="8" aria-label="Chapter 8: Start"><span class="v9-progress__label">Start</span></button>
      </div>
    </nav>

    <!-- ═══════════════════════════════════════════════════════════
         CHAPTER 1 — "It starts with a promise" — CHECKOUT
         ═══════════════════════════════════════════════════════════ -->
    <section class="v9-chapter v9-ch1" id="chapter1" data-chapter="1">
      <div class="v9-ch__scroll-space">
        <div class="v9-ch__sticky">
          <!-- Background orb -->
          <div class="v9-orb v9-orb--purple-1" aria-hidden="true"></div>
          <div class="v9-orb v9-orb--purple-2" aria-hidden="true"></div>

          <div class="container-pl relative z-10">
            <div class="v9-ch1__layout">
              <!-- Left: narrative text -->
              <div class="v9-ch1__text">
                <span class="v9-chapter-label">Chapter 1 &mdash; Convert</span>
                <h2 class="v9-ch1__headline v9-reveal" id="ch1Headline">
                  It starts with<br/><span class="v9-gradient-text">a promise.</span>
                </h2>
                <p class="v9-ch1__sub v9-reveal" style="transition-delay: 0.1s;">
                  A customer lands on your product page. They hesitate. Will it arrive in time?
                </p>
                <div class="v9-ch1__stat v9-reveal" style="transition-delay: 0.2s;">
                  <span class="v9-stat-number">+5%</span>
                  <span class="v9-stat-desc">cart conversion when delivery dates are shown</span>
                </div>
                <p class="v9-ch1__note v9-reveal" style="transition-delay: 0.3s;">
                  That single promise &mdash; a precise, trustworthy delivery date &mdash; converts browsers into buyers.
                </p>
              </div>

              <!-- Right: product page mockup with delivery date widget -->
              <div class="v9-ch1__mockup v9-reveal" style="transition-delay: 0.15s;">
                <div class="v9-mock-card v9-mock-card--product">
                  <!-- Product image area -->
                  <div class="v9-product-img">
                    <div class="v9-product-img__placeholder">
                      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                      <span>Parker's Ceramic Desk Lamp</span>
                    </div>
                  </div>
                  <!-- Product details -->
                  <div class="v9-product-details">
                    <div class="v9-product-brand">Parker's Home</div>
                    <div class="v9-product-name">Ceramic Desk Lamp — Matte White</div>
                    <div class="v9-product-price">$89.00</div>
                    <div class="v9-product-rating">
                      <span class="v9-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                      <span class="v9-rating-count">2,847 reviews</span>
                    </div>
                    <!-- parcelLab Delivery Date Widget -->
                    <div class="v9-delivery-widget" id="deliveryWidget">
                      <div class="v9-dw-header">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                      <span class="v9-dw-title">Estimated Delivery</span>
                    </div>
                    <div class="v9-dw-date" id="deliveryDate">
                      <span class="v9-dw-day">Wednesday, April 8</span>
                      <span class="v9-dw-speed">FREE Standard Shipping</span>
                    </div>
                    <div class="v9-dw-urgency">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      Order within <strong id="urgencyTimer">1h 47m</strong> for this date
                    </div>
                    <div class="v9-dw-zip">
                      <label for="zipInput" class="sr-only">ZIP Code</label>
                      <input type="text" id="zipInput" value="10001" maxlength="5" class="v9-dw-zip__input" aria-label="ZIP code for delivery estimate" />
                      <button class="v9-dw-zip__btn" id="zipBtn" type="button">Update</button>
                    </div>
                    <div class="v9-dw-powered">
                      Powered by <strong style="color:#3D3AD3;">parcelLab</strong>
                    </div>
                  </div>
                  <!-- Add to cart button -->
                  <button class="v9-product-atc" type="button">Add to Cart</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════════
         CHAPTER 2 — "The order is placed" — CONFIRMATION
         ═══════════════════════════════════════════════════════════ -->
    <section class="v9-chapter v9-ch2" id="chapter2" data-chapter="2">
      <div class="v9-ch__scroll-space">
        <div class="v9-ch__sticky">
          <div class="v9-orb v9-orb--violet-1" aria-hidden="true"></div>

          <div class="container-pl relative z-10">
            <div class="v9-ch2__layout">
              <!-- Left: email mockup -->
              <div class="v9-ch2__mockup v9-reveal">
                <div class="v9-mock-card v9-mock-card--email" id="emailCard">
                  <!-- Email header -->
                  <div class="v9-email-header">
                    <div class="v9-email-logo">
                      <div class="v9-email-logo__icon">P</div>
                      <span>Parker's Home</span>
                    </div>
                  </div>
                  <!-- Email hero banner -->
                  <div class="v9-email-hero">
                    <div class="v9-email-check">
                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <h3 class="v9-email-hero__title">Thank you for your order!</h3>
                    <p class="v9-email-hero__sub">Order #PK-2847391 &bull; Placed April 5, 2026</p>
                  </div>
                  <!-- Order summary -->
                  <div class="v9-email-body">
                    <div class="v9-email-item">
                      <div class="v9-email-item__img">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                      </div>
                      <div class="v9-email-item__info">
                        <div class="v9-email-item__name">Ceramic Desk Lamp — Matte White</div>
                        <div class="v9-email-item__meta">Qty: 1 &bull; $89.00</div>
                      </div>
                    </div>
                    <div class="v9-email-delivery">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                      <span>Estimated delivery: <strong>Wednesday, April 8</strong></span>
                    </div>
                    <!-- Cross-sell campaign banner -->
                    <div class="v9-email-campaign">
                      <div class="v9-email-campaign__badge">Exclusive Offer</div>
                      <div class="v9-email-campaign__text">Complete the look &mdash; <strong>15% off accessories</strong></div>
                      <div class="v9-email-campaign__cta">Shop Now &rarr;</div>
                    </div>
                  </div>
                  <!-- Email footer -->
                  <div class="v9-email-footer">
                    <div class="v9-email-footer__track">Track your order &rarr;</div>
                    <div class="v9-email-footer__help">Need help? <span>Contact Support</span></div>
                  </div>
                </div>
              </div>

              <!-- Right: narrative text -->
              <div class="v9-ch2__text">
                <span class="v9-chapter-label">Chapter 2 &mdash; Engage</span>
                <h2 class="v9-section-title v9-reveal">
                  The order<br/><span class="v9-gradient-text">is placed.</span>
                </h2>
                <p class="v9-body-text v9-reveal" style="transition-delay: 0.1s;">
                  A branded confirmation email lands in their inbox. Not a generic receipt &mdash; a curated touchpoint.
                </p>
                <div class="v9-ch2__stats v9-reveal" style="transition-delay: 0.2s;">
                  <div class="v9-stat-block">
                    <span class="v9-stat-number">95%</span>
                    <span class="v9-stat-desc">open rate on branded confirmations</span>
                  </div>
                  <div class="v9-stat-block">
                    <span class="v9-stat-number">30%</span>
                    <span class="v9-stat-desc">open rate on generic emails</span>
                  </div>
                </div>
                <p class="v9-body-text v9-reveal" style="transition-delay: 0.3s;">
                  Every email is a branded experience. Every experience is a revenue opportunity.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════════
         CHAPTER 3 — "In transit" — TRACKING
         ═══════════════════════════════════════════════════════════ -->
    <section class="v9-chapter v9-ch3" id="chapter3" data-chapter="3">
      <div class="v9-ch__scroll-space">
        <div class="v9-ch__sticky">
          <div class="v9-orb v9-orb--blue-1" aria-hidden="true"></div>
          <div class="v9-orb v9-orb--blue-2" aria-hidden="true"></div>

          <div class="container-pl relative z-10">
            <div class="v9-ch3__layout">
              <!-- Left: narrative -->
              <div class="v9-ch3__text">
                <span class="v9-chapter-label">Chapter 3 &mdash; Engage</span>
                <h2 class="v9-section-title v9-reveal">
                  In<br/><span class="v9-gradient-text">transit.</span>
                </h2>
                <p class="v9-body-text v9-reveal" style="transition-delay: 0.1s;">
                  The customer checks their order status. Instead of a carrier page, they land on a branded experience &mdash; yours.
                </p>
                <div class="v9-ch3__stats v9-reveal" style="transition-delay: 0.2s;">
                  <div class="v9-stat-block">
                    <span class="v9-stat-number">$8.50</span>
                    <span class="v9-stat-desc">average additional revenue per tracking page visit</span>
                  </div>
                  <div class="v9-stat-block">
                    <span class="v9-stat-number">-20%</span>
                    <span class="v9-stat-desc">"Where is my order?" support calls</span>
                  </div>
                </div>
                <p class="v9-body-text v9-reveal" style="transition-delay: 0.3s;">
                  Every touchpoint is an opportunity. Every status check is a storefront.
                </p>
              </div>

              <!-- Right: tracking page mockup -->
              <div class="v9-ch3__mockup v9-reveal" style="transition-delay: 0.1s;">
                <div class="v9-mock-card v9-mock-card--tracking">
                  <!-- Tracking header -->
                  <div class="v9-track-header">
                    <div class="v9-track-logo">
                      <div class="v9-track-logo__icon">P</div>
                      <span>Parker's Home</span>
                    </div>
                    <div class="v9-track-order">Order #PK-2847391</div>
                  </div>

                  <!-- Status -->
                  <div class="v9-track-status">
                    <div class="v9-track-status__badge v9-track-status__badge--transit">In Transit</div>
                    <div class="v9-track-status__eta">Estimated delivery: <strong>Wednesday, April 8</strong></div>
                  </div>

                  <!-- Progress bar with truck -->
                  <div class="v9-track-progress" id="trackProgress">
                    <div class="v9-track-progress__bar">
                      <div class="v9-track-progress__fill" id="trackFill" style="width: 55%;"></div>
                      <div class="v9-track-progress__truck" id="trackTruck" style="left: 55%;" aria-hidden="true">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                      </div>
                    </div>
                    <div class="v9-track-progress__labels">
                      <span class="v9-track-progress__label done">Ordered</span>
                      <span class="v9-track-progress__label done">Shipped</span>
                      <span class="v9-track-progress__label active">In Transit</span>
                      <span class="v9-track-progress__label">Delivered</span>
                    </div>
                  </div>

                  <!-- Timeline -->
                  <div class="v9-track-timeline">
                    <div class="v9-timeline-item v9-timeline-item--done">
                      <div class="v9-timeline-dot"></div>
                      <div class="v9-timeline-content">
                        <div class="v9-timeline-date">Apr 6, 2:14 PM</div>
                        <div class="v9-timeline-text">Package arrived at distribution center &mdash; Newark, NJ</div>
                      </div>
                    </div>
                    <div class="v9-timeline-item v9-timeline-item--done">
                      <div class="v9-timeline-dot"></div>
                      <div class="v9-timeline-content">
                        <div class="v9-timeline-date">Apr 5, 6:30 PM</div>
                        <div class="v9-timeline-text">Shipped from warehouse &mdash; Philadelphia, PA</div>
                      </div>
                    </div>
                    <div class="v9-timeline-item v9-timeline-item--done">
                      <div class="v9-timeline-dot"></div>
                      <div class="v9-timeline-content">
                        <div class="v9-timeline-date">Apr 5, 11:02 AM</div>
                        <div class="v9-timeline-text">Order confirmed and processing</div>
                      </div>
                    </div>
                  </div>

                  <!-- Campaign banner -->
                  <div class="v9-track-campaign">
                    <div class="v9-track-campaign__text">Level up your WFH &mdash; <strong>Shop desk accessories</strong></div>
                    <div class="v9-track-campaign__cta">Shop Now &rarr;</div>
                  </div>

                  <!-- Ordered items -->
                  <div class="v9-track-items">
                    <div class="v9-track-items__title">Items in this shipment</div>
                    <div class="v9-track-item">
                      <div class="v9-track-item__img">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                      </div>
                      <div class="v9-track-item__info">
                        <div class="v9-track-item__name">Ceramic Desk Lamp — Matte White</div>
                        <div class="v9-track-item__meta">Qty: 1</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════════
         CHAPTER 4 — "Delivered!" — DELIVERY
         ═══════════════════════════════════════════════════════════ -->
    <section class="v9-chapter v9-ch4" id="chapter4" data-chapter="4">
      <div class="v9-ch__scroll-space">
        <div class="v9-ch__sticky">
          <div class="v9-orb v9-orb--green-1" aria-hidden="true"></div>

          <div class="container-pl relative z-10">
            <div class="v9-ch4__layout">
              <!-- Left: mockup area -->
              <div class="v9-ch4__mockup v9-reveal">
                <!-- Confetti container (CSS-only) -->
                <div class="v9-confetti-container" id="confettiContainer" aria-hidden="true">
                  <div class="v9-confetti v9-c1"></div><div class="v9-confetti v9-c2"></div><div class="v9-confetti v9-c3"></div>
                  <div class="v9-confetti v9-c4"></div><div class="v9-confetti v9-c5"></div><div class="v9-confetti v9-c6"></div>
                  <div class="v9-confetti v9-c7"></div><div class="v9-confetti v9-c8"></div><div class="v9-confetti v9-c9"></div>
                  <div class="v9-confetti v9-c10"></div><div class="v9-confetti v9-c11"></div><div class="v9-confetti v9-c12"></div>
                  <div class="v9-confetti v9-c13"></div><div class="v9-confetti v9-c14"></div><div class="v9-confetti v9-c15"></div>
                  <div class="v9-confetti v9-c16"></div><div class="v9-confetti v9-c17"></div><div class="v9-confetti v9-c18"></div>
                </div>

                <div class="v9-mock-card v9-mock-card--delivered">
                  <div class="v9-delivered-check">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  </div>
                  <h3 class="v9-delivered-title">Delivered!</h3>
                  <p class="v9-delivered-sub">Your order was delivered on Wednesday, April 8 at 2:34 PM</p>

                  <!-- NPS Survey -->
                  <div class="v9-nps-survey">
                    <div class="v9-nps-question">How was your delivery experience?</div>
                    <div class="v9-nps-stars" role="group" aria-label="Rate your experience">
                      <button class="v9-nps-star" data-star="1" aria-label="1 star">&#9733;</button>
                      <button class="v9-nps-star" data-star="2" aria-label="2 stars">&#9733;</button>
                      <button class="v9-nps-star" data-star="3" aria-label="3 stars">&#9733;</button>
                      <button class="v9-nps-star active" data-star="4" aria-label="4 stars">&#9733;</button>
                      <button class="v9-nps-star active" data-star="5" aria-label="5 stars">&#9733;</button>
                    </div>
                    <!-- Satisfaction thumbs -->
                    <div class="v9-nps-thumbs">
                      <div class="v9-nps-thumb-group">
                        <span class="v9-nps-thumb-label">Carrier</span>
                        <div class="v9-thumb-btns">
                          <button class="v9-thumb-btn v9-thumb-btn--up active" aria-label="Thumbs up">&#128077;</button>
                          <button class="v9-thumb-btn v9-thumb-btn--down" aria-label="Thumbs down">&#128078;</button>
                        </div>
                      </div>
                      <div class="v9-nps-thumb-group">
                        <span class="v9-nps-thumb-label">Communication</span>
                        <div class="v9-thumb-btns">
                          <button class="v9-thumb-btn v9-thumb-btn--up active" aria-label="Thumbs up">&#128077;</button>
                          <button class="v9-thumb-btn v9-thumb-btn--down" aria-label="Thumbs down">&#128078;</button>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Push notification overlay -->
                <div class="v9-push-notification v9-reveal" style="transition-delay: 0.3s;">
                  <div class="v9-push-icon">
                    <div class="v9-push-icon__inner">P</div>
                  </div>
                  <div class="v9-push-content">
                    <div class="v9-push-app">Parker's Home &bull; now</div>
                    <div class="v9-push-text">Your order has been delivered! Rate your experience &rarr;</div>
                  </div>
                </div>
              </div>

              <!-- Right: narrative -->
              <div class="v9-ch4__text">
                <span class="v9-chapter-label">Chapter 4 &mdash; Engage</span>
                <h2 class="v9-section-title v9-reveal">
                  <span class="v9-gradient-text-green">Delivered!</span>
                </h2>
                <p class="v9-body-text v9-reveal" style="transition-delay: 0.1s;">
                  The package arrives. But the relationship doesn't end at the doorstep &mdash; it deepens.
                </p>
                <p class="v9-body-text v9-reveal" style="transition-delay: 0.2s;">
                  An NPS survey captures sentiment while it's fresh. A push notification drives re-engagement. Satisfaction data feeds back to optimize carrier selection.
                </p>
                <div class="v9-ch4__stat v9-reveal" style="transition-delay: 0.3s;">
                  <span class="v9-stat-number v9-stat-number--green">4.7x</span>
                  <span class="v9-stat-desc">higher survey response rates with proactive delivery notifications</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════════
         CHAPTER 5 — "Something doesn't fit" — RETURNS
         ═══════════════════════════════════════════════════════════ -->
    <section class="v9-chapter v9-ch5" id="chapter5" data-chapter="5">
      <div class="v9-ch__scroll-space">
        <div class="v9-ch__sticky">
          <div class="v9-orb v9-orb--amber-1" aria-hidden="true"></div>
          <div class="v9-orb v9-orb--amber-2" aria-hidden="true"></div>

          <div class="container-pl relative z-10">
            <div class="v9-ch5__layout">
              <!-- Left: narrative -->
              <div class="v9-ch5__text">
                <span class="v9-chapter-label">Chapter 5 &mdash; Retain</span>
                <h2 class="v9-section-title v9-reveal">
                  Something<br/><span class="v9-gradient-text-amber">doesn't fit.</span>
                </h2>
                <p class="v9-body-text v9-reveal" style="transition-delay: 0.1s;">
                  Returns are inevitable. But how you handle them defines whether a customer stays or goes.
                </p>
                <p class="v9-body-text v9-reveal" style="transition-delay: 0.2s;">
                  Smart returns don't just reduce costs. They create new revenue.
                </p>
                <div class="v9-ch5__stats v9-reveal" style="transition-delay: 0.3s;">
                  <div class="v9-stat-block">
                    <span class="v9-stat-number v9-stat-number--amber">11%</span>
                    <span class="v9-stat-desc">higher retention through exchanges</span>
                  </div>
                  <div class="v9-stat-block">
                    <span class="v9-stat-number v9-stat-number--amber">3x</span>
                    <span class="v9-stat-desc">more store credit adoption</span>
                  </div>
                </div>
              </div>

              <!-- Right: returns portal mockup -->
              <div class="v9-ch5__mockup v9-reveal" style="transition-delay: 0.15s;">
