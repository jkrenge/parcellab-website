  .v9-nps-thumbs {
    display: flex;
    justify-content: center;
    gap: 32px;
  }

  .v9-nps-thumb-group {
    text-align: center;
  }

  .v9-nps-thumb-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-muted);
    display: block;
    margin-bottom: 6px;
  }

  .v9-thumb-btns {
    display: flex;
    gap: 8px;
    justify-content: center;
  }

  .v9-thumb-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: white;
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .v9-thumb-btn.active {
    border-color: #3D3AD3;
    background: rgba(61, 58, 211, 0.05);
  }

  /* Push notification */
  .v9-push-notification {
    position: absolute;
    top: -20px;
    right: -24px;
    width: 280px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    padding: 12px 14px;
    display: flex;
    gap: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    z-index: 10;
  }

  .v9-push-icon {
    flex-shrink: 0;
  }

  .v9-push-icon__inner {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    font-size: 15px;
  }

  .v9-push-app {
    font-size: 11px;
    color: var(--ink-muted);
    margin-bottom: 2px;
  }

  .v9-push-text {
    font-size: 13px;
    color: var(--ink);
    font-weight: 500;
    line-height: 1.4;
  }

  /* CSS Confetti */
  .v9-confetti-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 5;
  }

  .v9-confetti {
    position: absolute;
    width: 8px;
    height: 8px;
    opacity: 0;
  }

  .v9-ch4.v9-chapter--active .v9-confetti {
    animation: v9-confetti-fall 2.5s ease-in-out forwards;
  }

  .v9-c1 { left: 10%; background: #3D3AD3; animation-delay: 0s; border-radius: 2px; }
  .v9-c2 { left: 20%; background: #FFC943; animation-delay: 0.1s; border-radius: 50%; width: 6px; height: 6px; }
  .v9-c3 { left: 30%; background: #035740; animation-delay: 0.2s; border-radius: 1px; width: 10px; height: 4px; }
  .v9-c4 { left: 40%; background: #F4373D; animation-delay: 0.15s; border-radius: 50%; }
  .v9-c5 { left: 50%; background: #3D3AD3; animation-delay: 0.3s; width: 6px; height: 10px; }
  .v9-c6 { left: 60%; background: #FFC943; animation-delay: 0.05s; border-radius: 50%; width: 10px; height: 10px; }
  .v9-c7 { left: 70%; background: #035740; animation-delay: 0.25s; }
  .v9-c8 { left: 80%; background: #F4373D; animation-delay: 0.12s; border-radius: 50%; width: 5px; height: 5px; }
  .v9-c9 { left: 90%; background: #3D3AD3; animation-delay: 0.18s; width: 4px; height: 12px; }
  .v9-c10 { left: 15%; background: #FFC943; animation-delay: 0.22s; border-radius: 50%; }
  .v9-c11 { left: 25%; background: #F4373D; animation-delay: 0.08s; width: 12px; height: 4px; }
  .v9-c12 { left: 35%; background: #035740; animation-delay: 0.28s; border-radius: 50%; width: 7px; height: 7px; }
  .v9-c13 { left: 45%; background: #3D3AD3; animation-delay: 0.14s; }
  .v9-c14 { left: 55%; background: #FFC943; animation-delay: 0.32s; border-radius: 50%; }
  .v9-c15 { left: 65%; background: #035740; animation-delay: 0.06s; width: 10px; height: 4px; }
  .v9-c16 { left: 75%; background: #F4373D; animation-delay: 0.2s; border-radius: 50%; width: 6px; height: 6px; }
  .v9-c17 { left: 85%; background: #3D3AD3; animation-delay: 0.26s; width: 4px; height: 10px; }
  .v9-c18 { left: 5%; background: #FFC943; animation-delay: 0.16s; }

  @keyframes v9-confetti-fall {
    0% {
      opacity: 1;
      top: -10%;
      transform: translateX(0) rotate(0deg);
    }
    100% {
      opacity: 0;
      top: 100%;
      transform: translateX(calc(var(--drift, 20px))) rotate(720deg);
    }
  }

  .v9-c1 { --drift: -30px; }
  .v9-c2 { --drift: 25px; }
  .v9-c3 { --drift: -15px; }
  .v9-c4 { --drift: 40px; }
  .v9-c5 { --drift: -20px; }
  .v9-c6 { --drift: 35px; }
  .v9-c7 { --drift: -25px; }
  .v9-c8 { --drift: 10px; }
  .v9-c9 { --drift: -35px; }
  .v9-c10 { --drift: 20px; }
  .v9-c11 { --drift: -10px; }
  .v9-c12 { --drift: 30px; }
  .v9-c13 { --drift: -40px; }
  .v9-c14 { --drift: 15px; }
  .v9-c15 { --drift: -20px; }
  .v9-c16 { --drift: 25px; }
  .v9-c17 { --drift: -30px; }
  .v9-c18 { --drift: 20px; }


  /* ═══════════════════════════════════════════════════════════
     CHAPTER 5 STYLES — Returns Portal
     ═══════════════════════════════════════════════════════════ */
  .v9-ch5 {
    background: linear-gradient(180deg, #ecfdf5 0%, #fefce8 100%);
  }

  .v9-ch5__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .v9-ch5__layout { grid-template-columns: 1fr 440px; gap: 64px; }
  }

  .v9-ch5__stats {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .v9-mock-card--returns {
    max-width: 440px;
    margin: 0 auto;
  }

  .v9-returns-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--line-subtle);
  }

  .v9-returns-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .v9-returns-step {
    font-size: 12px;
    color: var(--ink-muted);
    font-weight: 500;
  }

  .v9-returns-item {
    display: flex;
    gap: 12px;
    padding: 16px 20px;
    background: rgba(61, 58, 211, 0.03);
    border-bottom: 1px solid var(--line-subtle);
    align-items: flex-start;
  }

  .v9-returns-item__check {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    background: rgba(61, 58, 211, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .v9-returns-item__name {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .v9-returns-item__reason {
    font-size: 12px;
    color: var(--ink-muted);
  }

  .v9-returns-options {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .v9-returns-option {
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }

  .v9-returns-option:hover {
    border-color: var(--ink-muted);
  }

  .v9-returns-option--exchange {
    border-color: #035740;
    background: rgba(3, 87, 64, 0.03);
  }

  .v9-returns-option--recommended .v9-returns-option__badge {
    position: absolute;
    top: -8px;
    right: 12px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #035740;
    color: white;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .v9-returns-option--credit {
    border-color: #3D3AD3;
    background: rgba(61, 58, 211, 0.02);
  }

  .v9-returns-option__bonus {
    position: absolute;
    top: -8px;
    right: 12px;
    font-size: 10px;
    font-weight: 700;
    background: #3D3AD3;
    color: white;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .v9-returns-option__icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--surface-sunken);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .v9-returns-option__label {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }

  .v9-returns-option__desc {
    font-size: 12px;
    color: var(--ink-muted);
  }

  /* Retention offer */
  .v9-returns-retention {
    margin: 0 20px 20px;
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 10px;
    padding: 16px;
    position: relative;
    overflow: hidden;
  }

  .v9-returns-retention__pulse {
    position: absolute;
    top: 12px;
    left: 12px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #f59e0b;
    animation: v9-pulse 2s ease-in-out infinite;
  }

  @keyframes v9-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.5); }
  }

  .v9-returns-retention__content {
    padding-left: 20px;
  }

  .v9-returns-retention__title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #92400e;
    margin-bottom: 4px;
  }

  .v9-returns-retention__text {
    font-size: 14px;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .v9-returns-retention__value {
    font-size: 12px;
    color: #92400e;
  }


  /* ═══════════════════════════════════════════════════════════
     CHAPTER 6 STYLES — Exchange / Journey Circle
     ═══════════════════════════════════════════════════════════ */
  .v9-ch6 {
    background: linear-gradient(180deg, #fefce8 0%, #ecfeff 100%);
  }

  .v9-ch6__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .v9-ch6__layout { grid-template-columns: 480px 1fr; gap: 64px; }
  }

  .v9-ch6__mockup {
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: center;
  }

  /* Exchange tracking mini card */
  .v9-mock-card--exchange-track {
    max-width: 400px;
    width: 100%;
    padding: 20px;
    transform: perspective(1000px) rotateY(2deg) rotateX(1deg);
  }

  .v9-extrack-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .v9-extrack-badge {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #0d9668;
    background: rgba(13, 150, 104, 0.08);
    padding: 4px 10px;
    border-radius: 6px;
  }

  .v9-extrack-order {
    font-size: 12px;
    color: var(--ink-muted);
  }

  .v9-extrack-status {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
    font-size: 13px;
    color: var(--ink-secondary);
  }

  .v9-extrack-progress {
    margin-bottom: 16px;
  }

  .v9-extrack-progress__bar {
    height: 4px;
    background: var(--line);
    border-radius: 2px;
    overflow: hidden;
  }

  .v9-extrack-progress__fill {
    height: 100%;
    background: linear-gradient(90deg, #035740, #0d9668);
    border-radius: 2px;
  }

  .v9-extrack-campaign {
    background: rgba(13, 150, 104, 0.05);
    border: 1px solid rgba(13, 150, 104, 0.12);
    border-radius: 8px;
    padding: 12px;
    font-size: 13px;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .v9-extrack-campaign__code {
    display: inline-block;
    background: #035740;
    color: white;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 4px 12px;
    border-radius: 4px;
    width: fit-content;
  }

  /* Journey Circle */
  .v9-journey-circle {
    width: 300px;
    height: 300px;
    position: relative;
  }

  .v9-journey-svg {
    width: 100%;
    height: 100%;
  }

  .v9-journey-path {
    transition: stroke-dashoffset 1.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .v9-ch6.v9-chapter--active .v9-journey-path {
    stroke-dashoffset: 0;
  }

  .v9-journey-nodes circle {
    transition: r 0.3s ease;
  }

  .v9-journey-nodes g:hover circle {
    r: 13;
  }

  .v9-journey-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .v9-journey-center span {
    font-size: 11px;
    font-weight: 700;
    color: #3D3AD3;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }


  /* ═══════════════════════════════════════════════════════════
     CHAPTER 7 STYLES — Platform Overview (Dark)
     ═══════════════════════════════════════════════════════════ */
  .v9-ch7__bg {
    background: #0f172a;
    padding: 80px 0;
  }

  .v9-ch7__content {
    text-align: center;
  }

  .v9-ch7__title {
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: white;
    margin-bottom: 48px;
  }

  /* Flow diagram */
  .v9-flow-diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 64px;
    overflow-x: auto;
    padding: 16px 0;
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .v9-flow-diagram { flex-wrap: nowrap; }
  }

  .v9-flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 0 8px;
  }

  .v9-flow-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(61, 58, 211, 0.3);
  }

  .v9-flow-step span {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    white-space: nowrap;
  }

  .v9-flow-line {
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, rgba(61, 58, 211, 0.4), rgba(3, 87, 64, 0.4));
    flex-shrink: 0;
    margin-top: -18px;
  }

  @media (max-width: 767px) {
    .v9-flow-line { width: 20px; }
  }

  /* Product pillars */
  .v9-pillars {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 64px;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 768px) {
    .v9-pillars { grid-template-columns: repeat(3, 1fr); }
  }

  .v9-pillar {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 28px 24px;
    text-align: left;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .v9-pillar::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent 50%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .v9-pillar:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-4px);
  }

  .v9-pillar--convert:hover { border-color: rgba(61, 58, 211, 0.3); }
  .v9-pillar--engage:hover { border-color: rgba(61, 58, 211, 0.3); }
  .v9-pillar--retain:hover { border-color: rgba(3, 87, 64, 0.3); }

  .v9-pillar__header {
    margin-bottom: 20px;
  }

  .v9-pillar__icon {
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 12px;
  }

  .v9-pillar__title {
    font-size: 20px;
    font-weight: 700;
    color: white;
    margin-bottom: 4px;
  }

  .v9-pillar__stat {
    font-size: 13px;
    font-weight: 600;
    color: #FFC943;
  }

  .v9-pillar__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .v9-pillar__features li {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    padding-left: 18px;
    position: relative;
  }

  .v9-pillar__features li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 7px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
  }

  /* Logo bar */
  .v9-logo-bar {
    text-align: center;
  }

  .v9-logo-bar__label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.3);
    display: block;
    margin-bottom: 24px;
  }

  .v9-logo-bar__logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 32px;
    opacity: 0.4;
  }

  .v9-logo-bar__logos img {
    height: 24px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .v9-logo--invert {
    filter: brightness(0) invert(1) !important;
  }


  /* ═══════════════════════════════════════════════════════════
     CHAPTER 8 STYLES — CTA
     ═══════════════════════════════════════════════════════════ */
  .v9-ch8 {
    background: var(--surface);
  }

  .v9-ch8__inner {
    position: relative;
    padding: clamp(5rem, 10vw, 10rem) 0;
    overflow: hidden;
  }

  .v9-ch8__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #f8f7ff 0%, #ecfdf5 30%, #fefce8 60%, #f0f0ff 100%);
    opacity: 0.6;
  }

  .v9-ch8__content {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .v9-ch8__title {
    font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .v9-ch8__sub {
    font-size: clamp(1rem, 0.5vw + 0.75rem, 1.125rem);
    color: var(--ink-secondary);
    line-height: 1.7;
    margin-bottom: 36px;
  }

  .v9-ch8__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
  }

  .v9-cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: #3D3AD3;
    color: white;
    font-size: 16px;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 4px 20px rgba(61, 58, 211, 0.3), 0 0 0 0 rgba(61, 58, 211, 0);
    position: relative;
    overflow: hidden;
  }

  .v9-cta-btn-primary::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 14px;
    padding: 2px;
    background: linear-gradient(135deg, #6366f1, #3D3AD3, #035740, #3D3AD3);
    background-size: 300% 300%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: v9-border-glow 4s ease-in-out infinite;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .v9-cta-btn-primary:hover::before { opacity: 1; }

  .v9-cta-btn-primary:hover {
    box-shadow: 0 8px 32px rgba(61, 58, 211, 0.4), 0 0 0 4px rgba(61, 58, 211, 0.1);
    transform: translateY(-2px);
  }

  @keyframes v9-border-glow {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .v9-cta-btn-secondary {
    font-size: 15px;
    font-weight: 600;
    color: #3D3AD3;
    text-decoration: none;
    transition: color 0.2s;
  }

  .v9-cta-btn-secondary:hover { color: #312dba; }

  .v9-ch8__trust {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
  }

  .v9-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-muted);
  }

  .v9-trust-badge svg {
    color: var(--ink-muted);
  }


  /* ═══════════════════════════════════════════════════════════
     REDUCED MOTION
     ═══════════════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .v9-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .v9-gradient-text,
    .v9-gradient-text-green,
    .v9-gradient-text-amber,
    .v9-gradient-text-teal,
    .v9-gradient-text-multi {
      animation: none;
    }

    .v9-confetti { animation: none !important; display: none; }

    .v9-journey-path { transition: none; }

    .v9-cta-btn-primary::before { animation: none; }

    .v9-returns-retention__pulse { animation: none; }

    .v9-mock-card {
      transform: none;
    }

    .v9-mock-card:hover {
      transform: none;
    }

    .v9-track-progress__fill,
    .v9-track-progress__truck {
      transition: none;
    }
  }


  /* ═══════════════════════════════════════════════════════════
     RESPONSIVE FINE-TUNING
     ═══════════════════════════════════════════════════════════ */
  @media (max-width: 1023px) {
    .v9-ch__scroll-space {
      min-height: auto;
    }

    .v9-ch__sticky {
      position: relative;
      padding: 100px 0 60px;
    }

    .v9-mock-card {
      transform: none;
    }

    .v9-mock-card:hover {
      transform: translateY(-4px);
    }

    .v9-push-notification {
      position: relative;
      top: auto;
      right: auto;
      margin: 16px auto 0;
    }
  }

  /* Utility: screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>


<!-- ═══════════════════════════════════════════════════════════════════
     SCRIPT — Scroll mechanics, IntersectionObserver, interactions
     ═══════════════════════════════════════════════════════════════════ -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // ─── Reveal on scroll ────────────────────────────────────
    const reveals = document.querySelectorAll(".v9-reveal");
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
          }
        });
      },
      { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
    );

    reveals.forEach((el) => {
      if (prefersReducedMotion) {
        el.classList.add("visible");
      } else {
        revealObserver.observe(el);
      }
    });

    // ─── Chapter tracking (progress dots + active states) ────
    const chapters = document.querySelectorAll(".v9-chapter");
    const dots = document.querySelectorAll(".v9-progress__dot");

    const chapterObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const chapterNum = entry.target.dataset.chapter;
          if (entry.isIntersecting) {
            // Activate chapter
            entry.target.classList.add("v9-chapter--active");
            // Update progress dots
            dots.forEach((dot) => {
              dot.classList.toggle("active", dot.dataset.chapter === chapterNum);
            });
          }
        });
      },
      { threshold: 0.3 }
    );

    chapters.forEach((ch) => chapterObserver.observe(ch));

    // Dot click scrolling
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const target = document.getElementById(`chapter${dot.dataset.chapter}`);
        if (target) {
          target.scrollIntoView({ behavior: prefersReducedMotion ? "auto" : "smooth" });
        }
      });
    });

    // ─── Chapter 1: Delivery widget interaction ──────────────
    const zipBtn = document.getElementById("zipBtn");
    const zipInput = document.getElementById("zipInput") as HTMLInputElement | null;
    const deliveryDate = document.getElementById("deliveryDate");
    const urgencyTimer = document.getElementById("urgencyTimer");

    const dateMap: Record<string, { day: string; speed: string }> = {
      "10001": { day: "Wednesday, April 8", speed: "FREE Standard Shipping" },
      "90210": { day: "Thursday, April 9", speed: "FREE Standard Shipping" },
      "60601": { day: "Wednesday, April 8", speed: "FREE Standard Shipping" },
      "30301": { day: "Tuesday, April 7", speed: "Express Shipping — $4.99" },
      "98101": { day: "Friday, April 10", speed: "FREE Standard Shipping" },
    };

    if (zipBtn && zipInput && deliveryDate) {
      zipBtn.addEventListener("click", () => {
        const zip = zipInput.value.trim();
        const data = dateMap[zip] || { day: "Thursday, April 9", speed: "FREE Standard Shipping" };
        const dayEl = deliveryDate.querySelector(".v9-dw-day");
        const speedEl = deliveryDate.querySelector(".v9-dw-speed");
        if (dayEl) dayEl.textContent = data.day;
        if (speedEl) speedEl.textContent = data.speed;
      });
    }

    // Countdown timer (cosmetic)
    if (urgencyTimer) {
      let mins = 107;
      setInterval(() => {
        mins = Math.max(0, mins - 1);
        const h = Math.floor(mins / 60);
        const m = mins % 60;
        urgencyTimer.textContent = `${h}h ${String(m).padStart(2, "0")}m`;
      }, 60000);
    }

    // ─── Chapter 3: Truck scroll animation ───────────────────
    if (!prefersReducedMotion) {
      const ch3 = document.getElementById("chapter3");
      const trackFill = document.getElementById("trackFill");
      const trackTruck = document.getElementById("trackTruck");

      if (ch3 && trackFill && trackTruck) {
        const updateTruck = () => {
          const rect = ch3.getBoundingClientRect();
          const vh = window.innerHeight;
          // Compute scroll progress through the chapter
          const totalScroll = rect.height - vh;
          const scrolled = -rect.top;
          const progress = Math.max(0, Math.min(1, scrolled / totalScroll));
          const pct = 20 + progress * 75; // 20% to 95%
          trackFill.style.width = `${pct}%`;
          trackTruck.style.left = `${pct}%`;
        };

        window.addEventListener("scroll", updateTruck, { passive: true });
      }
    }

    // ─── Chapter 4: NPS stars interactivity ──────────────────
    const npsStars = document.querySelectorAll<HTMLButtonElement>(".v9-nps-star");
    npsStars.forEach((star) => {
      star.addEventListener("click", () => {
        const val = parseInt(star.dataset.star || "0", 10);
        npsStars.forEach((s) => {
          const sv = parseInt(s.dataset.star || "0", 10);
          s.classList.toggle("active", sv >= 4 && sv <= 5 ? sv <= val || sv >= val : sv <= val);
          // Re-evaluate: mark all up to clicked value
          s.classList.toggle("active", sv <= val);
        });
      });
    });

    // ─── Chapter 6: Journey circle animate on enter ──────────
    // (Handled by CSS .v9-chapter--active class from IntersectionObserver above)
  });
</script>
