<!-- ═══════════════════════════════════════════════════════════════════
     STYLES — All v9-* scoped CSS
     ═══════════════════════════════════════════════════════════════════ -->
<style>
  /* ── Base & Layout ─────────────────────────────────────────── */
  .v9-main {
    position: relative;
    overflow-x: hidden;
  }

  .v9-chapter {
    position: relative;
  }

  .v9-ch__scroll-space {
    min-height: 200vh;
    position: relative;
  }

  .v9-ch__sticky {
    position: sticky;
    top: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* ── Progress Indicator ────────────────────────────────────── */
  .v9-progress {
    position: fixed;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: none;
  }

  @media (min-width: 1024px) {
    .v9-progress { display: block; }
  }

  .v9-progress__track {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  .v9-progress__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--ink-muted);
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    padding: 0;
  }

  .v9-progress__dot.active {
    background: #3D3AD3;
    border-color: #3D3AD3;
    box-shadow: 0 0 0 4px rgba(61, 58, 211, 0.2);
    transform: scale(1.2);
  }

  .v9-progress__label {
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-secondary);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .v9-progress__dot:hover .v9-progress__label,
  .v9-progress__dot.active .v9-progress__label {
    opacity: 1;
  }

  /* ── Reveal Animation ──────────────────────────────────────── */
  .v9-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .v9-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Chapter Label ─────────────────────────────────────────── */
  .v9-chapter-label {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #3D3AD3;
    margin-bottom: 16px;
  }

  .v9-chapter-label--light {
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Section Title ─────────────────────────────────────────── */
  .v9-section-title {
    font-size: clamp(2.25rem, 4vw + 0.5rem, 3.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .v9-body-text {
    font-size: clamp(1rem, 0.5vw + 0.75rem, 1.125rem);
    line-height: 1.7;
    color: var(--ink-secondary);
    margin-bottom: 20px;
    max-width: 480px;
  }

  /* ── Gradient Text Variants ────────────────────────────────── */
  .v9-gradient-text {
    background: linear-gradient(135deg, #3D3AD3 0%, #6366f1 50%, #3D3AD3 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: v9-gradient-shift 4s ease-in-out infinite;
  }

  .v9-gradient-text-green {
    background: linear-gradient(135deg, #035740 0%, #0d9668 50%, #035740 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: v9-gradient-shift 4s ease-in-out infinite;
  }

  .v9-gradient-text-amber {
    background: linear-gradient(135deg, #d97706 0%, #FFC943 50%, #d97706 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: v9-gradient-shift 4s ease-in-out infinite;
  }

  .v9-gradient-text-teal {
    background: linear-gradient(135deg, #035740 0%, #14b8a6 50%, #035740 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: v9-gradient-shift 4s ease-in-out infinite;
  }

  .v9-gradient-text-multi {
    background: linear-gradient(135deg, #3D3AD3 0%, #035740 33%, #FFC943 66%, #3D3AD3 100%);
    background-size: 300% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: v9-gradient-shift-wide 6s ease-in-out infinite;
  }

  @keyframes v9-gradient-shift {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  @keyframes v9-gradient-shift-wide {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  /* ── Stat Numbers ──────────────────────────────────────────── */
  .v9-stat-number {
    display: block;
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #3D3AD3;
  }

  .v9-stat-number--green { color: #035740; }
  .v9-stat-number--amber { color: #d97706; }
  .v9-stat-number--teal { color: #0d9668; }

  .v9-stat-desc {
    display: block;
    font-size: 14px;
    color: var(--ink-secondary);
    margin-top: 4px;
  }

  .v9-stat-block {
    padding: 16px 0;
  }

  .v9-stat-block + .v9-stat-block {
    border-top: 1px solid var(--line-subtle);
  }

  /* ── Floating Orbs ─────────────────────────────────────────── */
  [class*="v9-orb"] {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
    pointer-events: none;
  }

  .v9-orb--purple-1 { width: 500px; height: 500px; background: #3D3AD3; top: -100px; right: -150px; }
  .v9-orb--purple-2 { width: 300px; height: 300px; background: #6366f1; bottom: -50px; left: -100px; opacity: 0.08; }
  .v9-orb--violet-1 { width: 400px; height: 400px; background: #7c3aed; top: 10%; left: -100px; }
  .v9-orb--blue-1 { width: 500px; height: 500px; background: #3D3AD3; top: -80px; left: -200px; opacity: 0.1; }
  .v9-orb--blue-2 { width: 300px; height: 300px; background: #0ea5e9; bottom: 0; right: -100px; opacity: 0.08; }
  .v9-orb--green-1 { width: 500px; height: 500px; background: #035740; top: -100px; right: -200px; opacity: 0.12; }
  .v9-orb--amber-1 { width: 400px; height: 400px; background: #FFC943; top: -50px; left: -150px; opacity: 0.12; }
  .v9-orb--amber-2 { width: 300px; height: 300px; background: #f59e0b; bottom: -100px; right: -100px; opacity: 0.08; }
  .v9-orb--teal-1 { width: 500px; height: 500px; background: #14b8a6; top: -100px; left: -150px; opacity: 0.1; }
  .v9-orb--cta-1 { width: 600px; height: 600px; background: #3D3AD3; top: -200px; left: -200px; opacity: 0.12; }
  .v9-orb--cta-2 { width: 400px; height: 400px; background: #035740; bottom: -150px; right: -150px; opacity: 0.1; }

  /* ── Mock Card Base ────────────────────────────────────────── */
  .v9-mock-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 16px;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.05),
      0 20px 40px -8px rgba(0, 0, 0, 0.08),
      0 0 0 1px rgba(0, 0, 0, 0.03);
    overflow: hidden;
    transition: box-shadow 0.4s ease, transform 0.4s ease;
    transform: perspective(1000px) rotateY(-2deg) rotateX(1deg);
  }

  .v9-mock-card:hover {
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.05),
      0 25px 50px -12px rgba(0, 0, 0, 0.12),
      0 0 0 1px rgba(61, 58, 211, 0.1),
      0 0 40px -8px rgba(61, 58, 211, 0.08);
    transform: perspective(1000px) rotateY(-1deg) rotateX(0.5deg) translateY(-4px);
  }


  /* ═══════════════════════════════════════════════════════════
     CHAPTER 1 STYLES — Product Page / Delivery Date
     ═══════════════════════════════════════════════════════════ */
  .v9-ch1 {
    background: var(--surface);
  }

  .v9-ch1 .v9-ch__sticky {
    padding-top: 100px;
  }

  .v9-ch1__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .v9-ch1__layout { grid-template-columns: 1fr 420px; gap: 64px; }
  }

  .v9-ch1__headline {
    font-size: clamp(2.75rem, 5vw + 0.5rem, 4.5rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .v9-ch1__sub {
    font-size: clamp(1.05rem, 0.5vw + 0.75rem, 1.2rem);
    line-height: 1.7;
    color: var(--ink-secondary);
    margin-bottom: 28px;
    max-width: 500px;
  }

  .v9-ch1__stat {
    margin-bottom: 24px;
  }

  .v9-ch1__note {
    font-size: 15px;
    color: var(--ink-secondary);
    line-height: 1.65;
    max-width: 460px;
  }

  /* Product card mockup */
  .v9-mock-card--product {
    max-width: 420px;
    margin: 0 auto;
  }

  .v9-product-img {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    padding: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .v9-product-img__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: var(--ink-muted);
  }

  .v9-product-img__placeholder span {
    font-size: 13px;
    font-weight: 500;
  }

  .v9-product-details {
    padding: 20px 24px 24px;
  }

  .v9-product-brand {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    margin-bottom: 4px;
  }

  .v9-product-name {
    font-size: 18px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .v9-product-price {
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .v9-product-rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .v9-stars {
    color: #FFC943;
    font-size: 14px;
  }

  .v9-rating-count {
    font-size: 13px;
    color: var(--ink-muted);
  }

  /* Delivery Date Widget */
  .v9-delivery-widget {
    background: #f8f7ff;
    border: 1px solid rgba(61, 58, 211, 0.15);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 20px;
  }

  .v9-dw-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .v9-dw-title {
    font-size: 13px;
    font-weight: 600;
    color: #3D3AD3;
  }

  .v9-dw-date {
    margin-bottom: 10px;
  }

  .v9-dw-day {
    display: block;
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
  }

  .v9-dw-speed {
    display: block;
    font-size: 12px;
    color: #035740;
    font-weight: 500;
    margin-top: 2px;
  }

  .v9-dw-urgency {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--ink-secondary);
    margin-bottom: 12px;
  }

  .v9-dw-zip {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
  }

  .v9-dw-zip__input {
    flex: 1;
    padding: 6px 10px;
    border: 1px solid var(--line);
    border-radius: 6px;
    font-size: 13px;
    background: white;
    color: var(--ink);
  }

  .v9-dw-zip__input:focus {
    outline: none;
    border-color: #3D3AD3;
    box-shadow: 0 0 0 3px rgba(61, 58, 211, 0.1);
  }

  .v9-dw-zip__btn {
    padding: 6px 14px;
    background: #3D3AD3;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .v9-dw-zip__btn:hover { background: #312dba; }

  .v9-dw-powered {
    font-size: 11px;
    color: var(--ink-muted);
  }

  .v9-product-atc {
    width: 100%;
    padding: 14px;
    background: var(--ink);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .v9-product-atc:hover { background: #1e293b; }


  /* ═══════════════════════════════════════════════════════════
     CHAPTER 2 STYLES — Order Confirmation Email
     ═══════════════════════════════════════════════════════════ */
  .v9-ch2 {
    background: linear-gradient(180deg, var(--surface) 0%, #f0eeff 100%);
  }

  .v9-ch2__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .v9-ch2__layout { grid-template-columns: 400px 1fr; gap: 64px; }
  }

  .v9-ch2__stats {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .v9-mock-card--email {
    max-width: 400px;
    margin: 0 auto;
    transform: perspective(1000px) rotateY(2deg) rotateX(1deg);
  }

  .v9-mock-card--email:hover {
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.05),
      0 25px 50px -12px rgba(0, 0, 0, 0.12),
      0 0 0 2px rgba(61, 58, 211, 0.2),
      0 0 60px -8px rgba(61, 58, 211, 0.1);
    transform: perspective(1000px) rotateY(1deg) rotateX(0.5deg) translateY(-4px);
  }

  .v9-email-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--line-subtle);
  }

  .v9-email-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }

  .v9-email-logo__icon,
  .v9-track-logo__icon,
  .v9-returns-logo__icon,
  .v9-push-icon__inner {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--ink);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
  }

  .v9-email-hero {
    background: linear-gradient(135deg, #3D3AD3 0%, #6366f1 100%);
    padding: 28px 20px;
    text-align: center;
  }

  .v9-email-check {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }

  .v9-email-hero__title {
    font-size: 18px;
    font-weight: 700;
    color: white;
    margin-bottom: 4px;
  }

  .v9-email-hero__sub {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.7);
  }

  .v9-email-body {
    padding: 20px;
  }

  .v9-email-item {
    display: flex;
    gap: 12px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line-subtle);
    margin-bottom: 16px;
  }

  .v9-email-item__img {
    width: 52px;
    height: 52px;
    border-radius: 8px;
    background: var(--surface-sunken);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .v9-email-item__name {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .v9-email-item__meta {
    font-size: 12px;
    color: var(--ink-muted);
  }

  .v9-email-delivery {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--ink-secondary);
    margin-bottom: 16px;
  }

  .v9-email-campaign {
    background: linear-gradient(135deg, #f8f7ff 0%, #eef2ff 100%);
    border: 1px solid rgba(61, 58, 211, 0.1);
    border-radius: 10px;
    padding: 14px 16px;
    text-align: center;
  }

  .v9-email-campaign__badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #3D3AD3;
    background: rgba(61, 58, 211, 0.08);
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 6px;
  }

  .v9-email-campaign__text {
    font-size: 14px;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .v9-email-campaign__cta {
    font-size: 13px;
    font-weight: 600;
    color: #3D3AD3;
    cursor: pointer;
  }

  .v9-email-footer {
    padding: 16px 20px;
    border-top: 1px solid var(--line-subtle);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .v9-email-footer__track {
    font-size: 13px;
    font-weight: 600;
    color: #3D3AD3;
    cursor: pointer;
  }

  .v9-email-footer__help {
    font-size: 12px;
    color: var(--ink-muted);
  }

  .v9-email-footer__help span {
    color: #3D3AD3;
    cursor: pointer;
  }


  /* ═══════════════════════════════════════════════════════════
     CHAPTER 3 STYLES — Tracking Page
     ═══════════════════════════════════════════════════════════ */
  .v9-ch3 {
    background: linear-gradient(180deg, #f0eeff 0%, #e8edff 100%);
  }

  .v9-ch3__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .v9-ch3__layout { grid-template-columns: 1fr 440px; gap: 64px; }
  }

  .v9-ch3__stats {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .v9-mock-card--tracking {
    max-width: 440px;
    margin: 0 auto;
  }

  .v9-track-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--line-subtle);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .v9-track-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }

  .v9-track-order {
    font-size: 12px;
    color: var(--ink-muted);
  }

  .v9-track-status {
    padding: 20px;
    text-align: center;
  }

  .v9-track-status__badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .v9-track-status__badge--transit {
    background: rgba(61, 58, 211, 0.1);
    color: #3D3AD3;
  }

  .v9-track-status__badge--delivered {
    background: rgba(3, 87, 64, 0.1);
    color: #035740;
  }

  .v9-track-status__eta {
    font-size: 14px;
    color: var(--ink-secondary);
  }

  /* Progress bar with truck */
  .v9-track-progress {
    padding: 0 20px 20px;
  }

  .v9-track-progress__bar {
    position: relative;
    height: 6px;
    background: var(--line);
    border-radius: 3px;
    margin-bottom: 12px;
  }

  .v9-track-progress__fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: linear-gradient(90deg, #3D3AD3, #6366f1);
    border-radius: 3px;
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .v9-track-progress__truck {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #3D3AD3;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(61, 58, 211, 0.3);
    transition: left 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 2;
  }

  .v9-track-progress__labels {
    display: flex;
    justify-content: space-between;
  }

  .v9-track-progress__label {
    font-size: 11px;
    color: var(--ink-muted);
    font-weight: 500;
  }

  .v9-track-progress__label.done { color: #3D3AD3; font-weight: 600; }
  .v9-track-progress__label.active { color: #3D3AD3; font-weight: 700; }

  /* Timeline */
  .v9-track-timeline {
    padding: 0 20px 20px;
  }

  .v9-timeline-item {
    display: flex;
    gap: 12px;
    padding: 10px 0;
    position: relative;
  }

  .v9-timeline-item + .v9-timeline-item {
    border-top: 1px solid var(--line-subtle);
  }

  .v9-timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--line);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .v9-timeline-item--done .v9-timeline-dot {
    background: #3D3AD3;
  }

  .v9-timeline-date {
    font-size: 11px;
    color: var(--ink-muted);
    margin-bottom: 2px;
  }

  .v9-timeline-text {
    font-size: 13px;
    color: var(--ink-secondary);
  }

  /* Campaign banner */
  .v9-track-campaign {
    margin: 0 20px 16px;
    background: linear-gradient(135deg, #f8f7ff, #eef2ff);
    border: 1px solid rgba(61, 58, 211, 0.1);
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .v9-track-campaign__text {
    font-size: 13px;
    color: var(--ink);
  }

  .v9-track-campaign__cta {
    font-size: 12px;
    font-weight: 600;
    color: #3D3AD3;
    white-space: nowrap;
    cursor: pointer;
  }

  /* Items in shipment */
  .v9-track-items {
    padding: 0 20px 20px;
  }

  .v9-track-items__title {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 10px;
  }

  .v9-track-item {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .v9-track-item__img {
    width: 40px;
    height: 40px;
    background: var(--surface-sunken);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .v9-track-item__name {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }

  .v9-track-item__meta {
    font-size: 11px;
    color: var(--ink-muted);
  }


  /* ═══════════════════════════════════════════════════════════
     CHAPTER 4 STYLES — Delivery + Confetti
     ═══════════════════════════════════════════════════════════ */
  .v9-ch4 {
    background: linear-gradient(180deg, #e8edff 0%, #ecfdf5 100%);
  }

  .v9-ch4__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .v9-ch4__layout { grid-template-columns: 420px 1fr; gap: 64px; }
  }

  .v9-ch4__mockup {
    position: relative;
  }

  .v9-mock-card--delivered {
    max-width: 400px;
    margin: 0 auto;
    text-align: center;
    padding: 32px 24px;
    transform: perspective(1000px) rotateY(2deg);
  }

  .v9-delivered-check {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(3, 87, 64, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
  }

  .v9-delivered-title {
    font-size: 24px;
    font-weight: 800;
    color: #035740;
    margin-bottom: 8px;
  }

  .v9-delivered-sub {
    font-size: 14px;
    color: var(--ink-secondary);
    margin-bottom: 24px;
  }

  /* NPS Survey */
  .v9-nps-survey {
    border-top: 1px solid var(--line-subtle);
    padding-top: 20px;
  }

  .v9-nps-question {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 12px;
  }

  .v9-nps-stars {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .v9-nps-star {
    font-size: 28px;
    color: var(--line);
    cursor: pointer;
    transition: color 0.2s, transform 0.2s;
    background: none;
    border: none;
    padding: 0;
  }

  .v9-nps-star.active {
    color: #FFC943;
  }

