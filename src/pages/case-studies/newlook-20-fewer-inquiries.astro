---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;
---

<Layout title="New Look Case Study - parcelLab" description="How New Look reduced WISMO inquiries by 20% with proactive, personalized post-purchase communications.">
  <Header client:load />
  <main>
    <!-- Hero -->
    <section class="section-generous rounded-b-[32px]" style="background: linear-gradient(135deg, #035740 0%, #023a2b 100%)">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-2xl">
            <a href={`${b}/case-studies/`} class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-white/60 transition-colors hover:text-white/90">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
              All case studies
            </a>
            <span class="mb-4 inline-block rounded-full border border-white/20 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.15em] text-white/60">
              Fashion & Retail
            </span>
            <h1 class="text-hero text-white">
              New Look reduces WISMO inquiries by 20%
            </h1>
            <p class="mt-5 max-w-xl text-lg font-light leading-relaxed text-white/70">
              How the leading UK fashion retailer strengthened customer loyalty through proactive, personalized post-purchase communications.
            </p>
          </div>

          <!-- Key stat card -->
          <div class="flex-shrink-0">
            <div class="rounded-2xl bg-white/10 p-10 text-center backdrop-blur-sm">
              <p class="text-6xl font-bold text-white">20%</p>
              <p class="mt-2 text-sm font-medium text-white/70">Fewer WISMO<br/>inquiries</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Company Overview -->
    <section class="section-standard border-b border-[var(--line)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto grid max-w-4xl gap-8 md:grid-cols-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--ink-muted)]">Company</p>
            <p class="mt-2 text-lg font-medium text-[var(--ink)]">New Look</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--ink-muted)]">Industry</p>
            <p class="mt-2 text-lg font-medium text-[var(--ink)]">Fashion & Luxury</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--ink-muted)]">Market</p>
            <p class="mt-2 text-lg font-medium text-[var(--ink)]">UK & Republic of Ireland</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Challenge -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">The Challenge</span>
          <h2 class="text-heading text-[var(--ink)]">Maintaining engagement and loyalty beyond checkout</h2>
          <div class="mt-6 space-y-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            <p>
              New Look, a leading fashion retailer operating in the value segment of clothing and footwear across the UK and Republic of Ireland, aimed to enhance their post-purchase experience to maintain customer engagement and strengthen brand loyalty.
            </p>
            <p>
              They recognized that timely, relevant communication throughout the purchase journey reduces support team strain while improving customer satisfaction. The retailer needed a post-purchase partner capable of delivering direct, personalized communications with the ability to enable multiple departments, streamline operations, increase efficiency, and enhance transparency.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">The Solution</span>
          <h2 class="text-heading text-[var(--ink)]">Proactive communication, personalized recommendations, and branded engagement</h2>
          <div class="mt-6 space-y-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            <p>
              parcelLab empowered New Look to take ownership of the post-purchase experience across three key dimensions -- reducing inquiry volume, driving additional revenue, and strengthening long-term customer relationships.
            </p>
          </div>

          <div class="mt-10 grid gap-6 sm:grid-cols-3">
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[#035740]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.2 8.4c.5.38.8.97.8 1.6v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 .8-1.6l8-6a2 2 0 0 1 2.4 0l8 6Z"/><path d="m22 10-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 10"/></svg>
              </div>
              <h3 class="font-semibold text-[var(--ink)]">Proactive communication</h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Customers receive timely, personalized order updates ensuring transparency and reducing WISMO inquiry volume significantly.</p>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[#3D3AD3]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>
              </div>
              <h3 class="font-semibold text-[var(--ink)]">Revenue growth</h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Leveraging purchase behavior data enables tailored product recommendations that drive additional revenue from existing customers.</p>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[#FFC943]/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#b8941f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
              </div>
              <h3 class="font-semibold text-[var(--ink)]">Brand loyalty</h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Direct, branded post-purchase communication maintains customer engagement beyond checkout, fostering long-term relationships.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Results -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">The Results</span>
          <h2 class="text-heading text-[var(--ink)]">Fewer inquiries, stronger engagement</h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-3">
          <div class="rounded-2xl bg-[#035740] p-8 text-center text-white">
            <p class="text-5xl font-bold">20%</p>
            <p class="mt-3 text-sm font-medium text-white/70">Reduction in WISMO inquiries</p>
          </div>
          <div class="rounded-2xl bg-[#3D3AD3] p-8 text-center text-white">
            <p class="text-5xl font-bold">&uarr;</p>
            <p class="mt-3 text-sm font-medium text-white/70">Improved email engagement metrics</p>
          </div>
          <div class="rounded-2xl bg-[var(--surface-dark)] p-8 text-center text-white">
            <p class="text-5xl font-bold">&uarr;</p>
            <p class="mt-3 text-sm font-medium text-white/70">Revenue growth through personalized recommendations</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Quote -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-6 opacity-30"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
          <blockquote class="text-heading text-[var(--ink)]">
            &ldquo;Our partnership with parcelLab will deliver seamless post-purchase interactions that keep our customers happy and engaged throughout their journey.&rdquo;
          </blockquote>
          <div class="mt-8">
            <p class="font-semibold text-[var(--ink)]">Nick Ormerod</p>
            <p class="mt-1 text-sm text-[var(--ink-secondary)]">Customer & Digital Director, New Look</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Second Quote -->
    <section class="section-standard">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 md:p-12">
          <p class="text-lg font-light leading-relaxed text-[var(--ink-secondary)]">
            &ldquo;This partnership creates a seamless post-purchase experience that reduces inquiries while strengthening customer relationships -- exactly what a modern retail brand needs to stand out.&rdquo;
          </p>
          <div class="mt-6">
            <p class="font-semibold text-[var(--ink)]">Sarah Hollington</p>
            <p class="mt-1 text-sm text-[var(--ink-secondary)]">Customer Success Manager, parcelLab</p>
          </div>
        </div>
      </div>
    </section>

    <InnerPageCTA
      title="Ready to strengthen your post-purchase loyalty?"
      description="See how parcelLab helps fashion retailers reduce WISMO, drive repeat purchases, and build lasting customer relationships."
    />
  </main>
  <Footer />
</Layout>
