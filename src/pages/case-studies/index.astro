---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import PageHero from "../../components/PageHero.astro";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const b = import.meta.env.BASE_URL;

interface CaseStudy {
  company: string;
  slug: string;
  stat: string;
  description: string;
  color: string;
  industry: string;
}

const caseStudies: CaseStudy[] = [
  {
    company: "Wyze",
    slug: "wyze",
    stat: "20% fewer WISMO inquiries",
    description: "Decreasing support burden via proactive post-purchase communications and unified shipment tracking.",
    color: "#3D3AD3",
    industry: "Electronics & Media",
  },
  {
    company: "True Classic",
    slug: "trueclassic-29-revenue-per-email",
    stat: "29% revenue growth per email",
    description: "Leveraging post-purchase messaging and branded tracking pages for repeat sales and reduced support tickets.",
    color: "#035740",
    industry: "Fashion & Apparel",
  },
  {
    company: "Farfetch",
    slug: "farfetch-79-return-to-website",
    stat: "79% return to website via tracking",
    description: "Maximizing engagement through consolidated luxury delivery experiences across 190+ countries.",
    color: "#3D3AD3",
    industry: "Fashion & Luxury",
  },
  {
    company: "New Look",
    slug: "newlook-20-fewer-inquiries",
    stat: "20% fewer WISMO inquiries",
    description: "Cutting customer service volume through proactive, personalized post-purchase communication.",
    color: "#035740",
    industry: "Fashion & Retail",
  },
  {
    company: "Conrad",
    slug: "conrad-self-service-returns",
    stat: "6,000+ man-hours saved",
    description: "Streamlining returns operations with a self-service portal that reduces support costs and paper waste.",
    color: "#3D3AD3",
    industry: "Electronics & Media",
  },
  {
    company: "Caraway Home",
    slug: "",
    stat: "Package theft reduced to 1%",
    description: "Enhancing delivery security and customer confidence through proactive tracking and notifications.",
    color: "#035740",
    industry: "Home & Kitchen",
  },
  {
    company: "PartyLite",
    slug: "",
    stat: "9% revenue growth",
    description: "Driving engagement and repeat purchases through branded embedded tracking pages.",
    color: "#3D3AD3",
    industry: "Home & Lifestyle",
  },
  {
    company: "Hugo Boss",
    slug: "",
    stat: "Personalized communications",
    description: "Strengthening customer relationships through tailored post-purchase messaging and loyalty building.",
    color: "#035740",
    industry: "Fashion & Luxury",
  },
  {
    company: "ALDI ONLINESHOP",
    slug: "",
    stat: "8M clicks back to website",
    description: "Converting tracking interactions into repeat visits and sustained customer engagement.",
    color: "#3D3AD3",
    industry: "Grocery & Retail",
  },
  {
    company: "Philipp Plein",
    slug: "",
    stat: "Branded delivery updates",
    description: "Elevating brand perception during the delivery phase with bespoke post-purchase communications.",
    color: "#035740",
    industry: "Fashion & Luxury",
  },
  {
    company: "PETER HAHN",
    slug: "",
    stat: "61% email open rate",
    description: "Achieving industry-leading email engagement metrics through optimized post-purchase communications.",
    color: "#3D3AD3",
    industry: "Fashion & Retail",
  },
  {
    company: "MediaMarktSaturn",
    slug: "",
    stat: "2M+ quarterly touchpoints",
    description: "Creating continuous customer engagement across the entire delivery lifecycle at scale.",
    color: "#035740",
    industry: "Electronics & Media",
  },
];
---

<Layout title="Case Studies - parcelLab" description="See how leading brands use parcelLab to transform their post-purchase experience, reduce support costs, and drive revenue growth.">
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Case Studies"
      title="Customer success stories"
      description="See how leading brands use parcelLab to transform their post-purchase experience, reduce WISMO inquiries, and turn every delivery into a revenue opportunity."
      dark
    />

    <!-- Case Studies Grid -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <!-- Filter pills -->
        <div class="mb-12 flex flex-wrap items-center gap-3">
          <span class="rounded-full bg-[var(--ink)] px-5 py-2 text-sm font-medium text-white">All</span>
          <span class="rounded-full border border-[var(--line)] px-5 py-2 text-sm font-medium text-[var(--ink-secondary)] transition-colors hover:border-[var(--ink-muted)] cursor-pointer">Fashion & Luxury</span>
          <span class="rounded-full border border-[var(--line)] px-5 py-2 text-sm font-medium text-[var(--ink-secondary)] transition-colors hover:border-[var(--ink-muted)] cursor-pointer">Electronics & Media</span>
          <span class="rounded-full border border-[var(--line)] px-5 py-2 text-sm font-medium text-[var(--ink-secondary)] transition-colors hover:border-[var(--ink-muted)] cursor-pointer">Home & Lifestyle</span>
        </div>

        <!-- Grid -->
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {caseStudies.map((study) => {
            const href = study.slug
              ? `${b}/case-studies/${study.slug}/`
              : `${b}/case-studies/`;
            const isExternal = !study.slug;
            return (
              <a
                href={href}
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
                class="group relative flex flex-col justify-between overflow-hidden rounded-2xl p-8 min-h-[320px] text-white transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
                style={`background: ${study.color}`}
              >
                {/* Subtle gradient overlay */}
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-white/[0.08] to-transparent" />

                <div class="relative z-10">
                  {/* Industry tag */}
                  <span class="mb-4 inline-block rounded-full border border-white/20 px-3 py-1 text-xs font-medium text-white/70">
                    {study.industry}
                  </span>

                  {/* Company */}
                  <h3 class="text-2xl font-semibold tracking-tight">
                    {study.company}
                  </h3>

                  {/* Description */}
                  <p class="mt-3 text-sm leading-relaxed text-white/70">
                    {study.description}
                  </p>
                </div>

                <div class="relative z-10 mt-8 flex items-end justify-between">
                  {/* Key stat */}
                  <div class="rounded-xl bg-white/10 px-4 py-3 backdrop-blur-sm">
                    <p class="text-lg font-bold leading-tight">{study.stat}</p>
                  </div>

                  {/* Arrow */}
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-all group-hover:bg-white/20">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5">
                      <path d="M5 12h14"/>
                      <path d="m12 5 7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <InnerPageCTA
      title="Ready to write your success story?"
      description="Join 1,000+ brands using parcelLab to transform their post-purchase experience into a competitive advantage."
    />
  </main>
  <Footer />
</Layout>
