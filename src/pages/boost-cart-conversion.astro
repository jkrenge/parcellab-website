---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Boost cart conversions with our software - parcelLab"
  description="Learn how you can boost cart conversions and achieve seamless order protection with parcelLab's cart conversion software."
>
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Convert"
      title="Turn hesitation into cart conversions"
      description="Boost cart conversions, eliminate doubt, and build trust with AI-powered predictive delivery dates and seamless order protection."
      ctaText="Book a demo"
      ctaHref={`${import.meta.env.BASE_URL}/live-demo/`}
      secondaryCtaText="See how it works"
      secondaryCtaHref={`${import.meta.env.BASE_URL}/live-demo/`}
    />

    <!-- Problem Statement -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="text-display text-[var(--ink)]">Is delivery uncertainty costing you customers?</h2>
          <p class="mt-5 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            When customers feel uncertain or disappointed, they abandon carts and leave.
            The solution is setting accurate expectations, offering delivery choices, and providing reassurance through order protection.
          </p>
        </div>
      </div>
    </section>

    <!-- Stats Banner -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
          <div class="text-center">
            <div class="text-4xl font-semibold text-[#3D3AD3] md:text-5xl">15%</div>
            <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">Faster checkout times</p>
          </div>
          <div class="text-center">
            <div class="text-4xl font-semibold text-[#3D3AD3] md:text-5xl">29%</div>
            <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">Higher cart conversion</p>
          </div>
          <div class="text-center">
            <div class="text-4xl font-semibold text-[#3D3AD3] md:text-5xl">1B+</div>
            <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">Global shipment dataset</p>
          </div>
          <div class="text-center">
            <div class="text-4xl font-semibold text-[#3D3AD3] md:text-5xl">550+</div>
            <p class="mt-2 text-sm font-medium text-[var(--ink-secondary)]">Carrier integrations</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Benefits Grid -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto mb-16 max-w-2xl text-center">
          <h2 class="text-display text-[var(--ink)]">How parcelLab drives conversion</h2>
        </div>
        <div class="grid gap-8 md:grid-cols-2">
          <!-- Reduce Cart Abandonment -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Reduce Cart Abandonment</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Eliminate purchase hesitation with AI-powered, real-time delivery predictions. Brands report 15% faster checkout times when customers know exactly when their order will arrive.
            </p>
          </div>
          <!-- Drive Higher Conversion -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Drive Higher Conversion</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Increase confidence through order protection coverage. Documented 29% higher cart conversion rates when customers feel secure about their purchase and delivery.
            </p>
          </div>
          <!-- Deliver Choice & Transparency -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/15">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Deliver Choice & Transparency</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Display multiple shipping options dynamically across product pages, cart, and checkout. Give customers the flexibility to choose the delivery option that works best for them.
            </p>
          </div>
          <!-- Minimize Support Burden -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Minimize Support Burden</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Proactive delivery expectations reduce WISMO inquiries. Streamlined claims resolution means your support team can focus on what matters most.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution: Predictive Delivery Promises -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div>
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Delivery Promises</span>
            <h2 class="text-heading text-[var(--ink)]">Set predictive delivery promises</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              AI-driven delivery dates that update in real-time. Get zip-code-level estimates powered by a dataset of over 1 billion global shipments, integrated seamlessly across PDPs, checkout, and your OMS.
            </p>
            <ul class="mt-8 space-y-4">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">AI-powered real-time delivery date predictions</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Zip-code-level accuracy across regions</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Seamless integration across PDPs, checkout, and OMS</span>
              </li>
            </ul>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-10">
            <div class="flex flex-col items-center text-center">
              <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-[#3D3AD3]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div class="text-sm font-medium text-[var(--ink-muted)]">Estimated Delivery</div>
              <div class="mt-2 text-2xl font-semibold text-[var(--ink)]">Wednesday, Apr 5</div>
              <div class="mt-1 text-sm text-[#035740]">On time &mdash; 92% confidence</div>
              <div class="mt-6 w-full rounded-xl bg-[var(--surface-sunken)] p-4">
                <div class="flex items-center justify-between text-sm">
                  <span class="text-[var(--ink-muted)]">Standard shipping</span>
                  <span class="font-medium text-[var(--ink)]">3&ndash;5 days</span>
                </div>
                <div class="mt-3 flex items-center justify-between text-sm">
                  <span class="text-[var(--ink-muted)]">Express shipping</span>
                  <span class="font-medium text-[var(--ink)]">1&ndash;2 days</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution: Order Protection -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="order-2 md:order-1 rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-10">
            <div class="flex flex-col items-center text-center">
              <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-[#035740]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div class="text-sm font-medium text-[var(--ink-muted)]">Order Protection</div>
              <div class="mt-2 text-2xl font-semibold text-[var(--ink)]">Your order is protected</div>
              <div class="mt-1 text-sm text-[#035740]">Coverage against lost, stolen & damaged packages</div>
              <div class="mt-6 w-full space-y-3">
                <div class="flex items-center gap-3 rounded-xl bg-[var(--surface-sunken)] p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-[var(--ink-secondary)]">Instant issue resolution</span>
                </div>
                <div class="flex items-center gap-3 rounded-xl bg-[var(--surface-sunken)] p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-[var(--ink-secondary)]">Branded self-service portal</span>
                </div>
                <div class="flex items-center gap-3 rounded-xl bg-[var(--surface-sunken)] p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-[var(--ink-secondary)]">Proactive customer updates</span>
                </div>
              </div>
            </div>
          </div>
          <div class="order-1 md:order-2">
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">Order Protection</span>
            <h2 class="text-heading text-[var(--ink)]">Protect your order</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Give customers optional protection against lost, stolen, or damaged packages. Provide instant issue resolution through a branded portal, with proactive updates every step of the way.
            </p>
            <ul class="mt-8 space-y-4">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Optional package protection at checkout</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Instant claims resolution through branded portal</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]">Proactive customer communication throughout</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="#3D3AD3" opacity="0.15" class="mx-auto mb-6"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
          <blockquote class="text-xl font-light leading-relaxed text-[var(--ink)] md:text-2xl">
            &ldquo;parcelLab works quietly in the background, highlighting our brand. The prediction feature has boosted orders.&rdquo;
          </blockquote>
          <div class="mt-6">
            <div class="font-medium text-[var(--ink)]">Sebastian H.</div>
            <div class="text-sm text-[var(--ink-muted)]">LocalHeroBox</div>
          </div>
        </div>
      </div>
    </section>

    <!-- G2 Recognition -->
    <section class="section-standard">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="flex flex-col items-center gap-8 md:flex-row md:justify-center md:gap-16">
          <div class="text-center">
            <div class="text-3xl font-semibold text-[var(--ink)]">150+</div>
            <div class="mt-1 text-sm text-[var(--ink-muted)]">G2 Reviews</div>
          </div>
          <div class="hidden h-12 w-px bg-[var(--line)] md:block"></div>
          <div class="text-center">
            <div class="text-lg font-semibold text-[var(--ink)]">G2 Leader</div>
            <div class="mt-1 text-sm text-[var(--ink-muted)]">in Post-Purchase</div>
          </div>
          <div class="hidden h-12 w-px bg-[var(--line)] md:block"></div>
          <div class="text-center">
            <div class="text-lg font-semibold text-[var(--ink)]">Top 50</div>
            <div class="mt-1 text-sm text-[var(--ink-muted)]">Supply Chain & Logistics Software 2025</div>
          </div>
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
