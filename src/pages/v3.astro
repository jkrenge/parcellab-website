---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";
const b = import.meta.env.BASE_URL;
---

<Layout title="parcelLab - Predictability Drives Profitability" description="Deliver accurate promises, proactive updates, and smart returns. parcelLab's AI-powered post-purchase platform drives profitability for 700+ leading brands.">
  <Header client:load />
  <main>

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 1 — HERO
         ═══════════════════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden" style="background: linear-gradient(180deg, #ffffff 0%, #f8f7ff 100%);">
      <div class="container-pl section-generous">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
          <!-- Left column -->
          <div class="max-w-xl">
            <h1 class="v3-hero-entrance v3-stagger-1" style="font-size: clamp(2.75rem, 5vw, 4.5rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.035em;">
              Predictability<br />drives <span class="v3-gradient-text">profitability</span>
            </h1>

            <ul class="mt-8 flex flex-col gap-4 v3-hero-entrance v3-stagger-2">
              <li class="flex items-start gap-3 text-[var(--ink-secondary)]" style="font-size: clamp(0.95rem, 0.5vw + 0.8rem, 1.1rem);">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-[#035740]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Deliver accurate promises that convert 5% more carts
              </li>
              <li class="flex items-start gap-3 text-[var(--ink-secondary)]" style="font-size: clamp(0.95rem, 0.5vw + 0.8rem, 1.1rem);">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-[#035740]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Send proactive updates that reduce WISMO calls by 20%
              </li>
              <li class="flex items-start gap-3 text-[var(--ink-secondary)]" style="font-size: clamp(0.95rem, 0.5vw + 0.8rem, 1.1rem);">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-[#035740]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Turn returns into exchanges that retain 11% more revenue
              </li>
            </ul>

            <div class="mt-10 flex flex-wrap items-center gap-4 v3-hero-entrance v3-stagger-3">
              <a href="/contact-us/" class="inline-flex items-center gap-2 rounded-xl bg-[#3D3AD3] px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-[#3D3AD3]/25 transition-all duration-200 hover:bg-[#3230b8] hover:shadow-xl hover:shadow-[#3D3AD3]/30 hover:-translate-y-px active:translate-y-0">
                Book a demo
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
              <a href="/post-purchase-platform/" class="inline-flex items-center gap-2 text-sm font-medium text-[#3D3AD3] transition-colors hover:text-[#3230b8]">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z"/></svg>
                Watch the platform tour
              </a>
            </div>
          </div>

          <!-- Right column — floating UI mockup -->
          <div class="relative v3-hero-entrance v3-stagger-4">
            <div class="relative mx-auto max-w-md lg:max-w-none">
              <!-- Main tracking card -->
              <div class="rounded-2xl bg-white p-6 shadow-xl shadow-slate-200/60 ring-1 ring-[var(--line)]">
                <!-- Header -->
                <div class="flex items-center justify-between border-b border-[var(--line)] pb-4">
                  <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
                      <svg class="h-5 w-5 text-[#3D3AD3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25m-2.25 0h-2.25m0 0V6.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v3.75m-5.25 0h5.25"/></svg>
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-[var(--ink)]">Order #PL-29481</p>
                      <p class="text-xs text-[var(--ink-muted)]">Premium Wireless Headphones</p>
                    </div>
                  </div>
                  <span class="rounded-full bg-[#035740]/10 px-3 py-1 text-xs font-medium text-[#035740]">In Transit</span>
                </div>

                <!-- Progress bar -->
                <div class="mt-5">
                  <div class="flex items-center justify-between text-xs text-[var(--ink-muted)]">
                    <span>Shipped</span><span>In Transit</span><span>Out for Delivery</span><span>Delivered</span>
                  </div>
                  <div class="relative mt-2 h-2 rounded-full bg-[var(--surface-sunken)]">
                    <div class="absolute left-0 top-0 h-full w-[55%] rounded-full bg-gradient-to-r from-[#3D3AD3] to-[#7C3AED]"></div>
                  </div>
                </div>

                <!-- ETA -->
                <div class="mt-5 rounded-xl bg-[#f5f3ff] p-4">
                  <div class="flex items-center gap-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-[#3D3AD3]">
                      <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div>
                      <p class="text-xs text-[var(--ink-muted)]">Estimated Delivery</p>
                      <p class="text-sm font-semibold text-[var(--ink)]">Tomorrow, Apr 6 &middot; 2:00 - 5:00 PM</p>
                    </div>
                  </div>
                </div>

                <!-- Upsell banner -->
                <div class="mt-4 flex items-center gap-3 rounded-xl border border-[#FFC943]/30 bg-[#FFC943]/10 p-3">
                  <svg class="h-5 w-5 shrink-0 text-[#b8860b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
                  <p class="text-xs text-[#78570a]"><strong>Recommended:</strong> Protective Case &mdash; 15% off with your order</p>
                </div>
              </div>

              <!-- Floating notification card -->
              <div class="absolute -bottom-6 -left-8 rounded-xl bg-white p-4 shadow-lg shadow-slate-200/60 ring-1 ring-[var(--line)] max-[1024px]:hidden v3-float" style="animation-delay: 0.8s;">
                <div class="flex items-center gap-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#035740]/10">
                    <svg class="h-4 w-4 text-[#035740]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </div>
                  <div>
                    <p class="text-xs font-medium text-[var(--ink)]">SMS sent successfully</p>
                    <p class="text-[11px] text-[var(--ink-muted)]">Delivery update &middot; 2 min ago</p>
                  </div>
                </div>
              </div>

              <!-- Floating stat card -->
              <div class="absolute -right-6 -top-4 rounded-xl bg-white p-4 shadow-lg shadow-slate-200/60 ring-1 ring-[var(--line)] max-[1024px]:hidden v3-float" style="animation-delay: 1.2s;">
                <div class="flex items-center gap-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#3D3AD3]/10">
                    <svg class="h-4 w-4 text-[#3D3AD3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>
                  </div>
                  <div>
                    <p class="text-xs font-medium text-[var(--ink)]">Conversion rate</p>
                    <p class="text-lg font-bold text-[#3D3AD3]">+5.2%</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Logo bar -->
      <div class="border-t border-[var(--line)] bg-white/60 backdrop-blur-sm">
        <div class="container-pl py-8">
          <p class="mb-6 text-center text-sm font-medium text-[var(--ink-muted)]">Trusted by 700+ leading brands</p>
          <div class="relative overflow-hidden">
            <div class="flex animate-marquee items-center gap-16" style="width: max-content;">
              <img src={`${b}/images/logos/IKEA_Logo_Black.svg`} alt="IKEA" class="h-7 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Hugo-Boss.svg`} alt="Hugo Boss" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Dyson.svg`} alt="Dyson" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Puma.svg`} alt="Puma" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Farfetch.svg`} alt="Farfetch" class="h-5 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/JohnLewis-1.svg`} alt="John Lewis" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/True-Classic-1.svg`} alt="True Classic" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Urban-Outfitters-1.svg`} alt="Urban Outfitters" class="h-5 w-auto opacity-40 grayscale" loading="lazy" />
              <!-- Duplicate for seamless loop -->
              <img src={`${b}/images/logos/IKEA_Logo_Black.svg`} alt="IKEA" class="h-7 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Hugo-Boss.svg`} alt="Hugo Boss" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Dyson.svg`} alt="Dyson" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Puma.svg`} alt="Puma" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Farfetch.svg`} alt="Farfetch" class="h-5 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/JohnLewis-1.svg`} alt="John Lewis" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/True-Classic-1.svg`} alt="True Classic" class="h-6 w-auto opacity-40 grayscale" loading="lazy" />
              <img src={`${b}/images/brands/Urban-Outfitters-1.svg`} alt="Urban Outfitters" class="h-5 w-auto opacity-40 grayscale" loading="lazy" />
            </div>
            <!-- Fade edges -->
            <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-white/80 to-transparent"></div>
            <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-white/80 to-transparent"></div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 2 — INTELLIGENT PERSONALIZATION (TABBED)
         ═══════════════════════════════════════════════════════════════ -->
    <section class="bg-[var(--surface)] section-generous">
      <div class="container-pl">
        <div class="mx-auto max-w-3xl text-center v3-reveal">
          <h2 class="text-display text-[var(--ink)]">
            Intelligent Personalization <span class="v3-gradient-text">Beyond Buy</span>
          </h2>
          <p class="mt-5 text-[var(--ink-secondary)]" style="font-size: clamp(1rem, 0.5vw + 0.75rem, 1.125rem); line-height: 1.7;">
            Powered by AI and trained on billions of shipments, parcelLab's platform adapts every touchpoint to each customer's context &mdash; from checkout to delivery to returns.
          </p>
        </div>

        <!-- CSS-only tabs -->
        <div class="v3-tabs mt-14 v3-reveal">
          <!-- Hidden radio inputs -->
          <input type="radio" name="v3-tab" id="v3-tab-promise" class="sr-only" checked />
          <input type="radio" name="v3-tab" id="v3-tab-engage" class="sr-only" />
          <input type="radio" name="v3-tab" id="v3-tab-retain" class="sr-only" />

          <!-- Tab labels -->
          <div class="flex flex-wrap justify-center gap-3">
            <label for="v3-tab-promise" class="v3-tab-label">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              <span>Promise <span class="hidden sm:inline">&middot; Convert</span></span>
            </label>
            <label for="v3-tab-engage" class="v3-tab-label">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              <span>Engage</span>
            </label>
            <label for="v3-tab-retain" class="v3-tab-label">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M3.985 14.652l3.181-3.182"/></svg>
              <span>Retain</span>
            </label>
          </div>

          <!-- Tab panels -->
          <div class="mt-8">
            <!-- Promise panel -->
            <div class="v3-tab-panel" id="v3-panel-promise">
              <div class="grid grid-cols-1 items-center gap-10 rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm ring-1 ring-[var(--line)] lg:grid-cols-2 lg:p-12">
                <div>
                  <div class="inline-flex items-center gap-2 rounded-full bg-[#3D3AD3]/10 px-4 py-1.5 text-xs font-semibold text-[#3D3AD3]">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75"/></svg>
                    CONVERT
                  </div>
                  <h3 class="mt-4 text-heading text-[var(--ink)]">Show precise delivery dates at PDP and checkout</h3>
                  <p class="mt-3 leading-relaxed text-[var(--ink-secondary)]">Customers who see an accurate delivery promise at product pages convert at 5% higher rates. parcelLab calculates delivery windows using real carrier data, weather, and holidays.</p>
                  <ul class="mt-5 flex flex-col gap-2 text-sm text-[var(--ink-secondary)]">
                    <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-[#3D3AD3]"></span>Dynamic calculation per SKU &amp; ZIP</li>
                    <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-[#3D3AD3]"></span>Split-shipment & pre-order support</li>
                    <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-[#3D3AD3]"></span>Carrier cutoff time awareness</li>
                  </ul>
                </div>
                <!-- Mock delivery widget -->
                <div class="flex justify-center">
                  <div class="w-full max-w-xs rounded-xl border border-[var(--line)] bg-white p-5 shadow-sm">
                    <p class="text-xs font-medium uppercase tracking-wide text-[var(--ink-muted)]">Delivery estimate</p>
                    <div class="mt-3 flex items-baseline gap-2">
                      <svg class="h-5 w-5 text-[#035740]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25"/></svg>
                      <p class="text-lg font-semibold text-[var(--ink)]">Wed, Apr 8 &ndash; Thu, Apr 9</p>
                    </div>
                    <p class="mt-1 text-xs text-[var(--ink-muted)]">Standard shipping &middot; Free</p>
                    <div class="mt-4 border-t border-[var(--line)] pt-4">
                      <div class="flex items-center gap-2 text-xs text-[#035740]">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Order within 2h 14m for dispatch today
                      </div>
                    </div>
                    <div class="mt-3 flex gap-2">
                      <div class="rounded-md bg-[#f5f3ff] px-3 py-1.5 text-xs font-medium text-[#3D3AD3]">Express: Apr 7</div>
                      <div class="rounded-md bg-[var(--surface-sunken)] px-3 py-1.5 text-xs text-[var(--ink-muted)]">Pick-up: Apr 8</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Engage panel -->
            <div class="v3-tab-panel" id="v3-panel-engage">
              <div class="grid grid-cols-1 items-center gap-10 rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm ring-1 ring-[var(--line)] lg:grid-cols-2 lg:p-12">
                <div>
                  <div class="inline-flex items-center gap-2 rounded-full bg-[#035740]/10 px-4 py-1.5 text-xs font-semibold text-[#035740]">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75"/></svg>
                    ENGAGE
                  </div>
                  <h3 class="mt-4 text-heading text-[var(--ink)]">Branded communications across every milestone</h3>
                  <p class="mt-3 leading-relaxed text-[var(--ink-secondary)]">Replace generic carrier emails with your brand experience. Every notification &mdash; shipped, in transit, delivered &mdash; becomes a touchpoint that builds loyalty and drives revenue.</p>
                  <ul class="mt-5 flex flex-col gap-2 text-sm text-[var(--ink-secondary)]">
                    <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-[#035740]"></span>Email, SMS, WhatsApp, push notifications</li>
                    <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-[#035740]"></span>Dynamic product recommendations</li>
                    <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-[#035740]"></span>AI-optimized send times</li>
                  </ul>
                </div>
                <!-- Mock email notification -->
                <div class="flex justify-center">
                  <div class="w-full max-w-xs overflow-hidden rounded-xl border border-[var(--line)] bg-white shadow-sm">
                    <div class="bg-[#3D3AD3] px-5 py-4">
                      <p class="text-xs font-medium text-white/70">SHIPPING UPDATE</p>
                      <p class="mt-1 text-sm font-semibold text-white">Your order is on its way!</p>
                    </div>
                    <div class="p-5">
                      <div class="flex items-center gap-3">
                        <div class="h-12 w-12 rounded-lg bg-[var(--surface-sunken)]"></div>
                        <div>
                          <p class="text-sm font-medium text-[var(--ink)]">Premium Wireless Headphones</p>
                          <p class="text-xs text-[var(--ink-muted)]">Arriving Apr 6, 2-5 PM</p>
                        </div>
                      </div>
                      <div class="my-4 h-px bg-[var(--line)]"></div>
                      <div class="rounded-lg bg-[var(--surface-sunken)] p-3 text-center">
                        <p class="text-xs font-medium text-[#3D3AD3]">Track your package</p>
                      </div>
                      <div class="mt-4">
                        <p class="text-[10px] uppercase tracking-wide text-[var(--ink-muted)]">You might also like</p>
                        <div class="mt-2 flex gap-2">
                          <div class="h-14 w-14 rounded-lg bg-[var(--surface-sunken)]"></div>
                          <div class="h-14 w-14 rounded-lg bg-[var(--surface-sunken)]"></div>
                          <div class="h-14 w-14 rounded-lg bg-[var(--surface-sunken)]"></div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
