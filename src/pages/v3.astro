<style>
  /* ── Gradient text ── */
  .v3-gradient-text {
    background: linear-gradient(135deg, #3D3AD3 0%, #7C3AED 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Hero entrance animation ── */
  @media (prefers-reduced-motion: no-preference) {
    .v3-hero-entrance {
      opacity: 0;
      transform: translateY(24px);
      animation: v3-hero-enter 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .v3-stagger-1 { animation-delay: 0ms; }
    .v3-stagger-2 { animation-delay: 150ms; }
    .v3-stagger-3 { animation-delay: 300ms; }
    .v3-stagger-4 { animation-delay: 450ms; }
  }

  @keyframes v3-hero-enter {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Floating cards animation ── */
  @media (prefers-reduced-motion: no-preference) {
    .v3-float {
      animation: v3-float 4s ease-in-out infinite;
    }
  }

  @keyframes v3-float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }

  /* ── Scroll reveal ── */
  .v3-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v3-reveal.v3-visible {
    opacity: 1;
    transform: translateY(0);
  }

