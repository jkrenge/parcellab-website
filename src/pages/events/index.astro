---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { Header } from "../../components/Header";
import PageHero from "../../components/PageHero.astro";
import InnerPageCTA from "../../components/InnerPageCTA.astro";
import Footer from "../../components/Footer.astro";

const PL = import.meta.env.BASE_URL;

const events = [
  {
    title: "ShopTalk Spring 2026",
    date: "March 2026",
    location: "Las Vegas, USA",
    description: "Premier retail event that brings together over 10,000 industry leaders, innovators, and top brands annually to explore emerging trends, technologies, and the future of retail.",
    category: "Conference",
    accent: "bg-[#3D3AD3]",
    tagColor: "bg-[#3D3AD3]/10 text-[#3D3AD3]",
    featured: true,
  },
  {
    title: "Barcelona Customer Day",
    date: "2026",
    location: "Barcelona, Spain",
    description: "An exceptional day where you can meet like-minded individuals, network, and learn about the latest innovations in post-purchase experience.",
    category: "Customer Day",
    accent: "bg-[#035740]",
    tagColor: "bg-[#035740]/10 text-[#035740]",
  },
  {
    title: "London Customer Day",
    date: "2026",
    location: "London, UK",
    description: "An exceptional day where you can meet like-minded individuals, network, and learn how leading UK retailers are transforming the post-purchase journey.",
    category: "Customer Day",
    accent: "bg-[#035740]",
    tagColor: "bg-[#035740]/10 text-[#035740]",
  },
  {
    title: "Customer Day Koln",
    date: "2026",
    location: "Cologne, Germany",
    description: "Erleben Sie Inspiration, Networking und neue Erkenntnisse. Mit Erfolgsgeschichten von parcelLab-Kunden und dem interaktiven parcelLab Expo Workshop.",
    category: "Customer Day",
    accent: "bg-[#FFC943]",
    tagColor: "bg-[#FFC943]/20 text-[#92700a]",
  },
  {
    title: "Munchen Customer Day",
    date: "2026",
    location: "Munich, Germany",
    description: "Networking, success stories, and the parcelLab Expo workshop showcasing latest products and features for the DACH region.",
    category: "Customer Day",
    accent: "bg-[#FFC943]",
    tagColor: "bg-[#FFC943]/20 text-[#92700a]",
  },
  {
    title: "Stockholm Customer Day",
    date: "2026",
    location: "Stockholm, Sweden",
    description: "Join parcelLab and fellow Nordic retailers for a day of networking, learning, and exploring the future of post-purchase experience in the Nordics.",
    category: "Customer Day",
    accent: "bg-[#035740]",
    tagColor: "bg-[#035740]/10 text-[#035740]",
  },
];

function getMonthDay(dateStr: string) {
  const parts = dateStr.split(" ");
  return { month: parts.length > 1 ? parts[0].substring(0, 3).toUpperCase() : "", year: parts[parts.length - 1] };
}
---

<Layout
  title="Events - parcelLab"
  description="Meet parcelLab at conferences, customer days, and industry events worldwide. See where we'll be next."
>
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Connect"
      title="Events"
      description="Meet parcelLab at conferences, customer days, and industry events worldwide. See where we'll be next and join us."
    />

    <section class="section-standard">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">

        <!-- Featured event -->
        <div class="mb-16">
          <a href={`${PL}/events/`} class="group block overflow-hidden rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] transition-shadow hover:shadow-lg">
            <div class="grid md:grid-cols-2">
              <div class="relative flex h-64 items-center justify-center bg-gradient-to-br from-[#3D3AD3] to-[#1e1b96] md:h-auto md:min-h-[320px]">
                <div class="text-center">
                  <div class="mb-3 text-sm font-medium uppercase tracking-wider text-white/60">{events[0].date}</div>
                  <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto opacity-40"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                </div>
                <span class="absolute top-4 left-4 rounded-full bg-white/20 px-3 py-1 text-xs font-medium text-white backdrop-blur-sm">
                  Featured
                </span>
              </div>
              <div class="flex flex-col justify-center p-8 md:p-10">
                <span class="mb-3 inline-block w-fit rounded-full bg-[#3D3AD3]/10 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">{events[0].category}</span>
                <h2 class="text-heading text-[var(--ink)] group-hover:text-[#3D3AD3] transition-colors">{events[0].title}</h2>
                <p class="mt-3 text-[var(--ink-secondary)] leading-relaxed">{events[0].description}</p>
                <div class="mt-4 flex items-center gap-4 text-sm text-[var(--ink-muted)]">
                  <span class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    {events[0].location}
                  </span>
                </div>
              </div>
            </div>
          </a>
        </div>

        <!-- Events grid -->
        <h2 class="text-display text-[var(--ink)] mb-10">Upcoming events</h2>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {events.slice(1).map((event) => {
            const { month, year } = getMonthDay(event.date);
            return (
              <article class="group flex flex-col overflow-hidden rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] transition-shadow hover:shadow-lg">
                <div class={`relative flex h-44 items-center justify-center ${event.accent}`}>
                  <div class="text-center">
                    {month && <div class="text-2xl font-bold text-white/90">{month}</div>}
                    <div class="text-sm font-medium text-white/60">{year}</div>
                  </div>
                  <span class="absolute top-4 left-4 rounded-full bg-white/20 px-3 py-1 text-xs font-medium text-white backdrop-blur-sm">
                    {event.category}
                  </span>
                </div>
                <div class="flex flex-1 flex-col p-6">
                  <h3 class="text-lg font-medium leading-snug text-[var(--ink)] group-hover:text-[#3D3AD3] transition-colors">
                    {event.title}
                  </h3>
                  <div class="mt-2 flex items-center gap-1.5 text-sm text-[var(--ink-muted)]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    {event.location}
                  </div>
                  <p class="mt-3 flex-1 text-sm leading-relaxed text-[var(--ink-secondary)]">
                    {event.description}
                  </p>
                  <div class="mt-4 flex items-center gap-2 text-sm font-medium text-[#3D3AD3]">
                    Learn more
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
