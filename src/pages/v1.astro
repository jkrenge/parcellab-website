---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";
const b = import.meta.env.BASE_URL;
---

<Layout title="parcelLab — Post-Purchase, Solved">
  <Header client:load />
  <main>
    <!-- ════════════════════════════════════════════════════════════════
         SECTION 1 — HERO + BENTO (combined, full-bleed)
         ════════════════════════════════════════════════════════════════ -->
    <section class="hero-bento relative overflow-hidden pb-24 pt-32 md:pb-32 md:pt-40">
      <!-- Animated floating orbs -->
      <div class="hero-orbs pointer-events-none absolute inset-0 -z-10 overflow-hidden">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="orb orb-4"></div>
        <div class="orb orb-5"></div>
      </div>
      <!-- Grid pattern overlay -->
      <div class="pointer-events-none absolute inset-0 -z-[5] opacity-[0.035]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(61,58,211,0.5) 59px, rgba(61,58,211,0.5) 60px), repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(61,58,211,0.5) 59px, rgba(61,58,211,0.5) 60px);"></div>

      <div class="container-pl relative z-10">
        <!-- Headline -->
        <div class="mx-auto max-w-5xl text-center">
          <h1 class="hero-headline mb-6">
            <span class="hero-word hero-word-1">Post-purchase</span>
            <span class="hero-word hero-word-2">experience</span>
            <br class="hidden sm:inline" />
            <span class="hero-word hero-word-3">management.</span>
            <span class="hero-word hero-word-4 hero-solved">Solved.</span>
          </h1>
          <p class="hero-subtitle mx-auto mt-8 max-w-xl text-lg text-[var(--ink-secondary)]">
            What would you like to do with parcelLab?
          </p>
        </div>

        <!-- Bento grid -->
        <div class="mx-auto mt-14 max-w-5xl">
          <div class="bento-grid grid gap-4 md:grid-cols-2 lg:grid-cols-6">
            <!-- Card 1: Engage (spans 3) -->
            <div class="bento-card bento-card-1 group relative cursor-pointer rounded-2xl p-7 transition-all duration-500 lg:col-span-3" data-bento>
              <div class="bento-card-border"></div>
              <div class="relative z-10">
                <div class="bento-check absolute top-0 right-0 flex h-7 w-7 items-center justify-center rounded-full border-2 border-white/40 transition-all duration-300">
                  <svg class="h-3.5 w-3.5 text-white opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div class="bento-icon mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-engage-gradient">
                  <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Engage customers post-purchase</h3>
                <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Send branded tracking updates, delivery notifications, and personalized messages across email, SMS, and push.</p>
              </div>
            </div>

            <!-- Card 2: Returns (spans 3) -->
            <div class="bento-card bento-card-2 group relative cursor-pointer rounded-2xl p-7 transition-all duration-500 lg:col-span-3" data-bento>
              <div class="bento-card-border"></div>
              <div class="relative z-10">
                <div class="bento-check absolute top-0 right-0 flex h-7 w-7 items-center justify-center rounded-full border-2 border-white/40 transition-all duration-300">
                  <svg class="h-3.5 w-3.5 text-white opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div class="bento-icon mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-returns-gradient">
                  <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
                  </svg>
                </div>
                <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Manage returns & exchanges</h3>
                <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Turn returns into retention with smart exchanges, store credit, and self-service portals.</p>
              </div>
            </div>

            <!-- Card 3: Convert (spans 2) -->
            <div class="bento-card bento-card-3 group relative cursor-pointer rounded-2xl p-7 transition-all duration-500 lg:col-span-2" data-bento>
              <div class="bento-card-border"></div>
              <div class="relative z-10">
                <div class="bento-check absolute top-0 right-0 flex h-7 w-7 items-center justify-center rounded-full border-2 border-white/40 transition-all duration-300">
                  <svg class="h-3.5 w-3.5 text-white opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div class="bento-icon mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-convert-gradient">
                  <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
                  </svg>
                </div>
                <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Convert with delivery promises</h3>
                <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Show accurate delivery dates at checkout to boost conversion rates by up to 5%.</p>
              </div>
            </div>

            <!-- Card 4: AI Insights (spans 2) -->
            <div class="bento-card bento-card-4 group relative cursor-pointer rounded-2xl p-7 transition-all duration-500 lg:col-span-2" data-bento>
              <div class="bento-card-border"></div>
              <div class="relative z-10">
                <div class="bento-check absolute top-0 right-0 flex h-7 w-7 items-center justify-center rounded-full border-2 border-white/40 transition-all duration-300">
                  <svg class="h-3.5 w-3.5 text-white opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div class="bento-icon mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-ai-gradient">
                  <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                  </svg>
                </div>
                <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Get AI-powered insights</h3>
                <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Chat with your data, predict trends, and get automated recommendations from our AI Copilot.</p>
              </div>
            </div>

            <!-- Card 5: Fraud Protection (spans 2) -->
            <div class="bento-card bento-card-5 group relative cursor-pointer rounded-2xl p-7 transition-all duration-500 lg:col-span-2" data-bento>
              <div class="bento-card-border"></div>
              <div class="relative z-10">
                <div class="bento-check absolute top-0 right-0 flex h-7 w-7 items-center justify-center rounded-full border-2 border-white/40 transition-all duration-300">
                  <svg class="h-3.5 w-3.5 text-white opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div class="bento-icon mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-fraud-gradient">
                  <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                  </svg>
                </div>
                <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Protect revenue from fraud</h3>
                <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Detect returns abuse and fraudulent claims before they impact your bottom line.</p>
              </div>
            </div>
          </div>

          <!-- CTA buttons -->
          <div class="hero-ctas mt-14 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6">
            <a href={`${b}/contact-us/`} class="cta-primary group inline-flex items-center justify-center rounded-full px-9 py-4 text-base font-semibold text-white shadow-lg shadow-[#3D3AD3]/25 transition-all duration-300 hover:shadow-xl hover:shadow-[#3D3AD3]/30 hover:-translate-y-0.5">
              Get started
              <svg class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href={`${b}/contact-us/`} class="inline-flex items-center gap-2 text-base font-medium text-[#3D3AD3] transition-colors duration-200 hover:text-[#3230b8]">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z" />
              </svg>
              Watch a demo
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 2 — STATS BAR
         ════════════════════════════════════════════════════════════════ -->
    <section class="stats-section relative overflow-hidden py-20 md:py-28">
      <div class="container-pl relative z-10">
        <div class="grid grid-cols-2 gap-10 md:grid-cols-4 md:gap-0">
          <div class="stat-item flex flex-col items-center text-center md:border-r md:border-[var(--ink)]/10" data-animate>
            <span class="stat-number font-bold text-transparent" data-count="700">700+</span>
            <span class="mt-2 text-sm font-medium tracking-wide text-[var(--ink-secondary)]">Global brands</span>
          </div>
          <div class="stat-item flex flex-col items-center text-center md:border-r md:border-[var(--ink)]/10" data-animate>
            <span class="stat-number font-bold text-transparent" data-count="50">50M+</span>
            <span class="mt-2 text-sm font-medium tracking-wide text-[var(--ink-secondary)]">Shipments tracked monthly</span>
          </div>
          <div class="stat-item flex flex-col items-center text-center md:border-r md:border-[var(--ink)]/10" data-animate>
            <span class="stat-number font-bold text-transparent" data-count="175">175+</span>
            <span class="mt-2 text-sm font-medium tracking-wide text-[var(--ink-secondary)]">Carriers integrated</span>
          </div>
          <div class="stat-item flex flex-col items-center text-center" data-animate>
            <span class="stat-number font-bold text-transparent" data-count="52">52</span>
            <span class="mt-2 text-sm font-medium tracking-wide text-[var(--ink-secondary)]">Countries supported</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 3 — PLATFORM OVERVIEW
         ════════════════════════════════════════════════════════════════ -->
    <section class="platform-section relative overflow-hidden py-24 md:py-32">
      <div class="container-pl">
        <div class="mx-auto max-w-3xl text-center" data-animate>
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#3D3AD3]/20 bg-[#3D3AD3]/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-[#3D3AD3]">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#3D3AD3]"></span>
            Platform
          </div>
          <p class="platform-title mb-5">The AI-powered post-purchase platform</p>
          <p class="mx-auto max-w-2xl text-lg leading-relaxed text-[var(--ink-secondary)]">
            parcelLab unifies tracking, communications, returns, and delivery predictions into one intelligent platform.
          </p>
        </div>

        <div class="mt-16 grid gap-6 md:grid-cols-3">
          <!-- Feature 1: Engage -->
          <div class="platform-card group relative rounded-2xl p-8 transition-all duration-500" data-animate data-tilt>
            <div class="platform-card-inner relative z-10">
              <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-engage-gradient shadow-lg shadow-[#3D3AD3]/15">
                <svg class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
                </svg>
              </div>
              <div class="mb-3 inline-flex items-center rounded-full bg-[#3D3AD3]/8 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Engage</div>
              <h3 class="mb-3 text-xl font-semibold text-[var(--ink)]">Branded post-purchase journeys</h3>
              <p class="mb-6 text-sm leading-relaxed text-[var(--ink-secondary)]">
                Send proactive updates across email, SMS, push. A/B test messaging. Reduce WISMO calls by 20%.
              </p>
              <a href={`${b}/enhance-delivery-experience/`} class="inline-flex items-center text-sm font-medium text-[#3D3AD3] transition-colors hover:text-[#3230b8]">
                Learn more
                <svg class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Feature 2: Retain -->
          <div class="platform-card group relative rounded-2xl p-8 transition-all duration-500" data-animate data-tilt>
            <div class="platform-card-inner relative z-10">
              <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-returns-gradient shadow-lg shadow-[#035740]/15">
                <svg class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3" />
                </svg>
              </div>
              <div class="mb-3 inline-flex items-center rounded-full bg-[#035740]/8 px-3 py-1 text-xs font-semibold text-[#035740]">Retain</div>
              <h3 class="mb-3 text-xl font-semibold text-[var(--ink)]">Smart returns & exchanges</h3>
              <p class="mb-6 text-sm leading-relaxed text-[var(--ink-secondary)]">
                Self-service returns portal with exchanges, store credit, retention offers. 11% higher retention.
              </p>
              <a href={`${b}/make-returns-seamless/`} class="inline-flex items-center text-sm font-medium text-[#3D3AD3] transition-colors hover:text-[#3230b8]">
                Learn more
                <svg class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Feature 3: Convert -->
          <div class="platform-card group relative rounded-2xl p-8 transition-all duration-500" data-animate data-tilt>
            <div class="platform-card-inner relative z-10">
              <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-convert-gradient shadow-lg shadow-[#FFC943]/20">
                <svg class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
                </svg>
              </div>
              <div class="mb-3 inline-flex items-center rounded-full bg-[#FFC943]/15 px-3 py-1 text-xs font-semibold text-[#b8860b]">Convert</div>
              <h3 class="mb-3 text-xl font-semibold text-[var(--ink)]">Delivery date promises</h3>
              <p class="mb-6 text-sm leading-relaxed text-[var(--ink-secondary)]">
                Accurate ETAs at checkout. 5% higher conversion. ML models trained on millions of shipments.
              </p>
              <a href={`${b}/boost-cart-conversion/`} class="inline-flex items-center text-sm font-medium text-[#3D3AD3] transition-colors hover:text-[#3230b8]">
                Learn more
                <svg class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 4 — SOCIAL PROOF (dark section)
         ════════════════════════════════════════════════════════════════ -->
    <section class="social-proof-section relative overflow-hidden py-24 md:py-32">
      <div class="container-pl relative z-10">
        <div class="mx-auto max-w-4xl text-center" data-animate>
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-white/60">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#FFC943]"></span>
            Social proof
          </div>
          <blockquote class="mb-10">
            <p class="social-quote text-2xl font-light leading-relaxed tracking-tight text-white sm:text-3xl md:text-4xl" style="letter-spacing: -0.02em;">
              "parcelLab transformed our post-purchase experience. We saw a 25% reduction in WISMO tickets and our satisfaction scores increased significantly."
            </p>
          </blockquote>
          <footer class="inline-flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-[#3D3AD3] to-[#7C3AED] text-sm font-semibold text-white">SH</div>
            <div class="text-left">
              <p class="text-sm font-semibold text-white">Sarah Henderson</p>
              <p class="text-xs text-white/50">VP of Customer Experience, Global Retailer</p>
            </div>
          </footer>
        </div>

        <!-- Logo grid floating -->
        <div class="mx-auto mt-20 max-w-4xl" data-animate>
          <p class="mb-8 text-center text-sm font-medium uppercase tracking-widest text-white/30">Trusted by 700+ brands worldwide</p>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
            <div class="logo-card flex h-20 items-center justify-center rounded-xl border border-white/8 bg-white/5 p-4 backdrop-blur-sm transition-all duration-300">
              <img src={`${b}/images/logos/IKEA_Logo_Black.svg`} alt="IKEA" class="h-7 max-w-[90px] object-contain opacity-30 brightness-0 invert transition-all duration-300" loading="lazy" />
            </div>
            <div class="logo-card flex h-20 items-center justify-center rounded-xl border border-white/8 bg-white/5 p-4 backdrop-blur-sm transition-all duration-300">
              <img src={`${b}/images/brands/Hugo-Boss.svg`} alt="Hugo Boss" class="h-7 max-w-[90px] object-contain opacity-30 brightness-0 invert transition-all duration-300" loading="lazy" />
            </div>
            <div class="logo-card flex h-20 items-center justify-center rounded-xl border border-white/8 bg-white/5 p-4 backdrop-blur-sm transition-all duration-300">
              <img src={`${b}/images/brands/Dyson.svg`} alt="Dyson" class="h-7 max-w-[90px] object-contain opacity-30 brightness-0 invert transition-all duration-300" loading="lazy" />
            </div>
