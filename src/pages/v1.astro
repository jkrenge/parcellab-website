---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";
const b = import.meta.env.BASE_URL;
---

<Layout title="parcelLab — Post-Purchase, Solved">
  <Header client:load />
  <main>
    <!-- ════════════════════════════════════════════════════════════════
         SECTION 1 — HERO
         ════════════════════════════════════════════════════════════════ -->
    <section class="hero-section relative flex min-h-screen items-center overflow-hidden">
      <div class="container-pl relative z-10 w-full py-32">
        <div class="mx-auto max-w-4xl text-center">
          <h1 class="hero-headline mb-6">
            <span class="hero-line hero-line-1 block">Post-purchase experience</span>
            <span class="hero-line hero-line-2 block">management.</span>
            <span class="hero-line hero-line-3 block text-[#3D3AD3]">Solved.</span>
          </h1>
          <p class="hero-subtitle mx-auto mt-8 max-w-xl text-lg text-[var(--ink-secondary)]">
            What would you like to do with parcelLab?
          </p>
        </div>
      </div>
      <!-- Subtle decorative gradient orb -->
      <div class="pointer-events-none absolute top-1/2 left-1/2 -z-0 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-30" style="background: radial-gradient(circle, rgba(61,58,211,0.08) 0%, transparent 70%);"></div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 2 — BENTO SELECTOR
         ════════════════════════════════════════════════════════════════ -->
    <section class="bento-section section-generous" style="background-color: #f5f3ff;">
      <div class="container-pl">
        <div class="mx-auto max-w-5xl">
          <h2 class="mb-4 text-center text-sm font-semibold uppercase tracking-widest text-[#3D3AD3]">Capabilities</h2>
          <p class="mx-auto mb-12 max-w-2xl text-center text-2xl font-light text-[var(--ink)]" style="letter-spacing: -0.02em;">
            What would you like to do?
          </p>

          <!-- Bento grid: 2 large top, 3 smaller bottom -->
          <div class="bento-grid grid gap-4 md:grid-cols-2">
            <!-- Card 1: Engage -->
            <div class="bento-card group relative cursor-pointer rounded-2xl border border-[var(--line)] bg-white p-8 transition-all duration-300 hover:border-[#3D3AD3]/40 hover:shadow-lg" data-animate>
              <div class="bento-check absolute top-6 right-6 flex h-6 w-6 items-center justify-center rounded-full border-2 border-[var(--line)] transition-all duration-300 group-hover:border-[#3D3AD3] group-hover:bg-[#3D3AD3]">
                <svg class="h-3 w-3 text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
                <svg class="h-6 w-6 text-[#3D3AD3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Engage customers post-purchase</h3>
              <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Send branded tracking updates, delivery notifications, and personalized messages across email, SMS, and push.</p>
            </div>

            <!-- Card 2: Returns -->
            <div class="bento-card group relative cursor-pointer rounded-2xl border border-[var(--line)] bg-white p-8 transition-all duration-300 hover:border-[#3D3AD3]/40 hover:shadow-lg" data-animate>
              <div class="bento-check absolute top-6 right-6 flex h-6 w-6 items-center justify-center rounded-full border-2 border-[var(--line)] transition-all duration-300 group-hover:border-[#3D3AD3] group-hover:bg-[#3D3AD3]">
                <svg class="h-3 w-3 text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
                <svg class="h-6 w-6 text-[#035740]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
                </svg>
              </div>
              <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Manage returns & exchanges</h3>
              <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Turn returns into retention with smart exchanges, store credit, and self-service portals.</p>
            </div>

            <!-- Card 3: Convert -->
            <div class="bento-card group relative cursor-pointer rounded-2xl border border-[var(--line)] bg-white p-8 transition-all duration-300 hover:border-[#3D3AD3]/40 hover:shadow-lg" data-animate>
              <div class="bento-check absolute top-6 right-6 flex h-6 w-6 items-center justify-center rounded-full border-2 border-[var(--line)] transition-all duration-300 group-hover:border-[#3D3AD3] group-hover:bg-[#3D3AD3]">
                <svg class="h-3 w-3 text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/20">
                <svg class="h-6 w-6 text-[#b8860b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
                </svg>
              </div>
              <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Convert with delivery promises</h3>
              <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Show accurate delivery dates at checkout to boost conversion rates by up to 5%.</p>
            </div>

            <!-- Card 4: AI Insights -->
            <div class="bento-card group relative cursor-pointer rounded-2xl border border-[var(--line)] bg-white p-8 transition-all duration-300 hover:border-[#3D3AD3]/40 hover:shadow-lg" data-animate>
              <div class="bento-check absolute top-6 right-6 flex h-6 w-6 items-center justify-center rounded-full border-2 border-[var(--line)] transition-all duration-300 group-hover:border-[#3D3AD3] group-hover:bg-[#3D3AD3]">
                <svg class="h-3 w-3 text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
                <svg class="h-6 w-6 text-[#3D3AD3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                </svg>
              </div>
              <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Get AI-powered insights</h3>
              <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Chat with your data, predict trends, and get automated recommendations from our AI Copilot.</p>
            </div>

            <!-- Card 5: Fraud Protection (spans full width on md) -->
            <div class="bento-card group relative cursor-pointer rounded-2xl border border-[var(--line)] bg-white p-8 transition-all duration-300 hover:border-[#3D3AD3]/40 hover:shadow-lg md:col-span-2" data-animate>
              <div class="bento-check absolute top-6 right-6 flex h-6 w-6 items-center justify-center rounded-full border-2 border-[var(--line)] transition-all duration-300 group-hover:border-[#3D3AD3] group-hover:bg-[#3D3AD3]">
                <svg class="h-3 w-3 text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div class="md:flex md:items-start md:gap-6">
                <div class="mb-5 flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#F4373D]/10 md:mb-0">
                  <svg class="h-6 w-6 text-[#F4373D]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                  </svg>
                </div>
                <div>
                  <h3 class="mb-2 text-lg font-semibold text-[var(--ink)]">Protect revenue from fraud</h3>
                  <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">Detect returns abuse and fraudulent claims before they impact your bottom line.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- CTA buttons -->
          <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6">
            <a href={`${b}/contact-us/`} class="inline-flex items-center justify-center rounded-full bg-[#3D3AD3] px-8 py-4 text-base font-medium text-white shadow-md transition-all duration-300 hover:bg-[#3230b8] hover:shadow-lg hover:-translate-y-0.5">
              Get started
              <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href={`${b}/contact-us/`} class="inline-flex items-center text-base font-medium text-[#3D3AD3] transition-colors duration-200 hover:text-[#3230b8]">
              Watch a demo
              <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 3 — STATS BAR
         ════════════════════════════════════════════════════════════════ -->
    <section class="section-standard border-y border-[var(--line)]">
      <div class="container-pl">
        <div class="grid grid-cols-2 gap-8 md:grid-cols-4 md:gap-0">
          <!-- Stat 1 -->
          <div class="stat-item flex flex-col items-center text-center md:border-r md:border-[var(--line)]" data-animate>
            <span class="stat-number text-4xl font-bold text-[var(--ink)]" data-count="700">700+</span>
            <span class="mt-1 text-sm text-[var(--ink-muted)]">Global brands</span>
          </div>
          <!-- Stat 2 -->
          <div class="stat-item flex flex-col items-center text-center md:border-r md:border-[var(--line)]" data-animate>
            <span class="stat-number text-4xl font-bold text-[var(--ink)]" data-count="50">50M+</span>
            <span class="mt-1 text-sm text-[var(--ink-muted)]">Shipments tracked monthly</span>
          </div>
          <!-- Stat 3 -->
          <div class="stat-item flex flex-col items-center text-center md:border-r md:border-[var(--line)]" data-animate>
            <span class="stat-number text-4xl font-bold text-[var(--ink)]" data-count="175">175+</span>
            <span class="mt-1 text-sm text-[var(--ink-muted)]">Carriers integrated</span>
          </div>
          <!-- Stat 4 -->
          <div class="stat-item flex flex-col items-center text-center" data-animate>
            <span class="stat-number text-4xl font-bold text-[var(--ink)]" data-count="52">52</span>
            <span class="mt-1 text-sm text-[var(--ink-muted)]">Countries supported</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 4 — PLATFORM OVERVIEW
         ════════════════════════════════════════════════════════════════ -->
    <section class="section-generous">
      <div class="container-pl">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-[#3D3AD3]">Platform</h2>
          <p class="text-display mb-4">The AI-powered post-purchase platform</p>
          <p class="mx-auto max-w-2xl text-lg leading-relaxed text-[var(--ink-secondary)]">
            parcelLab unifies tracking, communications, returns, and delivery predictions into one intelligent platform — so every customer touchpoint drives loyalty and revenue.
          </p>
        </div>

        <div class="mt-16 grid gap-8 md:grid-cols-3">
          <!-- Feature 1: Engage -->
          <div class="platform-card group rounded-2xl border border-[var(--line)] bg-white p-8 transition-all duration-300 hover:shadow-lg hover:-translate-y-1" data-animate>
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-[#3D3AD3]/8">
              <svg class="h-7 w-7 text-[#3D3AD3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
              </svg>
            </div>
            <div class="mb-3 inline-flex items-center rounded-full bg-[#3D3AD3]/8 px-3 py-1 text-xs font-semibold text-[#3D3AD3]">Engage</div>
            <h3 class="mb-3 text-xl font-semibold text-[var(--ink)]">Branded post-purchase journeys</h3>
            <p class="mb-6 text-sm leading-relaxed text-[var(--ink-secondary)]">
              Send proactive updates across email, SMS, push. A/B test messaging. Reduce WISMO calls by 20%.
            </p>
            <a href={`${b}/enhance-delivery-experience/`} class="inline-flex items-center text-sm font-medium text-[#3D3AD3] transition-colors hover:text-[#3230b8]">
              Learn more
              <svg class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>

          <!-- Feature 2: Retain -->
          <div class="platform-card group rounded-2xl border border-[var(--line)] bg-white p-8 transition-all duration-300 hover:shadow-lg hover:-translate-y-1" data-animate>
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-[#035740]/8">
              <svg class="h-7 w-7 text-[#035740]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3" />
              </svg>
            </div>
            <div class="mb-3 inline-flex items-center rounded-full bg-[#035740]/8 px-3 py-1 text-xs font-semibold text-[#035740]">Retain</div>
            <h3 class="mb-3 text-xl font-semibold text-[var(--ink)]">Smart returns & exchanges</h3>
            <p class="mb-6 text-sm leading-relaxed text-[var(--ink-secondary)]">
              Self-service returns portal with exchanges, store credit, retention offers. Monetize returns with 11% higher retention.
            </p>
            <a href={`${b}/make-returns-seamless/`} class="inline-flex items-center text-sm font-medium text-[#3D3AD3] transition-colors hover:text-[#3230b8]">
              Learn more
              <svg class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>

          <!-- Feature 3: Convert -->
          <div class="platform-card group rounded-2xl border border-[var(--line)] bg-white p-8 transition-all duration-300 hover:shadow-lg hover:-translate-y-1" data-animate>
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-[#FFC943]/15">
              <svg class="h-7 w-7 text-[#b8860b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
              </svg>
            </div>
            <div class="mb-3 inline-flex items-center rounded-full bg-[#FFC943]/15 px-3 py-1 text-xs font-semibold text-[#b8860b]">Convert</div>
            <h3 class="mb-3 text-xl font-semibold text-[var(--ink)]">Delivery date promises</h3>
            <p class="mb-6 text-sm leading-relaxed text-[var(--ink-secondary)]">
              Accurate ETAs at checkout. 5% higher conversion. Powered by ML models trained on millions of shipments.
            </p>
            <a href={`${b}/boost-cart-conversion/`} class="inline-flex items-center text-sm font-medium text-[#3D3AD3] transition-colors hover:text-[#3230b8]">
              Learn more
              <svg class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 5 — SOCIAL PROOF
         ════════════════════════════════════════════════════════════════ -->
    <section class="section-generous" style="background-color: #f5f3ff;">
      <div class="container-pl">
        <div class="grid gap-16 lg:grid-cols-2 lg:items-start">
          <!-- Left: testimonials -->
          <div data-animate>
            <h2 class="mb-2 text-sm font-semibold uppercase tracking-widest text-[#3D3AD3]">Social proof</h2>
            <p class="text-display mb-10">Why leading retailers choose parcelLab</p>

            <div class="space-y-8">
              <!-- Testimonial 1 -->
              <blockquote class="rounded-2xl border border-[var(--line)] bg-white p-8">
                <svg class="mb-4 h-8 w-8 text-[#3D3AD3]/20" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" />
                </svg>
                <p class="mb-4 text-base leading-relaxed text-[var(--ink)]">
                  "parcelLab transformed our post-purchase experience. We saw a 25% reduction in WISMO tickets within the first quarter and our customer satisfaction scores increased significantly."
                </p>
                <footer class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#3D3AD3]/10 text-sm font-semibold text-[#3D3AD3]">SH</div>
                  <div>
                    <p class="text-sm font-semibold text-[var(--ink)]">Sarah Henderson</p>
                    <p class="text-xs text-[var(--ink-muted)]">VP of Customer Experience, Global Retailer</p>
                  </div>
                </footer>
              </blockquote>

              <!-- Testimonial 2 -->
              <blockquote class="rounded-2xl border border-[var(--line)] bg-white p-8">
