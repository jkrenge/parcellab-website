---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<Layout
  title="AI-powered post-purchase experiences - parcelLab"
  description="AI-powered automation and predictive insights transform post-purchase experiences into a real competitive advantage while saving time and cost."
>
  <Header client:load />
  <main>
    <PageHero
      eyebrow="AI-Powered"
      title="Optimize every post-purchase interaction with parcelLab AI"
      description="We're ushering in a new era of post-purchase excellence with AI seamlessly embedded across our platform."
      ctaText="Book a demo"
      ctaHref={`${base}/live-demo/`}
      secondaryCtaText="See how it works"
      secondaryCtaHref={`${base}/live-demo/`}
    />

    <!-- Problem Statement -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="text-display text-[var(--ink)]">Are manual, time-consuming processes holding you back?</h2>
          <p class="mt-5 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            With our AI post-purchase platform, you can automate workflows, predict issues before they happen, and turn post-purchase into a competitive advantage. Optimize operations, drive revenue, and keep customers coming back &mdash; all without the extra effort.
          </p>
        </div>
      </div>
    </section>

    <!-- Four Key Benefits -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid gap-8 md:grid-cols-2">
          <!-- Resolve issues -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Resolve issues before they arise</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Don't wait for issues to pile up. Spot delivery delays, WISMO risks, and return spikes early with AI-powered predictions, so you can act before customers are impacted.
            </p>
          </div>
          <!-- Smarter support -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Smarter support, happier customers</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Give your service teams everything they need to resolve issues faster. AI-powered chatbots, centralized order and tracking data, and automated workflows cut down inquiries and speed up resolutions.
            </p>
          </div>
          <!-- Revenue -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/15">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Turn every touchpoint into revenue</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Turn post-purchase moments into growth opportunities with AI-driven personalization, product recommendations, and targeted messaging that increase conversions and boost retention.
            </p>
          </div>
          <!-- Automation -->
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 transition-all hover:shadow-lg hover:shadow-[#3D3AD3]/5">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Work smarter with AI automation</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Let AI do the heavy lifting. Cut down on manual effort with intelligent automation, smart agents, and self-service tools that free up resources while delivering a seamless post-purchase experience.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Banner -->
    <section class="section-standard">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto mb-12 max-w-2xl text-center">
          <h2 class="text-display text-[var(--ink)]">Smarter operations, happier customers, higher conversions</h2>
        </div>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 text-center">
            <div class="text-4xl font-semibold text-[#3D3AD3] md:text-5xl">29%</div>
            <p class="mt-2 text-sm font-semibold text-[var(--ink)]">Higher conversion</p>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Set clear expectations with real-time delivery promises and personalized options that keep customers reassured and engaged.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 text-center">
            <div class="text-4xl font-semibold text-[#035740] md:text-5xl">20%</div>
            <p class="mt-2 text-sm font-semibold text-[var(--ink)]">Fewer WISMO inquiries</p>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Keep customers informed with AI-powered tracking and self-service solutions, reducing support costs while enhancing their experience.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8 text-center">
            <div class="text-4xl font-semibold text-[#b8860b] md:text-5xl">40%</div>
            <p class="mt-2 text-sm font-semibold text-[var(--ink)]">More accurate returns forecasting</p>
            <p class="mt-2 text-sm text-[var(--ink-secondary)]">Optimize staffing and logistics with AI-powered predictions, ensuring seamless returns management.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Capabilities: Execute with AI agents -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto mb-16 max-w-2xl text-center">
          <h2 class="text-display text-[var(--ink)]">With parcelLab, you can</h2>
        </div>

        <div class="grid items-center gap-16 md:grid-cols-2">
          <div>
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Execute</span>
            <h2 class="text-heading text-[var(--ink)]">Execute with AI agents</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Boost efficiency and customer satisfaction with AI agents that handle tasks, resolve issues, and streamline key post-purchase processes.
            </p>
            <ul class="mt-8 space-y-4">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Assistive agents:</strong> Help your team work faster with AI-driven insights that automate repetitive tasks</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Autonomous agents:</strong> Resolve WISMO inquiries, process claims, and recover revenue &mdash; no manual effort needed</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Conversational returns:</strong> Let customers manage returns through AI-powered chat and self-service portals</span>
              </li>
            </ul>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-10">
            <div class="flex flex-col items-center text-center">
              <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-[#3D3AD3]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><path d="M9 9h6v6H9z"/><path d="M9 1v3"/><path d="M15 1v3"/><path d="M9 20v3"/><path d="M15 20v3"/><path d="M20 9h3"/><path d="M20 14h3"/><path d="M1 9h3"/><path d="M1 14h3"/></svg>
              </div>
              <div class="text-sm font-medium text-[var(--ink-muted)]">AI Agent Status</div>
              <div class="mt-2 text-2xl font-semibold text-[var(--ink)]">Agents Active</div>
              <div class="mt-1 text-sm text-[#035740]">Handling 40% of WISMO calls autonomously</div>
              <div class="mt-6 w-full space-y-3">
                <div class="flex items-center justify-between rounded-xl bg-[var(--surface-sunken)] p-4 text-sm">
                  <span class="text-[var(--ink-muted)]">WISMO resolution</span>
                  <span class="font-medium text-[#035740]">Automated</span>
                </div>
                <div class="flex items-center justify-between rounded-xl bg-[var(--surface-sunken)] p-4 text-sm">
                  <span class="text-[var(--ink-muted)]">Claims processing</span>
                  <span class="font-medium text-[#035740]">Automated</span>
                </div>
                <div class="flex items-center justify-between rounded-xl bg-[var(--surface-sunken)] p-4 text-sm">
                  <span class="text-[var(--ink-muted)]">Revenue recovery</span>
                  <span class="font-medium text-[#035740]">Active</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Simplify with AI -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="order-2 md:order-1 rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-10">
            <div class="flex flex-col items-center text-center">
              <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-[#035740]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              </div>
              <div class="text-sm font-medium text-[var(--ink-muted)]">Copilot</div>
              <div class="mt-2 text-2xl font-semibold text-[var(--ink)]">AI-powered workflow</div>
              <div class="mt-1 text-sm text-[#035740]">Real-time guidance &amp; automation</div>
              <div class="mt-6 w-full space-y-3">
                <div class="flex items-center gap-3 rounded-xl bg-[var(--surface-sunken)] p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-[var(--ink-secondary)]">Simplified workflow creation</span>
                </div>
                <div class="flex items-center gap-3 rounded-xl bg-[var(--surface-sunken)] p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-[var(--ink-secondary)]">Intuitive journey builder</span>
                </div>
                <div class="flex items-center gap-3 rounded-xl bg-[var(--surface-sunken)] p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-[var(--ink-secondary)]">Centralized service integration</span>
                </div>
              </div>
            </div>
          </div>
          <div class="order-1 md:order-2">
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">Simplify</span>
            <h2 class="text-heading text-[var(--ink)]">Simplify with AI</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Work smarter, not harder. Automate workflows, streamline customer service, and give your team the AI-powered tools they need to deliver faster, better experiences.
            </p>
            <ul class="mt-8 space-y-4">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">AI-powered agents:</strong> Handle WISMO inquiries, automate claims, and resolve issues proactively</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Copilot:</strong> Get real-time AI guidance to simplify workflows and make automation effortless</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Journey Manager:</strong> Design and optimize customer journeys with an intuitive self-service flow builder</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Service integration:</strong> Give agents a centralized view of order, tracking, and communication data</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Predict with AI -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div>
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Predict</span>
            <h2 class="text-heading text-[var(--ink)]">Predict with AI</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Anticipate customer needs and optimize operations with real-time data and machine learning so you're always one step ahead.
            </p>
            <ul class="mt-8 space-y-4">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Predictive delivery promises:</strong> AI-driven estimates with 92% precision to boost confidence and conversions</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Predictive delivery delays:</strong> Spot shipment delays before customers do and notify them proactively</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-[var(--ink-secondary)]"><strong class="text-[var(--ink)]">Better returns forecasting:</strong> Predict return volumes with 40% increased accuracy to optimize staffing</span>
              </li>
            </ul>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-10">
            <div class="flex flex-col items-center text-center">
              <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-[#3D3AD3]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              </div>
              <div class="text-sm font-medium text-[var(--ink-muted)]">Predictive Analytics</div>
              <div class="mt-2 text-2xl font-semibold text-[var(--ink)]">92% delivery precision</div>
              <div class="mt-1 text-sm text-[#035740]">AI-powered predictions across all carriers</div>
              <div class="mt-6 w-full rounded-xl bg-[var(--surface-sunken)] p-4">
                <div class="flex items-center justify-between text-sm">
                  <span class="text-[var(--ink-muted)]">Delivery accuracy</span>
                  <span class="font-medium text-[#3D3AD3]">92%</span>
                </div>
                <div class="mt-2 h-2 w-full rounded-full bg-[var(--line)]">
                  <div class="h-2 rounded-full bg-[#3D3AD3]" style="width: 92%"></div>
                </div>
                <div class="mt-4 flex items-center justify-between text-sm">
                  <span class="text-[var(--ink-muted)]">Returns forecast improvement</span>
                  <span class="font-medium text-[#035740]">+40%</span>
                </div>
                <div class="mt-2 h-2 w-full rounded-full bg-[var(--line)]">
                  <div class="h-2 rounded-full bg-[#035740]" style="width: 85%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Personalize with AI -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="order-2 md:order-1 rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-10">
            <div class="flex flex-col items-center text-center">
              <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-[#FFC943]/15">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <div class="text-sm font-medium text-[var(--ink-muted)]">Personalization Engine</div>
              <div class="mt-2 text-2xl font-semibold text-[var(--ink)]">Tailored for every customer</div>
              <div class="mt-1 text-sm text-[#035740]">160+ languages supported</div>
              <div class="mt-6 w-full space-y-3">
                <div class="flex items-center gap-3 rounded-xl bg-[var(--surface-sunken)] p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-sm text-[var(--ink-secondary)]">AI-generated emails in 160+ languages</span>
