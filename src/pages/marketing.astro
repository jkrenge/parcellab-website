---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Marketing the post-purchase customer experiences - parcelLab"
  description="Extend your brand and marketing through to the post-purchase experience and create a cohesive customer journey experience."
>
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Marketing"
      title="Turn every delivery into a marketing opportunity"
      description="Deliver 1:1 personalization and foster a deeper connection with your customers, cementing your brand at every step of the shopping journey."
      ctaText="Book a demo"
      ctaHref={`${import.meta.env.BASE_URL}/live-demo/`}
      secondaryCtaText="Take a tour"
      secondaryCtaHref={`${import.meta.env.BASE_URL}/product-tour/`}
    />

    <!-- Problem / Opportunity -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div>
            <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#FFC943]">The Opportunity</span>
            <h2 class="text-display text-[var(--ink)]">Turn every post-purchase touchpoint into brand growth</h2>
            <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
              Many brands struggle with generic carrier emails that dilute visibility and fragmented data hindering real-time insights. By optimizing post-purchase communication, you can transform these moments into powerful channels for upselling, cross-selling, and building customer loyalty.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6 text-center">
              <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/15">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <p class="text-sm font-semibold text-[var(--ink)]">Brand Consistency</p>
              <p class="mt-1 text-xs text-[var(--ink-muted)]">Own every touchpoint</p>
            </div>
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6 text-center">
              <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/15">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              </div>
              <p class="text-sm font-semibold text-[var(--ink)]">Revenue Growth</p>
              <p class="mt-1 text-xs text-[var(--ink-muted)]">Cross-sell & upsell</p>
            </div>
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6 text-center">
              <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/15">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <p class="text-sm font-semibold text-[var(--ink)]">1:1 Personalization</p>
              <p class="mt-1 text-xs text-[var(--ink-muted)]">Tailored journeys</p>
            </div>
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6 text-center">
              <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/15">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              </div>
              <p class="text-sm font-semibold text-[var(--ink)]">Campaign Insights</p>
              <p class="mt-1 text-xs text-[var(--ink-muted)]">Data-driven decisions</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How parcelLab helps -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mb-14 max-w-2xl">
          <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#FFC943]">How It Works</span>
          <h2 class="text-display text-[var(--ink)]">Marketing tools built for post-purchase</h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:border-[#FFC943]/30 hover:shadow-[0_4px_24px_rgba(255,201,67,0.08)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/12">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Create a cohesive brand experience</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Extend your brand presence through every post-purchase touchpoint with consistent messaging that reinforces your identity and builds trust.</p>
          </div>
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:border-[#FFC943]/30 hover:shadow-[0_4px_24px_rgba(255,201,67,0.08)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/12">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Boost repeat purchases</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Tailor emails and tracking pages with personalized recommendations for cross-selling and upselling opportunities that drive incremental revenue.</p>
          </div>
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:border-[#FFC943]/30 hover:shadow-[0_4px_24px_rgba(255,201,67,0.08)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/12">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">1:1 customer journeys</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Create multi-step nurture campaigns with relevant promotions tailored to each customer's behavior, preferences, and purchase history.</p>
          </div>
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:border-[#FFC943]/30 hover:shadow-[0_4px_24px_rgba(255,201,67,0.08)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FFC943]/12">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Maximize engagement & performance</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Use Campaign Manager to target important customer segments, measure campaign performance, and optimize based on real-time data.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Three Core Capabilities -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mb-14 max-w-2xl">
          <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#FFC943]">Capabilities</span>
          <h2 class="text-display text-[var(--ink)]">Three ways to unlock post-purchase marketing</h2>
        </div>
        <div class="grid gap-10 lg:grid-cols-3">
          <!-- Capability 1 -->
          <div class="rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm ring-1 ring-[var(--line)]">
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-[#f59e0b] to-[#FFC943]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Drive Revenue with Post-Purchase Communications</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">Build dynamic segments that update automatically and promote personalized offers throughout the customer journey.</p>
            <ul class="mt-5 space-y-2.5">
              <li class="flex items-start gap-2.5 text-sm text-[var(--ink-secondary)]">
                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Dynamic customer segmentation
              </li>
              <li class="flex items-start gap-2.5 text-sm text-[var(--ink-secondary)]">
                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Personalized offers in emails & tracking
              </li>
              <li class="flex items-start gap-2.5 text-sm text-[var(--ink-secondary)]">
                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Behavioral & demographic grouping
              </li>
            </ul>
          </div>

          <!-- Capability 2 -->
          <div class="rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm ring-1 ring-[var(--line)]">
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-[#3D3AD3] to-[#6360e8]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Personalize Post-Purchase Journeys</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">Embed personalized recommendations across emails and portals. Leverage the AI Email Editor and run A/B tests on subject lines, visuals, and CTAs.</p>
            <ul class="mt-5 space-y-2.5">
              <li class="flex items-start gap-2.5 text-sm text-[var(--ink-secondary)]">
                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                AI-powered email editor
              </li>
              <li class="flex items-start gap-2.5 text-sm text-[var(--ink-secondary)]">
                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                A/B testing on subject lines, visuals, CTAs
              </li>
              <li class="flex items-start gap-2.5 text-sm text-[var(--ink-secondary)]">
                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Embedded product recommendations
              </li>
            </ul>
          </div>

          <!-- Capability 3 -->
          <div class="rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm ring-1 ring-[var(--line)]">
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-[#035740] to-[#0d7a5f]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[var(--ink)]">Unlock New Marketing in Returns</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--ink-secondary)]">Use the embedded returns portal with campaign banners, encourage exchanges with smart recommendations, and offer incentives for store credit refunds.</p>
            <ul class="mt-5 space-y-2.5">
              <li class="flex items-start gap-2.5 text-sm text-[var(--ink-secondary)]">
                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Campaign banners in returns portal
              </li>
              <li class="flex items-start gap-2.5 text-sm text-[var(--ink-secondary)]">
                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Smart exchange recommendations
              </li>
              <li class="flex items-start gap-2.5 text-sm text-[var(--ink-secondary)]">
                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Store credit incentives
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mb-14 max-w-2xl">
          <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#FFC943]">Customer Stories</span>
          <h2 class="text-display text-[var(--ink)]">Marketing teams powered by parcelLab</h2>
        </div>
        <div class="grid gap-8 md:grid-cols-2">
          <div class="rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm">
            <svg class="mb-4 text-[var(--ink-muted)]" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" opacity="0.15"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">"parcelLab has been an incredibly proactive solutions provider... allowing us to leverage powerful tools to engage our customer base."</p>
            <div class="mt-6 border-t border-[var(--line)] pt-5">
              <p class="text-sm font-semibold text-[var(--ink)]">Veronica Lu</p>
              <p class="mt-0.5 text-xs text-[var(--ink-muted)]">Senior eCommerce Growth Marketer, Wyze</p>
            </div>
          </div>
          <div class="rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm">
            <svg class="mb-4 text-[var(--ink-muted)]" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" opacity="0.15"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">"With parcelLab, we have tailored shipping communication... and our request reaches customers when they're ready to evaluate and give feedback."</p>
            <div class="mt-6 border-t border-[var(--line)] pt-5">
              <p class="text-sm font-semibold text-[var(--ink)]">Deborah Kirchner</p>
              <p class="mt-0.5 text-xs text-[var(--ink-muted)]">Online Marketing Manager, Hessnatur</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
