---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";

const offices = [
  {
    city: "London",
    country: "United Kingdom",
    address: "Moor Place, 1 Fore Street Avenue, London, EC2Y 9DT",
    email: "info@parcellab.com",
    phone: "+44 2045256763",
    flag: "UK",
  },
  {
    city: "Boston",
    country: "United States",
    address: "75 State Street, Boston, MA 02109, USA",
    email: "info@parcellab.com",
    phone: "+1 9294506979",
    flag: "US",
  },
  {
    city: "Munich",
    country: "Germany",
    address: "Kapellenweg 6, 81371 Munich, Germany",
    email: "info@parcellab.com",
    phone: "+49 20657083068",
    flag: "DE",
  },
  {
    city: "Paris",
    country: "France",
    address: "24-26 Rue De la Pepiniere, 75008 Paris",
    email: "info@parcellab.com",
    phone: "+33 366883695",
    flag: "FR",
  },
];

const contactOptions = [
  {
    title: "Sales Support",
    desc: "Chat with our team to see how parcelLab can work for your business.",
    href: `${import.meta.env.BASE_URL}/live-demo/`,
    linkText: "Book a demo",
    icon: "message",
  },
  {
    title: "Press Inquiries",
    desc: "For media inquiries, interviews, or press kit requests.",
    href: "mailto:marketing@parcellab.com",
    linkText: "marketing@parcellab.com",
    icon: "newspaper",
  },
  {
    title: "Platform Tour",
    desc: "See the platform in action with a personalized tour.",
    href: `${import.meta.env.BASE_URL}/live-demo/`,
    linkText: "Take a tour",
    icon: "play",
  },
  {
    title: "Technical Support",
    desc: "Access our knowledge base and technical documentation.",
    href: "https://how.parcellab.works/docs",
    linkText: "Visit docs",
    icon: "code",
  },
];
---

<Layout title="Contact Us - parcelLab" description="Got a question? Need support? Or just want to chat about post-purchase magic? We're here for it. Contact parcelLab today.">
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Contact"
      title="We'd love to hear from you"
      description="Got a question? Need support? Or just want to chat about post-purchase magic? We're here for it. Whether you're looking for a platform tour, sales support, or tech help, we've got you covered."
    />

    <!-- Contact Options -->
    <section class="section-standard">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {contactOptions.map((option) => (
            <a
              href={option.href}
              class="group flex flex-col rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6 transition-all hover:border-[#3D3AD3]/20 hover:shadow-[0_4px_24px_rgba(61,58,211,0.08)]"
            >
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[#3D3AD3]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <h3 class="text-base font-semibold text-[var(--ink)]">{option.title}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-[var(--ink-secondary)]">{option.desc}</p>
              <span class="mt-4 text-sm font-medium text-[#3D3AD3] transition-colors group-hover:text-[#3D3AD3]/80">{option.linkText} &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact Form + Info -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="grid gap-12 lg:grid-cols-5">
          <!-- Form -->
          <div class="lg:col-span-3">
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Send Us a Message</span>
            <h2 class="text-display text-[var(--ink)]">Get in touch</h2>
            <p class="mt-3 text-[var(--ink-secondary)]">Fill out the form below and we'll get back to you within one business day.</p>

            <form class="mt-8 space-y-6" onsubmit="return false;">
              <div class="grid gap-6 sm:grid-cols-2">
                <div>
                  <label for="firstName" class="mb-2 block text-sm font-medium text-[var(--ink)]">First name *</label>
                  <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    required
                    class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20 transition-all"
                    placeholder="Jane"
                  />
                </div>
                <div>
                  <label for="lastName" class="mb-2 block text-sm font-medium text-[var(--ink)]">Last name *</label>
                  <input
                    type="text"
                    id="lastName"
                    name="lastName"
                    required
                    class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20 transition-all"
                    placeholder="Doe"
                  />
                </div>
              </div>
              <div>
                <label for="email" class="mb-2 block text-sm font-medium text-[var(--ink)]">Work email *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20 transition-all"
                  placeholder="jane@company.com"
                />
              </div>
              <div>
                <label for="company" class="mb-2 block text-sm font-medium text-[var(--ink)]">Company *</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  required
                  class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20 transition-all"
                  placeholder="Your company"
                />
              </div>
              <div>
                <label for="subject" class="mb-2 block text-sm font-medium text-[var(--ink)]">Subject</label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-3 text-sm text-[var(--ink)] focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20 transition-all"
                >
                  <option value="">Select a topic...</option>
                  <option value="sales">Sales inquiry</option>
                  <option value="support">Technical support</option>
                  <option value="partnership">Partnership</option>
                  <option value="press">Press inquiry</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="message" class="mb-2 block text-sm font-medium text-[var(--ink)]">Message *</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="w-full rounded-xl border border-[var(--line)] bg-[var(--surface-raised)] px-4 py-3 text-sm text-[var(--ink)] placeholder:text-[var(--ink-muted)] focus:border-[#3D3AD3] focus:outline-none focus:ring-2 focus:ring-[#3D3AD3]/20 transition-all resize-none"
                  placeholder="How can we help?"
                ></textarea>
              </div>
              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="privacy"
                  name="privacy"
                  class="mt-1 h-4 w-4 rounded border-[var(--line)] accent-[#3D3AD3]"
                />
                <label for="privacy" class="text-xs leading-relaxed text-[var(--ink-secondary)]">
                  I agree to the processing of my personal data in accordance with parcelLab's privacy policy. *
                </label>
              </div>
              <button
                type="submit"
                class="group inline-flex items-center gap-3 rounded-full bg-[#3D3AD3] py-4 pl-7 pr-6 text-base font-medium text-white shadow-[0_2px_16px_rgba(61,58,211,0.3)] transition-all hover:shadow-[0_4px_24px_rgba(61,58,211,0.4)] hover:-translate-y-0.5"
              >
                Send message
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>
            </form>
          </div>

          <!-- General Contact Info -->
          <div class="lg:col-span-2">
            <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">General</span>
            <h3 class="text-heading text-[var(--ink)]">Contact info</h3>
            <div class="mt-6 space-y-4">
              <div class="flex items-center gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#3D3AD3]/10">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div>
                  <p class="text-xs text-[var(--ink-muted)]">Email</p>
                  <a href="mailto:info@parcellab.com" class="text-sm font-medium text-[var(--ink)] hover:text-[#3D3AD3]">info@parcellab.com</a>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#3D3AD3]/10">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3D3AD3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div>
                  <p class="text-xs text-[var(--ink-muted)]">Press</p>
                  <a href="mailto:marketing@parcellab.com" class="text-sm font-medium text-[var(--ink)] hover:text-[#3D3AD3]">marketing@parcellab.com</a>
                </div>
              </div>
            </div>

            <div class="mt-10 border-t border-[var(--line)] pt-8">
              <h3 class="text-heading text-[var(--ink)]">Resources</h3>
              <ul class="mt-4 space-y-3">
                <li>
                  <a href="https://how.parcellab.works/docs" class="text-sm text-[var(--ink-secondary)] hover:text-[#3D3AD3] transition-colors">Knowledge Base &rarr;</a>
                </li>
                <li>
                  <a href={`${import.meta.env.BASE_URL}/live-demo/`} class="text-sm text-[var(--ink-secondary)] hover:text-[#3D3AD3] transition-colors">Book a Demo &rarr;</a>
                </li>
                <li>
                  <a href={`${import.meta.env.BASE_URL}/careers/`} class="text-sm text-[var(--ink-secondary)] hover:text-[#3D3AD3] transition-colors">Careers &rarr;</a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Office Locations -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mx-auto max-w-2xl text-center">
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#3D3AD3]">Locations</span>
          <h2 class="text-display text-[var(--ink)]">Our offices around the world</h2>
        </div>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {offices.map((office) => (
            <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-6">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--surface-sunken)] text-sm font-bold text-[var(--ink-secondary)]">
                {office.flag}
              </div>
              <h3 class="text-lg font-semibold text-[var(--ink)]">{office.city}</h3>
              <p class="text-sm text-[var(--ink-secondary)]">{office.country}</p>
              <p class="mt-3 text-sm leading-relaxed text-[var(--ink-muted)]">{office.address}</p>
              <div class="mt-4 space-y-1.5 border-t border-[var(--line)] pt-4">
                <p class="text-xs text-[var(--ink-secondary)]">
                  <span class="text-[var(--ink-muted)]">Phone:</span> {office.phone}
                </p>
                <p class="text-xs text-[var(--ink-secondary)]">
                  <span class="text-[var(--ink-muted)]">Email:</span>{" "}
                  <a href={`mailto:${office.email}`} class="hover:text-[#3D3AD3]">{office.email}</a>
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
