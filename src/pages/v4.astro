<style>
  /* ─── Hero Rotating Words ─── */
  .v4-rotating-wrapper {
    display: inline-block;
    position: relative;
    width: 5.5em;
    height: 1.15em;
    vertical-align: bottom;
    overflow: hidden;
  }

  .v4-rotating-word {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    display: block;
    opacity: 0;
    transform: translateY(40%);
    animation: v4-rotate-word 12s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  .v4-rotating-word:nth-child(1) { animation-delay: 0s; }
  .v4-rotating-word:nth-child(2) { animation-delay: 3s; }
  .v4-rotating-word:nth-child(3) { animation-delay: 6s; }
  .v4-rotating-word:nth-child(4) { animation-delay: 9s; }

  @keyframes v4-rotate-word {
    0%, 2% {
      opacity: 0;
      transform: translateY(40%);
    }
    5%, 20% {
      opacity: 1;
      transform: translateY(0);
    }
    23%, 25% {
      opacity: 0;
      transform: translateY(-40%);
    }
    100% {
      opacity: 0;
      transform: translateY(-40%);
    }
  }

  /* ─── Product Tabs ─── */
  .v4-tab-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-secondary);
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    user-select: none;
  }

  .v4-tab-label:hover {
    color: var(--ink);
    background-color: var(--surface-sunken);
  }

  .v4-tab-content {
    opacity: 0;
    visibility: hidden;
    position: absolute;
    width: 100%;
    transition: opacity 0.35s ease, visibility 0.35s ease;
  }

  /* ─── Scroll Reveal: Pain Point Cards ─── */
  .v4-reveal-card {
    opacity: 0;
    transform: translateY(24px);
    animation: v4-reveal 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
  }

  .v4-reveal-card.v4-visible {
    animation-play-state: running;
  }

  @keyframes v4-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ─── Stats Fade In ─── */
  .v4-stat-item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .v4-stats-grid.v4-visible .v4-stat-item {
    opacity: 1;
    transform: translateY(0);
  }

  .v4-stats-grid.v4-visible .v4-stat-item:nth-child(2) {
    transition-delay: 0.15s;
  }

  .v4-stats-grid.v4-visible .v4-stat-item:nth-child(3) {
    transition-delay: 0.3s;
  }

  /* ─── Feature Slide In ─── */
  .v4-slide-in-left {
    opacity: 0;
    transform: translateX(-32px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .v4-slide-in-right {
    opacity: 0;
    transform: translateX(32px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .v4-feature-row.v4-visible .v4-slide-in-left,
  .v4-feature-row.v4-visible .v4-slide-in-right {
    opacity: 1;
    transform: translateX(0);
  }

  /* ─── Case Study Cards ─── */
  .v4-case-card {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .v4-case-card.v4-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .v4-case-card.v4-visible:nth-child(2) {
    transition-delay: 0.12s;
  }

  .v4-case-card.v4-visible:nth-child(3) {
    transition-delay: 0.24s;
  }

  /* ─── Reduced Motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .v4-rotating-word {
      animation: none;
    }

    .v4-rotating-word:first-child {
      opacity: 1;
      transform: translateY(0);
    }

    .v4-reveal-card,
    .v4-stat-item,
    .v4-slide-in-left,
    .v4-slide-in-right,
    .v4-case-card {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }

    .v4-tab-content {
      transition: none;
    }
  }
</style>

<script>
  // Intersection Observer for scroll-triggered animations
  function initScrollAnimations() {
    const observerOptions: IntersectionObserverInit = {
      threshold: 0.15,
      rootMargin: '0px 0px -40px 0px',
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('v4-visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Pain point cards
    document.querySelectorAll('.v4-reveal-card').forEach((el) => observer.observe(el));

    // Stats section
    document.querySelectorAll('.v4-stats-grid').forEach((el) => observer.observe(el));

    // Feature rows
    document.querySelectorAll('.v4-feature-row').forEach((el) => observer.observe(el));

    // Case study cards
    document.querySelectorAll('.v4-case-card').forEach((el) => observer.observe(el));
  }

  // Check for reduced motion preference
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollAnimations);
    } else {
      initScrollAnimations();
    }
  } else {
    // If reduced motion, make everything visible immediately
    document.querySelectorAll('.v4-reveal-card, .v4-stats-grid, .v4-feature-row, .v4-case-card, .v4-stat-item, .v4-slide-in-left, .v4-slide-in-right').forEach((el) => {
      (el as HTMLElement).style.opacity = '1';
      (el as HTMLElement).style.transform = 'none';
    });
  }
</script>
