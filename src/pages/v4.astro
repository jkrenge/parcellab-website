    transform: translateY(-2px);
  }

  /* ═══════════════════════════════════════════════════════════
     PRODUCT TABS
     ═══════════════════════════════════════════════════════════ */

  .v4-tab-bar {
    position: relative;
  }

  .v4-tab-indicator {
    position: absolute;
    top: 6px;
    left: 6px;
    width: calc(33.333% - 4px);
    height: calc(100% - 12px);
    border-radius: 9999px;
    background: linear-gradient(135deg, #3D3AD3, #4a47e8);
    box-shadow: 0 2px 12px rgba(61, 58, 211, 0.4);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 0;
  }

  :has(#tab-returns:checked) .v4-tab-indicator {
    transform: translateX(100%);
  }

  :has(#tab-convert:checked) .v4-tab-indicator {
    transform: translateX(200%);
  }

  .v4-tab-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-secondary);
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    user-select: none;
  }

  .v4-tab-label:hover {
    color: var(--ink);
  }

  /* Tab backgrounds */
  .v4-tab-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }

  .v4-tab-bg-tracking { background: radial-gradient(ellipse 80% 60% at 50% 60%, rgba(61, 58, 211, 0.04) 0%, transparent 70%); }
  .v4-tab-bg-returns { background: radial-gradient(ellipse 80% 60% at 50% 60%, rgba(3, 87, 64, 0.04) 0%, transparent 70%); }
  .v4-tab-bg-convert { background: radial-gradient(ellipse 80% 60% at 50% 60%, rgba(255, 201, 67, 0.06) 0%, transparent 70%); }

  .v4-tab-content {
    opacity: 0;
    visibility: hidden;
    position: absolute;
    width: 100%;
    transform: scale(0.96);
    filter: blur(4px);
    transition: opacity 0.45s ease, visibility 0.45s ease, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), filter 0.45s ease;
  }

  .v4-tab-content.v4-tab-active,
  .v4-tab-content:where(.peer-checked\/tracking &, .peer-checked\/returns &, .peer-checked\/convert &) {
    /* fallback: the actual activation is driven by the peer-checked utilities below */
  }

  /* Glass card */
  .v4-glass-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.06),
      0 0 0 1px rgba(255, 255, 255, 0.1) inset;
    overflow: hidden;
    position: relative;
  }

  .v4-glass-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1), rgba(61,58,211,0.1), rgba(255,255,255,0.2));
    background-size: 300% 300%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: v4-border-flow 6s ease infinite;
    pointer-events: none;
  }

  @keyframes v4-border-flow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Animated progress bar */
  .v4-animated-progress-bar {
    background: linear-gradient(90deg, #3D3AD3, #6366f1, #3D3AD3);
    background-size: 200% 100%;
    animation: v4-progress-shimmer 2s ease infinite;
  }

  @keyframes v4-progress-shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  /* Animated bars in charts */
  .v4-animate-bar {
    width: 0;
    animation: v4-bar-grow 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
  }

  .v4-feature-row.v4-visible .v4-animate-bar {
