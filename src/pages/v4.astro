  .v4-integration-badge:hover {
    border-color: #3D3AD3;
    background: rgba(61, 58, 211, 0.05);
    color: #3D3AD3;
    box-shadow: 0 0 12px rgba(61, 58, 211, 0.1);
  }

  /* 175+ carriers pulse */
  .v4-carrier-pulse {
    display: inline-flex;
    align-items: center;
    border-radius: 0.5rem;
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #3D3AD3;
    background: rgba(61, 58, 211, 0.05);
    border: 1px solid rgba(61, 58, 211, 0.2);
    animation: v4-pulse-glow 3s ease-in-out infinite;
  }

  @keyframes v4-pulse-glow {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(61, 58, 211, 0.15);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(61, 58, 211, 0);
    }
  }

  /* ═══════════════════════════════════════════════════════════
     CTA SECTION
     ═══════════════════════════════════════════════════════════ */

  .v4-cta-section {
    background: #0f0f23;
  }

  .v4-cta-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 30% 40%, rgba(61, 58, 211, 0.3) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 70% 60%, rgba(3, 87, 64, 0.2) 0%, transparent 60%);
    animation: v4-cta-shift 12s ease-in-out infinite alternate;
  }

  @keyframes v4-cta-shift {
    0% { opacity: 1; }
    100% { opacity: 0.6; transform: scale(1.05) translateX(2%); }
  }

  /* ═══════════════════════════════════════════════════════════
     SCROLL REVEAL + FEATURE ANIMATIONS
     ═══════════════════════════════════════════════════════════ */

  .v4-reveal-card {
    opacity: 0;
    transform: translateY(24px);
    animation: v4-reveal 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
  }

  .v4-reveal-card.v4-visible {
    animation-play-state: running;
  }

  @keyframes v4-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .v4-slide-in-left {
    opacity: 0;
    transform: translateX(-32px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .v4-slide-in-right {
    opacity: 0;
    transform: translateX(32px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .v4-feature-row.v4-visible .v4-slide-in-left,
  .v4-feature-row.v4-visible .v4-slide-in-right {
    opacity: 1;
    transform: translateX(0);
  }

  /* ═══════════════════════════════════════════════════════════
     3D TILT EFFECT
     ═══════════════════════════════════════════════════════════ */

  .v4-tilt-card {
    transition: transform 0.3s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* ═══════════════════════════════════════════════════════════
     TAB CONTENT ACTIVATION (using Astro-compatible CSS)
     We must override inline from peer-checked pseudo-classes
     ═══════════════════════════════════════════════════════════ */

  :has(#tab-tracking:checked) .peer-checked\/tracking\:v4-tab-active,
  :has(#tab-returns:checked) .peer-checked\/returns\:v4-tab-active,
  :has(#tab-convert:checked) .peer-checked\/convert\:v4-tab-active {
    opacity: 1;
    visibility: visible;
    position: relative;
    transform: scale(1);
    filter: blur(0px);
  }

  :has(#tab-tracking:checked) .peer-checked\/tracking\:opacity-100,
  :has(#tab-returns:checked) .peer-checked\/returns\:opacity-100,
  :has(#tab-convert:checked) .peer-checked\/convert\:opacity-100 {
    opacity: 1;
  }

  :has(#tab-tracking:checked) .peer-checked\/tracking\:text-white,
  :has(#tab-returns:checked) .peer-checked\/returns\:text-white,
  :has(#tab-convert:checked) .peer-checked\/convert\:text-white {
    color: white;
  }

  /* ═══════════════════════════════════════════════════════════
     REDUCED MOTION
     ═══════════════════════════════════════════════════════════ */

  @media (prefers-reduced-motion: reduce) {
    .v4-rotating-word {
      animation: none;
      filter: none;
    }

    .v4-rotating-word:first-child {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: none;
    }

    .v4-rotating-word::after {
      animation: none;
    }

    .v4-reveal-card,
    .v4-stat-item,
    .v4-slide-in-left,
    .v4-slide-in-right,
    .v4-case-card {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }

    .v4-tab-content {
      transition: none;
      filter: none;
      transform: none;
    }

    .v4-mesh-bg,
    .v4-orb,
    .v4-stats-mesh-bg,
    .v4-cta-gradient {
      animation: none;
    }

    .v4-animated-progress-bar {
      animation: none;
      background: #3D3AD3;
    }

    .v4-star {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .v4-animate-bar {
      animation: none;
      width: var(--bar-width);
    }

    .v4-carrier-pulse {
      animation: none;
    }

    .v4-glass-card::before {
      animation: none;
    }

    .v4-tilt-card {
      transform: none !important;
    }

    .v4-stat-number,
    .v4-gradient-stat-1,
    .v4-gradient-stat-2,
    .v4-gradient-stat-3 {
      animation: none;
    }
  }
</style>

<script>
  // ─── 3D Tilt Effect ───
  function initTiltCards() {
    const cards = document.querySelectorAll('.v4-tilt-card');
    cards.forEach((card) => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = ((y - centerY) / centerY) * -4;
        const rotateY = ((x - centerX) / centerX) * 4;
        el.style.transform = `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg)';
      });
    });
  }

  // ─── Intersection Observer for scroll-triggered animations ───
  function initScrollAnimations() {
    const observerOptions: IntersectionObserverInit = {
      threshold: 0.15,
      rootMargin: '0px 0px -40px 0px',
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('v4-visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Pain point cards
    document.querySelectorAll('.v4-reveal-card').forEach((el) => observer.observe(el));

    // Stats section
    document.querySelectorAll('.v4-stats-grid').forEach((el) => observer.observe(el));

    // Feature rows
    document.querySelectorAll('.v4-feature-row').forEach((el) => observer.observe(el));

    // Case study cards
    document.querySelectorAll('.v4-case-card').forEach((el) => observer.observe(el));
  }

  // ─── Stat counter animation ───
  function initStatCounters() {
    const statsGrid = document.querySelector('.v4-stats-grid');
    if (!statsGrid) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const numbers = entry.target.querySelectorAll('.v4-stat-number');
          numbers.forEach((numEl) => {
            const target = parseInt((numEl as HTMLElement).dataset.target || '0', 10);
            let current = 0;
            const duration = 1500;
            const startTime = performance.now();
            const step = (now: number) => {
              const elapsed = now - startTime;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              current = Math.round(eased * target);
              numEl.textContent = current + '%';
              if (progress < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    observer.observe(statsGrid);
  }

  // ─── Icon bounce on hover ───
  function initIconBounce() {
    document.querySelectorAll('.v4-icon-glow').forEach((icon) => {
      icon.addEventListener('mouseenter', () => {
        (icon as HTMLElement).style.animation = 'none';
        void (icon as HTMLElement).offsetHeight;
        (icon as HTMLElement).style.animation = 'v4-icon-bounce 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
      });
    });
  }

  // Add bounce keyframes dynamically
  const bounceStyle = document.createElement('style');
  bounceStyle.textContent = `
    @keyframes v4-icon-bounce {
      0% { transform: scale(1.05); }
      40% { transform: scale(1.15); }
      60% { transform: scale(0.95); }
      100% { transform: scale(1.05); }
    }
  `;
  document.head.appendChild(bounceStyle);

  // Check for reduced motion preference
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        initScrollAnimations();
        initTiltCards();
        initStatCounters();
        initIconBounce();
      });
    } else {
      initScrollAnimations();
      initTiltCards();
      initStatCounters();
      initIconBounce();
    }
  } else {
    // If reduced motion, make everything visible immediately
    document.querySelectorAll('.v4-reveal-card, .v4-stats-grid, .v4-feature-row, .v4-case-card, .v4-stat-item, .v4-slide-in-left, .v4-slide-in-right').forEach((el) => {
      (el as HTMLElement).style.opacity = '1';
      (el as HTMLElement).style.transform = 'none';
    });
  }
</script>
