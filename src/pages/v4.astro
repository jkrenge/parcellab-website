<style>
  /* ═══════════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════════ */

  .v4-hero {
    background: var(--surface);
  }

  .v4-mesh-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 20%, rgba(61, 58, 211, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 30%, rgba(3, 87, 64, 0.06) 0%, transparent 55%),
      radial-gradient(ellipse 70% 60% at 50% 80%, rgba(255, 201, 67, 0.05) 0%, transparent 50%);
    animation: v4-mesh-shift 20s ease-in-out infinite alternate;
  }

  @keyframes v4-mesh-shift {
    0% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05) translateX(2%); }
    100% { opacity: 1; transform: scale(1) translateX(-1%); }
  }

  .v4-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .v4-orb-1 {
    width: 400px;
    height: 400px;
    background: rgba(61, 58, 211, 0.12);
    top: -10%;
    left: -5%;
    animation: v4-float-1 25s ease-in-out infinite;
  }

  .v4-orb-2 {
    width: 300px;
    height: 300px;
    background: rgba(3, 87, 64, 0.08);
    top: 30%;
    right: -5%;
    animation: v4-float-2 30s ease-in-out infinite;
  }

  .v4-orb-3 {
    width: 250px;
    height: 250px;
    background: rgba(255, 201, 67, 0.08);
    bottom: -5%;
    left: 30%;
    animation: v4-float-3 22s ease-in-out infinite;
  }

  @keyframes v4-float-1 {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(40px, 30px); }
    66% { transform: translate(-20px, 50px); }
  }

  @keyframes v4-float-2 {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(-30px, -40px); }
    66% { transform: translate(20px, -20px); }
  }

  @keyframes v4-float-3 {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(50px, -20px); }
    66% { transform: translate(-30px, 30px); }
  }

  /* Hero headline */
  .v4-hero-headline {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  /* ─── Hero Rotating Words ─── */
  .v4-rotating-wrapper {
    display: inline-block;
    position: relative;
    width: 5.5em;
    height: 1.15em;
    vertical-align: bottom;
    overflow: hidden;
  }

  .v4-rotating-word {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    display: block;
    opacity: 0;
    filter: blur(8px);
    transform: translateY(40%) scale(0.9);
    background: linear-gradient(135deg, #3D3AD3 0%, #6366f1 40%, #818cf8 70%, #3D3AD3 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation:
      v4-rotate-word 12s cubic-bezier(0.4, 0, 0.2, 1) infinite,
      v4-gradient-flow 4s ease infinite;
  }

  .v4-rotating-word::after {
    content: '';
    position: absolute;
    inset: -10px -20px;
    background: radial-gradient(ellipse, rgba(61, 58, 211, 0.3) 0%, transparent 70%);
    filter: blur(20px);
    z-index: -1;
    opacity: 0;
    animation: v4-glow-pulse 12s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  .v4-rotating-word:nth-child(1) { animation-delay: 0s, 0s; }
  .v4-rotating-word:nth-child(1)::after { animation-delay: 0s; }
  .v4-rotating-word:nth-child(2) { animation-delay: 3s, 0s; }
  .v4-rotating-word:nth-child(2)::after { animation-delay: 3s; }
  .v4-rotating-word:nth-child(3) { animation-delay: 6s, 0s; }
  .v4-rotating-word:nth-child(3)::after { animation-delay: 6s; }
  .v4-rotating-word:nth-child(4) { animation-delay: 9s, 0s; }
  .v4-rotating-word:nth-child(4)::after { animation-delay: 9s; }

  @keyframes v4-rotate-word {
    0%, 2% {
      opacity: 0;
      filter: blur(8px);
      transform: translateY(40%) scale(0.9);
    }
    5%, 20% {
      opacity: 1;
      filter: blur(0px);
      transform: translateY(0) scale(1);
    }
    22% {
      transform: translateY(0) scale(1.03);
    }
    23%, 25% {
      opacity: 0;
      filter: blur(8px);
      transform: translateY(-40%) scale(0.9);
    }
    100% {
      opacity: 0;
      filter: blur(8px);
      transform: translateY(-40%) scale(0.9);
    }
  }

  @keyframes v4-glow-pulse {
    0%, 2% { opacity: 0; }
    5%, 20% { opacity: 1; }
    23%, 100% { opacity: 0; }
  }

  @keyframes v4-gradient-flow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Trust text gradient */
  .v4-trust-text {
    color: var(--ink-muted);
  }

  .v4-gradient-text-trust {
    background: linear-gradient(135deg, #3D3AD3, #6366f1);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Star sequential animation */
  .v4-star {
    opacity: 0;
    transform: scale(0) rotate(-30deg);
    animation: v4-star-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .v4-star:nth-child(1) { animation-delay: 0.5s; }
  .v4-star:nth-child(2) { animation-delay: 0.65s; }
  .v4-star:nth-child(3) { animation-delay: 0.8s; }
  .v4-star:nth-child(4) { animation-delay: 0.95s; }
  .v4-star:nth-child(5) { animation-delay: 1.1s; }

  @keyframes v4-star-pop {
    to {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  /* ═══════════════════════════════════════════════════════════
     BUTTONS
     ═══════════════════════════════════════════════════════════ */

  .v4-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 9999px;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
