  /* ═══════════════════════════════════════════════════════════
     STATS SECTION
     ═══════════════════════════════════════════════════════════ */

  .v4-stats-section {
    background: #1a1a2e;
  }

  .v4-stats-mesh-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 30%, rgba(61, 58, 211, 0.4) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 80% 70%, rgba(3, 87, 64, 0.3) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 50% 50%, rgba(255, 201, 67, 0.15) 0%, transparent 60%);
