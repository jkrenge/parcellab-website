     KEYFRAMES
     ══════════════════════════════════════════════════════ */
  @keyframes v6OrbDrift1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.05); }
    66% { transform: translate(-20px, 15px) scale(0.95); }
  }
  @keyframes v6OrbDrift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-40px, 25px) scale(1.08); }
    66% { transform: translate(25px, -30px) scale(0.92); }
  }
  @keyframes v6OrbDrift3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(35px, 20px) scale(1.1); }
  }
  @keyframes v6GradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  @keyframes v6ScanLine {
    0% { transform: translateY(0); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(500px); opacity: 0; }
  }
  @keyframes v6Pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  @keyframes v6PulseScale {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
  }
  @keyframes v6BarGrow {
    from { width: 0; }
    to { width: var(--bar-width, 0%); }
  }
  @keyframes v6ShimmerBorder {
    0% { background-position: 0% 0%; }
    50% { background-position: 0% 100%; }
    100% { background-position: 0% 0%; }
  }
  @keyframes v6TimelineGradient {
    0% { background-position: 50% 0%; }
    50% { background-position: 50% 100%; }
    100% { background-position: 50% 0%; }
  }
  @keyframes v6DotPulse {
    0% { box-shadow: 0 0 0 0 rgba(3,87,64,0.4); }
    100% { box-shadow: 0 0 0 8px rgba(3,87,64,0); }
  }
  @keyframes v6CellWave {
    0%, 100% { opacity: var(--cell-base-opacity); }
    50% { opacity: 1; box-shadow: 0 0 4px var(--cell-color); }
  }
  @keyframes v6FadeInUp {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes v6FadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes v6FloatIn {
    from { opacity: 0; transform: translateY(20px) scale(0.9); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes v6SlideInLeft {
    from { opacity: 0; transform: translateX(-40px); filter: blur(4px); }
    to { opacity: 1; transform: translateX(0); filter: blur(0); }
  }
  @keyframes v6SpringIn {
    0% { opacity: 0; transform: translateY(40px) scale(0.9); }
    60% { transform: translateY(-4px) scale(1.01); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes v6CheckDraw {
    from { stroke-dashoffset: 20; }
    to { stroke-dashoffset: 0; }
  }

  /* ══════════════════════════════════════════════════════
     ANIMATIONS (prefers-reduced-motion)
     ══════════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: no-preference) {
    .v6-hero-content {
      animation: v6FadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .v6-trust-pill {
      animation: v6SpringIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .v6-trust-pill:nth-child(1) { animation-delay: 0.5s; }
    .v6-trust-pill:nth-child(2) { animation-delay: 0.65s; }
    .v6-trust-pill:nth-child(3) { animation-delay: 0.8s; }
    .v6-trust-pill:nth-child(4) { animation-delay: 0.95s; }

    .v6-hero-viz {
      animation: v6FadeIn 1.2s 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .v6-float-card {
      animation: v6FloatIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .v6-dataviz-cell {
      animation: v6CellWave 3s ease-in-out infinite;
      animation-delay: var(--cell-delay, 0ms);
    }

    .v6-dash-kpi {
      animation: v6FadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 30%;
    }
    .v6-dash-chart {
      animation: v6FadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 30%;
    }

    .v6-product-card {
      animation: v6SlideInLeft 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 25%;
    }

    .v6-journey-step {
      animation: v6FadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 40%;
    }

    .v6-timeline-entry {
      animation: v6SpringIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 30%;
    }

    .v6-security-card {
      animation: v6FadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 30%;
    }

    .v6-metric-item {
      animation: v6FadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 40%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .v6-orb,
    .v6-cta-orb,
    .v6-scan-line,
    .v6-shimmer-border,
    .v6-animated-border-pill,
    .v6-metrics-bg-gradient,
    .v6-timeline-line,
    .v6-dashboard-border,
    .v6-btn-primary,
    .v6-cta-section,
    .v6-metric-underline {
      animation: none !important;
    }
    .v6-pulse-dot,
    .v6-pulse-indicator,
    .v6-live-dot {
      animation: none !important;
    }
    .v6-dataviz-cell {
      animation: none !important;
    }
    .v6-bar {
      animation: none !important;
      width: var(--bar-width, 0%) !important;
    }
  }

  /* Scrollbar-none utility */
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
</style>

<!-- ════════════════════════════════════════════════════════════════
     SCRIPTS
     ════════════════════════════════════════════════════════════════ -->
<script>
  // ── Hero Data Visualization with wave animation + gradient colors ──
  (function buildHeroViz() {
    const container = document.getElementById("heroDataViz");
    if (!container) return;

    const cols = 28;
    const rows = 20;
    const total = cols * rows;
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const regions = [
      { colMin: 13, colMax: 17, rowMin: 3, rowMax: 8, intensity: 0.9 },
      { colMin: 2, colMax: 9, rowMin: 3, rowMax: 9, intensity: 0.7 },
      { colMin: 18, colMax: 26, rowMin: 3, rowMax: 11, intensity: 0.65 },
      { colMin: 6, colMax: 10, rowMin: 11, rowMax: 17, intensity: 0.5 },
      { colMin: 12, colMax: 17, rowMin: 9, rowMax: 16, intensity: 0.45 },
      { colMin: 22, colMax: 26, rowMin: 13, rowMax: 17, intensity: 0.4 },
    ];

    function getIntensity(col: number, row: number): number {
      let maxI = 0.08;
      for (const r of regions) {
        if (col >= r.colMin && col <= r.colMax && row >= r.rowMin && row <= r.rowMax) {
          maxI = Math.max(maxI, r.intensity);
        }
      }
      return maxI;
    }

    // Gradient color scheme: green -> blue -> purple across the grid
    function getCellColor(col: number, row: number): string {
      const t = col / cols;
      if (t < 0.33) {
        return `hsl(${155 + t * 30}, 70%, ${35 + Math.random() * 15}%)`;
      } else if (t < 0.66) {
        return `hsl(${220 + (t - 0.33) * 60}, 65%, ${40 + Math.random() * 15}%)`;
      } else {
        return `hsl(${260 + (t - 0.66) * 40}, 55%, ${45 + Math.random() * 15}%)`;
      }
    }

    const fragment = document.createDocumentFragment();

    for (let i = 0; i < total; i++) {
      const col = i % cols;
      const row = Math.floor(i / cols);
      const intensity = getIntensity(col, row);
      const jitter = Math.random() * 0.3;
      const finalOpacity = Math.max(0.04, intensity * (0.6 + jitter));

      const cell = document.createElement("div");
      cell.className = "v6-dataviz-cell";

      const color = getCellColor(col, row);
      cell.style.backgroundColor = color;
      cell.style.opacity = String(finalOpacity);
      cell.style.setProperty("--cell-color", color);
      cell.style.setProperty("--cell-base-opacity", String(finalOpacity));

      if (!prefersReduced) {
        // Wave pattern delay based on position
        const waveDelay = (col * 80) + (row * 40);
        cell.style.setProperty("--cell-delay", `${waveDelay}ms`);
      }

      fragment.appendChild(cell);
    }
    container.appendChild(fragment);
  })();

  // ── Counter animation with glow ──
  (function initCounters() {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const counters = document.querySelectorAll<HTMLElement>(".v6-counter");

    if (prefersReduced) {
      counters.forEach((el) => {
        const target = parseInt(el.dataset.target || "0", 10);
        const suffix = el.dataset.suffix || "";
        el.textContent = target + suffix;
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);

          const target = parseInt(el.dataset.target || "0", 10);
          const suffix = el.dataset.suffix || "";
          const duration = 2000;
          const start = performance.now();

          function tick(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = Math.round(eased * target);
            el.textContent = current + suffix;
            if (progress < 1) {
              requestAnimationFrame(tick);
            }
          }
          requestAnimationFrame(tick);
        });
      },
      { threshold: 0.3 }
    );

    counters.forEach((el) => observer.observe(el));
  })();

  // ── Bar chart animation ──
  (function initBars() {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReduced) return;

    const bars = document.querySelectorAll<HTMLElement>(".v6-bar");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);
          el.classList.add("v6-bar-animate");
        });
      },
      { threshold: 0.2 }
    );
    bars.forEach((el) => observer.observe(el));
  })();

  // ── Journey line fill animation ──
  (function initJourneyLine() {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const lineFill = document.querySelector<HTMLElement>(".v6-journey-line-fill");
    const circles = document.querySelectorAll<HTMLElement>(".v6-journey-circle");
    if (!lineFill) return;

    if (prefersReduced) {
      lineFill.style.width = "100%";
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);
          lineFill.style.width = "100%";
          // Sequentially activate circles
          circles.forEach((circle, i) => {
            setTimeout(() => {
              circle.closest(".v6-journey-step")?.classList.add("v6-step-active");
            }, 200 * (i + 1));
          });
        });
      },
      { threshold: 0.2 }
    );
    observer.observe(lineFill.closest(".v6-journey-track") || lineFill);
  })();

  // ── Timeline dot pulse animation ──
  (function initTimelineDots() {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReduced) return;

    const dots = document.querySelectorAll<HTMLElement>(".v6-timeline-dot");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);
          el.classList.add("v6-dot-pulse");
        });
      },
      { threshold: 0.5 }
    );
    dots.forEach((el) => observer.observe(el));
  })();

  // ── Security checkmark draw-in animation ──
  (function initCheckmarks() {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const checkmarks = document.querySelectorAll<HTMLElement>(".v6-checkmark");

    if (prefersReduced) {
      checkmarks.forEach((el) => el.classList.add("v6-check-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);
          setTimeout(() => el.classList.add("v6-check-visible"), 300);
        });
      },
      { threshold: 0.5 }
    );
    checkmarks.forEach((el) => observer.observe(el));
  })();

  // ── Scroll-based fallback animations (for browsers without animation-timeline) ──
  (function initScrollAnimations() {
    const supportsTimeline = CSS.supports("animation-timeline", "view()");
    if (supportsTimeline) return;

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReduced) return;

    const selectors = [
      ".v6-dash-kpi",
      ".v6-dash-chart",
      ".v6-product-card",
      ".v6-journey-step",
      ".v6-timeline-entry",
      ".v6-security-card",
      ".v6-metric-item",
    ];

    const elements = document.querySelectorAll<HTMLElement>(selectors.join(","));

    elements.forEach((el) => {
      el.style.opacity = "0";
      el.style.transform = "translateY(30px) scale(0.97)";
      el.style.filter = "blur(2px)";
      el.style.transition = "opacity 0.7s cubic-bezier(0.22,1,0.36,1), transform 0.7s cubic-bezier(0.22,1,0.36,1), filter 0.7s ease";
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);

          const parent = el.parentElement;
          if (parent) {
            const siblings = Array.from(parent.children);
            const index = siblings.indexOf(el);
            el.style.transitionDelay = `${index * 100}ms`;
          }

          el.style.opacity = "1";
          el.style.transform = "translateY(0) scale(1)";
          el.style.filter = "blur(0)";
        });
      },
      { threshold: 0.1 }
    );

    elements.forEach((el) => observer.observe(el));
  })();
</script>
