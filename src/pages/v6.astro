---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";
const b = import.meta.env.BASE_URL;
---

<Layout title="parcelLab — The Enterprise Post-Purchase Command Center">
  <Header client:load />
  <main>
    <!-- ════════════════════════════════════════════════════════════════
         SECTION 1 — HERO (Premium gradient + mesh + floating orbs)
         ════════════════════════════════════════════════════════════════ -->
    <section class="v6-hero relative overflow-hidden" style="padding-top: clamp(7rem, 12vw, 10rem); padding-bottom: clamp(5rem, 8vw, 8rem);">
      <!-- Animated mesh gradient background -->
      <div class="v6-hero-mesh pointer-events-none absolute inset-0 -z-10" aria-hidden="true"></div>
      <!-- Dot pattern overlay -->
      <div class="v6-hero-dots pointer-events-none absolute inset-0 -z-5" aria-hidden="true"></div>
      <!-- Floating orbs -->
      <div class="v6-orb v6-orb--1 pointer-events-none absolute -z-5" aria-hidden="true"></div>
      <div class="v6-orb v6-orb--2 pointer-events-none absolute -z-5" aria-hidden="true"></div>
      <div class="v6-orb v6-orb--3 pointer-events-none absolute -z-5" aria-hidden="true"></div>
      <div class="v6-orb v6-orb--4 pointer-events-none absolute -z-5" aria-hidden="true"></div>

      <div class="container-pl relative z-10">
        <div class="grid items-center gap-12 lg:grid-cols-[1fr_480px] xl:grid-cols-[1fr_520px]">
          <!-- Left: copy -->
          <div class="v6-hero-content">
            <h1 class="v6-hero-headline mb-6" style="font-size: clamp(3rem, 5.5vw, 4.5rem); font-weight: 700; line-height: 1.04; letter-spacing: -0.035em;">
              <span class="v6-gradient-text-hero">The post-purchase platform</span><br/>
              <span style="color: white;">that scales with you</span>
            </h1>
            <p class="mb-8 max-w-xl text-lg leading-relaxed text-white/70">
              From startup to global enterprise, parcelLab powers every delivery, return, and customer touchpoint — with the security, reliability, and integrations you need.
            </p>
            <!-- Trust badges with animated borders -->
            <div class="mb-10 flex flex-wrap items-center gap-3 v6-trust-badges">
              <span class="v6-trust-pill v6-animated-border-pill">
                <span class="v6-pill-inner">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  SOC 2 Type II
                </span>
              </span>
              <span class="v6-trust-pill v6-animated-border-pill">
                <span class="v6-pill-inner">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  GDPR Compliant
                </span>
              </span>
              <span class="v6-trust-pill v6-animated-border-pill">
                <span class="v6-pill-inner">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  99.9% Uptime
                </span>
              </span>
              <span class="v6-trust-pill v6-animated-border-pill">
                <span class="v6-pill-inner">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  ISO 27001
                </span>
              </span>
            </div>
            <!-- CTAs with gradient hover -->
            <div class="flex flex-wrap items-center gap-4">
              <a href={`${b}/contact-us/`} class="v6-btn-primary inline-flex items-center gap-2 rounded-lg px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-emerald-900/30">
                Schedule a consultation
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href={`${b}/contact-us/`} class="v6-btn-secondary inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/5 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/40 hover:bg-white/10">
                See pricing
              </a>
            </div>
          </div>

          <!-- Right: dramatic data visualization -->
          <div class="v6-hero-viz relative hidden lg:block" aria-hidden="true">
            <div class="v6-dataviz-container relative mx-auto" style="width: 480px; height: 400px;">
              <!-- Abstract heatmap grid with wave animation -->
              <div class="v6-dataviz-grid absolute inset-0" id="heroDataViz"></div>
              <!-- Floating metric cards with glassmorphism + animated borders -->
              <div class="v6-float-card v6-glass-card absolute top-4 right-0 z-10" style="animation-delay: 0.8s;">
                <div class="v6-glass-inner rounded-xl px-5 py-3.5">
                  <div class="text-[10px] font-medium uppercase tracking-wider text-white/60">Shipments today</div>
                  <div class="mt-0.5 text-2xl font-bold v6-gradient-text-metric">1.67M</div>
                </div>
              </div>
              <div class="v6-float-card v6-glass-card absolute bottom-8 left-0 z-10" style="animation-delay: 1.2s;">
                <div class="v6-glass-inner rounded-xl px-5 py-3.5">
                  <div class="text-[10px] font-medium uppercase tracking-wider text-white/60">On-time rate</div>
                  <div class="mt-0.5 text-2xl font-bold v6-gradient-text-metric">94.2%</div>
                </div>
              </div>
              <div class="v6-float-card v6-glass-card absolute right-8 bottom-20 z-10" style="animation-delay: 1.6s;">
                <div class="v6-glass-inner rounded-xl px-5 py-3.5">
                  <div class="text-[10px] font-medium uppercase tracking-wider text-white/60">Countries</div>
                  <div class="mt-0.5 text-2xl font-bold v6-gradient-text-metric">52</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section divider -->
    <div class="v6-section-divider" aria-hidden="true"></div>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 2 — SCALE METRICS (Gradient text + glow + underlines)
         ════════════════════════════════════════════════════════════════ -->
    <section class="v6-metrics-section section-tight relative overflow-hidden">
      <div class="v6-metrics-bg-gradient pointer-events-none absolute inset-0" aria-hidden="true"></div>
      <div class="container-pl relative z-10">
        <p class="mb-8 text-center text-sm font-semibold uppercase tracking-widest text-[#035740]/60">Built for global scale</p>
        <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
          <div class="v6-metric-item text-center">
            <div class="v6-counter v6-gradient-number" data-target="700" data-suffix="+">0</div>
            <div class="v6-metric-underline" aria-hidden="true"></div>
            <div class="mt-3 text-sm text-[var(--ink-secondary)]">Enterprise brands</div>
          </div>
          <div class="v6-metric-item text-center">
            <div class="v6-counter v6-gradient-number" data-target="50" data-suffix="M+">0</div>
            <div class="v6-metric-underline" aria-hidden="true"></div>
            <div class="mt-3 text-sm text-[var(--ink-secondary)]">Shipments per month</div>
          </div>
          <div class="v6-metric-item text-center">
            <div class="v6-counter v6-gradient-number" data-target="175" data-suffix="+">0</div>
            <div class="v6-metric-underline" aria-hidden="true"></div>
            <div class="mt-3 text-sm text-[var(--ink-secondary)]">Carrier integrations</div>
          </div>
          <div class="v6-metric-item text-center">
            <div class="v6-counter v6-gradient-number" data-target="52" data-suffix="">0</div>
            <div class="v6-metric-underline" aria-hidden="true"></div>
            <div class="mt-3 text-sm text-[var(--ink-secondary)]">Countries served</div>
          </div>
        </div>
      </div>
    </section>

    <div class="v6-section-divider" aria-hidden="true"></div>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 3 — COMMAND CENTER (Premium dashboard + scan-line)
         ════════════════════════════════════════════════════════════════ -->
    <section class="section-generous bg-[var(--surface)]">
      <div class="container-pl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-[#035740]">Operations</p>
          <h2 class="text-display text-[var(--ink)]">Your post-purchase command center</h2>
          <p class="mx-auto mt-4 max-w-2xl text-[var(--ink-secondary)]">
            Real-time visibility into every shipment, communication, and return — across all carriers and markets.
          </p>
        </div>

        <!-- Premium dashboard with glassmorphism + animated border + scan-line -->
        <div class="v6-dashboard-wrapper mx-auto mt-14 max-w-5xl">
          <div class="v6-dashboard-border">
            <div class="v6-dashboard relative overflow-hidden rounded-2xl bg-white shadow-2xl shadow-[#035740]/8">
              <!-- Animated scan-line -->
              <div class="v6-scan-line pointer-events-none absolute inset-x-0 top-0 z-50" aria-hidden="true"></div>
              <!-- Subtle grid background -->
              <div class="v6-dash-grid-bg pointer-events-none absolute inset-0 z-0" aria-hidden="true"></div>

              <!-- Dashboard header -->
              <div class="relative z-10 flex items-center justify-between border-b border-[var(--line)] bg-[var(--surface-sunken)] px-6 py-3">
                <div class="flex items-center gap-2">
                  <div class="h-3 w-3 rounded-full bg-[#F4373D]/60"></div>
                  <div class="h-3 w-3 rounded-full bg-[#FFC943]/60"></div>
                  <div class="h-3 w-3 rounded-full bg-[#035740]/60"></div>
                </div>
                <div class="text-xs font-medium text-[var(--ink-muted)]">Control Tower — Live Dashboard</div>
                <div class="flex items-center gap-2 text-xs text-[var(--ink-muted)]">
                  <span class="inline-flex items-center gap-1"><span class="v6-live-dot h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Live</span>
                </div>
              </div>

              <!-- KPI row with gradient top borders -->
              <div class="v6-dash-kpis relative z-10 grid grid-cols-2 gap-px bg-[var(--line)] md:grid-cols-4">
                <div class="v6-dash-kpi v6-kpi-gradient-border flex flex-col bg-white p-5" data-color="#035740">
                  <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">On-time rate</span>
                  <span class="mt-1 text-2xl font-bold text-[var(--ink)]">94.2%</span>
                  <span class="mt-1 inline-flex items-center gap-1 text-xs text-emerald-600">
                    <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.577 4.878a.75.75 0 01.919-.53l4.78 1.281a.75.75 0 01.531.919l-1.281 4.78a.75.75 0 01-1.449-.387l.81-3.022a19.407 19.407 0 00-5.594 5.203.75.75 0 01-1.139.093L7 10.06l-4.72 4.72a.75.75 0 01-1.06-1.06l5.25-5.25a.75.75 0 011.06 0l3.074 3.073a20.923 20.923 0 015.545-4.93l-3.041.815a.75.75 0 01-.53-.919z" clip-rule="evenodd"/></svg>
                    +1.3% vs last week
                  </span>
                </div>
                <div class="v6-dash-kpi v6-kpi-gradient-border flex flex-col bg-white p-5" data-color="#3D3AD3">
                  <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">Active shipments</span>
                  <span class="mt-1 text-2xl font-bold text-[var(--ink)]">123,456</span>
                  <span class="mt-1 text-xs text-[var(--ink-muted)]">Across 38 carriers</span>
                </div>
                <div class="v6-dash-kpi v6-kpi-gradient-border flex flex-col bg-white p-5" data-color="#FFC943">
                  <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">Open returns</span>
                  <span class="mt-1 text-2xl font-bold text-[var(--ink)]">2,341</span>
                  <span class="mt-1 inline-flex items-center gap-1 text-xs text-emerald-600">
                    <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.577 4.878a.75.75 0 01.919-.53l4.78 1.281a.75.75 0 01.531.919l-1.281 4.78a.75.75 0 01-1.449-.387l.81-3.022a19.407 19.407 0 00-5.594 5.203.75.75 0 01-1.139.093L7 10.06l-4.72 4.72a.75.75 0 01-1.06-1.06l5.25-5.25a.75.75 0 011.06 0l3.074 3.073a20.923 20.923 0 015.545-4.93l-3.041.815a.75.75 0 01-.53-.919z" clip-rule="evenodd"/></svg>
                    -8% exchange rate up
                  </span>
                </div>
                <div class="v6-dash-kpi v6-kpi-gradient-border flex flex-col bg-white p-5" data-color="#035740">
                  <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">CSAT Score</span>
                  <span class="mt-1 text-2xl font-bold text-[var(--ink)]">4.6<span class="text-base font-normal text-[var(--ink-muted)]">/5</span></span>
                  <span class="mt-1 text-xs text-[var(--ink-muted)]">Based on 12,847 surveys</span>
                </div>
              </div>

              <!-- Charts row -->
              <div class="relative z-10 grid gap-px bg-[var(--line)] md:grid-cols-2">
                <!-- Left: Carrier Performance bar chart with staggered animation -->
                <div class="v6-dash-chart bg-white p-6">
                  <div class="mb-4 flex items-center justify-between">
                    <span class="text-xs font-semibold uppercase tracking-wider text-[var(--ink)]">Carrier Performance</span>
                    <span class="text-[10px] text-[var(--ink-muted)]">Last 7 days</span>
                  </div>
                  <div class="space-y-3">
                    <div class="flex items-center gap-3">
                      <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">DHL</span>
                      <div class="flex-1">
                        <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                          <div class="v6-bar h-5 rounded-r" style="--bar-width: 96%; --bar-color: #035740; --bar-delay: 0s;"></div>
                        </div>
                      </div>
                      <span class="w-10 text-xs font-medium text-[var(--ink)]">96%</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">UPS</span>
                      <div class="flex-1">
                        <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                          <div class="v6-bar h-5 rounded-r" style="--bar-width: 93%; --bar-color: #047857; --bar-delay: 0.15s;"></div>
                        </div>
                      </div>
                      <span class="w-10 text-xs font-medium text-[var(--ink)]">93%</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">FedEx</span>
                      <div class="flex-1">
                        <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                          <div class="v6-bar h-5 rounded-r" style="--bar-width: 91%; --bar-color: #0d9488; --bar-delay: 0.3s;"></div>
                        </div>
                      </div>
                      <span class="w-10 text-xs font-medium text-[var(--ink)]">91%</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">Hermes</span>
                      <div class="flex-1">
                        <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                          <div class="v6-bar h-5 rounded-r" style="--bar-width: 84%; --bar-color: #FFC943; --bar-delay: 0.45s;"></div>
                        </div>
                      </div>
                      <span class="w-10 text-xs font-medium text-[var(--ink)]">84%</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">Royal Mail</span>
                      <div class="flex-1">
                        <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                          <div class="v6-bar h-5 rounded-r" style="--bar-width: 78%; --bar-color: #F4373D; --bar-delay: 0.6s;"></div>
                        </div>
                      </div>
                      <span class="w-10 text-xs font-medium text-[var(--ink)]">78%</span>
                    </div>
                  </div>
                </div>

                <!-- Right: Exception Alerts feed with pulsing indicators -->
                <div class="v6-dash-chart bg-white p-6">
                  <div class="mb-4 flex items-center justify-between">
                    <span class="text-xs font-semibold uppercase tracking-wider text-[var(--ink)]">Exception Alerts</span>
                    <span class="inline-flex items-center gap-1 rounded-full bg-[#F4373D]/10 px-2 py-0.5 text-[10px] font-medium text-[#F4373D]">
                      <span class="v6-pulse-dot h-1.5 w-1.5 rounded-full bg-[#F4373D]"></span>
                      4 active
                    </span>
                  </div>
                  <div class="space-y-3">
                    <div class="v6-alert-item rounded-lg border border-[#F4373D]/15 bg-[#F4373D]/[0.03] p-3">
                      <div class="flex items-start justify-between">
                        <div class="flex items-start gap-2.5">
                          <span class="v6-pulse-indicator mt-1.5 h-2 w-2 shrink-0 rounded-full bg-[#F4373D]"></span>
                          <div>
                            <div class="text-xs font-medium text-[var(--ink)]">Trending Late — DPD UK</div>
                            <div class="mt-0.5 text-[10px] text-[var(--ink-muted)]">247 shipments affected</div>
                          </div>
                        </div>
                        <span class="text-[10px] text-[var(--ink-muted)]">2m ago</span>
                      </div>
                    </div>
                    <div class="v6-alert-item rounded-lg border border-[#FFC943]/30 bg-[#FFC943]/[0.04] p-3">
                      <div class="flex items-start justify-between">
                        <div class="flex items-start gap-2.5">
                          <span class="v6-pulse-indicator mt-1.5 h-2 w-2 shrink-0 rounded-full bg-[#FFC943]"></span>
                          <div>
                            <div class="text-xs font-medium text-[var(--ink)]">Return spike — DE market</div>
                            <div class="mt-0.5 text-[10px] text-[var(--ink-muted)]">+34% vs avg</div>
                          </div>
                        </div>
                        <span class="text-[10px] text-[var(--ink-muted)]">18m ago</span>
                      </div>
                    </div>
                    <div class="v6-alert-item rounded-lg border border-[#FFC943]/30 bg-[#FFC943]/[0.04] p-3">
                      <div class="flex items-start justify-between">
                        <div class="flex items-start gap-2.5">
                          <span class="v6-pulse-indicator mt-1.5 h-2 w-2 shrink-0 rounded-full bg-[#FFC943]"></span>
                          <div>
                            <div class="text-xs font-medium text-[var(--ink)]">Carrier API timeout — GLS</div>
                            <div class="mt-0.5 text-[10px] text-[var(--ink-muted)]">Updates delayed ~15 min</div>
                          </div>
                        </div>
                        <span class="text-[10px] text-[var(--ink-muted)]">34m ago</span>
                      </div>
                    </div>
                    <div class="v6-alert-item rounded-lg border border-[var(--line)] bg-[var(--surface-sunken)]/50 p-3">
                      <div class="flex items-start justify-between">
                        <div class="flex items-start gap-2.5">
                          <span class="v6-pulse-indicator mt-1.5 h-2 w-2 shrink-0 rounded-full bg-[var(--ink-muted)]"></span>
                          <div>
                            <div class="text-xs font-medium text-[var(--ink)]">CSAT drop — FR tracking page</div>
                            <div class="mt-0.5 text-[10px] text-[var(--ink-muted)]">Score dropped 4.7 to 4.1</div>
                          </div>
                        </div>
                        <span class="text-[10px] text-[var(--ink-muted)]">1h ago</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="v6-section-divider" aria-hidden="true"></div>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 4 — PRODUCT SUITE (Enhanced cards with shimmer borders)
         ════════════════════════════════════════════════════════════════ -->
    <section class="section-generous bg-[var(--surface-sunken)] relative overflow-hidden">
      <!-- Connecting lines between cards -->
      <div class="v6-system-lines pointer-events-none absolute inset-0 z-0" aria-hidden="true"></div>
      <div class="container-pl relative z-10">
        <div class="mx-auto max-w-3xl text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-[#035740]">Platform</p>
          <h2 class="text-display text-[var(--ink)]">One platform, three pillars</h2>
          <p class="mx-auto mt-4 max-w-2xl text-[var(--ink-secondary)]">
            Every stage of the post-purchase journey, unified in a single platform with shared data and insights.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl space-y-6">
          <!-- Convert card -->
          <div class="v6-product-card group" data-accent="#035740">
            <div class="v6-product-card-inner overflow-hidden rounded-2xl border border-[var(--line)] bg-white/80 shadow-sm backdrop-blur-sm">
              <div class="grid gap-0 md:grid-cols-[6px_1fr]">
                <div class="v6-shimmer-border hidden md:block" style="--shimmer-color: #035740;" aria-hidden="true"></div>
                <div class="p-8 md:p-10">
                  <div class="grid gap-8 lg:grid-cols-[1fr_280px]">
                    <div>
                      <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-[#035740]/8 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-[#035740]">
