---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";
const b = import.meta.env.BASE_URL;
---

<Layout title="parcelLab — The Enterprise Post-Purchase Command Center">
  <Header client:load />
  <main>
    <!-- ════════════════════════════════════════════════════════════════
         SECTION 1 — HERO
         ════════════════════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden bg-[var(--surface)]" style="padding-top: clamp(7rem, 12vw, 10rem); padding-bottom: clamp(5rem, 8vw, 8rem);">
      <div class="container-pl relative z-10">
        <div class="grid items-center gap-12 lg:grid-cols-[1fr_420px] xl:grid-cols-[1fr_480px]">
          <!-- Left: copy -->
          <div class="v6-hero-content">
            <h1 class="mb-6" style="font-size: clamp(2.5rem, 4vw, 3.75rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.03em; color: var(--ink);">
              The post-purchase platform that scales with you
            </h1>
            <p class="mb-8 max-w-xl text-lg leading-relaxed text-[var(--ink-secondary)]">
              From startup to global enterprise, parcelLab powers every delivery, return, and customer touchpoint — with the security, reliability, and integrations you need.
            </p>
            <!-- Trust badges -->
            <div class="mb-10 flex flex-wrap items-center gap-3 v6-trust-badges">
              <span class="v6-trust-pill inline-flex items-center gap-1.5 rounded-full border border-[#035740]/20 bg-[#035740]/5 px-3.5 py-1.5 text-xs font-medium text-[#035740]">
                <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                SOC 2 Type II
              </span>
              <span class="v6-trust-pill inline-flex items-center gap-1.5 rounded-full border border-[#035740]/20 bg-[#035740]/5 px-3.5 py-1.5 text-xs font-medium text-[#035740]">
                <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                GDPR Compliant
              </span>
              <span class="v6-trust-pill inline-flex items-center gap-1.5 rounded-full border border-[#035740]/20 bg-[#035740]/5 px-3.5 py-1.5 text-xs font-medium text-[#035740]">
                <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                99.9% Uptime
              </span>
              <span class="v6-trust-pill inline-flex items-center gap-1.5 rounded-full border border-[#035740]/20 bg-[#035740]/5 px-3.5 py-1.5 text-xs font-medium text-[#035740]">
                <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                ISO 27001
              </span>
            </div>
            <!-- CTAs -->
            <div class="flex flex-wrap items-center gap-4">
              <a href={`${b}/contact-us/`} class="inline-flex items-center gap-2 rounded-lg bg-[#035740] px-7 py-3.5 text-sm font-semibold text-white shadow-md transition-all duration-200 hover:bg-[#024530] hover:shadow-lg">
                Schedule a consultation
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href={`${b}/contact-us/`} class="inline-flex items-center gap-2 rounded-lg border border-[var(--line)] bg-white px-7 py-3.5 text-sm font-semibold text-[var(--ink)] transition-all duration-200 hover:border-[var(--ink-muted)] hover:shadow-sm">
                See pricing
              </a>
            </div>
          </div>

          <!-- Right: abstract data visualization -->
          <div class="v6-hero-viz relative hidden lg:block" aria-hidden="true">
            <div class="v6-dataviz-container relative mx-auto" style="width: 420px; height: 380px;">
              <!-- Abstract heatmap grid -->
              <div class="v6-dataviz-grid absolute inset-0" id="heroDataViz"></div>
              <!-- Floating metric cards -->
              <div class="v6-float-card absolute top-4 right-0 z-10 rounded-xl border border-[var(--line)] bg-white px-4 py-3 shadow-lg" style="animation-delay: 0.8s;">
                <div class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">Shipments today</div>
                <div class="mt-0.5 text-xl font-bold text-[#035740]">1.67M</div>
              </div>
              <div class="v6-float-card absolute bottom-8 left-0 z-10 rounded-xl border border-[var(--line)] bg-white px-4 py-3 shadow-lg" style="animation-delay: 1.2s;">
                <div class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">On-time rate</div>
                <div class="mt-0.5 text-xl font-bold text-[#035740]">94.2%</div>
              </div>
              <div class="v6-float-card absolute right-8 bottom-20 z-10 rounded-xl border border-[var(--line)] bg-white px-4 py-3 shadow-lg" style="animation-delay: 1.6s;">
                <div class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">Countries</div>
                <div class="mt-0.5 text-xl font-bold text-[#035740]">52</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Background subtle gradient -->
      <div class="pointer-events-none absolute top-0 right-0 -z-0 h-full w-1/2 opacity-40" style="background: radial-gradient(ellipse at 80% 40%, rgba(3,87,64,0.06) 0%, transparent 70%);"></div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 2 — SCALE METRICS
         ════════════════════════════════════════════════════════════════ -->
    <section class="section-tight" style="background-color: #f0fdf4;">
      <div class="container-pl">
        <p class="mb-8 text-center text-sm font-semibold uppercase tracking-widest text-[#035740]/60">Built for global scale</p>
        <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
          <div class="text-center">
            <div class="v6-counter text-5xl font-bold text-[#035740]" data-target="700" data-suffix="+">0</div>
            <div class="mt-2 text-sm text-[var(--ink-secondary)]">Enterprise brands</div>
          </div>
          <div class="text-center">
            <div class="v6-counter text-5xl font-bold text-[#035740]" data-target="50" data-suffix="M+">0</div>
            <div class="mt-2 text-sm text-[var(--ink-secondary)]">Shipments per month</div>
          </div>
          <div class="text-center">
            <div class="v6-counter text-5xl font-bold text-[#035740]" data-target="175" data-suffix="+">0</div>
            <div class="mt-2 text-sm text-[var(--ink-secondary)]">Carrier integrations</div>
          </div>
          <div class="text-center">
            <div class="v6-counter text-5xl font-bold text-[#035740]" data-target="52" data-suffix="">0</div>
            <div class="mt-2 text-sm text-[var(--ink-secondary)]">Countries served</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 3 — COMMAND CENTER
         ════════════════════════════════════════════════════════════════ -->
    <section class="section-generous bg-[var(--surface)]">
      <div class="container-pl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-[#035740]">Operations</p>
          <h2 class="text-display text-[var(--ink)]">Your post-purchase command center</h2>
          <p class="mx-auto mt-4 max-w-2xl text-[var(--ink-secondary)]">
            Real-time visibility into every shipment, communication, and return — across all carriers and markets.
          </p>
        </div>

        <!-- Mock dashboard -->
        <div class="v6-dashboard mx-auto mt-14 max-w-5xl overflow-hidden rounded-2xl border border-[var(--line)] bg-white shadow-xl">
          <!-- Dashboard header -->
          <div class="flex items-center justify-between border-b border-[var(--line)] bg-[var(--surface-sunken)] px-6 py-3">
            <div class="flex items-center gap-2">
              <div class="h-3 w-3 rounded-full bg-[#F4373D]/60"></div>
              <div class="h-3 w-3 rounded-full bg-[#FFC943]/60"></div>
              <div class="h-3 w-3 rounded-full bg-[#035740]/60"></div>
            </div>
            <div class="text-xs font-medium text-[var(--ink-muted)]">Control Tower — Live Dashboard</div>
            <div class="flex items-center gap-2 text-xs text-[var(--ink-muted)]">
              <span class="inline-flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Live</span>
            </div>
          </div>

          <!-- KPI row -->
          <div class="v6-dash-kpis grid grid-cols-2 gap-px bg-[var(--line)] md:grid-cols-4">
            <div class="v6-dash-kpi flex flex-col bg-white p-5">
              <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">On-time rate</span>
              <span class="mt-1 text-2xl font-bold text-[var(--ink)]">94.2%</span>
              <span class="mt-1 inline-flex items-center gap-1 text-xs text-emerald-600">
                <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.577 4.878a.75.75 0 01.919-.53l4.78 1.281a.75.75 0 01.531.919l-1.281 4.78a.75.75 0 01-1.449-.387l.81-3.022a19.407 19.407 0 00-5.594 5.203.75.75 0 01-1.139.093L7 10.06l-4.72 4.72a.75.75 0 01-1.06-1.06l5.25-5.25a.75.75 0 011.06 0l3.074 3.073a20.923 20.923 0 015.545-4.93l-3.041.815a.75.75 0 01-.53-.919z" clip-rule="evenodd"/></svg>
                +1.3% vs last week
              </span>
            </div>
            <div class="v6-dash-kpi flex flex-col bg-white p-5">
              <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">Active shipments</span>
              <span class="mt-1 text-2xl font-bold text-[var(--ink)]">123,456</span>
              <span class="mt-1 text-xs text-[var(--ink-muted)]">Across 38 carriers</span>
            </div>
            <div class="v6-dash-kpi flex flex-col bg-white p-5">
              <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">Open returns</span>
              <span class="mt-1 text-2xl font-bold text-[var(--ink)]">2,341</span>
              <span class="mt-1 inline-flex items-center gap-1 text-xs text-emerald-600">
                <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.577 4.878a.75.75 0 01.919-.53l4.78 1.281a.75.75 0 01.531.919l-1.281 4.78a.75.75 0 01-1.449-.387l.81-3.022a19.407 19.407 0 00-5.594 5.203.75.75 0 01-1.139.093L7 10.06l-4.72 4.72a.75.75 0 01-1.06-1.06l5.25-5.25a.75.75 0 011.06 0l3.074 3.073a20.923 20.923 0 015.545-4.93l-3.041.815a.75.75 0 01-.53-.919z" clip-rule="evenodd"/></svg>
                -8% exchange rate up
              </span>
            </div>
            <div class="v6-dash-kpi flex flex-col bg-white p-5">
              <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--ink-muted)]">CSAT Score</span>
              <span class="mt-1 text-2xl font-bold text-[var(--ink)]">4.6<span class="text-base font-normal text-[var(--ink-muted)]">/5</span></span>
              <span class="mt-1 text-xs text-[var(--ink-muted)]">Based on 12,847 surveys</span>
            </div>
          </div>

          <!-- Charts row -->
          <div class="grid gap-px bg-[var(--line)] md:grid-cols-2">
            <!-- Left: Carrier Performance bar chart -->
            <div class="v6-dash-chart bg-white p-6">
              <div class="mb-4 flex items-center justify-between">
                <span class="text-xs font-semibold uppercase tracking-wider text-[var(--ink)]">Carrier Performance</span>
                <span class="text-[10px] text-[var(--ink-muted)]">Last 7 days</span>
              </div>
              <div class="space-y-3">
                <div class="flex items-center gap-3">
                  <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">DHL</span>
                  <div class="flex-1">
                    <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                      <div class="h-5 rounded-r bg-[#035740]" style="width: 96%;"></div>
                    </div>
                  </div>
                  <span class="w-10 text-xs font-medium text-[var(--ink)]">96%</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">UPS</span>
                  <div class="flex-1">
                    <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                      <div class="h-5 rounded-r bg-[#035740]/80" style="width: 93%;"></div>
                    </div>
                  </div>
                  <span class="w-10 text-xs font-medium text-[var(--ink)]">93%</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">FedEx</span>
                  <div class="flex-1">
                    <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                      <div class="h-5 rounded-r bg-[#035740]/60" style="width: 91%;"></div>
                    </div>
                  </div>
                  <span class="w-10 text-xs font-medium text-[var(--ink)]">91%</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">Hermes</span>
                  <div class="flex-1">
                    <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                      <div class="h-5 rounded-r bg-[#FFC943]" style="width: 84%;"></div>
                    </div>
                  </div>
                  <span class="w-10 text-xs font-medium text-[var(--ink)]">84%</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="w-16 text-right text-xs text-[var(--ink-secondary)]">Royal Mail</span>
                  <div class="flex-1">
                    <div class="h-5 rounded-r bg-[var(--surface-sunken)]">
                      <div class="h-5 rounded-r bg-[#F4373D]/70" style="width: 78%;"></div>
                    </div>
                  </div>
                  <span class="w-10 text-xs font-medium text-[var(--ink)]">78%</span>
                </div>
              </div>
            </div>

            <!-- Right: Exception Alerts feed -->
            <div class="v6-dash-chart bg-white p-6">
              <div class="mb-4 flex items-center justify-between">
                <span class="text-xs font-semibold uppercase tracking-wider text-[var(--ink)]">Exception Alerts</span>
                <span class="inline-flex items-center gap-1 rounded-full bg-[#F4373D]/10 px-2 py-0.5 text-[10px] font-medium text-[#F4373D]">
                  <span class="h-1.5 w-1.5 rounded-full bg-[#F4373D]"></span>
                  4 active
                </span>
              </div>
              <div class="space-y-3">
                <div class="rounded-lg border border-[#F4373D]/15 bg-[#F4373D]/[0.03] p-3">
                  <div class="flex items-start justify-between">
                    <div>
                      <div class="text-xs font-medium text-[var(--ink)]">Trending Late — DPD UK</div>
                      <div class="mt-0.5 text-[10px] text-[var(--ink-muted)]">247 shipments affected • East Midlands hub</div>
                    </div>
                    <span class="text-[10px] text-[var(--ink-muted)]">2m ago</span>
                  </div>
                </div>
                <div class="rounded-lg border border-[#FFC943]/30 bg-[#FFC943]/[0.04] p-3">
                  <div class="flex items-start justify-between">
                    <div>
                      <div class="text-xs font-medium text-[var(--ink)]">Return spike — DE market</div>
                      <div class="mt-0.5 text-[10px] text-[var(--ink-muted)]">+34% vs avg • Product ID: SKU-8842</div>
                    </div>
                    <span class="text-[10px] text-[var(--ink-muted)]">18m ago</span>
                  </div>
                </div>
                <div class="rounded-lg border border-[#FFC943]/30 bg-[#FFC943]/[0.04] p-3">
                  <div class="flex items-start justify-between">
                    <div>
                      <div class="text-xs font-medium text-[var(--ink)]">Carrier API timeout — GLS</div>
                      <div class="mt-0.5 text-[10px] text-[var(--ink-muted)]">Tracking updates delayed ~15 min</div>
                    </div>
                    <span class="text-[10px] text-[var(--ink-muted)]">34m ago</span>
                  </div>
                </div>
                <div class="rounded-lg border border-[var(--line)] bg-[var(--surface-sunken)]/50 p-3">
                  <div class="flex items-start justify-between">
                    <div>
                      <div class="text-xs font-medium text-[var(--ink)]">CSAT drop — FR tracking page</div>
                      <div class="mt-0.5 text-[10px] text-[var(--ink-muted)]">Score dropped from 4.7 to 4.1</div>
                    </div>
                    <span class="text-[10px] text-[var(--ink-muted)]">1h ago</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 4 — PRODUCT SUITE
         ════════════════════════════════════════════════════════════════ -->
    <section class="section-generous bg-[var(--surface-sunken)]">
      <div class="container-pl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-[#035740]">Platform</p>
          <h2 class="text-display text-[var(--ink)]">One platform, three pillars</h2>
          <p class="mx-auto mt-4 max-w-2xl text-[var(--ink-secondary)]">
            Every stage of the post-purchase journey, unified in a single platform with shared data and insights.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl space-y-6">
          <!-- Convert card -->
          <div class="v6-product-card group overflow-hidden rounded-2xl border border-[var(--line)] bg-white shadow-sm transition-shadow duration-300 hover:shadow-md">
            <div class="grid gap-0 md:grid-cols-[6px_1fr]">
              <div class="hidden bg-[#035740] md:block" aria-hidden="true"></div>
              <div class="p-8 md:p-10">
                <div class="grid gap-8 lg:grid-cols-[1fr_280px]">
                  <div>
                    <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-[#035740]/8 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-[#035740]">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
                      Convert
                    </div>
                    <h3 class="mb-2 text-xl font-semibold text-[var(--ink)]">Delivery promises that convert</h3>
                    <p class="mb-6 text-sm leading-relaxed text-[var(--ink-secondary)]">
                      ML-powered delivery date predictions at checkout. Trained on millions of shipments across 175+ carriers.
                    </p>
                    <div class="flex flex-wrap gap-2">
                      <span class="rounded-md bg-[var(--surface-sunken)] px-2.5 py-1 text-[11px] font-medium text-[var(--ink-secondary)]">PDP widget</span>
                      <span class="rounded-md bg-[var(--surface-sunken)] px-2.5 py-1 text-[11px] font-medium text-[var(--ink-secondary)]">Checkout integration</span>
                      <span class="rounded-md bg-[var(--surface-sunken)] px-2.5 py-1 text-[11px] font-medium text-[var(--ink-secondary)]">Post-purchase ETA updates</span>
                    </div>
                  </div>
                  <div class="flex flex-col justify-center gap-4">
                    <div class="rounded-xl border border-[#035740]/10 bg-[#035740]/[0.03] p-4 text-center">
                      <div class="text-2xl font-bold text-[#035740]">5%</div>
                      <div class="text-xs text-[var(--ink-secondary)]">Conversion lift</div>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                      <div class="rounded-lg bg-[var(--surface-sunken)] p-3 text-center">
                        <div class="text-sm font-bold text-[var(--ink)]">&lt;1s</div>
                        <div class="text-[10px] text-[var(--ink-muted)]">Response time</div>
                      </div>
                      <div class="rounded-lg bg-[var(--surface-sunken)] p-3 text-center">
                        <div class="text-sm font-bold text-[var(--ink)]">98.5%</div>
                        <div class="text-[10px] text-[var(--ink-muted)]">Accuracy</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Engage card -->
          <div class="v6-product-card group overflow-hidden rounded-2xl border border-[var(--line)] bg-white shadow-sm transition-shadow duration-300 hover:shadow-md">
            <div class="grid gap-0 md:grid-cols-[6px_1fr]">
              <div class="hidden bg-[#3D3AD3] md:block" aria-hidden="true"></div>
              <div class="p-8 md:p-10">
                <div class="grid gap-8 lg:grid-cols-[1fr_280px]">
                  <div>
                    <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-[#3D3AD3]/8 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-[#3D3AD3]">
