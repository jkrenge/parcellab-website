<!-- ════════════════════════════════════════════════════════════════
     STYLES
     ════════════════════════════════════════════════════════════════ -->
<style>
  /* ── Hero animations ── */
  @media (prefers-reduced-motion: no-preference) {
    .v6-hero-content {
      animation: v6FadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .v6-trust-pill {
      animation: v6FadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .v6-trust-pill:nth-child(1) { animation-delay: 0.4s; }
    .v6-trust-pill:nth-child(2) { animation-delay: 0.5s; }
    .v6-trust-pill:nth-child(3) { animation-delay: 0.6s; }
    .v6-trust-pill:nth-child(4) { animation-delay: 0.7s; }

    .v6-hero-viz {
      animation: v6FadeIn 1s 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .v6-float-card {
      animation: v6FloatIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    /* Dashboard sequential reveal */
    .v6-dash-kpi {
      animation: v6FadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 30%;
    }

    .v6-dash-chart {
      animation: v6FadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 30%;
    }

    /* Product cards slide-in */
    .v6-product-card {
      animation: v6SlideInLeft 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 25%;
    }

    /* Journey timeline reveal */
    .v6-journey-step {
      animation: v6FadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 40%;
    }

    /* Innovation timeline entries */
    .v6-timeline-entry {
      animation: v6FadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 30%;
    }
  }

  @keyframes v6FadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes v6FadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes v6FloatIn {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes v6SlideInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ── Data visualization grid ── */
  .v6-dataviz-grid {
    display: grid;
    grid-template-columns: repeat(28, 1fr);
    grid-template-rows: repeat(20, 1fr);
    gap: 3px;
    padding: 20px;
    opacity: 0.85;
  }

  .v6-dataviz-cell {
    border-radius: 2px;
    transition: opacity 0.3s ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .v6-dataviz-cell {
      animation: v6CellFadeIn 0.4s ease both;
    }
  }

  @keyframes v6CellFadeIn {
    from { opacity: 0; transform: scale(0.5); }
    to { opacity: 1; transform: scale(1); }
  }

  /* ── Floating card subtle hover ── */
  .v6-float-card {
    backdrop-filter: blur(8px);
  }
</style>

<!-- ════════════════════════════════════════════════════════════════
     SCRIPTS
     ════════════════════════════════════════════════════════════════ -->
<script>
  // ── Hero Data Visualization ──
  (function buildHeroViz() {
    const container = document.getElementById("heroDataViz");
    if (!container) return;

    const cols = 28;
    const rows = 20;
    const total = cols * rows;
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Approximate a world map shape with denser dots for continents
    // Represent intensity by region (col, row ranges)
    const regions = [
      // Europe
      { colMin: 13, colMax: 17, rowMin: 3, rowMax: 8, intensity: 0.9 },
      // North America
      { colMin: 2, colMax: 9, rowMin: 3, rowMax: 9, intensity: 0.7 },
      // Asia
      { colMin: 18, colMax: 26, rowMin: 3, rowMax: 11, intensity: 0.65 },
      // South America
      { colMin: 6, colMax: 10, rowMin: 11, rowMax: 17, intensity: 0.5 },
      // Africa
      { colMin: 12, colMax: 17, rowMin: 9, rowMax: 16, intensity: 0.45 },
      // Australia
      { colMin: 22, colMax: 26, rowMin: 13, rowMax: 17, intensity: 0.4 },
    ];

    function getIntensity(col: number, row: number): number {
      let maxI = 0.08; // base very faint
      for (const r of regions) {
        if (col >= r.colMin && col <= r.colMax && row >= r.rowMin && row <= r.rowMax) {
          maxI = Math.max(maxI, r.intensity);
        }
      }
      return maxI;
    }

    const colors = ["#035740", "#3D3AD3", "#FFC943", "#035740"];
    const fragment = document.createDocumentFragment();

    for (let i = 0; i < total; i++) {
      const col = i % cols;
      const row = Math.floor(i / cols);
      const intensity = getIntensity(col, row);
      const jitter = Math.random() * 0.3;
      const finalOpacity = Math.max(0.04, intensity * (0.6 + jitter));

      const cell = document.createElement("div");
      cell.className = "v6-dataviz-cell";

      const colorPick = colors[Math.floor(Math.random() * colors.length)];
      cell.style.backgroundColor = colorPick;
      cell.style.opacity = String(finalOpacity);

      if (!prefersReduced) {
        const delay = (col * 20) + (row * 30) + Math.random() * 200;
        cell.style.animationDelay = `${delay}ms`;
      }

      fragment.appendChild(cell);
    }
    container.appendChild(fragment);
  })();

  // ── Counter animation ──
  (function initCounters() {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const counters = document.querySelectorAll<HTMLElement>(".v6-counter");

    if (prefersReduced) {
      counters.forEach((el) => {
        const target = parseInt(el.dataset.target || "0", 10);
        const suffix = el.dataset.suffix || "";
        el.textContent = target + suffix;
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);

          const target = parseInt(el.dataset.target || "0", 10);
          const suffix = el.dataset.suffix || "";
          const duration = 1800;
          const start = performance.now();

          function tick(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            // Ease out cubic
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = Math.round(eased * target);
            el.textContent = current + suffix;
            if (progress < 1) {
              requestAnimationFrame(tick);
            }
          }
          requestAnimationFrame(tick);
        });
      },
      { threshold: 0.3 }
    );

    counters.forEach((el) => observer.observe(el));
  })();

  // ── Scroll-based fallback animations for browsers without animation-timeline ──
  (function initScrollAnimations() {
    // Test if animation-timeline is supported
    const supportsTimeline = CSS.supports("animation-timeline", "view()");
    if (supportsTimeline) return;

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReduced) return;

    // Gather all elements that need scroll reveal
    const selectors = [
      ".v6-dash-kpi",
      ".v6-dash-chart",
      ".v6-product-card",
      ".v6-journey-step",
      ".v6-timeline-entry",
    ];

    const elements = document.querySelectorAll<HTMLElement>(selectors.join(","));

    // Set initial state
    elements.forEach((el) => {
      el.style.opacity = "0";
      el.style.transform = "translateY(20px)";
      el.style.transition = "opacity 0.6s cubic-bezier(0.22,1,0.36,1), transform 0.6s cubic-bezier(0.22,1,0.36,1)";
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);

          // Stagger siblings by a small delay
          const parent = el.parentElement;
          if (parent) {
            const siblings = Array.from(parent.children);
            const index = siblings.indexOf(el);
            el.style.transitionDelay = `${index * 80}ms`;
          }

          el.style.opacity = "1";
          el.style.transform = "translateY(0)";
        });
      },
      { threshold: 0.15 }
    );

    elements.forEach((el) => observer.observe(el));
  })();
</script>
