---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import PageHero from "../components/PageHero.astro";
import InnerPageCTA from "../components/InnerPageCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Reduced operational costs and improved logistics - parcelLab"
  description="Streamline reverse logistics and minimize return-related disruptions. Gain insights and optimize logistics to reduce operational costs."
>
  <Header client:load />
  <main>
    <PageHero
      eyebrow="Operations & Logistics"
      title="Empower your logistics team with smarter, data-driven decisions"
      description="Optimize your delivery network, reduce exceptions, and enhance supply chain visibility with real-time insights."
      ctaText="Book a demo"
      ctaHref={`${import.meta.env.BASE_URL}/live-demo/`}
      secondaryCtaText="Take a tour"
      secondaryCtaHref={`${import.meta.env.BASE_URL}/product-tour/`}
    />

    <!-- Pain Points -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mb-14 max-w-2xl">
          <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">Challenges</span>
          <h2 class="text-display text-[var(--ink)]">The operational hurdles holding your team back</h2>
          <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
            Logistics teams face constant pressure to manage carrier performance, maintain delivery reliability, and handle complex exceptions — all while keeping costs down.
          </p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:border-[#035740]/20 hover:shadow-[0_4px_24px_rgba(3,87,64,0.06)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/8">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Optimize Delivery Performance</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Monitor carrier lead times and service levels through real-time visibility across your entire delivery network.</p>
          </div>
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:border-[#035740]/20 hover:shadow-[0_4px_24px_rgba(3,87,64,0.06)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/8">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="M12 22v-8.3a4 4 0 0 0-1.172-2.872L3 3"/><path d="m15 9 6-6"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Manage Split-Shipments</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Reduce exceptions, identify bottlenecks, and address inefficiencies proactively across complex multi-shipment orders.</p>
          </div>
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:border-[#035740]/20 hover:shadow-[0_4px_24px_rgba(3,87,64,0.06)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/8">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Lower WISMO Inquiries</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Enable customers with real-time tracking and proactive communications to dramatically reduce support volume.</p>
          </div>
          <div class="group rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-7 transition-all hover:border-[#035740]/20 hover:shadow-[0_4px_24px_rgba(3,87,64,0.06)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#035740]/8">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--ink)]">Improve Return Logistics</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--ink-secondary)]">Streamline reverse logistics and reduce return-related operational disruptions with automated workflows.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Detailed Features -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mb-14 max-w-2xl">
          <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">Platform Features</span>
          <h2 class="text-display text-[var(--ink)]">Data-driven tools for modern logistics</h2>
        </div>

        <!-- Feature row 1 -->
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div>
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[#035740]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            </div>
            <h3 class="text-heading text-[var(--ink)]">Carrier Performance Insights</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">Real-time carrier performance benchmarking with customizable dashboards tracking lead times by region, carrier, or method. AI-powered exception detection flags late deliveries before they impact customers.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
            <div class="space-y-5">
              <div class="flex items-center justify-between rounded-xl bg-[var(--surface-sunken)] px-5 py-4">
                <div>
                  <p class="text-sm font-medium text-[var(--ink)]">Carrier A</p>
                  <p class="text-xs text-[var(--ink-muted)]">2.1 days avg lead time</p>
                </div>
                <div class="h-2.5 w-32 overflow-hidden rounded-full bg-[var(--line)]">
                  <div class="h-full w-[92%] rounded-full bg-[#035740]"></div>
                </div>
                <span class="text-sm font-semibold text-[#035740]">92%</span>
              </div>
              <div class="flex items-center justify-between rounded-xl bg-[var(--surface-sunken)] px-5 py-4">
                <div>
                  <p class="text-sm font-medium text-[var(--ink)]">Carrier B</p>
                  <p class="text-xs text-[var(--ink-muted)]">2.8 days avg lead time</p>
                </div>
                <div class="h-2.5 w-32 overflow-hidden rounded-full bg-[var(--line)]">
                  <div class="h-full w-[85%] rounded-full bg-[#FFC943]"></div>
                </div>
                <span class="text-sm font-semibold text-[#b8860b]">85%</span>
              </div>
              <div class="flex items-center justify-between rounded-xl bg-[var(--surface-sunken)] px-5 py-4">
                <div>
                  <p class="text-sm font-medium text-[var(--ink)]">Carrier C</p>
                  <p class="text-xs text-[var(--ink-muted)]">3.4 days avg lead time</p>
                </div>
                <div class="h-2.5 w-32 overflow-hidden rounded-full bg-[var(--line)]">
                  <div class="h-full w-[71%] rounded-full bg-[#EF4444]"></div>
                </div>
                <span class="text-sm font-semibold text-[#EF4444]">71%</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Feature row 2 -->
        <div class="mt-20 grid items-center gap-12 lg:grid-cols-2">
          <div class="order-2 lg:order-1 rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
            <div class="grid grid-cols-2 gap-4">
              <div class="rounded-xl bg-[var(--surface-sunken)] p-5 text-center">
                <svg class="mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                <p class="text-xs font-medium text-[var(--ink-secondary)]">At-Risk Shipments</p>
                <p class="mt-1 text-2xl font-bold text-[#035740]">23</p>
              </div>
              <div class="rounded-xl bg-[var(--surface-sunken)] p-5 text-center">
                <svg class="mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <p class="text-xs font-medium text-[var(--ink-secondary)]">Avg Resolution</p>
                <p class="mt-1 text-2xl font-bold text-[#035740]">4.2h</p>
              </div>
              <div class="rounded-xl bg-[var(--surface-sunken)] p-5 text-center">
                <svg class="mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                <p class="text-xs font-medium text-[var(--ink-secondary)]">Disruptions Forecast</p>
                <p class="mt-1 text-2xl font-bold text-[#035740]">Low</p>
              </div>
              <div class="rounded-xl bg-[var(--surface-sunken)] p-5 text-center">
                <svg class="mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <p class="text-xs font-medium text-[var(--ink-secondary)]">Auto-Resolved</p>
                <p class="mt-1 text-2xl font-bold text-[#035740]">67%</p>
              </div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[#035740]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <h3 class="text-heading text-[var(--ink)]">Exception Management</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">Predictive analytics for disruption forecasting with automated alerts for at-risk shipments. Get data-driven resolution recommendations that help your team resolve issues before they escalate.</p>
          </div>
        </div>

        <!-- Feature row 3 -->
        <div class="mt-20 grid items-center gap-12 lg:grid-cols-2">
          <div>
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[#035740]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
            </div>
            <h3 class="text-heading text-[var(--ink)]">Reverse Logistics Optimization</h3>
            <p class="mt-3 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">Return rate analysis by product category and region. Automated return authorization workflows with built-in fraud detection and carrier cost comparison tools to minimize return costs.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] bg-[var(--surface-raised)] p-8">
            <ul class="space-y-4">
              <li class="flex items-start gap-4">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[#035740]/10">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-[var(--ink)]">Return rate analysis by product & region</p>
                  <p class="mt-0.5 text-xs text-[var(--ink-muted)]">Identify patterns and optimize policies</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[#035740]/10">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-[var(--ink)]">Automated return authorization with fraud detection</p>
                  <p class="mt-0.5 text-xs text-[var(--ink-muted)]">Reduce manual review while catching abuse</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[#035740]/10">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#035740" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-[var(--ink)]">Carrier cost & performance comparison</p>
                  <p class="mt-0.5 text-xs text-[var(--ink-muted)]">Choose the best carrier for every return route</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="section-generous">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mb-14 text-center">
          <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">Impact</span>
          <h2 class="text-display text-[var(--ink)]">Measurable logistics improvements</h2>
        </div>
        <div class="mx-auto grid max-w-4xl gap-px overflow-hidden rounded-2xl bg-[var(--line)] sm:grid-cols-3">
          <div class="flex flex-col items-center justify-center bg-[var(--surface-raised)] px-8 py-12 text-center">
            <span class="text-[3.5rem] font-bold leading-none tracking-tight text-[#035740]">72%</span>
            <p class="mt-3 text-sm font-medium text-[var(--ink-secondary)]">Positive post-purchase feedback at FARFETCH</p>
          </div>
          <div class="flex flex-col items-center justify-center bg-[var(--surface-raised)] px-8 py-12 text-center">
            <span class="text-[3.5rem] font-bold leading-none tracking-tight text-[#035740]">20%</span>
            <p class="mt-3 text-sm font-medium text-[var(--ink-secondary)]">Reduction in WISMO inquiries at Wyze</p>
          </div>
          <div class="flex flex-col items-center justify-center bg-[var(--surface-raised)] px-8 py-12 text-center">
            <span class="text-[3.5rem] font-bold leading-none tracking-tight text-[#035740]">YoY</span>
            <p class="mt-3 text-sm font-medium text-[var(--ink-secondary)]">Platform pays for itself year-over-year</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="section-standard bg-[var(--surface-sunken)]">
      <div class="mx-auto max-w-[1440px] px-6 md:px-12">
        <div class="mb-14 max-w-2xl">
          <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.15em] text-[#035740]">Customer Stories</span>
          <h2 class="text-display text-[var(--ink)]">Operations teams that trust parcelLab</h2>
        </div>
        <div class="grid gap-8 md:grid-cols-3">
          <div class="rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm">
            <svg class="mb-4 text-[var(--ink-muted)]" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" opacity="0.15"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">"parcelLab pays for itself year-over-year by maintaining predictability of WISMO volume, bringing incremental value through email and tracking page revenue."</p>
            <div class="mt-6 border-t border-[var(--line)] pt-5">
              <p class="text-sm font-semibold text-[var(--ink)]">Julia Babina</p>
              <p class="mt-0.5 text-xs text-[var(--ink-muted)]">VP of Supply Chain, Ana Luisa</p>
            </div>
          </div>
          <div class="rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm">
            <svg class="mb-4 text-[var(--ink-muted)]" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" opacity="0.15"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">"Integration of post-purchase communication and DIY returns into one platform removed silos. Automation lowered WISMO tickets significantly."</p>
            <div class="mt-6 border-t border-[var(--line)] pt-5">
              <p class="text-sm font-semibold text-[var(--ink)]">Richard Wang</p>
              <p class="mt-0.5 text-xs text-[var(--ink-muted)]">eCommerce & Retail Operations Manager, Wyze</p>
            </div>
          </div>
          <div class="rounded-2xl bg-[var(--surface-raised)] p-8 shadow-sm">
            <svg class="mb-4 text-[var(--ink-muted)]" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" opacity="0.15"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-sm leading-relaxed text-[var(--ink-secondary)]">"parcelLab enables us to maintain FARFETCH brand presence throughout customer communications across our intricate fulfillment chain."</p>
            <div class="mt-6 border-t border-[var(--line)] pt-5">
              <p class="text-sm font-semibold text-[var(--ink)]">Stuart Hill</p>
              <p class="mt-0.5 text-xs text-[var(--ink-muted)]">SVP of Logistics, FARFETCH</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <InnerPageCTA />
  </main>
  <Footer />
</Layout>
