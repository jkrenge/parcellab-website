---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { Header } from "../components/Header";
import Footer from "../components/Footer.astro";
import { OrderStatusDemo } from "../components/OrderStatusDemo";
import { ReturnsDemo } from "../components/ReturnsDemo";
const b = import.meta.env.BASE_URL;
---

<Layout title="parcelLab — See It In Action | Interactive Product Demos">
  <Header client:load />
  <main>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 1 — HERO: "See it in action"
         Dark mesh gradient, floating orbs, animated gradient text
         ════════════════════════════════════════════════════════════════ -->
    <section class="v7-hero relative overflow-hidden" style="padding-top: clamp(7rem, 12vw, 10rem); padding-bottom: clamp(5rem, 8vw, 7rem);">
      <!-- Mesh gradient background -->
      <div class="v7-hero-mesh pointer-events-none absolute inset-0 -z-10" aria-hidden="true"></div>
      <!-- Floating orbs -->
      <div class="v7-orb v7-orb--1 pointer-events-none absolute -z-5" aria-hidden="true"></div>
      <div class="v7-orb v7-orb--2 pointer-events-none absolute -z-5" aria-hidden="true"></div>
      <div class="v7-orb v7-orb--3 pointer-events-none absolute -z-5" aria-hidden="true"></div>
      <div class="v7-orb v7-orb--4 pointer-events-none absolute -z-5" aria-hidden="true"></div>
      <!-- Noise texture overlay -->
      <div class="pointer-events-none absolute inset-0 -z-5 opacity-[0.035]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');" aria-hidden="true"></div>

      <div class="container-pl relative z-10 text-center">
        <div class="mx-auto max-w-4xl">
          <!-- Eyebrow badge -->
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium tracking-wide text-white/70 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
            </span>
            INTERACTIVE DEMOS &mdash; NO SIGN-UP REQUIRED
          </div>

          <h1 class="mb-6" style="font-size: clamp(2.75rem, 5.5vw, 4.25rem); font-weight: 700; line-height: 1.06; letter-spacing: -0.035em;">
            <span style="color: white;">See the post-purchase experience</span><br />
            <span class="v7-gradient-text-hero">your customers deserve</span>
          </h1>

          <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-white/65" style="text-wrap: balance;">
            Don't take our word for it. Click through real product demos &mdash; branded tracking, returns, exchanges &mdash; all fully interactive.
          </p>

          <!-- Anchor buttons -->
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a href="#order-tracking-demo" class="v7-btn-primary group inline-flex items-center gap-2.5 rounded-xl px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-indigo-900/40 transition-all duration-300">
              Try Order Tracking
              <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </a>
            <a href="#returns-demo" class="v7-btn-ghost group inline-flex items-center gap-2.5 rounded-xl border border-white/15 bg-white/5 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/30 hover:bg-white/10">
              Try Returns Portal
              <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </a>
          </div>
        </div>

        <!-- Trust logos bar -->
        <div class="mt-16 border-t border-white/8 pt-10">
          <p class="mb-6 text-xs font-medium uppercase tracking-widest text-white/35">Trusted by 700+ brands worldwide</p>
          <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4 opacity-40 grayscale brightness-200">
            <img src={`${b}/images/brands/Dyson.svg`} alt="Dyson" class="h-6" loading="lazy" />
            <img src={`${b}/images/brands/Hugo-Boss.svg`} alt="Hugo Boss" class="h-5" loading="lazy" />
            <img src={`${b}/images/brands/Puma.svg`} alt="Puma" class="h-6" loading="lazy" />
            <img src={`${b}/images/brands/Farfetch.svg`} alt="Farfetch" class="h-5" loading="lazy" />
            <img src={`${b}/images/brands/True-Classic-1.svg`} alt="True Classic" class="h-5" loading="lazy" />
            <img src={`${b}/images/brands/Urban-Outfitters-1.svg`} alt="Urban Outfitters" class="h-4" loading="lazy" />
            <img src={`${b}/images/brands/JohnLewis-1.svg`} alt="John Lewis" class="h-5" loading="lazy" />
          </div>
        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════════════════════════
         SECTION 2 — ORDER STATUS PAGE DEMO: "Branded Order Tracking"
         Purple-tinted section, text left (40%), demo right (60%)
         ════════════════════════════════════════════════════════════════ -->
    <section id="order-tracking-demo" class="v7-section-osp relative overflow-hidden scroll-mt-20" style="padding-top: clamp(5rem, 8vw, 8rem); padding-bottom: clamp(5rem, 8vw, 8rem);">
      <!-- Subtle gradient background -->
      <div class="pointer-events-none absolute inset-0 -z-10" style="background: linear-gradient(135deg, rgba(80, 70, 229, 0.04) 0%, rgba(255,255,255,0) 50%, rgba(80, 70, 229, 0.02) 100%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute top-0 left-0 h-px w-full" style="background: linear-gradient(90deg, transparent, rgba(80, 70, 229, 0.15), transparent);" aria-hidden="true"></div>

      <div class="container-pl">
        <div class="grid items-start gap-12 lg:grid-cols-[minmax(0,2fr)_minmax(0,3fr)] xl:gap-16">

          <!-- Left: copy -->
          <div class="lg:sticky lg:top-32 lg:self-start">
            <span class="v7-eyebrow mb-4 inline-block rounded-full bg-indigo-50 px-3.5 py-1 text-[11px] font-bold uppercase tracking-widest text-indigo-600">Engage</span>
            <h2 class="mb-4 text-display text-[var(--ink)]">Your brand, every step of the&nbsp;way</h2>
            <p class="mb-8 text-base leading-relaxed text-[var(--ink-secondary)]">
              Replace generic carrier pages with branded tracking experiences. Add campaign banners, product recommendations, surveys, and live tracking &mdash; all on YOUR domain.
            </p>

            <!-- Feature list -->
            <ul class="v7-features mb-10 grid gap-3">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9" stroke-width="2.5" fill="none"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Estimated delivery predictions</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Real-time tracking timeline</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Campaign banners that drive 29% more revenue</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Product recommendations</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">NPS surveys &amp; feedback</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">SMS opt-in for updates</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Live map tracking</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Multi-language support (25+ languages)</span>
              </li>
            </ul>

            <!-- Stats row -->
            <div class="mb-8 flex flex-wrap gap-6">
              <div>
                <div class="text-2xl font-bold text-[var(--ink)]">85%</div>
                <div class="text-xs text-[var(--ink-muted)]">Open rate</div>
              </div>
              <div class="h-10 w-px bg-[var(--line)]" aria-hidden="true"></div>
              <div>
                <div class="text-2xl font-bold text-[var(--ink)]">29%</div>
                <div class="text-xs text-[var(--ink-muted)]">Revenue per email</div>
              </div>
              <div class="h-10 w-px bg-[var(--line)]" aria-hidden="true"></div>
              <div>
                <div class="text-2xl font-bold text-[var(--ink)]">20%</div>
                <div class="text-xs text-[var(--ink-muted)]">Fewer WISMO</div>
              </div>
            </div>

            <a href={`${b}/contact-us/`} class="v7-cta-btn inline-flex items-center gap-2 rounded-xl px-7 py-3.5 text-sm font-semibold text-white transition-all duration-300">
              Book a demo
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>

          <!-- Right: Demo component with gradient glow -->
          <div class="relative">
            <!-- Gradient glow behind demo -->
            <div class="pointer-events-none absolute -inset-8 -z-10 rounded-3xl opacity-60 blur-3xl" style="background: radial-gradient(ellipse at center, rgba(80, 70, 229, 0.15), transparent 70%);" aria-hidden="true"></div>
            <!-- Animated gradient border container -->
            <div class="v7-demo-container relative overflow-hidden rounded-2xl shadow-2xl shadow-indigo-900/10">
              <!-- Hint label -->
              <div class="v7-click-hint absolute -top-3 right-6 z-20 flex items-center gap-1.5 rounded-full bg-indigo-600 px-3 py-1 text-[11px] font-semibold text-white shadow-lg shadow-indigo-600/40">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-white opacity-75"></span>
                  <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-white"></span>
                </span>
                Click to explore
              </div>
              <OrderStatusDemo client:visible />
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ════════════════════════════════════════════════════════════════
         SECTION 3 — RETURNS PORTAL DEMO: "Smart Returns & Exchanges"
         Green-tinted section, demo left (60%), text right (40%)
         ════════════════════════════════════════════════════════════════ -->
    <section id="returns-demo" class="v7-section-returns relative overflow-hidden scroll-mt-20" style="padding-top: clamp(5rem, 8vw, 8rem); padding-bottom: clamp(5rem, 8vw, 8rem);">
      <!-- Subtle gradient background -->
      <div class="pointer-events-none absolute inset-0 -z-10" style="background: linear-gradient(225deg, rgba(3, 87, 64, 0.04) 0%, rgba(255,255,255,0) 50%, rgba(3, 87, 64, 0.02) 100%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute top-0 left-0 h-px w-full" style="background: linear-gradient(90deg, transparent, rgba(3, 87, 64, 0.15), transparent);" aria-hidden="true"></div>

      <div class="container-pl">
        <div class="grid items-start gap-12 lg:grid-cols-[minmax(0,3fr)_minmax(0,2fr)] xl:gap-16">

          <!-- Left: Demo component with gradient glow -->
          <div class="relative order-2 lg:order-1">
            <!-- Gradient glow behind demo -->
            <div class="pointer-events-none absolute -inset-8 -z-10 rounded-3xl opacity-60 blur-3xl" style="background: radial-gradient(ellipse at center, rgba(3, 87, 64, 0.12), transparent 70%);" aria-hidden="true"></div>
            <!-- Animated gradient border container -->
            <div class="v7-demo-container v7-demo-container--green relative overflow-hidden rounded-2xl shadow-2xl shadow-emerald-900/10">
              <!-- Hint label -->
              <div class="v7-click-hint absolute -top-3 right-6 z-20 flex items-center gap-1.5 rounded-full bg-emerald-700 px-3 py-1 text-[11px] font-semibold text-white shadow-lg shadow-emerald-700/40">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-white opacity-75"></span>
                  <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-white"></span>
                </span>
                Click to explore
              </div>
              <ReturnsDemo client:visible />
            </div>
          </div>

          <!-- Right: copy -->
          <div class="order-1 lg:sticky lg:top-32 lg:order-2 lg:self-start">
            <span class="v7-eyebrow mb-4 inline-block rounded-full bg-emerald-50 px-3.5 py-1 text-[11px] font-bold uppercase tracking-widest text-emerald-700">Retain</span>
            <h2 class="mb-4 text-display text-[var(--ink)]">Turn every return into a second&nbsp;chance</h2>
            <p class="mb-8 text-base leading-relaxed text-[var(--ink-secondary)]">
              Guide customers through a branded returns experience that prioritizes exchanges and store credit. Detect fraud, offer retention incentives, and recover revenue.
            </p>

            <!-- Feature list -->
            <ul class="v7-features mb-10 grid gap-3">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">5-step guided returns flow</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Exchange-first logic (same item, different variant)</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Retention offers: keep item + partial refund</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Store credit with bonus incentive</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">QR code + Apple/Google Wallet labels</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Carrier selection with map</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </span>
                <span class="text-sm text-[var(--ink-secondary)]">Image upload for warranty claims</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
