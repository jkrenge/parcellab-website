<!-- ════════════════════════════════════════════════════════════════════
     SCRIPTS — Count-up animation + scroll reveal
     ════════════════════════════════════════════════════════════════════ -->
<script>
  /* ─── Stats count-up on scroll ─── */
  function animateCountUp() {
    const grid = document.getElementById("v7StatsGrid");
    if (!grid) return;
    const stats = grid.querySelectorAll<HTMLElement>(".v7-stat-number");
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          stats.forEach((stat) => {
            const target = parseInt(stat.dataset.target || "0", 10);
            const suffix = stat.dataset.suffix || "";
            const span = stat.querySelector("span");
            if (!span) return;

            if (prefersReduced) {
              span.textContent = target + suffix;
              return;
            }

            let current = 0;
            const duration = 2000;
            const startTime = performance.now();

            function step(now: number) {
              const elapsed = now - startTime;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              current = Math.round(eased * target);
              if (span) span.textContent = current + suffix;
              if (progress < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
          });
          observer.disconnect();
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(grid);
  }

  /* ─── Scroll reveal for comparison cards ─── */
  function initScrollReveal() {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReduced) return;

    const revealElements = document.querySelectorAll<HTMLElement>(".v7-reveal-slide");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("v7-revealed");
          }
        });
      },
      { threshold: 0.2 }
    );

    revealElements.forEach((el) => observer.observe(el));
  }

  document.addEventListener("DOMContentLoaded", () => {
    animateCountUp();
    initScrollReveal();
  });

  /* Also fire on Astro page transitions */
  document.addEventListener("astro:page-load", () => {
    animateCountUp();
    initScrollReveal();
  });
</script>


