---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "parcelLab - Post-Purchase Experience Software",
  description = "With parcelLab, every delivery and return becomes a personalized experience that drives customer satisfaction and lifetime value.",
} = Astro.props;
const b = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/webp" sizes="32x32" href={`${b}seo/favicon-32x32.webp`} />
    <link rel="icon" type="image/webp" sizes="192x192" href={`${b}seo/favicon-192x192.webp`} />
    <link rel="apple-touch-icon" href={`${b}seo/apple-touch-icon-180x180.webp`} />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-full flex flex-col font-sans">
    <slot />
  </body>
</html>
