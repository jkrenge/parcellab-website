---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title = "Ready to transform your post-purchase experience?",
  description = "See how parcelLab can help you turn every delivery and return into a loyalty-building moment.",
  ctaText = "Book a demo",
  ctaHref = `${import.meta.env.BASE_URL}/live-demo/`,
} = Astro.props;
---

<section class="section-generous bg-[var(--surface-dark)] rounded-t-[32px]">
  <div class="mx-auto max-w-[1440px] px-6 md:px-12">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-display text-white">{title}</h2>
      <p class="mt-4 text-lg font-light leading-relaxed text-white/60">{description}</p>
      <div class="mt-10">
        <a
          href={ctaHref}
          class="group inline-flex items-center gap-3 rounded-full bg-[#3D3AD3] py-4 pl-7 pr-6 text-base font-medium text-white shadow-[0_2px_16px_rgba(61,58,211,0.4)] transition-all hover:shadow-[0_4px_24px_rgba(61,58,211,0.5)] hover:-translate-y-0.5"
        >
          {ctaText}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
