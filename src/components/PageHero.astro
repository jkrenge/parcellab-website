---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  dark?: boolean;
  gradient?: string;
}

const {
  eyebrow,
  title,
  description,
  ctaText,
  ctaHref,
  secondaryCtaText,
  secondaryCtaHref,
  dark = false,
  gradient,
} = Astro.props;

const bg = gradient ? `background: ${gradient}` : dark ? "background: var(--surface-dark)" : "";
const textColor = dark || gradient ? "text-white" : "text-[var(--ink)]";
const descColor = dark || gradient ? "text-white/70" : "text-[var(--ink-secondary)]";
---

<section class:list={["section-generous", { "rounded-b-[32px]": dark || gradient }]} style={bg}>
  <div class="mx-auto max-w-[1440px] px-6 md:px-12">
    <div class="max-w-3xl">
      {eyebrow && (
        <span class:list={["mb-4 inline-block text-xs font-semibold uppercase tracking-[0.15em]", dark || gradient ? "text-white/50" : "text-[#3D3AD3]"]}>
          {eyebrow}
        </span>
      )}
      <h1 class:list={["text-hero", textColor]}>
        {title}
      </h1>
      {description && (
        <p class:list={["mt-5 max-w-xl text-[var(--text-body-lg)] font-light leading-relaxed", descColor]}>
          {description}
        </p>
      )}
      {(ctaText || secondaryCtaText) && (
        <div class="mt-10 flex flex-wrap items-center gap-4">
          {ctaText && ctaHref && (
            <a
              href={ctaHref}
              class="group inline-flex items-center gap-3 rounded-full bg-[#3D3AD3] py-4 pl-7 pr-6 text-base font-medium text-white shadow-[0_2px_16px_rgba(61,58,211,0.3)] transition-all hover:shadow-[0_4px_24px_rgba(61,58,211,0.4)] hover:-translate-y-0.5"
            >
              {ctaText}
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          )}
          {secondaryCtaText && secondaryCtaHref && (
            <a
              href={secondaryCtaHref}
              class:list={["inline-flex items-center rounded-full border px-7 py-4 text-base font-medium transition-all", dark || gradient ? "border-white/20 text-white/80 hover:border-white/40 hover:text-white" : "border-[var(--line)] text-[var(--ink)] hover:border-[var(--ink-muted)] hover:bg-[var(--surface-sunken)]"]}
            >
              {secondaryCtaText}
            </a>
          )}
        </div>
      )}
    </div>
    <slot />
  </div>
</section>
