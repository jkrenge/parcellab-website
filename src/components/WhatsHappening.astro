---
const stats = [
  { value: "11+", label: "Customers worldwide" },
  { value: "2+", label: "Global Employees" },
  { value: "$1m", label: "in Series C Funding" },
];
---

<section class="py-20 md:py-28">
  <div class="mx-auto max-w-[1440px] px-6 md:px-12">
    <h2 class="mb-12 text-center text-[40px] leading-[50px] font-medium tracking-[-1px] text-black md:mb-16 md:text-[50px] md:leading-[60px] md:tracking-[-1.5px]">
      What&apos;s happening at parcelLab
    </h2>

    <div class="flex flex-col gap-6">
      <!-- Row 1 -->
      <div class="flex flex-col gap-6 md:flex-row">
        <!-- Featured Report -->
        <div class="relative flex min-h-[420px] flex-col justify-end overflow-hidden rounded-2xl bg-gradient-to-br from-[#1a1a2e] via-[#16213e] to-[#0f3460] p-8 md:w-[60%] md:min-h-[480px] md:p-10">
          <div class="pointer-events-none absolute top-8 right-8 h-[280px] w-[160px] rounded-[24px] border-2 border-white/10 bg-white/5 md:top-10 md:right-10 md:h-[340px] md:w-[180px]">
            <div class="mx-auto mt-3 h-1.5 w-10 rounded-full bg-white/10"></div>
            <div class="mt-6 space-y-2 px-3">
              <div class="h-2 w-full rounded bg-white/10"></div>
              <div class="h-2 w-3/4 rounded bg-white/10"></div>
              <div class="h-2 w-5/6 rounded bg-white/10"></div>
              <div class="mt-4 h-16 w-full rounded-lg bg-white/5"></div>
              <div class="mt-3 h-2 w-2/3 rounded bg-white/10"></div>
              <div class="h-2 w-1/2 rounded bg-white/10"></div>
            </div>
          </div>
          <div class="relative z-10 max-w-md">
            <span class="mb-3 inline-block text-xs font-semibold tracking-widest text-white/70 uppercase">Featured report</span>
            <h3 class="mb-3 text-[28px] leading-[36px] font-medium text-white md:text-[32px] md:leading-[40px]">U.S. eCommerce Shipping Experience Study</h3>
            <p class="mb-6 text-base leading-relaxed text-white/80">We analyzed the post-purchase experiences of the top retailers in the U.S. to see what they did well and what they could improve upon. The results may surprise you.</p>
            <a href="#" class="inline-flex items-center gap-2 rounded-full border border-white/40 px-6 py-2.5 text-sm font-medium text-white transition-colors hover:border-white hover:bg-white/10">
              Read report
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
        <!-- Right stacked -->
        <div class="flex flex-col gap-6 md:w-[40%]">
          <div class="flex flex-1 flex-col justify-between rounded-2xl border border-gray-200 bg-white p-8">
            <div>
              <h3 class="mb-3 text-[22px] leading-[28px] font-semibold text-gray-900 md:text-[24px] md:leading-[30px]">Join the parcellab.community</h3>
              <p class="text-base leading-relaxed text-gray-600">We believe in putting you, our customers, at the heart of everything we do.</p>
            </div>
            <div class="mt-6">
              <a href="#" class="inline-flex items-center gap-2 rounded-full bg-gray-900 px-6 py-2.5 text-sm font-medium text-white transition-colors hover:bg-gray-800">
                Join today
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
          <div class="relative flex flex-1 flex-col justify-end overflow-hidden rounded-2xl bg-[#5046E5] p-8">
            <div class="pointer-events-none absolute -top-6 -right-6 h-32 w-32 rounded-full bg-white/10"></div>
            <div class="pointer-events-none absolute top-12 right-16 h-16 w-16 rounded-full bg-white/5"></div>
            <div class="pointer-events-none absolute bottom-16 -left-4 h-20 w-20 rounded-full bg-white/5"></div>
            <div class="relative z-10">
              <div class="mb-3 flex items-center gap-2">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-white/20">
                  <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 text-white"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z" fill="currentColor"/><path d="M19 10v2a7 7 0 0 1-14 0v-2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M12 19v3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </div>
                <span class="text-xs font-semibold tracking-widest text-white/70 uppercase">Podcast</span>
              </div>
              <h3 class="text-[22px] leading-[28px] font-semibold text-white md:text-[24px] md:leading-[30px]">parcelLab Podcast</h3>
              <p class="mt-2 text-sm leading-relaxed text-white/70">Insights from industry leaders on post-purchase experience.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="flex flex-col gap-6 md:flex-row">
        <div class="flex flex-col gap-6 md:w-[50%]">
          <div class="rounded-2xl bg-gray-100 p-8">
            <div class="grid grid-cols-3 gap-6">
              {stats.map((stat) => (
                <div class="text-center">
                  <div class="text-[40px] leading-[48px] font-semibold text-gray-900 md:text-[48px] md:leading-[56px]">{stat.value}</div>
                  <div class="mt-1 text-[13px] leading-[18px] font-medium text-gray-500 md:text-[14px] md:leading-[20px]">{stat.label}</div>
                </div>
              ))}
            </div>
          </div>
          <div class="relative flex flex-1 items-center justify-center overflow-hidden rounded-2xl bg-[#035740] p-8 md:min-h-[260px]">
            <div class="pointer-events-none absolute inset-0 flex select-none items-center justify-center text-[200px] font-bold text-white/[0.06] md:text-[280px]">86</div>
            <div class="relative z-10 text-center">
              <div class="text-[100px] leading-[1] font-bold text-white md:text-[120px]">86</div>
              <div class="mt-2 text-lg font-medium text-white/80">NPS Score</div>
            </div>
          </div>
        </div>
        <div class="relative flex min-h-[420px] flex-col justify-end overflow-hidden rounded-2xl bg-gradient-to-t from-black/80 via-black/40 to-transparent p-8 md:w-[50%] md:min-h-[540px] md:p-10">
          <div class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-br from-[#2d2d3f] via-[#3a3a5c] to-[#4a4a6a]"></div>
          <div class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
          <div class="relative z-10 max-w-md">
            <span class="mb-3 inline-block text-xs font-semibold tracking-widest text-white/70 uppercase">Latest update</span>
            <h3 class="mb-3 text-[24px] leading-[32px] font-semibold text-white md:text-[28px] md:leading-[36px]">parcelLab and Salesforce Commerce Cloud Join Forces to Transform Post-Purchase Experience</h3>
            <p class="mb-6 text-base leading-relaxed text-white/80">Discover how our new partnership empowers brands to deliver exceptional post-purchase experiences at scale.</p>
            <a href="#" class="inline-flex items-center gap-2 rounded-full bg-[#FFC943] px-6 py-2.5 text-sm font-semibold text-gray-900 transition-colors hover:bg-[#ffbe1a]">
              Read more
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
