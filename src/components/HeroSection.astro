---
const b = import.meta.env.BASE_URL;
---

<section class="section-generous">
  <div class="mx-auto max-w-[1440px] px-6 md:px-12">
    <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-[1.15fr_1fr] md:gap-16 lg:gap-20">
      <!-- Text Content -->
      <div>
        <h1 class="text-hero text-[var(--ink)]">
          Turn deliveries<br class="hidden md:block" /> into loyalty
        </h1>
        <p class="mt-5 max-w-[480px] text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
          With parcelLab, every delivery and return becomes a personalized
          experience that drives customer satisfaction and lifetime value.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a
            href="https://parcellab.com/live-demo/"
            class="group inline-flex items-center gap-3 rounded-full bg-[#3D3AD3] py-4 pl-7 pr-6 text-base font-medium text-white shadow-[0_2px_16px_rgba(61,58,211,0.3)] transition-all hover:shadow-[0_4px_24px_rgba(61,58,211,0.4)] hover:-translate-y-0.5 active:translate-y-0"
          >
            Take a tour
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="https://parcellab.com/live-demo/"
            class="inline-flex items-center rounded-full border border-[var(--line)] bg-transparent px-7 py-4 text-base font-medium text-[var(--ink)] transition-all hover:border-[var(--ink-muted)] hover:bg-[var(--surface-sunken)]"
          >
            Book a demo
          </a>
        </div>
      </div>

      <!-- Video -->
      <div class="overflow-hidden rounded-2xl bg-[var(--surface-dark)] shadow-2xl shadow-black/10">
        <video
          class="h-full w-full object-cover aspect-[4/3]"
          controls
          preload="metadata"
          playsinline
        >
          <source
            src={`${b}/videos/ParcelLab-Brand-Video_Homeage-web-700.webm`}
            type="video/webm"
          />
          <source
            src={`${b}/videos/ParcelLab-Brand-Video_Homeage-web-700.mp4`}
            type="video/mp4"
          />
          Your browser does not support the video tag.
        </video>
      </div>
    </div>
  </div>
</section>
