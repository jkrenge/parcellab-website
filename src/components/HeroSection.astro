---
const b = import.meta.env.BASE_URL;
---

<section class="pt-[60px] pb-[30px]">
  <div class="mx-auto max-w-[1440px] px-12">
    <div class="flex flex-col gap-8 md:flex-row">
      <!-- Left Column — Text Content -->
      <div class="flex flex-1 basis-0 flex-col justify-center">
        <h1 class="mb-4 text-[36px] font-medium leading-[44px] tracking-[-1.5px] text-black md:text-[50px] md:leading-[60px]">
          Turn deliveries into loyalty
        </h1>
        <p class="text-[18px] leading-[29px] text-[#666666]">
          With parcelLab, every delivery and return becomes a personalized
          experience that drives customer satisfaction and lifetime value.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a
            href="https://parcellab.com/live-demo/"
            class="inline-flex items-center gap-2 rounded-full bg-[#3D3AD3] py-4 pr-[50px] pl-[22px] text-[18px] text-white transition-opacity hover:opacity-90"
          >
            Take a tour
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="https://parcellab.com/live-demo/"
            class="inline-flex items-center rounded-full border border-[#dfdfdf] bg-transparent px-[22px] py-4 text-[18px] text-black transition-colors hover:border-[#bbb]"
          >
            Book a demo
          </a>
        </div>
      </div>

      <!-- Right Column — Video -->
      <div class="flex flex-1 basis-0 items-stretch">
        <div class="w-full overflow-hidden rounded-2xl bg-[#2a2a2a]">
          <video
            class="h-full w-full object-cover"
            controls
            preload="metadata"
            playsinline
          >
            <source
              src={`${b}/videos/ParcelLab-Brand-Video_Homeage-web-700.webm`}
              type="video/webm"
            />
            <source
              src={`${b}/videos/ParcelLab-Brand-Video_Homeage-web-700.mp4`}
              type="video/mp4"
            />
            Your browser does not support the video tag.
          </video>
        </div>
      </div>
    </div>
  </div>
</section>
