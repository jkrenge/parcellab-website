---
const b = import.meta.env.BASE_URL;
const logos = [
  { name: "IKEA", src: `${b}/images/logos/IKEA_Logo_Black.svg` },
  { name: "Hugo Boss", src: `${b}/images/brands/Hugo-Boss.svg` },
  { name: "dyson", src: `${b}/images/brands/Dyson.svg` },
  { name: "Urban Outfitters", src: `${b}/images/brands/Urban-Outfitters-1.svg` },
  { name: "HC Group", src: `${b}/images/brands/Group-1000002364.svg` },
  { name: "True Classic", src: `${b}/images/brands/True-Classic-1.svg` },
  { name: "Puma", src: `${b}/images/brands/Puma.svg` },
  { name: "Farfetch", src: `${b}/images/brands/Farfetch.svg` },
  { name: "John Lewis", src: `${b}/images/brands/JohnLewis-1.svg` },
  { name: "Wyze", src: `${b}/images/logos/Wyze_Logo_Black.svg` },
];
const doubled = [...logos, ...logos];
---

<section class="w-full overflow-hidden border-y border-[var(--line-subtle)] py-8 md:py-10" aria-label="Trusted by leading brands">
  <div class="animate-marquee flex items-center gap-16 md:gap-20" style="width: max-content;">
    {doubled.map((logo) => (
      <img
        src={logo.src}
        alt={`${logo.name} logo`}
        width="120"
        height="48"
        class="h-7 w-auto shrink-0 object-contain opacity-25 grayscale transition-all duration-300 hover:opacity-50 hover:grayscale-0 md:h-9"
        loading="lazy"
      />
    ))}
  </div>
</section>
