---
const reviews = [
  { name: "Alex B.", date: "December 8th, 2024", rating: 5, title: "Highly recommend for businesses looking to elevate their order tracking experience!", body: "Its seamless integration with e-commerce platforms and focus on branding make it a standout solution for improving customer satisfaction and loyalty." },
  { name: "Sarah M.", date: "November 22nd, 2024", rating: 5, title: "A game-changer for post-purchase communication and customer engagement", body: "parcelLab has transformed how we handle post-purchase touchpoints. The platform is intuitive, powerful, and the team behind it is incredibly supportive." },
  { name: "James K.", date: "October 15th, 2024", rating: 5, title: "Outstanding platform for delivery experience management", body: "The insights we get from parcelLab have helped us reduce WISMO calls significantly while keeping our customers informed at every step." },
];

const badges = [
  { src: "/images/medal.webp", alt: "G2 Leader badge", fallback: "G2 Leader" },
  { src: "/images/medal-1.webp", alt: "G2 Best Relationship badge", fallback: "Best Relationship" },
  { src: "/images/g2-best-software-supply-chain-logistics-products.webp", alt: "G2 Top 50 badge", fallback: "Top 50" },
];
---

<section class="w-full py-20 lg:py-28">
  <div class="mx-auto max-w-[1440px] px-6 md:px-12">
    <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:gap-16">
      <!-- Left Side -->
      <div class="flex flex-col gap-10 lg:w-1/2">
        <div class="max-w-[500px]">
          <h2 class="mb-4 text-[50px] font-medium leading-[60px] tracking-[-1.5px] text-black">
            Top-rated platform
          </h2>
          <p class="text-lg leading-[29px] text-[rgb(102,102,102)]">
            With 25+ awards in G2&apos;s 2026 reports, parcelLab is trusted
            as a leader in post-purchase experience.
          </p>
        </div>

        <!-- Badges Row -->
        <div class="flex flex-wrap gap-4">
          {badges.map((badge) => (
            <div class="flex h-40 w-[180px] shrink-0 items-center justify-center rounded-2xl bg-[#f4f4f4]">
              <img
                src={badge.src}
                alt={badge.alt}
                width="120"
                height="120"
                class="g2-badge-img object-contain"
                data-fallback={badge.fallback}
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Right Side -- Review Cards on Purple Background -->
      <div class="lg:w-1/2">
        <div class="relative overflow-hidden rounded-3xl bg-[#5046E5] p-8 md:p-12">
          <!-- Stacked / Cascading Cards -->
          <div class="relative min-h-[480px]">
            <!-- Card 3 -- deepest, peeking from behind -->
            <div class="absolute left-6 top-8 w-[calc(100%-48px)] rotate-[-1deg] opacity-40">
              <div class="relative rounded-2xl bg-white p-6 shadow-lg">
                <div class="absolute right-4 top-4">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="G2 logo">
                    <rect width="24" height="24" rx="4" fill="#FF492C" />
                    <path d="M12.5 7.5c-1.4 0-2.6.5-3.4 1.3-.8.8-1.1 1.9-1.1 3 0 1.2.4 2.2 1.2 3 .8.8 1.9 1.2 3.3 1.2 1 0 1.8-.2 2.5-.6v-3h-2.8v1.4h1.2v.9c-.3.1-.6.2-1 .2-.8 0-1.4-.3-1.8-.7-.4-.5-.7-1.1-.7-1.9 0-.8.2-1.4.6-1.8.4-.5 1-.7 1.7-.7.8 0 1.4.3 1.9.8l1-1.1c-.8-.8-1.7-1-2.6-1z" fill="white" />
                    <path d="M15.2 16.5h4.3v-1.4h-2.4l2.3-2.6c.3-.4.5-.8.5-1.3 0-.5-.2-1-.6-1.3-.4-.3-.9-.5-1.5-.5-.7 0-1.2.2-1.7.5-.4.4-.7.8-.7 1.4h1.5c0-.2.1-.4.2-.5.2-.2.4-.2.6-.2s.4.1.5.2c.1.1.2.3.2.5 0 .3-.1.5-.3.7l-3 3.4v1.1z" fill="white" />
                  </svg>
                </div>
                <div class="mb-2">
                  <p class="text-base font-bold text-gray-900">{reviews[2].name}</p>
                  <p class="text-sm text-gray-400">{reviews[2].date}</p>
                </div>
                <div class="mb-3 flex gap-0.5" aria-label={`${reviews[2].rating} out of 5 stars`}>
                  {Array.from({ length: 5 }, (_, i) => (
                    <svg class="h-4 w-4 fill-amber-400 text-amber-400" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ))}
                </div>
                <h4 class="mb-2 line-clamp-3 text-lg font-bold leading-snug text-gray-900">{reviews[2].title}</h4>
                <p class="line-clamp-4 text-sm leading-relaxed text-gray-500">{reviews[2].body}</p>
              </div>
            </div>

            <!-- Card 2 -- middle layer -->
            <div class="absolute left-3 top-4 w-[calc(100%-24px)] rotate-[0.5deg] opacity-70">
              <div class="relative rounded-2xl bg-white p-6 shadow-lg">
                <div class="absolute right-4 top-4">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="G2 logo">
                    <rect width="24" height="24" rx="4" fill="#FF492C" />
                    <path d="M12.5 7.5c-1.4 0-2.6.5-3.4 1.3-.8.8-1.1 1.9-1.1 3 0 1.2.4 2.2 1.2 3 .8.8 1.9 1.2 3.3 1.2 1 0 1.8-.2 2.5-.6v-3h-2.8v1.4h1.2v.9c-.3.1-.6.2-1 .2-.8 0-1.4-.3-1.8-.7-.4-.5-.7-1.1-.7-1.9 0-.8.2-1.4.6-1.8.4-.5 1-.7 1.7-.7.8 0 1.4.3 1.9.8l1-1.1c-.8-.8-1.7-1-2.6-1z" fill="white" />
                    <path d="M15.2 16.5h4.3v-1.4h-2.4l2.3-2.6c.3-.4.5-.8.5-1.3 0-.5-.2-1-.6-1.3-.4-.3-.9-.5-1.5-.5-.7 0-1.2.2-1.7.5-.4.4-.7.8-.7 1.4h1.5c0-.2.1-.4.2-.5.2-.2.4-.2.6-.2s.4.1.5.2c.1.1.2.3.2.5 0 .3-.1.5-.3.7l-3 3.4v1.1z" fill="white" />
                  </svg>
                </div>
                <div class="mb-2">
                  <p class="text-base font-bold text-gray-900">{reviews[1].name}</p>
                  <p class="text-sm text-gray-400">{reviews[1].date}</p>
                </div>
                <div class="mb-3 flex gap-0.5" aria-label={`${reviews[1].rating} out of 5 stars`}>
                  {Array.from({ length: 5 }, (_, i) => (
                    <svg class="h-4 w-4 fill-amber-400 text-amber-400" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ))}
                </div>
                <h4 class="mb-2 line-clamp-3 text-lg font-bold leading-snug text-gray-900">{reviews[1].title}</h4>
                <p class="line-clamp-4 text-sm leading-relaxed text-gray-500">{reviews[1].body}</p>
              </div>
            </div>

            <!-- Card 1 -- front, fully visible -->
            <div class="relative z-10 w-full">
              <div class="relative rounded-2xl bg-white p-6 shadow-lg">
                <div class="absolute right-4 top-4">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="G2 logo">
                    <rect width="24" height="24" rx="4" fill="#FF492C" />
                    <path d="M12.5 7.5c-1.4 0-2.6.5-3.4 1.3-.8.8-1.1 1.9-1.1 3 0 1.2.4 2.2 1.2 3 .8.8 1.9 1.2 3.3 1.2 1 0 1.8-.2 2.5-.6v-3h-2.8v1.4h1.2v.9c-.3.1-.6.2-1 .2-.8 0-1.4-.3-1.8-.7-.4-.5-.7-1.1-.7-1.9 0-.8.2-1.4.6-1.8.4-.5 1-.7 1.7-.7.8 0 1.4.3 1.9.8l1-1.1c-.8-.8-1.7-1-2.6-1z" fill="white" />
                    <path d="M15.2 16.5h4.3v-1.4h-2.4l2.3-2.6c.3-.4.5-.8.5-1.3 0-.5-.2-1-.6-1.3-.4-.3-.9-.5-1.5-.5-.7 0-1.2.2-1.7.5-.4.4-.7.8-.7 1.4h1.5c0-.2.1-.4.2-.5.2-.2.4-.2.6-.2s.4.1.5.2c.1.1.2.3.2.5 0 .3-.1.5-.3.7l-3 3.4v1.1z" fill="white" />
                  </svg>
                </div>
                <div class="mb-2">
                  <p class="text-base font-bold text-gray-900">{reviews[0].name}</p>
                  <p class="text-sm text-gray-400">{reviews[0].date}</p>
                </div>
                <div class="mb-3 flex gap-0.5" aria-label={`${reviews[0].rating} out of 5 stars`}>
                  {Array.from({ length: 5 }, (_, i) => (
                    <svg class="h-4 w-4 fill-amber-400 text-amber-400" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ))}
                </div>
                <h4 class="mb-2 line-clamp-3 text-lg font-bold leading-snug text-gray-900">{reviews[0].title}</h4>
                <p class="line-clamp-4 text-sm leading-relaxed text-gray-500">{reviews[0].body}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.querySelectorAll('.g2-badge-img').forEach(img => {
  img.addEventListener('error', () => {
    img.style.display = 'none';
    const span = document.createElement('span');
    span.className = 'text-sm font-medium text-gray-500 text-center px-4';
    span.textContent = img.dataset.fallback || '';
    img.parentElement?.appendChild(span);
  });
});
</script>
