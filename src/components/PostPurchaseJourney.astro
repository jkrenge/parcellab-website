---
const b = import.meta.env.BASE_URL;
---

<section class="section-generous bg-[var(--surface-sunken)]">
  <div class="mx-auto max-w-[1440px] px-5 md:px-12">
    <div class="mx-auto mb-12 max-w-2xl text-center md:mb-16">
      <h2 class="text-display text-[var(--ink)]">
        Own the entire post-purchase journey
      </h2>
      <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
        We turn checkout, delivery, and returns into loyalty-building moments.
      </p>
    </div>
    <div class="mx-auto max-w-[1200px] overflow-hidden rounded-2xl shadow-xl shadow-black/5">
      <video
        class="h-auto w-full"
        autoplay
        muted
        loop
        playsinline
        poster={`${b}/images/JOURNEY-MAP-MOBILE-1.webp`}
      >
        <source
          src={`${b}/videos/ParcelLab-UI-Design-Homepage-2_1-compressed.mp4`}
          type="video/mp4"
        />
      </video>
    </div>
  </div>
</section>
