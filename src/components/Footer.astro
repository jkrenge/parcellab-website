---

<footer class="bg-[var(--surface-dark)] text-white">
  <div class="mx-auto max-w-[1440px] px-6 md:px-12">
    <!-- Top row: logo + columns -->
    <div class="grid grid-cols-1 gap-12 pt-20 pb-14 lg:grid-cols-[200px_1fr] lg:gap-16">
      <!-- Logo area -->
      <div class="flex flex-col items-start gap-6">
        <img
          src={`${b}/images/logos/parcelab-logo-white-1.svg`}
          alt="parcelLab"
          width="144"
          height="48"
          class="h-12 w-auto"
        />

        <!-- Social icons -->
        <div class="flex items-center gap-3">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              aria-label={social.label}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white transition-colors hover:border-white/50"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d={social.path} />
              </svg>
            </a>
          ))}
        </div>

        <!-- Log in button -->
        <a
          href="https://portal.parcellab.com/login"
          class="inline-flex items-center gap-2 rounded-full bg-[#3D3AD3] px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-[#3230b8]"
        >
          Log in
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
            <polyline points="15 3 21 3 21 9" />
            <line x1="10" y1="14" x2="21" y2="3" />
          </svg>
        </a>
      </div>

      <!-- Link columns -->
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-2 md:grid-cols-4">
        {footerColumns.map((column) => (
          <div class="flex flex-col gap-8">
            {column.sections.map((section) => (
              <div>
                <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-white/50">
                  {section.heading}
                </h3>
                <ul class="flex flex-col">
                  {section.links.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class="inline-block text-sm leading-[2.2] text-white/70 transition-colors hover:text-white hover:underline"
                      >
                        {link.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom row: copyright -->
    <div class="flex flex-col items-start gap-2 border-t border-white/[0.06] py-6 text-xs text-white/40 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; 2015 &ndash; 2026 parcelLab. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="https://parcellab.com/legal-notice/" class="underline transition-colors hover:text-white/70">
          Legal notice
        </a>
        <a href="https://parcellab.com/privacy-policy/" class="underline transition-colors hover:text-white/70">
          Cookie policy
        </a>
      </div>
    </div>
  </div>
</footer>
