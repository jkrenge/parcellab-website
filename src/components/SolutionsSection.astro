---
const solutions = [
  {
    title: "Cut WISMO & WISMR",
    description: "20% fewer WISMO calls, saving thousands of support hours",
    stat: "20%",
    iconPath: "M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z",
  },
  {
    title: "Monetize returns",
    description: "11% higher retention through exchanges and store credit",
    stat: "11%",
    iconPath: "M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15",
  },
  {
    title: "Convert more carts",
    description: "5% higher checkout conversion with delivery promises",
    stat: "5%",
    iconPath: "M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6m0 0 1 5m14 6a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm-8 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0z",
  },
  {
    title: "Make it personal",
    description: "29% higher revenue per email with branded post-purchase messaging",
    stat: "29%",
    iconPath: "M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z",
  },
];
---

<section class="section-generous">
  <div class="mx-auto max-w-[1440px] px-6 md:px-12">
    <div class="mb-14 max-w-2xl md:mb-20">
      <h2 class="text-display text-[var(--ink)]">
        Solutions that grow customer lifetime value
      </h2>
      <p class="mt-4 text-[var(--text-body-lg)] font-light leading-relaxed text-[var(--ink-secondary)]">
        From delivery to returns, see how parcelLab reduces costs and unlocks new revenue streams.
      </p>
    </div>

    <!-- Hero card — full width, horizontal layout -->
    <div class="mb-6 flex flex-col items-start gap-8 rounded-2xl bg-[#035740] p-8 text-white md:flex-row md:items-center md:p-12">
      <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-white/15">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d={solutions[0].iconPath} />
        </svg>
      </div>
      <div class="flex-1">
        <div class="flex flex-col gap-2 md:flex-row md:items-baseline md:gap-6">
          <span class="text-[3rem] font-bold leading-none tracking-tight text-white/90 md:text-[3.5rem]">{solutions[0].stat}</span>
          <h3 class="text-heading text-white">{solutions[0].title}</h3>
        </div>
        <p class="mt-3 max-w-xl text-base font-light leading-relaxed text-white/70">{solutions[0].description}</p>
      </div>
    </div>

    <!-- Remaining 3 cards -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {solutions.slice(1).map((s) => (
        <div class="group rounded-2xl bg-[#035740] p-8 text-white transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-[#035740]/20">
          <div class="mb-5 flex items-center justify-between">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-white/15">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={s.iconPath} />
              </svg>
            </div>
            <span class="text-[2rem] font-bold leading-none tracking-tight text-white/30">{s.stat}</span>
          </div>
          <h3 class="text-[1.375rem] font-semibold leading-tight text-white">{s.title}</h3>
          <p class="mt-3 text-[0.9375rem] font-light leading-relaxed text-white/70">{s.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
